---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n/config';
import { useTranslations, useTranslatedPath } from '../i18n/utils';

export interface Props {
  lang: Lang;
  slug: string;
}

const { lang, slug } = Astro.props;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

const siteUrl = "https://intellica.net";

// Product data keyed by slug with translated content
const products: Record<string, {
  name: string;
  tagline: string;
  category: string;
  desc: string;
  features: string[];
  icon: string;
}> = {
  ifdm: {
    name: 'IFDM',
    tagline: t('productsDetail.ifdm.tagline'),
    category: t('productsDetail.ifdm.category'),
    desc: t('productsDetail.ifdm.desc'),
    features: [t('productsDetail.ifdm.feature1'), t('productsDetail.ifdm.feature2'), t('productsDetail.ifdm.feature3')],
    icon: '\u{1F4CA}',
  },
  itdm: {
    name: 'ITDM',
    tagline: t('productsDetail.itdm.tagline'),
    category: t('productsDetail.itdm.category'),
    desc: t('productsDetail.itdm.desc'),
    features: [t('productsDetail.itdm.feature1'), t('productsDetail.itdm.feature2'), t('productsDetail.itdm.feature3')],
    icon: '\u{1F4F1}',
  },
  hrdm: {
    name: 'HRDM',
    tagline: t('productsDetail.hrdm.tagline'),
    category: t('productsDetail.hrdm.category'),
    desc: t('productsDetail.hrdm.desc'),
    features: [t('productsDetail.hrdm.feature1'), t('productsDetail.hrdm.feature2'), t('productsDetail.hrdm.feature3')],
    icon: '\u{1F465}',
  },
  icc: {
    name: 'ICC',
    tagline: t('productsDetail.icc.tagline'),
    category: t('productsDetail.icc.category'),
    desc: t('productsDetail.icc.desc'),
    features: [t('productsDetail.icc.feature1'), t('productsDetail.icc.feature2'), t('productsDetail.icc.feature3')],
    icon: '\u{2696}\u{FE0F}',
  },
  retouch: {
    name: 'ReTouch',
    tagline: t('productsDetail.retouch.tagline'),
    category: t('productsDetail.retouch.category'),
    desc: t('productsDetail.retouch.desc'),
    features: [t('productsDetail.retouch.feature1'), t('productsDetail.retouch.feature2'), t('productsDetail.retouch.feature3')],
    icon: '\u{270F}\u{FE0F}',
  },
  retable: {
    name: 'Retable',
    tagline: t('productsDetail.retable.tagline'),
    category: t('productsDetail.retable.category'),
    desc: t('productsDetail.retable.desc'),
    features: [t('productsDetail.retable.feature1'), t('productsDetail.retable.feature2'), t('productsDetail.retable.feature3')],
    icon: '\u{1F3E2}',
  },
  talkto: {
    name: 'Talk To',
    tagline: t('productsDetail.talkto.tagline'),
    category: t('productsDetail.talkto.category'),
    desc: t('productsDetail.talkto.desc'),
    features: [t('productsDetail.talkto.feature1'), t('productsDetail.talkto.feature2'), t('productsDetail.talkto.feature3')],
    icon: '\u{1F4AC}',
  },
  blueoctopus: {
    name: 'Blue Octopus',
    tagline: t('productsDetail.blueoctopus.tagline'),
    category: t('productsDetail.blueoctopus.category'),
    desc: t('productsDetail.blueoctopus.desc'),
    features: [t('productsDetail.blueoctopus.feature1'), t('productsDetail.blueoctopus.feature2'), t('productsDetail.blueoctopus.feature3')],
    icon: '\u{1F419}',
  },
  var: {
    name: 'VAR',
    tagline: t('productsDetail.var.tagline'),
    category: t('productsDetail.var.category'),
    desc: t('productsDetail.var.desc'),
    features: [t('productsDetail.var.feature1'), t('productsDetail.var.feature2'), t('productsDetail.var.feature3')],
    icon: '\u{1F399}\u{FE0F}',
  },
};

const product = products[slug];

// If product not found, show a fallback
if (!product) {
  return Astro.redirect(tp('/products'));
}

const breadcrumbs = [
  { name: t('productsDetail.breadcrumbProducts'), url: `${siteUrl}${tp('/products')}` },
  { name: product.name, url: `${siteUrl}${tp(`/products/${slug}`)}` }
];

const ctaTitle = t('productsDetail.ctaTitle').replace('{name}', product.name);
---

<Layout title={`${product.name} | Intellica`} description={product.desc} breadcrumbs={breadcrumbs} hideCta={true} lang={lang}>
  <section class="page-hero">
    <div class="container">
      <div class="section-label anim-fade-up">{product.category}</div>
      <h1 class="anim-fade-up">{product.name}</h1>
      <p class="product-tagline anim-fade-up">{product.tagline}</p>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="product-detail-grid">
        <div class="product-info-panel anim-fade-up">
          <h2>{t('productsDetail.overview')}</h2>
          <p class="product-description">{product.desc}</p>

          <div class="feature-list-wrap">
            <h3>{t('productsDetail.keyFeatures')}</h3>
            <ul class="feature-list">
              {product.features.map((feature: string) => (
                <li>{feature}</li>
              ))}
            </ul>
          </div>
        </div>

        <div class="product-cta-panel anim-fade-up">
          <div class="product-icon-large">{product.icon}</div>
          <div class="cta-box">
            <h3>{ctaTitle}</h3>
            <p>{t('productsDetail.ctaDesc')}</p>
            <a href={tp('/contact')} class="btn btn-primary btn-pill btn-lg">{t('productsDetail.ctaButton')}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.product-tagline {
  font-size: 1.25rem;
  color: var(--grad-brand);
  font-weight: 600;
  margin-top: -12px;
}
.product-detail-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 64px;
}
.product-info-panel h2 {
  color: var(--clr-light-text);
  margin-bottom: 24px;
}
.product-description {
  font-size: 1.15rem;
  line-height: 1.7;
  color: var(--clr-light-muted);
  margin-bottom: 40px;
}
.feature-list-wrap h3 {
  color: var(--clr-light-text);
  margin-bottom: 20px;
  font-size: 1.2rem;
}
.feature-list {
  list-style: none; padding: 0; margin: 0;
  display: grid; gap: 16px;
}
.feature-list li {
  display: flex; align-items: center; gap: 12px;
  font-size: 1rem; color: var(--clr-light-text);
  padding: 12px 16px;
  background: #F8FAFC;
  border-radius: 12px;
  border: 1px solid #E8EEF5;
}
.feature-list li::before {
  content: '\2713';
  color: var(--clr-primary);
  font-weight: bold;
}
.product-cta-panel {
  display: flex;
  flex-direction: column;
  gap: 32px;
}
.product-icon-large {
  font-size: 5rem;
  display: flex; align-items: center; justify-content: center;
  height: 200px;
  background: linear-gradient(145deg, #F0FDF9, #EFF6FF);
  border-radius: 24px;
  border: 1px solid rgba(0,200,150,0.1);
}
.cta-box {
  padding: 32px;
  background: #030B16;
  border-radius: 24px;
  color: #fff;
  text-align: center;
}
.cta-box h3 { margin-bottom: 12px; font-size: 1.4rem; }
.cta-box p { color: rgba(255,255,255,0.7); margin-bottom: 24px; font-size: 0.95rem; }

@media (max-width: 960px) {
  .product-detail-grid { grid-template-columns: 1fr; gap: 40px; }
  .product-cta-panel { order: -1; }
}
</style>
