---
import Layout from '../layouts/Layout.astro';
import ReadingPaths from '../components/gamification/ReadingPaths.astro';
import { useTranslations, useTranslatedPath } from '../i18n/utils';
import type { Lang } from '../i18n/config';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

const siteUrl = "https://intellica.net";
const breadcrumbs = [{ name: t('insights.breadcrumb'), url: `${siteUrl}${tp('/insights')}` }];

const insights = [
  {
    title: "Why Trust Decreases as the Number of Dashboards Increases?",
    desc: "Why does dashboard inflation actually hurt trust? A practical framework exploring definition drift, loss of lineage, and maintenance obesity.",
    slug: "dashboard-guven",
    time: "6 min",
    date: "Feb 1, 2026",
    topics: ["Data Governance", "Dashboard Governance", "Data Lineage", "Semantic Layer"]
  },
  {
    title: "Why Manual Controls Are Still Alive: Excel Shelters in the Age of Data",
    desc: "Why, in this golden age of data and automation, do manual controls remain a 'survival mechanism' for so many companies?",
    slug: "manuel-kontroller",
    time: "5 min",
    date: "Feb 1, 2026",
    topics: ["Data Quality", "Reconciliation", "Operational Risk", "Data Lineage"]
  },
  {
    title: "Data Autopsy or Data Pulse? The Paradigm Shift in Early Warning Systems",
    desc: "Standard reports are autopsies; true early warning is a data-in-motion discipline. Catching the pulse before the crisis arises with live tracking.",
    slug: "verinin-nabzi",
    time: "6 min",
    date: "Feb 1, 2026",
    topics: ["Early Warning", "Data Observability", "Anomaly Detection", "Event Correlation"]
  },
  {
    title: "Business Analysis: The \"Reality Filter\" That Determines a Project's Fate",
    desc: "Success starts before the code. A professional approach to clarify scope and reduce regression risk with 5W1H and impact analysis.",
    slug: "is-analizi",
    time: "7 min",
    date: "Feb 1, 2026",
    topics: ["Business Analysis", "Scope Management", "Impact Analysis", "CR Process"]
  },
  {
    title: "When Does RAG (Retrieval) Work and When Does It Mislead?",
    desc: "The success of RAG depends more on the quality of information access than the model: chunking, metadata, relevance, freshness, and attribution.",
    slug: "rag-ne-zaman-ise-yarar",
    time: "8 min",
    date: "Feb 1, 2026",
    topics: ["RAG", "GenAI", "Information Retrieval", "Document AI"]
  },
  {
    title: "How to Establish a 'Trust Standard' in Enterprise GenAI?",
    desc: "Trust in GenAI is built through processes, measurement, and governance. Leveraging attribution, access, evaluation, and traceability.",
    slug: "genai-guven-standardi",
    time: "9 min",
    date: "Feb 1, 2026",
    topics: ["GenAI", "Governance", "Security", "LLM Evaluation"]
  }
];

const allTopics = Array.from(new Set(insights.flatMap(i => i.topics))).sort();
---

<Layout title={t('meta.insights.title')} description={t('meta.insights.description')} breadcrumbs={breadcrumbs} hideCta={true} lang={lang}>
  <!-- HERO -->
  <section class="hero noise" id="insights-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">{t('insights.hero.label')}</div>
          <h1 class="hero__title">
            {t('insights.hero.title')}<br />
            <span class="grad-text">{t('insights.hero.titleHighlight')}</span>
          </h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">{t('insights.hero.desc')}</p>
        </div>

        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/insights_hero_v3.png" alt={t('insights.hero.imgAlt')} class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

<style>
#insights-hero { min-height: 750px !important; }
@media (max-width: 1100px) {
  #insights-hero { min-height: auto !important; }
}
</style>

  <!-- READING PATHS -->
  <ReadingPaths />

  <!-- FEATURED -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2 anim-fade-up" style="gap:48px; align-items: center;">
        <div>
          <div class="div-badge">{t('insights.featured.badge')}</div>
          <h2 style="color:var(--clr-light-text); font-size: 2.5rem; line-height: 1.1; margin-bottom: 24px;">{t('insights.featured.title')}<span class="grad-text">{t('insights.featured.titleHighlight')}</span></h2>
          <p style="color:var(--clr-light-muted); font-size: 1.1rem; line-height: 1.6; margin-bottom: 32px;">
            {t('insights.featured.desc')}
          </p>
          <a href={tp('/insights/genai-guven-standardi')} class="btn btn-primary btn-pill btn-lg">{t('insights.featured.cta')}</a>
        </div>
        <div class="featured-visual">
          <img src="/assets/img/ai_knowledge_abstract_1772398712333.png" alt={t('insights.featured.imgAlt')} style="width:100%; border-radius: 32px; box-shadow: 0 40px 80px rgba(0,0,0,0.15);" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- LIST -->
  <section class="section section--light" id="insights-list">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title" style="color:var(--clr-light-text);">{t('insights.library.title')}<span class="grad-text">{t('insights.library.titleHighlight')}</span></h2>
        <p class="section-sub">{t('insights.library.sub')}</p>
      </div>

      <div class="insights-toolbar anim-fade-up">
        <div class="search-box">
          <input id="insight-search" type="search" placeholder={t('insights.library.searchPlaceholder')} />
        </div>
        <div class="filter-box">
          <select id="topic-filter">
            <option value="">{t('insights.library.allTopics')}</option>
            {allTopics.map(topic => <option value={topic}>{topic}</option>)}
          </select>
        </div>
      </div>

      <div class="grid-3 anim-fade-up" id="insights-grid">
        {insights.map(item => (
          <a href={tp(`/insights/${item.slug}`)} class="insight-card card-light" data-topics={item.topics.join(',')} data-title={item.title.toLowerCase()}>
            <div class="insight-meta">
              <span>{item.date}</span>
              <span class="dot"></span>
              <span>{item.time} {t('insights.library.readSuffix')}</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <div class="insight-tags">
              {item.topics.slice(0, 3).map(topic => <span class="topic-pill">{topic}</span>)}
              {item.topics.length > 3 && <span class="topic-pill">+{item.topics.length - 3}</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA STRIP -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>{t('insights.cta.title')}<span class="grad-text">{t('insights.cta.titleHighlight')}</span></h2>
        <p>{t('insights.cta.desc')}</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href={tp('/contact')}>{t('insights.cta.primary')}</a>
          <a class="btn btn-ghost btn-pill btn-lg" href={tp('/clients')}>{t('insights.cta.secondary')}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.insights-toolbar { display: flex; gap: 20px; margin-bottom: 48px; margin-top: 32px; }
.search-box { flex: 2; }
.filter-box { flex: 1; }
.insights-toolbar input, .insights-toolbar select { width: 100%; padding: 14px 20px; border-radius: 12px; border: 1px solid #e2e8f0; background: #fff; font-size: 0.95rem; color: #1e293b; outline: none; transition: border-color 0.2s ease; }
.insights-toolbar input:focus, .insights-toolbar select:focus { border-color: var(--clr-primary); }
.insight-card { display: flex; flex-direction: column; padding: 32px; text-decoration: none; transition: all 0.3s ease; }
.insight-card:hover { transform: translateY(-8px); border-color: var(--clr-primary); box-shadow: 0 20px 40px rgba(0,200,150,0.08); }
.insight-meta { display: flex; align-items: center; gap: 10px; font-size: 0.75rem; font-weight: 600; color: var(--clr-light-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 16px; }
.insight-meta .dot { width: 4px; height: 4px; border-radius: 50%; background: #cbd5e1; }
.insight-card h3 { font-size: 1.25rem; color: var(--clr-light-text); margin-bottom: 12px; line-height: 1.4; }
.insight-card p { font-size: 0.95rem; color: var(--clr-light-muted); line-height: 1.6; margin-bottom: 24px; flex-grow: 1; }
.insight-tags { display: flex; flex-wrap: wrap; gap: 8px; }
.topic-pill { font-size: 0.7rem; font-weight: 700; padding: 4px 10px; border-radius: 999px; background: #f1f5f9; color: #475569; }
.div-badge { display: inline-block; padding: 6px 16px; background: rgba(16,185,129,0.1); color: var(--clr-primary); border-radius: 100px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; margin-bottom: 24px; }

@media (max-width: 768px) {
  .insights-toolbar { flex-direction: column; }
  .grid-2 { grid-template-columns: 1fr; }
}
</style>

<script>
  const searchInput = document.querySelector<HTMLInputElement>('#insight-search');
  const topicFilter = document.querySelector<HTMLSelectElement>('#topic-filter');
  const cards = document.querySelectorAll<HTMLElement>('.insight-card');

  function filterInsights() {
    const query = searchInput?.value.toLowerCase() ?? '';
    const topic = topicFilter?.value ?? '';

    cards.forEach(card => {
      const title = card.getAttribute('data-title') || '';
      const topics = card.getAttribute('data-topics') || '';
      const matchesSearch = title.includes(query) || topics.toLowerCase().includes(query);
      const matchesTopic = !topic || topics.includes(topic);

      if (matchesSearch && matchesTopic) {
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
    });
  }

  searchInput?.addEventListener('input', filterInsights);
  topicFilter?.addEventListener('change', filterInsights);
</script>
