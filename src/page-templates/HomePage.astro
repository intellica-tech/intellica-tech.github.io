/* Map */
.map-wrap {
  position: relative;
  margin-bottom: 32px;
}
.map-image {
  width: 100%;
  filter: contrast(1.1);
}
.map-overlay {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.conn {
  fill: none;
  stroke: #F97316;
  stroke-width: 1.2;
  stroke-dasharray: 4 4;
  opacity: 0.45;
}
.dot circle {
  fill: #F97316;
  opacity: 0.1;
}
.dot .ring {
  fill: none;
  stroke: #F97316;
  stroke-width: 2.5;
  animation: pulse-ring 2.5s ease-out infinite;
  animation-delay: var(--delay, 0s);
}

