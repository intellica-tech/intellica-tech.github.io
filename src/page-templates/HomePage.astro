<script define:vars={{ lang }}>
  // Rotating hero text — language-aware
  // These are hardcoded string arrays used only for visual text rotation.
  // They are NOT user-controlled input.
  const rotatingTextsEN = [
    { title: "Unleashing<br />Value From Data", description: "We design and deliver enterprise data platforms that enable reliable analytics and production-ready AI." },
    { title: "Clear Decisions,<br />Faster", description: "Empower your organization with modern data platforms and trusted analytics." },
    { title: "AI-Ready Data<br />Foundations", description: "Make your AI investments sustainable with modern and reliable data architecture." },
    { title: "From Insight<br />to Action", description: "Turn data into real business impact with our consulting, platforms and AI solutions." }
  ];
  const highlightsEN = ["Value From Data", "Faster", "AI", "to Action"];

  const rotatingTextsTR = [
    { title: "Veriden<br />De\u011Fer \u00DCretmek", description: "G\u00FCvenilir analitik ve \u00fcretime haz\u0131r yapay zeka sa\u011Flayan kurumsal veri platformlar\u0131 tasar\u0131l\u0131yor ve sunuyoruz." },
    { title: "Net Kararlar,<br />Daha H\u0131zl\u0131", description: "Modern veri platformlar\u0131 ve g\u00FCvenilir analitikle organizasyonunuzu g\u00FC\u00E7lendirin." },
    { title: "YZ'ye Haz\u0131r Veri<br />Temelleri", description: "Yapay zeka yat\u0131r\u0131mlar\u0131n\u0131z\u0131 modern ve g\u00FCvenilir veri mimarisiyle s\u00FCrd\u00FCr\u00FClebilir k\u0131l\u0131n." },
    { title: "\u0130\u00E7g\u00F6r\u00FCden<br />Eyleme", description: "Dan\u0131\u015Fmanl\u0131k, platformlar ve yapay zeka \u00E7\u00F6z\u00FCmlerimizle veriyi ger\u00E7ek i\u015F etkisine d\u00F6n\u00FC\u015Ft\u00FCr\u00FCn." }
  ];
  const highlightsTR = ["De\u011Fer \u00DCretmek", "Daha H\u0131zl\u0131", "YZ", "Eyleme"];

  const rotatingTexts = lang === 'tr' ? rotatingTextsTR : rotatingTextsEN;
  const highlights = lang === 'tr' ? highlightsTR : highlightsEN;

  let currentTextIndex = 0;
  function rotateText() {
    const titleEl = document.getElementById('heroTitle');
    const descEl = document.getElementById('heroDesc');
    if (!titleEl || !descEl) return;
    titleEl.style.opacity = '0';
    descEl.style.opacity = '0';
    setTimeout(function() {
      currentTextIndex = (currentTextIndex + 1) % rotatingTexts.length;
      const text = rotatingTexts[currentTextIndex];

      let processedTitle = text.title;
      highlights.forEach(function(h) {
        if (processedTitle.indexOf(h) !== -1) {
          processedTitle = processedTitle.replace(h, '<span class="grad-text">' + h + '</span>');
        }
      });

      titleEl.innerHTML = processedTitle;
      descEl.textContent = text.description;
      titleEl.style.opacity = '1';
      descEl.style.opacity = '1';
    }, 600);
  }
  setInterval(rotateText, 4500);
</script>
