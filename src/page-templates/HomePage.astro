<style>
/* Hero mini link */
.hero__mini-link {
  display: inline-flex;
  font-size: 0.9rem;
  color: rgba(255,255,255,0.7);
  transition: color 0.2s ease;
  margin-top: 8px;
}
.hero__mini-link:hover { color: #fff; }

.hero__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 100%;
}

.hero__content-wrap {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  align-items: center;
  gap: 40px;
  width: 100%;
}

.hero {
  min-height: 500px;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.hero__content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-block: 60px;
}

.hero__subactions {
  display: flex;
  gap: 32px;
  margin-top: 4px;
}

.hero-sublink {
  color: rgba(255, 255, 255, 0.65);
  text-decoration: none;
  font-size: 0.95rem;
  font-weight: 600;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 6px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding-bottom: 2px;
}

.hero-sublink:hover {
  color: var(--clr-primary);
  border-color: var(--clr-primary);
}

.hero-sublink::after {
  content: '\2192';
  font-size: 1.1rem;
  transition: transform 0.3s ease;
}

.hero-sublink:hover::after {
  transform: translateX(5px);
}

.hero__title {
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  font-weight: 950;
  line-height: 1.1;
  color: #fff;
  margin-bottom: 24px;
  transition: opacity 0.6s ease;
  min-height: 2.2em;
  display: block;
}

.hero__accent {
  display: block;
  width: 80px;
  height: 4px;
  border-radius: 4px;
  background: var(--grad-brand);
  margin-bottom: 24px;
}

.hero__desc {
  font-size: 1.15rem;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.8);
  max-width: 580px;
  margin-bottom: 30px;
  transition: opacity 0.6s ease;
  min-height: 3.2em;
}

.hero__visual {
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero__shape-new {
  width: 100%;
  max-width: 500px;
  animation: float 8s ease-in-out infinite;
  filter: drop-shadow(0 20px 80px rgba(0, 200, 150, 0.3));
  image-rendering: -webkit-optimize-contrast;
}

@media (max-width: 1100px) {
  .hero {
    min-height: auto !important;
    padding-top: 5px;
    padding-bottom: 25px;
    height: auto;
  }
  .hero__inner { padding-top: 10px; }
  .hero__content-wrap {
    grid-template-columns: 1fr;
    text-align: left;
    position: relative;
    display: flex;
    flex-direction: column;
    padding-top: 10px;
    align-items: flex-start;
    width: 100%;
  }
  .hero__content {
    align-items: flex-start;
    padding-block: 10px;
    padding-top: 30px;
