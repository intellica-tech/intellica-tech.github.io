---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n/config';
import { useTranslations, useTranslatedPath } from '../i18n/utils';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

const siteUrl = "https://intellica.net";

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Intellica",
  "url": siteUrl,
  "description": t('meta.home.description'),
  "publisher": { "@id": `${siteUrl}/#organization` }
};
---

<Layout title={t('meta.home.title')} description={t('meta.home.description')} hideCta={true} lang={lang}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- ===== HERO ===== -->
  <section class="hero noise" id="index-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content">
          <div class="section-label anim-fade-up">{t('home.hero.label')}</div>
          <h1 class="hero__title anim-fade-up" id="heroTitle">{t('home.hero.titleLine1')}<br /><span class="grad-text">{t('home.hero.titleHighlight')}</span></h1>
          <span class="hero__accent anim-fade-up"></span>
          <p class="hero__desc anim-fade-up" id="heroDesc">{t('home.hero.desc')}</p>
          <div class="hero__actions anim-fade-up">
            <a class="btn btn-primary btn-pill btn-lg uppercase-never" href={tp('/contact')}>{t('home.hero.cta')}</a>
          </div>
          <div class="hero__subactions anim-fade-up">
            <a href={tp('/solutions')} class="hero-sublink">{t('home.hero.sublinkSolutions')}</a>
            <a href={tp('/products')} class="hero-sublink">{t('home.hero.sublinkProducts')}</a>
          </div>
        </div>
        <div class="hero__visual anim-fade-up">
           <img class="hero__shape-new" src="/assets/img/intellica_camlogo_icibos.png" alt={t('home.hero.imgAlt')} />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HERO PROOF ===== -->
  <section class="section section--white" style="padding-top: 36px; padding-bottom: 36px;">
    <div class="container">
      <div class="hero-proof anim-fade-up">
        <p class="hero-proof__text">
          {t('home.proof.text')}
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITIES ===== -->
  <section class="section section--light" id="capabilities">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">{t('home.capabilities.label')}</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">
          {t('home.capabilities.title')}<span class="grad-text">{t('home.capabilities.titleHighlight')}</span>
        </h2>
        <p class="section-sub">
          {t('home.capabilities.sub')}
        </p>
      </div>
      <div class="cap-grid-custom anim-fade-up">
        {/* Row 1: 3 cards */}
        <a href={tp('/data-platforms')} class="cap-card-v2" style="text-decoration:none;">
          <div class="cap-icon-box">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3>{t('home.capabilities.card1.title')}</h3>
          <p>{t('home.capabilities.card1.desc')}</p>
        </a>

        <a href={tp('/solutions#framework')} class="cap-card-v2" style="text-decoration:none;">
          <div class="cap-icon-box">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
          </div>
          <h3>{t('home.capabilities.card2.title')}</h3>
          <p>{t('home.capabilities.card2.desc')}</p>
        </a>

        <a href={tp('/solutions#framework')} class="cap-card-v2" style="text-decoration:none;">
          <div class="cap-icon-box">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
          </div>
          <h3>{t('home.capabilities.card3.title')}</h3>
          <p>{t('home.capabilities.card3.desc')}</p>
        </a>

        {/* Row 2: 2 cards centered */}
        <div class="cap-grid-row-2">
          <a href={tp('/products')} class="cap-card-v2" style="text-decoration:none;">
            <div class="cap-icon-box">
               <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
            </div>
            <h3>{t('home.capabilities.card4.title')}</h3>
            <p>{t('home.capabilities.card4.desc')}</p>
          </a>

          <a href={tp('/contact')} class="cap-card-v2" style="text-decoration:none;">
            <div class="cap-icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <h3>{t('home.capabilities.card5.title')}</h3>
            <p>{t('home.capabilities.card5.desc')}</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== GLOBAL IMPACT ===== -->
  <section class="section section--white" id="global-impact">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">{t('home.globalImpact.label')}</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">
          {t('home.globalImpact.title')}<span class="grad-text">{t('home.globalImpact.titleHighlight')}</span>
        </h2>
        <p class="section-sub">
          {t('home.globalImpact.sub')}
        </p>
      </div>
      <!-- MAP -->
      <div class="map-wrap anim-fade-up">
        <img alt={t('home.globalImpact.mapAlt')} class="map-image" src="/assets/images/map/world-impact-map.png" loading="lazy" />
        <svg aria-hidden="true" class="map-overlay" preserveAspectRatio="none" viewBox="0 0 1200 520">
          <path class="conn" d="M108,255 C300,180 400,140 500,137" />
          <path class="conn" d="M500,137 C530,150 550,165 573,172" />
          <path class="conn" d="M573,172 C600,185 620,195 645,208" />
          <path class="conn" d="M645,208 C670,250 690,285 708,305" />
          <path class="conn" d="M645,208 C700,230 730,245 748,260" />
          <path class="conn" d="M645,208 C700,210 750,215 788,215" />
          <g class="dot" style="--delay:0s"><circle cx="108" cy="255" r="5"/><circle class="ring" cx="108" cy="255" r="5"/></g>
          <g class="dot" style="--delay:0.2s"><circle cx="500" cy="137" r="5"/><circle class="ring" cx="500" cy="137" r="5"/></g>
          <g class="dot" style="--delay:0.35s"><circle cx="573" cy="172" r="5"/><circle class="ring" cx="573" cy="172" r="5"/></g>
          <g class="dot" style="--delay:0.5s"><circle cx="645" cy="208" r="5"/><circle class="ring" cx="645" cy="208" r="5"/></g>
          <g class="dot" style="--delay:0.65s"><circle cx="708" cy="305" r="5"/><circle class="ring" cx="708" cy="305" r="5"/></g>
          <g class="dot" style="--delay:0.8s"><circle cx="748" cy="260" r="5"/><circle class="ring" cx="748" cy="260" r="5"/></g>
          <g class="dot" style="--delay:0.95s"><circle cx="788" cy="215" r="5"/><circle class="ring" cx="788" cy="215" r="5"/></g>
        </svg>
      </div>
      <!-- METRICS -->
      <div class="grid-4 metrics-grid anim-fade-up">
        <div class="metric-item">
          <span class="metric-label" style="font-weight: 800; color: #111; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 8px; display: block;">{t('home.globalImpact.metric1.label')}</span>
          <span class="metric-number"><span class="counter" data-target="20">0</span>{t('home.globalImpact.metric1.number')}</span>
          <p style="font-size: 0.9rem; color: #64748b; margin-top: 8px;">{t('home.globalImpact.metric1.desc')}</p>
        </div>
        <div class="metric-item">
          <span class="metric-label" style="font-weight: 800; color: #111; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 8px; display: block;">{t('home.globalImpact.metric2.label')}</span>
          <span class="metric-number"><span class="counter" data-target="80">0</span>{t('home.globalImpact.metric2.number')}</span>
          <p style="font-size: 0.9rem; color: #64748b; margin-top: 8px;">{t('home.globalImpact.metric2.desc')}</p>
        </div>
        <div class="metric-item">
          <span class="metric-label" style="font-weight: 800; color: #111; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 8px; display: block;">{t('home.globalImpact.metric3.label')}</span>
          <span class="metric-number"><span class="counter" data-target="100">0</span>{t('home.globalImpact.metric3.number')}</span>
          <p style="font-size: 0.9rem; color: #64748b; margin-top: 8px;">{t('home.globalImpact.metric3.desc')}</p>
        </div>
        <div class="metric-item">
          <span class="metric-label" style="font-weight: 800; color: #111; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 8px; display: block;">{t('home.globalImpact.metric4.label')}</span>
          <span class="metric-number"><span class="counter" data-target="30">0</span>{t('home.globalImpact.metric4.number')}</span>
          <p style="font-size: 0.9rem; color: #64748b; margin-top: 8px;">{t('home.globalImpact.metric4.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRUSTED CLIENTS ===== -->
  <section class="section section--light" id="trusted-clients">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">{t('home.trustedClients.label')}</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">
          {t('home.trustedClients.title')}<span class="grad-text">{t('home.trustedClients.titleHighlight')}</span>
        </h2>
        <p class="section-sub">
          {t('home.trustedClients.sub')}
        </p>
      </div>
      <div class="logo-grid anim-fade-up">
        <a class="logo-tile logo-tile--lg" aria-label="Ministry of Interior"><img alt="Ministry of Interior" src="/assets/images/logos/InteriorMinistryTR.png" loading="lazy" /></a>
        <a class="logo-tile logo-tile--lg" aria-label="EGM"><img alt="EGM" src="/assets/images/logos/egm_logo2.png" loading="lazy" /></a>
        <a class="logo-tile logo-tile--lg" aria-label="SGK"><img alt="SGK" src="/assets/images/logos/SGKLOGOTYPE-RENKLI.svg" loading="lazy" /></a>
        <a class="logo-tile logo-tile--lg" aria-label="TCDD"><img alt="TCDD" src="/assets/images/logos/TCDD_Taşımacılık_Logo.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Akbank"><img alt="Akbank" src="/assets/images/logos/Akbank_logo.svg" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Fibabanka"><img alt="Fibabanka" src="/assets/images/logos/Fibabanka.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="ING"><img alt="ING" src="/assets/images/logos/ING.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Odeabank"><img alt="Odeabank" src="/assets/images/logos/Odeabank_logo.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="TEB"><img alt="TEB" src="/assets/images/logos/TEB_LOGO.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="DenizBank"><img alt="DenizBank" src="/assets/images/logos/DenizBank_logo.svg (1).png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="TBI Bank"><img alt="TBI Bank" src="/assets/images/logos/tbi-bank.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Birbank"><img alt="Birbank" src="/assets/images/logos/birbank..svg" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Yapı Kredi"><img alt="Yapı Kredi" src="/assets/images/logos/Yapı_kredi_logo.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Vodafone"><img alt="Vodafone" src="/assets/images/logos/Vodafone_logo_2017.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Turkcell"><img alt="Turkcell" src="/assets/images/logos/Turkcell_logo.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Turk Telekom"><img alt="Turk Telekom" src="/assets/images/logos/TURKTELEKOM.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Zain"><img alt="Zain" src="/assets/images/logos/ZAINr.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="T-Mobile"><img alt="T-Mobile" src="/assets/images/logos/TMOBILE.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Boyner"><img alt="Boyner" src="/assets/images/logos/Boyner_Logo.jpg" loading="lazy" /></a>
        <a class="logo-tile" aria-label="LC Waikiki"><img alt="LC Waikiki" src="/assets/images/logos/lcw.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Allianz"><img alt="Allianz" src="/assets/images/logos/Allianz.svg.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Anadolu Sigorta"><img alt="Anadolu Sigorta" src="/assets/images/logos/Anadolu_Sigorta_logo.svg" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Hopi"><img alt="Hopi" src="/assets/images/logos/hopi.png" loading="lazy" /></a>
        <a class="logo-tile" aria-label="Erciyes Anadolu Holding"><img alt="Erciyes Anadolu Holding" src="/assets/images/logos/Erciyes_Anadolu_Holding_logo.svg" loading="lazy" /></a>
      </div>
      <div class="text-center anim-fade-up" style="margin-top: 48px;">
        <a href={tp('/clients')} class="btn btn-primary btn-pill btn-lg">{t('home.trustedClients.viewAll')}</a>
      </div>
    </div>
  </section>

  <!-- ===== DWH / DATA PLATFORM TRANSFORMATION ===== -->
  <section class="section section--white" id="dwh-transformation" style="overflow:hidden;">
    <div class="deco-blob" aria-hidden="true" style="top:-80px;right:-80px;width:400px;height:400px;background:radial-gradient(circle,rgba(16,185,129,0.06) 0%,transparent 70%);"></div>
    <div class="deco-blob" aria-hidden="true" style="bottom:-80px;left:-80px;width:350px;height:350px;background:radial-gradient(circle,rgba(59,130,246,0.06) 0%,transparent 70%);"></div>
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">{t('home.dwh.label')}</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">
          {t('home.dwh.title')}<span class="grad-text">{t('home.dwh.titleHighlight')}</span>{t('home.dwh.titleSuffix')}
        </h2>
        <p class="section-sub">
          {t('home.dwh.sub')}
        </p>
      </div>
      <div class="grid-3 dwh-grid anim-fade-up">
        <div class="dwh-card">
          <div class="cap-icon-box">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3>{t('home.dwh.card1.title')}</h3>
          <p>{t('home.dwh.card1.desc')}</p>
          <ul class="dwh-card__list">
            <li>{t('home.dwh.card1.li1')}</li>
            <li>{t('home.dwh.card1.li2')}</li>
            <li>{t('home.dwh.card1.li3')}</li>
          </ul>
        </div>
        <div class="dwh-card">
          <div class="cap-icon-box">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>{t('home.dwh.card2.title')}</h3>
          <p>{t('home.dwh.card2.desc')}</p>
          <ul class="dwh-card__list">
            <li>{t('home.dwh.card2.li1')}</li>
            <li>{t('home.dwh.card2.li2')}</li>
            <li>{t('home.dwh.card2.li3')}</li>
          </ul>
        </div>
        <div class="dwh-card">
          <div class="cap-icon-box">
             <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
          </div>
          <h3>{t('home.dwh.card3.title')}</h3>
          <p>{t('home.dwh.card3.desc')}</p>
          <ul class="dwh-card__list">
            <li>{t('home.dwh.card3.li1')}</li>
            <li>{t('home.dwh.card3.li2')}</li>
            <li>{t('home.dwh.card3.li3')}</li>
          </ul>
        </div>
      </div>
      <div class="text-center anim-fade-up" style="margin-top:24px;">
        <a href={tp('/data-platforms')} class="btn btn-primary btn-pill btn-lg">{t('home.dwh.cta')}</a>
      </div>
    </div>
  </section>

  <!-- ===== ENTERPRISE PRODUCT PORTFOLIO ===== -->
  <section class="section section--light" id="products-ecosystem">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">{t('home.products.label')}</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">{t('home.products.title')}<span class="grad-text">{t('home.products.titleHighlight')}</span></h2>
        <p class="section-sub">{t('home.products.sub')}</p>
      </div>

      <div class="premium-products anim-fade-up">
        <!-- Group 1: Data Models -->
        <div class="product-shelf">
          <div class="shelf-header">
            <h3 class="shelf-title">{t('home.products.shelf1.title')}<span class="grad-text">{t('home.products.shelf1.titleHighlight')}</span></h3>
            <p class="shelf-desc">{t('home.products.shelf1.desc')}</p>
          </div>
          <div class="shelf-grid">
            <a href={tp('/products/ifdm')} class="premium-card">
              <div class="card-p-logo"><img alt="IFDM" src="/assets/images/logos/IFDM_logo.png" loading="lazy" /></div>
              <div class="card-p-content">
                <h4>{t('home.products.ifdm.title')}</h4>
                <p>{t('home.products.ifdm.desc')}</p>
              </div>
              <div class="card-p-arrow">&rarr;</div>
            </a>
            <a href={tp('/products/itdm')} class="premium-card">
              <div class="card-p-logo"><img alt="ITDM" src="/assets/images/logos/ITDM_logo.png" loading="lazy" /></div>
              <div class="card-p-content">
                <h4>{t('home.products.itdm.title')}</h4>
                <p>{t('home.products.itdm.desc')}</p>
              </div>
              <div class="card-p-arrow">&rarr;</div>
            </a>
            <a href={tp('/products/hrdm')} class="premium-card">
              <div class="card-p-logo"><img alt="HRDM" src="/assets/images/logos/hrdm.png" loading="lazy" /></div>
              <div class="card-p-content">
                <h4>{t('home.products.hrdm.title')}</h4>
                <p>{t('home.products.hrdm.desc')}</p>
              </div>
              <div class="card-p-arrow">&rarr;</div>
            </a>
          </div>
        </div>

        <!-- Group 2: Data Platform & Governance -->
        <div class="product-shelf">
          <div class="shelf-header">
            <h3 class="shelf-title">{t('home.products.shelf2.title')}<span class="grad-text">{t('home.products.shelf2.titleHighlight')}</span></h3>
            <p class="shelf-desc">{t('home.products.shelf2.desc')}</p>
          </div>
          <div class="shelf-grid">
            <a href={tp('/products/icc')} class="premium-card">
              <div class="card-p-logo"><img alt="ICC" src="/assets/images/logos/ıcc.png" loading="lazy" /></div>
              <div class="card-p-content">
                <h4>{t('home.products.icc.title')}</h4>
                <p>{t('home.products.icc.desc')}</p>
              </div>
              <div class="card-p-arrow">&rarr;</div>
            </a>
            <a href={tp('/products/retouch')} class="premium-card">
              <div class="card-p-logo"><img alt="ReTouch" src="/assets/images/logos/retouch.svg" loading="lazy" /></div>
              <div class="card-p-content">
                <h4>{t('home.products.retouch.title')}</h4>
                <p>{t('home.products.retouch.desc')}</p>
              </div>
              <div class="card-p-arrow">&rarr;</div>
            </a>
            <a href={tp('/products/retable')} class="premium-card">
              <div class="card-p-logo"><img alt="Retable" src="/assets/images/logos/retable.png" loading="lazy" /></div>
              <div class="card-p-content">
                <h4>{t('home.products.retable.title')}</h4>
                <p>{t('home.products.retable.desc')}</p>
              </div>
              <div class="card-p-arrow">&rarr;</div>
            </a>
            <a href={tp('/products/orqenta')} class="premium-card" target="_blank">
              <div class="card-p-logo"><img alt="Orqenta" src="/assets/images/logos/orqenta_logo.png" loading="lazy" /></div>
              <div class="card-p-content">
                <h4>{t('home.products.orqenta.title')}</h4>
                <p>{t('home.products.orqenta.desc')}</p>
              </div>
              <div class="card-p-arrow">&rarr;</div>
            </a>
          </div>
        </div>

        <!-- Group 3: AI Products -->
        <div class="product-shelf">
          <div class="shelf-header">
            <h3 class="shelf-title">{t('home.products.shelf3.title')}<span class="grad-text">{t('home.products.shelf3.titleHighlight')}</span></h3>
            <p class="shelf-desc">{t('home.products.shelf3.desc')}</p>
