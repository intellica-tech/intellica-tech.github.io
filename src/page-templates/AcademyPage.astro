---
import Layout from '../layouts/Layout.astro';
import ChallengeArena from '../components/gamification/ChallengeArena.astro';
import { useTranslations, useTranslatedPath } from '../i18n/utils';
import type { Lang } from '../i18n/config';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

const breadcrumbs = [
  { name: t('academy.breadcrumbAbout'), url: tp('/about') },
  { name: t('academy.breadcrumb'), url: tp('/academy') }
];

const stats = [
  { value: t('academy.hero.stat1.value'), label: t('academy.hero.stat1.label') },
  { value: t('academy.hero.stat2.value'), label: t('academy.hero.stat2.label') },
  { value: t('academy.hero.stat3.value'), label: t('academy.hero.stat3.label') }
];

const modules = [
  {
    title: t('academy.module1.title'),
    items: [t('academy.module1.i1'), t('academy.module1.i2'), t('academy.module1.i3')]
  },
  {
    title: t('academy.module2.title'),
    items: [t('academy.module2.i1'), t('academy.module2.i2'), t('academy.module2.i3')],
    highlight: [t('academy.module2.h1'), t('academy.module2.h2'), t('academy.module2.h3')]
  },
  {
    title: t('academy.module3.title'),
    items: [t('academy.module3.i1'), t('academy.module3.i2'), t('academy.module3.i3')]
  }
];

const universities = [
  { name: 'Alaaddin Keykubat University', logo: '/assets/images/logos/universities/alku.png' },
  { name: 'Bahcesehir University', logo: '/assets/images/logos/universities/bau.png' },
  { name: 'Dokuz Eylul University', logo: '/assets/images/logos/universities/deu.png' },
  { name: 'Ege University', logo: '/assets/images/logos/universities/ege.png' },
  { name: 'Gebze Technical University', logo: '/assets/images/logos/universities/gtu.png' },
  { name: 'Istanbul Technical University', logo: '/assets/images/logos/universities/itu.png' },
  { name: 'Istanbul University', logo: '/assets/images/logos/universities/istanbul.png' },
  { name: 'Kocaeli University', logo: '/assets/images/logos/universities/kou.png' },
  { name: 'Marmara University', logo: '/assets/images/logos/universities/marmara.png' },
  { name: 'Yildiz Technical University', logo: '/assets/images/logos/universities/ytu.png' }
];

const testimonials = [
  { quote: t('academy.testimonial1.quote'), author: t('academy.testimonial1.author'), role: t('academy.testimonial1.role') },
  { quote: t('academy.testimonial2.quote'), author: t('academy.testimonial2.author'), role: t('academy.testimonial2.role') },
  { quote: t('academy.testimonial3.quote'), author: t('academy.testimonial3.author'), role: t('academy.testimonial3.role') }
];

const faqs = [
  { q: t('academy.faq1.q'), a: t('academy.faq1.a') },
  { q: t('academy.faq2.q'), a: t('academy.faq2.a') },
  { q: t('academy.faq3.q'), a: t('academy.faq3.a') },
  { q: t('academy.faq4.q'), a: t('academy.faq4.a') },
  { q: t('academy.faq5.q'), a: t('academy.faq5.a') },
  { q: t('academy.faq6.q'), a: t('academy.faq6.a') },
  { q: t('academy.faq7.q'), a: t('academy.faq7.a') },
  { q: t('academy.faq8.q'), a: t('academy.faq8.a') },
  { q: t('academy.faq9.q'), a: t('academy.faq9.a') },
  { q: t('academy.faq10.q'), a: t('academy.faq10.a') }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
};
---

<Layout
  title={t('meta.academy.title')}
  description={t('meta.academy.description')}
  breadcrumbs={breadcrumbs}
  hideCta={true}
  lang={lang}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="hero noise" id="academy-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">{t('academy.hero.label')}</div>
          <h1 class="hero__title">
            {t('academy.hero.title')}<br /><span class="grad-text">{t('academy.hero.titleHighlight')}</span>
          </h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">{t('academy.hero.desc')}</p>

          <div class="hero-stats">
            {stats.map(stat => (
              <div class="stat-item">
                <div class="stat-value">{stat.value}</div>
                <div class="stat-label">{stat.label}</div>
              </div>
            ))}
          </div>

          <div class="hero__actions">
            <a href={tp('/contact')} class="btn btn-primary btn-pill btn-lg">{t('academy.hero.cta')}</a>
          </div>
        </div>

        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/academy_hero.png" alt={t('academy.hero.imgAlt')} class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section section--white">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">{t('academy.about.title')}<span class="grad-text">{t('academy.about.titleHighlight')}</span></h2>
        <p class="section-sub">{t('academy.about.desc')}</p>
      </div>

      <div class="grid-2 anim-fade-up" style="margin-top: 60px;">
        <div class="card-light luxury-card">
          <div class="icon-box">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="" style="width: 32px; height: 32px;" loading="lazy" />
          </div>
          <h3>{t('academy.about.card1.title')}</h3>
          <p>{t('academy.about.card1.desc')}</p>
        </div>
        <div class="card-light luxury-card">
          <div class="icon-box">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="" style="width: 32px; height: 32px;" loading="lazy" />
          </div>
          <h3>{t('academy.about.card2.title')}</h3>
          <p>{t('academy.about.card2.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- INVITATION -->
  <section class="section section--dark">
    <div class="container">
      <div class="card-glass text-center anim-fade-up invite-card">
        <h2 class="hero__title invite-heading">
          {t('academy.invite.title')}<span class="grad-text">{t('academy.invite.titleHighlight')}</span>
        </h2>
        <p class="hero__desc" style="margin-inline: auto; max-width: 800px;">{t('academy.invite.desc')}</p>
        <div class="hero__actions" style="justify-content: center;">
          <a href={tp('/contact')} class="btn btn-primary btn-pill btn-lg">{t('academy.invite.cta')}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CAMP CONTENT -->
  <section class="section section--white">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">{t('academy.curriculum.label')}</div>
        <h2 class="section-title">{t('academy.curriculum.title')}<span class="grad-text">{t('academy.curriculum.titleHighlight')}</span></h2>
        <p class="section-sub">{t('academy.curriculum.desc')}</p>
      </div>

      <div class="grid-3 anim-fade-up" style="margin-top: 60px;">
        {modules.map(mod => (
          <div class="card-light curriculum-card">
            <h3 style="color: var(--clr-primary); margin-bottom: 24px;">{mod.title}</h3>
            <ul class="curriculum-list">
              {mod.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
            {mod.highlight && (
              <div class="highlight-box">
                <div class="divider"></div>
                <ul>
                  {mod.highlight.map(h => <li>{h}</li>)}
                </ul>
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="grid-2 anim-fade-up" style="margin-top: 40px;">
        <div class="card-light promo-card">
          <h4>{t('academy.who.title')}</h4>
          <p>{t('academy.who.desc')}</p>
        </div>
        <div class="card-light promo-card">
          <h4>{t('academy.why.title')}</h4>
          <p>{t('academy.why.desc')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- UNIVERSITIES -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">{t('academy.uni.title')}<span class="grad-text">{t('academy.uni.titleHighlight')}</span></h2>
        <p class="section-sub">{t('academy.uni.desc')}</p>
      </div>

      <div class="uni-grid anim-fade-up">
        {universities.map(uni => (
          <div class="uni-tile" title={uni.name}>
            <img src={uni.logo} alt={uni.name} class="uni-logo" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section section--white">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">{t('academy.testimonials.title')}<span class="grad-text">{t('academy.testimonials.titleHighlight')}</span></h2>
        <p class="section-sub">{t('academy.testimonials.sub')}</p>
      </div>

      <div class="grid-3 anim-fade-up" style="margin-top: 60px;">
        {testimonials.map(item => (
          <div class="card-light testimonial-card">
            <div class="quote-icon">"</div>
            <p class="quote-text">{item.quote}</p>
            <div class="author-info">
              <div class="author-avatar">{item.author[0]}</div>
              <div class="author-meta">
                <div class="author-name">{item.author}</div>
                <div class="author-role">{item.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">{t('academy.faq.title')}<span class="grad-text">{t('academy.faq.titleHighlight')}</span></h2>
        <p class="section-sub">{t('academy.faq.sub')}</p>
      </div>

      <div class="grid-2 anim-fade-up" style="margin-top: 60px; gap: 24px;">
        {faqs.map(item => (
          <div class="card-light faq-item">
            <h4>{item.q}</h4>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CHALLENGE ARENA -->
  <ChallengeArena />

  <!-- CTA -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip text-center anim-fade-up">
        <h3>{t('academy.cta.title')}</h3>
        <p>{t('academy.cta.desc')}</p>
        <div class="hero__actions" style="justify-content: center; margin-top: 32px;">
          <a href={tp('/contact')} class="btn btn-primary btn-pill btn-lg">{t('academy.cta.primary')}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.hero-stats { display: flex; gap: 40px; margin-bottom: 48px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 24px; }
.stat-value { font-size: 2.5rem; font-weight: 900; color: var(--clr-primary); line-height: 1; }
.stat-label { font-size: 0.9rem; color: rgba(255,255,255,0.6); margin-top: 4px; }
@media (max-width: 1100px) { .hero-stats { justify-content: flex-start; flex-wrap: wrap; gap: 20px; } }
.invite-card { padding: 80px 40px; border-radius: 48px; }
.invite-heading { font-size: clamp(1.5rem, 5vw, 2.5rem); margin-inline: auto; text-align: center; line-height: 1.2; }
@media (max-width: 768px) { .invite-card { padding: 48px 24px; border-radius: 28px; } .invite-heading { font-size: 1.5rem; } }
.luxury-card { transition: all 0.4s; }
.luxury-card:hover { transform: translateY(-8px); border-color: var(--clr-primary); }
.curriculum-card { display: flex; flex-direction: column; height: 100%; }
.curriculum-list { list-style: none; padding: 0; margin: 0; }
.curriculum-list li { position: relative; padding-left: 24px; margin-bottom: 12px; font-size: 0.95rem; color: #475569; }
.curriculum-list li::before { content: "\2192"; position: absolute; left: 0; color: var(--clr-primary); font-weight: 700; }
.highlight-box { margin-top: auto; padding-top: 24px; }
.divider { height: 1px; background: #E2E8F0; margin-bottom: 20px; }
.highlight-box ul { list-style: none; padding: 0; }
.highlight-box li { font-size: 0.85rem; font-weight: 600; color: #1E293B; margin-bottom: 8px; }
.uni-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-top: 48px; }
.uni-tile { background: #FFF; border: 1px solid #E2E8F0; border-radius: 12px; padding: 16px; text-align: center; display: flex; align-items: center; justify-content: center; min-height: 120px; transition: transform 0.3s ease, box-shadow 0.3s ease; }
.uni-tile:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.06); border-color: var(--clr-primary); }
.uni-logo { max-width: 100%; max-height: 80px; object-fit: contain; filter: grayscale(1); opacity: 0.7; transition: all 0.3s ease; }
.uni-tile:hover .uni-logo { filter: grayscale(0); opacity: 1; }
@media (max-width: 1024px) { .uni-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 600px) { .uni-grid { grid-template-columns: repeat(2, 1fr); } }
.testimonial-card { display: flex; flex-direction: column; background: #FFF; border: 1px solid #E2E8F0; }
.quote-icon { font-size: 4rem; color: var(--clr-primary); line-height: 1; height: 3rem; margin-top: -10px; opacity: 0.2; }
.quote-text { font-size: 1rem; color: #475569; font-style: italic; line-height: 1.6; margin-bottom: 32px; flex: 1; }
.author-info { display: flex; align-items: center; gap: 16px; border-top: 1px solid #F1F5F9; padding-top: 20px; }
.author-avatar { width: 44px; height: 44px; background: var(--grad-brand); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #FFF; font-weight: 800; }
.author-name { font-weight: 750; color: #1E293B; font-size: 0.95rem; }
.author-role { font-size: 0.8rem; color: #64748B; }
.faq-item h4 { font-size: 1.1rem; font-weight: 800; color: #1E293B; margin-bottom: 12px; }
.faq-item p { font-size: 0.95rem; color: #64748B; }
</style>
