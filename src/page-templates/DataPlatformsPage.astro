---
import Layout from '../layouts/Layout.astro';
import DataFlowStory from '../components/gamification/DataFlowStory.astro';
import PipelineBuilder from '../components/gamification/PipelineBuilder.astro';
import { useTranslations, useTranslatedPath } from '../i18n/utils';
import type { Lang } from '../i18n/config';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

const breadcrumbs = [
  { name: t('dataPlatforms.breadcrumbSolutions'), url: tp('/solutions') },
  { name: t('dataPlatforms.breadcrumb'), url: tp('/data-platforms') }
];
---

<Layout
  title={t('meta.dataPlatforms.title')}
  description={t('meta.dataPlatforms.description')}
  breadcrumbs={breadcrumbs}
  hideCta={true}
  lang={lang}
>
  <!-- HERO -->
  <section class="hero noise" id="data-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">{t('dataPlatforms.hero.label')}</div>
          <h1 class="hero__title">{t('dataPlatforms.hero.title')}<br /><span class="grad-text">{t('dataPlatforms.hero.titleHighlight')}</span></h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">{t('dataPlatforms.hero.desc')}</p>
          <div class="hero__actions">
            <a class="btn btn-primary btn-pill btn-lg" href={tp('/contact')}>{t('dataPlatforms.hero.cta')}</a>
          </div>
        </div>
        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/data_platforms_hero_v2.png" alt={t('dataPlatforms.hero.imgAlt')} class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

  <!-- STRATEGIC OVERVIEW -->
  <section class="section section--light" style="padding-top: 60px; padding-bottom: 80px;">
    <div class="container">
      <div class="grid-4 metrics-grid anim-fade-up">
        <div class="metric-card">
          <div class="metric-header"><div class="metric-dot teal"></div><span>{t('dataPlatforms.overview.card1.label')}</span></div>
          <div class="metric-body"><h3>{t('dataPlatforms.overview.card1.title')}</h3><p>{t('dataPlatforms.overview.card1.desc')}</p></div>
        </div>
        <div class="metric-card">
          <div class="metric-header"><div class="metric-dot blue"></div><span>{t('dataPlatforms.overview.card2.label')}</span></div>
          <div class="metric-body"><h3>{t('dataPlatforms.overview.card2.title')}</h3><p>{t('dataPlatforms.overview.card2.desc')}</p></div>
        </div>
        <div class="metric-card">
          <div class="metric-header"><div class="metric-dot purple"></div><span>{t('dataPlatforms.overview.card3.label')}</span></div>
          <div class="metric-body"><h3>{t('dataPlatforms.overview.card3.title')}</h3><p>{t('dataPlatforms.overview.card3.desc')}</p></div>
        </div>
        <div class="metric-card">
          <div class="metric-header"><div class="metric-dot amber"></div><span>{t('dataPlatforms.overview.card4.label')}</span></div>
          <div class="metric-body"><h3>{t('dataPlatforms.overview.card4.title')}</h3><p>{t('dataPlatforms.overview.card4.desc')}</p></div>
        </div>
      </div>
    </div>
  </section>

  <DataFlowStory />
  <PipelineBuilder />

  <!-- WHY -->
  <section class="section section--white" id="why">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">{t('dataPlatforms.why.label')}</div>
        <h2 class="section-title">{t('dataPlatforms.why.title')}<span class="grad-text">{t('dataPlatforms.why.titleHighlight')}</span></h2>
        <p class="section-sub">{t('dataPlatforms.why.desc')}</p>
      </div>
      <div class="grid-3 cap-grid anim-fade-up">
        <div class="card-light">
          <div class="cap-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
          <h3>{t('dataPlatforms.why.card1.title')}</h3>
          <p>{t('dataPlatforms.why.card1.desc')}</p>
        </div>
        <div class="card-light">
          <div class="cap-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg></div>
          <h3>{t('dataPlatforms.why.card2.title')}</h3>
          <p>{t('dataPlatforms.why.card2.desc')}</p>
        </div>
        <div class="card-light">
          <div class="cap-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg></div>
          <h3>{t('dataPlatforms.why.card3.title')}</h3>
          <p>{t('dataPlatforms.why.card3.desc')}</p>
        </div>
      </div>
      <div class="kpi-banner anim-fade-up">
        <div class="kpi-item"><b>{t('dataPlatforms.why.kpi1.title')}</b><span>{t('dataPlatforms.why.kpi1.desc')}</span></div>
        <div class="kpi-item"><b>{t('dataPlatforms.why.kpi2.title')}</b><span>{t('dataPlatforms.why.kpi2.desc')}</span></div>
        <div class="kpi-item"><b>{t('dataPlatforms.why.kpi3.title')}</b><span>{t('dataPlatforms.why.kpi3.desc')}</span></div>
      </div>
    </div>
  </section>

  <!-- ARCHITECTURE -->
  <section class="section section--dark" id="architecture" style="background: radial-gradient(circle at 50% 50%, #1a365d 0%, #020617 100%);">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">{t('dataPlatforms.arch.title')}<span class="grad-text">{t('dataPlatforms.arch.titleHighlight')}</span></h2>
        <p class="section-sub" style="color: rgba(255,255,255,0.7);">{t('dataPlatforms.arch.desc')}</p>
      </div>
      <div class="architecture-main anim-fade-up">
        <div class="card-glass archi-card-modern">
          <div class="archi-layers-grid">
            <div class="archi-layer-col">
              <div class="layer-title">{t('dataPlatforms.arch.sources')}</div>
              <div class="layer-chip">{t('dataPlatforms.arch.source1')}</div>
              <div class="layer-chip">{t('dataPlatforms.arch.source2')}</div>
              <div class="layer-chip">{t('dataPlatforms.arch.source3')}</div>
            </div>
            <div class="archi-arrow">&rarr;</div>
            <div class="archi-layer-col main-layer">
              <div class="layer-title">{t('dataPlatforms.arch.engine')}</div>
              <div class="platform-box">
                <div class="platform-row">
                  <div class="platform-segment">{t('dataPlatforms.arch.ingestion')}</div>
                  <div class="platform-segment">{t('dataPlatforms.arch.integration')}</div>
                </div>
                <div class="platform-row">
                  <div class="platform-segment destaque">{t('dataPlatforms.arch.warehouse')}</div>
                </div>
                <div class="platform-row">
                  <div class="platform-segment">{t('dataPlatforms.arch.governance')}</div>
                  <div class="platform-segment">{t('dataPlatforms.arch.quality')}</div>
                </div>
              </div>
            </div>
            <div class="archi-arrow">&rarr;</div>
            <div class="archi-layer-col">
              <div class="layer-title">{t('dataPlatforms.arch.value')}</div>
              <div class="layer-chip highlight">{t('dataPlatforms.arch.biAi')}</div>
              <div class="layer-chip highlight">{t('dataPlatforms.arch.analytics')}</div>
              <div class="layer-chip highlight">{t('dataPlatforms.arch.insights')}</div>
            </div>
          </div>
          <div class="archi-note" style="background: rgba(255,255,255,0.03); border-top: 1px solid rgba(255,255,255,0.1);">
            <p style="color: rgba(255,255,255,0.8);">{t('dataPlatforms.arch.note')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="section section--white" id="capabilities">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">{t('dataPlatforms.cap.label')}</div>
        <h2 class="section-title">{t('dataPlatforms.cap.title')}<span class="grad-text">{t('dataPlatforms.cap.titleHighlight')}</span></h2>
        <p class="section-sub">{t('dataPlatforms.cap.desc')}</p>
      </div>
      <div class="grid-3 cap-grid anim-fade-up">
        <div class="card-light"><h3>{t('dataPlatforms.cap.card1.title')}</h3><p>{t('dataPlatforms.cap.card1.desc')}</p></div>
        <div class="card-light"><h3>{t('dataPlatforms.cap.card2.title')}</h3><p>{t('dataPlatforms.cap.card2.desc')}</p></div>
        <div class="card-light"><h3>{t('dataPlatforms.cap.card3.title')}</h3><p>{t('dataPlatforms.cap.card3.desc')}</p></div>
        <div class="card-light"><h3>{t('dataPlatforms.cap.card4.title')}</h3><p>{t('dataPlatforms.cap.card4.desc')}</p></div>
        <div class="card-light"><h3>{t('dataPlatforms.cap.card5.title')}</h3><p>{t('dataPlatforms.cap.card5.desc')}</p></div>
        <div class="card-light"><h3>{t('dataPlatforms.cap.card6.title')}</h3><p>{t('dataPlatforms.cap.card6.desc')}</p></div>
      </div>
    </div>
  </section>

  <!-- VENDOR-AGNOSTIC -->
  <section class="section section--dark" id="vendor-agnostic" style="border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
    <div class="container">
      <div class="vendor-box anim-fade-up">
        <div class="vendor-content">
          <h2 class="section-title" style="text-align: left; color: #fff;">{t('dataPlatforms.vendor.title')}<span class="grad-text">{t('dataPlatforms.vendor.titleHighlight')}</span></h2>
          <p class="section-sub" style="text-align: left; margin-inline: 0; margin-bottom: 24px; color: rgba(255,255,255,0.8);">{t('dataPlatforms.vendor.desc')}</p>
          <ul class="check-list">
            <li style="color: rgba(255,255,255,0.7);">{t('dataPlatforms.vendor.li1')}</li>
            <li style="color: rgba(255,255,255,0.7);">{t('dataPlatforms.vendor.li2')}</li>
            <li style="color: rgba(255,255,255,0.7);">{t('dataPlatforms.vendor.li3')}</li>
            <li style="color: rgba(255,255,255,0.7);">{t('dataPlatforms.vendor.li4')}</li>
          </ul>
          <div class="vendor-badge" style="background: rgba(0,200,150,0.1); color: var(--clr-primary); border: 1px solid rgba(0,200,150,0.2);">{t('dataPlatforms.vendor.badge')}</div>
        </div>
        <div class="vendor-visual">
          <div class="tech-glow-box">
            <img src="/assets/img/vendor_agnostic_hub.png" alt={t('dataPlatforms.vendor.imgAlt')} class="vendor-img" style="filter: drop-shadow(0 0 30px rgba(0,200,150,0.3)); border-radius: 20px;" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TECHNOLOGY ECOSYSTEM -->
  <section class="section section--white" id="technology">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">{t('dataPlatforms.tech.title')}<span class="grad-text">{t('dataPlatforms.tech.titleHighlight')}</span></h2>
        <p class="section-sub">{t('dataPlatforms.tech.desc')}</p>
      </div>
      <div class="architecture-main anim-fade-up">
        <div class="card-light archi-card">
          <img src="/assets/images/technology.png" alt={t('dataPlatforms.tech.imgAlt')} class="archi-img" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- SOLUTIONS ON TOP -->
  <section class="section section--light" id="solutions-on-top">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">{t('dataPlatforms.solutions.title')}<span class="grad-text">{t('dataPlatforms.solutions.titleHighlight')}</span></h2>
        <p class="section-sub">{t('dataPlatforms.solutions.desc')}</p>
      </div>
      <div class="grid-4 anim-fade-up">
        <a href={tp('/products/icc')} class="card-link"><div class="card-light prod-card"><h4>{t('dataPlatforms.solutions.icc.title')}</h4><p>{t('dataPlatforms.solutions.icc.desc')}</p></div></a>
        <a href={tp('/products/retouch')} class="card-link"><div class="card-light prod-card"><h4>{t('dataPlatforms.solutions.retouch.title')}</h4><p>{t('dataPlatforms.solutions.retouch.desc')}</p></div></a>
        <a href={tp('/products/talk-to-your-data')} class="card-link"><div class="card-light prod-card"><h4>{t('dataPlatforms.solutions.talkto.title')}</h4><p>{t('dataPlatforms.solutions.talkto.desc')}</p></div></a>
        <a href={`${tp('/solutions')}?id=document-answers#portfolio`} class="card-link"><div class="card-light prod-card"><h4>{t('dataPlatforms.solutions.docAnswers.title')}</h4><p>{t('dataPlatforms.solutions.docAnswers.desc')}</p></div></a>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section section--white" id="services">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">{t('dataPlatforms.services.label')}</div>
        <h2 class="section-title">{t('dataPlatforms.services.title')}<span class="grad-text">{t('dataPlatforms.services.titleHighlight')}</span></h2>
        <p class="section-sub">{t('dataPlatforms.services.desc')}</p>
      </div>
      <div class="grid-2 services-grid anim-fade-up">
        <div class="card-light service-card">
          <div class="service-h"><div class="cap-icon-box" style="margin-bottom: 0;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div><h3>{t('dataPlatforms.services.card1.title')}</h3></div>
          <ul class="serv-list"><li>{t('dataPlatforms.services.card1.li1')}</li><li>{t('dataPlatforms.services.card1.li2')}</li><li>{t('dataPlatforms.services.card1.li3')}</li><li>{t('dataPlatforms.services.card1.li4')}</li></ul>
        </div>
        <div class="card-light service-card">
          <div class="service-h"><div class="cap-icon-box" style="margin-bottom: 0;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg></div><h3>{t('dataPlatforms.services.card2.title')}</h3></div>
          <ul class="serv-list"><li>{t('dataPlatforms.services.card2.li1')}</li><li>{t('dataPlatforms.services.card2.li2')}</li><li>{t('dataPlatforms.services.card2.li3')}</li><li>{t('dataPlatforms.services.card2.li4')}</li></ul>
        </div>
        <div class="card-light service-card">
          <div class="service-h"><div class="cap-icon-box" style="margin-bottom: 0;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg></div><h3>{t('dataPlatforms.services.card3.title')}</h3></div>
          <ul class="serv-list"><li>{t('dataPlatforms.services.card3.li1')}</li><li>{t('dataPlatforms.services.card3.li2')}</li><li>{t('dataPlatforms.services.card3.li3')}</li><li>{t('dataPlatforms.services.card3.li4')}</li></ul>
        </div>
        <div class="card-light service-card">
          <div class="service-h"><div class="cap-icon-box" style="margin-bottom: 0;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg></div><h3>{t('dataPlatforms.services.card4.title')}</h3></div>
          <ul class="serv-list"><li>{t('dataPlatforms.services.card4.li1')}</li><li>{t('dataPlatforms.services.card4.li2')}</li><li>{t('dataPlatforms.services.card4.li3')}</li><li>{t('dataPlatforms.services.card4.li4')}</li></ul>
        </div>
      </div>
    </div>
  </section>

  <!-- DELIVERY -->
  <section class="section section--light" id="delivery">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title"><span class="grad-text">{t('dataPlatforms.delivery.title')}</span>{t('dataPlatforms.delivery.titleHighlight')}</h2>
        <p class="section-sub">{t('dataPlatforms.delivery.desc')}</p>
      </div>
      <div class="grid-4 anim-fade-up delivery-steps">
        <div class="d-step"><div class="d-num">1</div><div class="d-info"><h4>{t('dataPlatforms.delivery.step1.title')}</h4><p>{t('dataPlatforms.delivery.step1.desc')}</p></div></div>
        <div class="d-step"><div class="d-num">2</div><div class="d-info"><h4>{t('dataPlatforms.delivery.step2.title')}</h4><p>{t('dataPlatforms.delivery.step2.desc')}</p></div></div>
        <div class="d-step"><div class="d-num">3</div><div class="d-info"><h4>{t('dataPlatforms.delivery.step3.title')}</h4><p>{t('dataPlatforms.delivery.step3.desc')}</p></div></div>
        <div class="d-step"><div class="d-num">4</div><div class="d-info"><h4>{t('dataPlatforms.delivery.step4.title')}</h4><p>{t('dataPlatforms.delivery.step4.desc')}</p></div></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>{t('dataPlatforms.cta.title')}<span class="grad-text">{t('dataPlatforms.cta.titleHighlight')}</span></h2>
        <p>{t('dataPlatforms.cta.desc')}</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href={tp('/contact')}>{t('dataPlatforms.cta.primary')}</a>
          <a class="btn btn-ghost btn-pill btn-lg" href={tp('/clients')}>{t('dataPlatforms.cta.secondary')}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .metrics-grid { gap: 16px; }
  .metric-card { background: #ffffff; border: 1px solid #E8EEF5; border-radius: 24px; padding: 24px; transition: var(--transition); display: flex; flex-direction: column; gap: 16px; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04); }
  .metric-card:hover { background: #ffffff; border-color: rgba(0,200,150,0.3); transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08); }
  .metric-header { display: flex; align-items: center; gap: 10px; }
  .metric-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--clr-primary); box-shadow: 0 0 10px rgba(0, 200, 150, 0.4); }
  .metric-dot.blue { background: #3b82f6 !important; box-shadow: 0 0 10px rgba(59, 130, 246, 0.5) !important; }
  .metric-dot.purple { background: #8b5cf6 !important; box-shadow: 0 0 10px rgba(139, 92, 246, 0.5) !important; }
  .metric-dot.teal { background: #00c896 !important; box-shadow: 0 0 10px rgba(0, 200, 150, 0.5) !important; }
  .metric-dot.amber { background: #ff9800 !important; box-shadow: 0 0 10px rgba(255, 152, 0, 0.5) !important; }
  .metric-header span { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--clr-light-muted); }
  .metric-body h3 { font-size: 1.1rem; color: var(--clr-light-text); margin-bottom: 8px; font-weight: 800; }
  .metric-body p { font-size: 0.9rem; color: var(--clr-light-muted); line-height: 1.5; margin: 0; }
  .cap-icon-box { width: 48px; height: 48px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; }
  .cap-icon-box svg { width: 26px; height: 26px; }
  .kpi-banner { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 20px; padding: 32px; margin-top: 64px; width: 100%; box-sizing: border-box; }
  @media (max-width: 1100px) { .kpi-banner { grid-template-columns: 1fr !important; gap: 20px; padding: 24px; margin-inline: 0; } .kpi-item { width: 100%; } }
  .kpi-item b { display: block; font-size: 1.1rem; margin-bottom: 8px; color: var(--clr-primary); }
  .kpi-item span { font-size: 0.95rem; color: var(--clr-light-muted); }
  .archi-card { padding: 16px; border-radius: 32px; overflow: hidden; }
  .archi-img { width: 100%; max-width: 900px; height: auto; border-radius: 20px; display: block; margin: 0 auto; }
  .archi-note { padding: 16px 8px 8px; text-align: center; color: var(--clr-light-muted); font-weight: 500; }
  .archi-card-modern { background: rgba(255, 255, 255, 0.02); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 40px; padding: 60px; box-shadow: 0 40px 100px rgba(0,0,0,0.4); backdrop-filter: blur(10px); }
  .archi-layers-grid { display: flex; align-items: center; justify-content: space-between; gap: 20px; margin-bottom: 40px; }
