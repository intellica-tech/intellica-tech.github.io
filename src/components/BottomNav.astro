    ]
  },
  {
    category: 'Company',
    items: [
      { name: 'About Us', desc: 'Our mission and footprint', href: '/about' },
      { name: 'Academy', desc: 'Data & AI training center', href: '/academy' },
      { name: 'Careers', desc: 'Join our journey', href: '/careers' },
