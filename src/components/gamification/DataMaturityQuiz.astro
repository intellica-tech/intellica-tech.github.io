---
/**
 * DataMaturityQuiz.astro
 * 5-question interactive quiz assessing data maturity across
 * Governance, Infrastructure, Analytics, AI Readiness, and Culture.
 * Shows SVG radar chart result with product recommendations.
 */

// ── Question data ──
const questions = [
  {
    category: "Governance",
    question: "How do you manage data quality and consistency?",
    options: [
      { label: "Ad hoc / manual checks", score: 1 },
      { label: "Basic rules in place, some automation", score: 2 },
      { label: "Formal governance framework with monitoring", score: 3 },
      { label: "Automated quality gates with real-time alerts", score: 4 },
    ],
  },
  {
    category: "Infrastructure",
    question: "What describes your data infrastructure?",
    options: [
      { label: "Spreadsheets and local databases", score: 1 },
      { label: "Central database with basic ETL", score: 2 },
      { label: "Cloud data warehouse with orchestrated pipelines", score: 3 },
      { label: "Modern lakehouse with streaming and batch processing", score: 4 },
    ],
  },
  {
    category: "Analytics",
    question: "How does your organization use analytics?",
    options: [
      { label: "Basic reports and manual dashboards", score: 1 },
      { label: "Self-service BI with standard KPIs", score: 2 },
      { label: "Advanced analytics with predictive models", score: 3 },
      { label: "AI-driven insights embedded in workflows", score: 4 },
    ],
  },
  {
    category: "AI Readiness",
    question: "Where are you on the AI journey?",
    options: [
      { label: "No AI initiatives yet", score: 1 },
      { label: "Exploring POCs and pilots", score: 2 },
      { label: "Production AI in specific use cases", score: 3 },
      { label: "Scaled AI with MLOps and governance", score: 4 },
    ],
  },
  {
    category: "Culture",
    question: "How data-driven is your organization?",
    options: [
      { label: "Decisions mostly based on intuition", score: 1 },
      { label: "Some teams use data for decisions", score: 2 },
      { label: "Data-driven culture with training programs", score: 3 },
      { label: "Organization-wide data literacy and self-service", score: 4 },
    ],
  },
];

// ── Maturity levels ──
const maturityLevels = [
  { min: 1.0, max: 1.5, level: "Reactive", desc: "Starting the data journey" },
  { min: 1.6, max: 2.5, level: "Managed", desc: "Building foundations" },
  { min: 2.6, max: 3.5, level: "Optimized", desc: "Leveraging data effectively" },
  { min: 3.6, max: 4.0, level: "Leading", desc: "Data-driven enterprise" },
];

// ── Category insights ──
const categoryInsights = [
  { category: "Governance", low: "Data quality issues may be costing you trust and rework.", high: "Strong governance ensures reliable, trustworthy data." },
  { category: "Infrastructure", low: "Legacy infrastructure limits your ability to scale.", high: "Modern infrastructure accelerates time-to-insight." },
  { category: "Analytics", low: "Manual reporting slows decision-making.", high: "Advanced analytics unlock predictive capabilities." },
  { category: "AI Readiness", low: "AI adoption gaps leave competitive advantages untapped.", high: "AI at scale drives measurable business impact." },
  { category: "Culture", low: "Low data literacy limits adoption of new tools.", high: "A data-driven culture multiplies every tech investment." },
];

// ── Product recommendations by weak category ──
const productRecommendations = [
  { category: "Governance", products: [
    { name: "ICC", tagline: "Data Consistency Checker", url: "/products/icc" },
    { name: "ReTouch", tagline: "Data Entry Management", url: "/products/retouch" },
  ]},
  { category: "Infrastructure", products: [
    { name: "IFDM", tagline: "Finance Data Model", url: "/products/ifdm" },
    { name: "ITDM", tagline: "Telecom Data Model", url: "/products/itdm" },
    { name: "HRDM", tagline: "HR Data Model", url: "/products/hrdm" },
  ]},
  { category: "Analytics", products: [
    { name: "Talk To", tagline: "NL-to-SQL AI", url: "/products/talk-to-your-data" },
    { name: "Blue Octopus", tagline: "Event Intelligence", url: "/products/blue-octopus" },
  ]},
  { category: "AI Readiness", products: [
    { name: "Talk To", tagline: "NL-to-SQL AI", url: "/products/talk-to-your-data" },
    { name: "Blue Octopus", tagline: "Event Intelligence", url: "/products/blue-octopus" },
    { name: "VAR", tagline: "Voice AI Recognition", url: "/products/var" },
  ]},
  { category: "Culture", products: [
    { name: "Retable", tagline: "No-Code Self-Service Platform", url: "/products/retable" },
  ]},
];

// Serialize for client script
const questionsJson = JSON.stringify(questions);
const maturityLevelsJson = JSON.stringify(maturityLevels);
const categoryInsightsJson = JSON.stringify(categoryInsights);
const productRecommendationsJson = JSON.stringify(productRecommendations);
---

<section class="section dmq-section noise" id="data-maturity-quiz">
  <div class="container">
    <div class="dmq-header anim-fade-up">
      <div class="section-label">ASSESSMENT</div>
      <h2 class="section-title">
        How Mature Is Your <span class="grad-text">Data Strategy</span>?
      </h2>
      <p class="dmq-subtitle">
        Answer five quick questions to benchmark your organization and get tailored recommendations.
      </p>
    </div>

    <div class="dmq-card anim-fade-up" id="dmq-card">
      <!-- Progress bar -->
      <div class="dmq-progress" aria-label="Quiz progress">
        <div
          class="dmq-progress__fill"
          id="dmq-progress-fill"
          role="progressbar"
          aria-valuenow="20"
          aria-valuemin="0"
          aria-valuemax="100"
        ></div>
      </div>

      <!-- Step containers -->
      {questions.map((q, idx) => (
        <div class="dmq-step" data-step={idx} style={idx === 0 ? "" : "display:none"}>
          <div class="dmq-step__badge">{q.category}</div>
          <h3 class="dmq-step__title">{q.question}</h3>
          <div class="dmq-options" role="radiogroup" aria-label={q.question}>
            {q.options.map((opt) => (
              <button
                class="dmq-option"
                type="button"
                role="radio"
                aria-checked="false"
                data-score={opt.score}
                data-step-index={idx}
              >
                <span class="dmq-option__score">{opt.score}</span>
                <span class="dmq-option__label">{opt.label}</span>
              </button>
            ))}
          </div>
        </div>
      ))}

      <!-- Result screen -->
      <div class="dmq-result" id="dmq-result" aria-live="polite" style="display:none">
        <div class="dmq-result__top">
          <div class="dmq-result__level-wrap" id="dmq-level-wrap">
            <!-- Level badge + description populated by JS -->
          </div>
          <div class="dmq-result__chart" id="dmq-chart">
            <!-- SVG radar chart populated by JS -->
          </div>
        </div>
        <div class="dmq-result__insights" id="dmq-insights">
          <!-- Per-category insights populated by JS -->
        </div>
        <div class="dmq-result__recs">
          <h4 class="dmq-result__recs-title">Recommended Products</h4>
          <div class="dmq-result__recs-list" id="dmq-recs-list">
            <!-- Product cards populated by JS -->
          </div>
        </div>
        <div class="dmq-result__actions">
          <a href="/contact" class="btn btn-primary btn-pill btn-lg">Discuss Your Roadmap With Us</a>
          <button type="button" class="dmq-restart" id="dmq-restart">Start Over</button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .dmq-section {
    background: var(--clr-dark-2);
    padding-block: clamp(64px, 8vw, 100px);
  }

  .dmq-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .dmq-header .section-label {
    margin-inline: auto;
  }
  .dmq-subtitle {
    color: var(--clr-muted);
    font-size: 1.05rem;
    max-width: 560px;
    margin: 8px auto 0;
    line-height: 1.7;
  }

  /* ── Card shell ── */
  .dmq-card {
    background: var(--clr-card);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg);
    padding: 40px;
    position: relative;
    overflow: hidden;
    max-width: 720px;
    margin-inline: auto;
    backdrop-filter: blur(12px);
  }

  /* ── Progress bar ── */
  .dmq-progress {
    height: 6px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 999px;
    margin-bottom: 40px;
    overflow: hidden;
  }
  .dmq-progress__fill {
    height: 100%;
    width: 20%;
    background: var(--grad-brand);
    border-radius: 999px;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Step ── */
  .dmq-step {
    animation: dmqSlideIn 0.35s ease both;
    text-align: center;
  }
  .dmq-step__badge {
    display: inline-flex;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--clr-primary);
    padding: 4px 12px;
    border: 1px solid rgba(0, 200, 150, 0.2);
    border-radius: 999px;
    background: rgba(0, 200, 150, 0.06);
    margin-bottom: 16px;
  }
  .dmq-step__title {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--clr-text);
    margin-bottom: 28px;
  }

  /* ── Options (vertical stack) ── */
  .dmq-options {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 560px;
    margin-inline: auto;
  }
  .dmq-option {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 24px;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.02);
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--clr-text);
    text-align: left;
  }
  .dmq-option:hover {
    border-color: var(--clr-primary);
    background: rgba(0, 200, 150, 0.06);
    transform: translateX(4px);
    box-shadow: 0 4px 20px rgba(0, 200, 150, 0.1);
  }
  .dmq-option:focus-visible {
    outline: 2px solid var(--clr-primary);
    outline-offset: 2px;
  }
  .dmq-option__score {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0, 200, 150, 0.1);
    color: var(--clr-primary);
    font-weight: 800;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    border: 1px solid rgba(0, 200, 150, 0.2);
  }
  .dmq-option__label {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.4;
  }

  /* ── Slide-in animation ── */
  @keyframes dmqSlideIn {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ── Result screen ── */
  .dmq-result {
    animation: dmqSlideIn 0.35s ease both;
  }
  .dmq-result__top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: center;
    margin-bottom: 32px;
  }
  .dmq-result__level-wrap {
    text-align: center;
  }

  /* ── Insights ── */
  .dmq-result__insights {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 32px;
    padding: 20px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-md);
  }

  /* ── Recommendations ── */
  .dmq-result__recs {
    margin-bottom: 32px;
  }
  .dmq-result__recs-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--clr-text);
    margin-bottom: 16px;
    text-align: center;
  }
  .dmq-result__recs-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Result actions ── */
  .dmq-result__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .dmq-restart {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--clr-muted);
    cursor: pointer;
    padding: 8px 16px;
    border-radius: 999px;
    transition: all 0.2s ease;
    background: none;
    border: none;
  }
  .dmq-restart:hover {
    color: var(--clr-primary);
    background: rgba(0, 200, 150, 0.06);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .dmq-card {
      padding: 24px 16px;
    }
    .dmq-option {
      padding: 14px 16px;
      gap: 12px;
    }
    .dmq-option__score {
      width: 32px;
      height: 32px;
      font-size: 0.8rem;
    }
    .dmq-result__top {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .dmq-result__chart {
      order: -1;
    }
    .dmq-result__actions {
      flex-direction: column;
    }
    .dmq-result__insights {
      padding: 14px;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .dmq-step,
    .dmq-result {
      animation: none;
    }
    .dmq-option,
    .dmq-progress__fill {
      transition: none;
    }
  }
</style>

<script define:vars={{ questionsJson, maturityLevelsJson, categoryInsightsJson, productRecommendationsJson }}>
  (function () {
    var questionsData = JSON.parse(questionsJson);
    var maturityLevelsData = JSON.parse(maturityLevelsJson);
    var insightsData = JSON.parse(categoryInsightsJson);
    var recsData = JSON.parse(productRecommendationsJson);

    var totalSteps = questionsData.length;
    var currentStep = 0;
    var scores = [];
    var prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    var progressFill = document.getElementById("dmq-progress-fill");
    var resultPanel = document.getElementById("dmq-result");
    var levelWrap = document.getElementById("dmq-level-wrap");
    var chartWrap = document.getElementById("dmq-chart");
    var insightsWrap = document.getElementById("dmq-insights");
    var recsList = document.getElementById("dmq-recs-list");
    var restartBtn = document.getElementById("dmq-restart");

    var stepEls = document.querySelectorAll(".dmq-step");

    // ── Radar chart constants ──
    var SVG_NS = "http://www.w3.org/2000/svg";
    var CX = 150;
    var CY = 150;
    var R = 120;
    var CATEGORIES = ["Governance", "Infrastructure", "Analytics", "AI", "Culture"];
    // Angles: -90, -18, 54, 126, 198 degrees
    var ANGLES_DEG = [-90, -18, 54, 126, 198];
    var ANGLES_RAD = ANGLES_DEG.map(function (d) {
      return (d * Math.PI) / 180;
    });

    // ── Utility: get point on pentagon at given angle & radius ──
    function getPoint(angle, radius) {
      return {
        x: CX + radius * Math.cos(angle),
        y: CY + radius * Math.sin(angle),
      };
    }

    // ── Utility: build polygon points string ──
    function polygonPoints(radius) {
      return ANGLES_RAD.map(function (angle) {
        var pt = getPoint(angle, radius);
        return pt.x + "," + pt.y;
      }).join(" ");
    }

    // ── Show a specific step ──
    function showStep(index) {
      stepEls.forEach(function (el) {
        el.style.display = "none";
      });
      if (stepEls[index]) {
        stepEls[index].style.display = "";
        if (!prefersReducedMotion) {
          stepEls[index].style.animation = "none";
          void stepEls[index].offsetHeight;
          stepEls[index].style.animation = "";
        }
        var firstOption = stepEls[index].querySelector(".dmq-option");
        if (firstOption) {
          firstOption.focus();
        }
      }
      var pct = ((index + 1) / totalSteps) * 100;
      progressFill.style.width = pct + "%";
      progressFill.setAttribute("aria-valuenow", String(Math.round(pct)));
    }

    // ── Build SVG radar chart ──
    function buildRadarChart(categoryScores) {
      // Create SVG element
      var svg = document.createElementNS(SVG_NS, "svg");
      svg.setAttribute("viewBox", "0 0 300 300");
      svg.setAttribute("width", "280");
      svg.setAttribute("height", "280");
      svg.setAttribute("role", "img");
      svg.setAttribute("aria-label", "Radar chart showing maturity scores across five categories");
      svg.style.display = "block";
      svg.style.margin = "0 auto";

      // Defs for gradient
      var defs = document.createElementNS(SVG_NS, "defs");
      var gradient = document.createElementNS(SVG_NS, "linearGradient");
      gradient.setAttribute("id", "dmq-radar-grad");
      gradient.setAttribute("x1", "0%");
      gradient.setAttribute("y1", "0%");
      gradient.setAttribute("x2", "100%");
      gradient.setAttribute("y2", "100%");

      var stop1 = document.createElementNS(SVG_NS, "stop");
      stop1.setAttribute("offset", "0%");
      stop1.setAttribute("stop-color", "#00C896");

      var stop2 = document.createElementNS(SVG_NS, "stop");
      stop2.setAttribute("offset", "100%");
      stop2.setAttribute("stop-color", "#009FE3");

      gradient.appendChild(stop1);
      gradient.appendChild(stop2);
      defs.appendChild(gradient);
      svg.appendChild(defs);

      // Background grid: 4 concentric pentagons (25%, 50%, 75%, 100%)
      var gridLevels = [0.25, 0.5, 0.75, 1.0];
      gridLevels.forEach(function (scale) {
        var poly = document.createElementNS(SVG_NS, "polygon");
        poly.setAttribute("points", polygonPoints(R * scale));
        poly.setAttribute("fill", "none");
        poly.setAttribute("stroke", "rgba(255,255,255,0.08)");
        poly.setAttribute("stroke-width", "1");
        svg.appendChild(poly);
      });

      // Axis lines from center to each vertex
      ANGLES_RAD.forEach(function (angle) {
        var pt = getPoint(angle, R);
        var line = document.createElementNS(SVG_NS, "line");
        line.setAttribute("x1", String(CX));
        line.setAttribute("y1", String(CY));
        line.setAttribute("x2", String(pt.x));
        line.setAttribute("y2", String(pt.y));
        line.setAttribute("stroke", "rgba(255,255,255,0.05)");
        line.setAttribute("stroke-width", "1");
        svg.appendChild(line);
      });

      // Data polygon
      var dataPoints = categoryScores.map(function (score, i) {
        var scaledR = (score / 4) * R;
        return getPoint(ANGLES_RAD[i], scaledR);
      });
      var dataPoly = document.createElementNS(SVG_NS, "polygon");
      dataPoly.setAttribute(
        "points",
        dataPoints
          .map(function (pt) {
            return pt.x + "," + pt.y;
          })
          .join(" ")
      );
      dataPoly.setAttribute("fill", "url(#dmq-radar-grad)");
      dataPoly.setAttribute("fill-opacity", "0.3");
      dataPoly.setAttribute("stroke", "url(#dmq-radar-grad)");
      dataPoly.setAttribute("stroke-width", "2.5");
      dataPoly.setAttribute("stroke-linejoin", "round");
      svg.appendChild(dataPoly);

      // Data point dots
      dataPoints.forEach(function (pt) {
        var circle = document.createElementNS(SVG_NS, "circle");
        circle.setAttribute("cx", String(pt.x));
        circle.setAttribute("cy", String(pt.y));
        circle.setAttribute("r", "4");
        circle.setAttribute("fill", "#00C896");
        circle.setAttribute("stroke", "#fff");
        circle.setAttribute("stroke-width", "1.5");
        svg.appendChild(circle);
      });

      // Labels at each vertex
      var labelOffsets = [
        { dx: 0, dy: -14, anchor: "middle" },
        { dx: 14, dy: 4, anchor: "start" },
        { dx: 10, dy: 16, anchor: "start" },
        { dx: -10, dy: 16, anchor: "end" },
        { dx: -14, dy: 4, anchor: "end" },
      ];
      CATEGORIES.forEach(function (cat, i) {
        var pt = getPoint(ANGLES_RAD[i], R);
        var text = document.createElementNS(SVG_NS, "text");
        text.setAttribute("x", String(pt.x + labelOffsets[i].dx));
        text.setAttribute("y", String(pt.y + labelOffsets[i].dy));
        text.setAttribute("text-anchor", labelOffsets[i].anchor);
        text.setAttribute("fill", "rgba(255,255,255,0.7)");
        text.setAttribute("font-size", "11");
        text.setAttribute("font-family", "Inter, sans-serif");
        text.setAttribute("font-weight", "600");
        text.textContent = cat;
        svg.appendChild(text);
      });

      return svg;
    }

    // ── Determine maturity level ──
    function getMaturityLevel(avg) {
      for (var i = 0; i < maturityLevelsData.length; i++) {
        var level = maturityLevelsData[i];
        if (avg >= level.min && avg <= level.max) {
          return level;
        }
      }
      return maturityLevelsData[maturityLevelsData.length - 1];
    }

    // ── Show results ──
    function showResults() {
      stepEls.forEach(function (el) {
        el.style.display = "none";
      });
      progressFill.style.width = "100%";
      progressFill.setAttribute("aria-valuenow", "100");

      var sum = 0;
      scores.forEach(function (s) {
        sum += s;
      });
      var avg = sum / totalSteps;
      var maturity = getMaturityLevel(avg);

      // ── Build level display ──
      while (levelWrap.firstChild) {
        levelWrap.removeChild(levelWrap.firstChild);
      }

      var avgLabel = document.createElement("div");
      avgLabel.style.cssText =
        "font-size:3rem;font-weight:900;background:linear-gradient(135deg,#00C896,#009FE3);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;line-height:1.1;margin-bottom:8px;";
      avgLabel.textContent = avg.toFixed(1) + " / 4.0";

      var levelName = document.createElement("div");
      levelName.style.cssText =
        "font-size:1.4rem;font-weight:800;color:#F0F4FF;margin-bottom:4px;";
      levelName.textContent = maturity.level;

      var levelDesc = document.createElement("div");
      levelDesc.style.cssText = "font-size:0.9rem;color:#8A99B3;";
      levelDesc.textContent = maturity.desc;

      levelWrap.appendChild(avgLabel);
      levelWrap.appendChild(levelName);
      levelWrap.appendChild(levelDesc);

      // ── Build radar chart ──
      while (chartWrap.firstChild) {
        chartWrap.removeChild(chartWrap.firstChild);
      }
      var svgChart = buildRadarChart(scores);
      chartWrap.appendChild(svgChart);

      // ── Build insights ──
      while (insightsWrap.firstChild) {
        insightsWrap.removeChild(insightsWrap.firstChild);
      }
      insightsData.forEach(function (insight, i) {
        var row = document.createElement("div");
        row.style.cssText =
          "display:flex;align-items:center;gap:12px;padding:6px 0;";

        var catLabel = document.createElement("span");
        catLabel.style.cssText =
          "font-size:0.78rem;font-weight:700;color:#00C896;min-width:100px;text-transform:uppercase;letter-spacing:0.05em;flex-shrink:0;";
        catLabel.textContent = insight.category;

        var scoreLabel = document.createElement("span");
        scoreLabel.style.cssText =
          "font-size:0.85rem;font-weight:700;color:#F0F4FF;min-width:28px;flex-shrink:0;";
        scoreLabel.textContent = scores[i] + "/4";

        var textEl = document.createElement("span");
        textEl.style.cssText = "font-size:0.85rem;color:#8A99B3;line-height:1.4;";
        textEl.textContent = scores[i] <= 2 ? insight.low : insight.high;

        row.appendChild(catLabel);
        row.appendChild(scoreLabel);
        row.appendChild(textEl);
        insightsWrap.appendChild(row);
      });

      // ── Build product recommendations (based on 2 weakest areas) ──
      while (recsList.firstChild) {
        recsList.removeChild(recsList.firstChild);
      }

      // Find weakest categories
      var indexed = scores.map(function (s, i) {
        return { score: s, index: i };
      });
      indexed.sort(function (a, b) {
        return a.score - b.score;
      });
      var weakest = indexed.slice(0, 2);

      // Collect unique products from weakest categories
      var seen = {};
      var recommended = [];
      weakest.forEach(function (w) {
        var catRecs = recsData[w.index];
        if (catRecs && catRecs.products) {
          catRecs.products.forEach(function (p) {
            if (!seen[p.name]) {
              seen[p.name] = true;
              recommended.push({ product: p, reason: catRecs.category });
            }
          });
        }
      });

      // Limit to top 4
      recommended = recommended.slice(0, 4);

      recommended.forEach(function (item) {
        var link = document.createElement("a");
        link.href = item.product.url;
        link.style.cssText =
          "display:flex;align-items:center;gap:16px;padding:16px 20px;border:1px solid rgba(255,255,255,0.08);border-radius:16px;background:rgba(255,255,255,0.02);text-decoration:none;color:inherit;transition:all 0.2s ease;";

        link.addEventListener("mouseenter", function () {
          this.style.borderColor = "#00C896";
          this.style.transform = "translateX(4px)";
          this.style.boxShadow = "0 4px 20px rgba(0,200,150,0.1)";
        });
        link.addEventListener("mouseleave", function () {
          this.style.borderColor = "rgba(255,255,255,0.08)";
          this.style.transform = "translateX(0)";
          this.style.boxShadow = "none";
        });

        var info = document.createElement("div");
        info.style.cssText = "flex:1;min-width:0;";

        var name = document.createElement("div");
        name.style.cssText = "font-size:1rem;font-weight:700;color:#F0F4FF;margin-bottom:2px;";
        name.textContent = item.product.name;

        var tagline = document.createElement("div");
        tagline.style.cssText = "font-size:0.8rem;color:#8A99B3;";
        tagline.textContent = item.product.tagline;

        info.appendChild(name);
        info.appendChild(tagline);

        var reason = document.createElement("div");
        reason.style.cssText =
          "font-size:0.75rem;font-weight:600;color:#00C896;white-space:nowrap;padding:4px 10px;border:1px solid rgba(0,200,150,0.2);border-radius:999px;background:rgba(0,200,150,0.06);";
        reason.textContent = item.reason;

        var arrow = document.createElement("div");
        arrow.style.cssText = "font-size:1.1rem;color:#00C896;opacity:0.4;flex-shrink:0;";
        arrow.textContent = "\u2192";

        link.appendChild(info);
        link.appendChild(reason);
        link.appendChild(arrow);

        recsList.appendChild(link);
      });

      // Show result panel
      resultPanel.style.display = "";
      if (!prefersReducedMotion) {
        resultPanel.style.animation = "none";
        void resultPanel.offsetHeight;
        resultPanel.style.animation = "";
      }

      // Focus the level heading
      var firstFocusable = levelWrap.querySelector("div");
      if (firstFocusable) {
        firstFocusable.setAttribute("tabindex", "-1");
        firstFocusable.focus();
      }
    }

    // ── Option click handler ──
    function handleOptionClick(e) {
      var btn = e.target.closest(".dmq-option");
      if (!btn) return;

      var score = parseInt(btn.getAttribute("data-score"), 10);
      var stepIndex = parseInt(btn.getAttribute("data-step-index"), 10);

      // Update aria-checked
      var stepEl = stepEls[stepIndex];
      if (stepEl) {
        var allOptions = stepEl.querySelectorAll(".dmq-option");
        allOptions.forEach(function (opt) {
          opt.setAttribute("aria-checked", "false");
        });
        btn.setAttribute("aria-checked", "true");
      }

      scores[stepIndex] = score;
      currentStep = stepIndex + 1;

      if (currentStep < totalSteps) {
        showStep(currentStep);
      } else {
        showResults();
      }
    }

    // ── Restart handler ──
    function handleRestart() {
      currentStep = 0;
      scores = [];
      resultPanel.style.display = "none";
      // Clear dynamic content
      while (levelWrap.firstChild) levelWrap.removeChild(levelWrap.firstChild);
      while (chartWrap.firstChild) chartWrap.removeChild(chartWrap.firstChild);
      while (insightsWrap.firstChild) insightsWrap.removeChild(insightsWrap.firstChild);
      while (recsList.firstChild) recsList.removeChild(recsList.firstChild);
      // Reset aria
      document.querySelectorAll(".dmq-option").forEach(function (opt) {
        opt.setAttribute("aria-checked", "false");
      });
      showStep(0);
    }

    // ── Bind events ──
    stepEls.forEach(function (stepEl) {
      stepEl.addEventListener("click", handleOptionClick);
    });

    if (restartBtn) {
      restartBtn.addEventListener("click", handleRestart);
    }

    // ── Initial state ──
    showStep(0);
  })();
</script>
