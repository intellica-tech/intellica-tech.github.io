---
/**
 * ProductFitWizard.astro
 * 3-step interactive wizard that recommends products based on
 * industry, challenge, and priority selections.
 * Scoring: each answer maps to a tag; product score = matched tag count.
 */

// ── Inline SVG icons (24x24 viewBox, stroke-based) ──
const iconMap: Record<string, string> = {
  bank: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M3 10h18"/><path d="M12 3l9 7H3l9-7z"/><path d="M5 10v11"/><path d="M19 10v11"/><path d="M9 10v11"/><path d="M15 10v11"/></svg>`,
  signal: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h.01"/><path d="M7 20v-4"/><path d="M12 20v-8"/><path d="M17 20v-12"/><path d="M22 20V4"/></svg>`,
  people: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="3"/><circle cx="17" cy="7" r="3"/><path d="M3 21v-2a4 4 0 014-4h4a4 4 0 014 4v2"/><path d="M17 11a4 4 0 014 4v2"/></svg>`,
  building: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M8 10h.01"/><path d="M16 10h.01"/><path d="M8 14h.01"/><path d="M16 14h.01"/></svg>`,
  search: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/><path d="M11 8v6"/><path d="M8 11h6"/></svg>`,
  chart: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 16l4-8 4 4 4-8"/></svg>`,
  gear: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09a1.65 1.65 0 00-1.08-1.51 1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09a1.65 1.65 0 001.51-1.08 1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001.08 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9c.26.604.852.997 1.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1.08z"/></svg>`,
  robot: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="12" rx="2"/><path d="M12 2v6"/><circle cx="9" cy="14" r="1.5"/><circle cx="15" cy="14" r="1.5"/><path d="M9 18h6"/><path d="M1 12h2"/><path d="M21 12h2"/></svg>`,
  money: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1v22"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
  bolt: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  shield: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
  rocket: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
};

// ── Step definitions ──
const steps = [
  {
    title: "What is your industry?",
    options: [
      { label: "Finance & Banking", value: "finance", icon: "bank" },
      { label: "Telecom", value: "telecom", icon: "signal" },
      { label: "Human Resources", value: "hr", icon: "people" },
      { label: "Other", value: "other", icon: "building" },
    ],
  },
  {
    title: "What is your biggest data challenge?",
    options: [
      { label: "Data Quality & Consistency", value: "data-quality", icon: "search" },
      { label: "Reporting Gaps", value: "reporting-gaps", icon: "chart" },
      { label: "Manual Processes", value: "manual-processes", icon: "gear" },
      { label: "AI Readiness", value: "ai-readiness", icon: "robot" },
    ],
  },
  {
    title: "What is your top priority?",
    options: [
      { label: "Cost Reduction", value: "cost-reduction", icon: "money" },
      { label: "Speed & Efficiency", value: "speed", icon: "bolt" },
      { label: "Compliance & Governance", value: "compliance", icon: "shield" },
      { label: "Innovation", value: "innovation", icon: "rocket" },
    ],
  },
];

// ── Product data with tags ──
const products = [
  { id: "ifdm", name: "IFDM", tagline: "Finance Data Model", url: "/products/ifdm", tags: ["finance", "data-quality", "compliance", "cost-reduction"] },
  { id: "itdm", name: "ITDM", tagline: "Telecom Data Model", url: "/products/itdm", tags: ["telecom", "data-quality", "speed", "cost-reduction"] },
  { id: "hrdm", name: "HRDM", tagline: "HR Data Model", url: "/products/hrdm", tags: ["hr", "data-quality", "speed", "cost-reduction"] },
  { id: "icc", name: "ICC", tagline: "Consistency Checker", url: "/products/icc", tags: ["finance", "telecom", "hr", "other", "data-quality", "compliance", "cost-reduction"] },
  { id: "retouch", name: "ReTouch", tagline: "Data Entry Management", url: "/products/retouch", tags: ["finance", "telecom", "hr", "other", "data-quality", "manual-processes", "compliance"] },
  { id: "retable", name: "Retable", tagline: "No-Code Platform", url: "/products/retable", tags: ["finance", "telecom", "hr", "other", "manual-processes", "speed", "innovation"] },
  { id: "orqenta", name: "Orqenta", tagline: "Workflow Orchestration", url: "/products/orqenta", tags: ["finance", "telecom", "other", "manual-processes", "speed", "cost-reduction"] },
  { id: "talkto", name: "Talk To", tagline: "NL-to-SQL AI", url: "/products/talk-to-your-data", tags: ["finance", "telecom", "hr", "other", "reporting-gaps", "speed", "innovation"] },
  { id: "blueoctopus", name: "Blue Octopus", tagline: "Event Intelligence", url: "/products/blue-octopus", tags: ["finance", "telecom", "other", "ai-readiness", "compliance", "innovation"] },
  { id: "var", name: "VAR", tagline: "Voice AI Recognition", url: "/products/var", tags: ["finance", "telecom", "ai-readiness", "compliance", "innovation"] },
];

// Serialise for client script via define:vars
const stepsJson = JSON.stringify(steps);
const productsJson = JSON.stringify(products);
---

<section class="section section--light" id="product-fit-wizard">
  <div class="container">
    <div class="pfw-header anim-fade-up">
      <div class="section-label">PRODUCT FINDER</div>
      <h2 class="section-title" style="color:var(--clr-light-text);text-align:left;">
        Find Your <span class="grad-text">Ideal Solution</span>
      </h2>
      <p class="section-sub" style="text-align:left;margin:0 0 48px;">
        Answer three quick questions and we'll recommend the best products for your needs.
      </p>
    </div>

    <div class="pfw-card anim-fade-up" id="pfw-card">
      <!-- Progress bar -->
      <div class="pfw-progress" aria-label="Wizard progress">
        <div class="pfw-progress__fill" id="pfw-progress-fill" role="progressbar" aria-valuenow="33" aria-valuemin="0" aria-valuemax="100"></div>
      </div>

      <!-- Step containers (rendered server-side, toggled client-side) -->
      {steps.map((step, idx) => (
        <div class="pfw-step" data-step={idx} style={idx === 0 ? "" : "display:none"}>
          <h3 class="pfw-step__title">{step.title}</h3>
          <div class="pfw-options" role="radiogroup" aria-label={step.title}>
            {step.options.map((opt) => (
              <button
                class="pfw-option"
                type="button"
                role="radio"
                aria-checked="false"
                data-value={opt.value}
                data-step-index={idx}
              >
                <span class="pfw-option__icon" set:html={iconMap[opt.icon]} />
                <span class="pfw-option__label">{opt.label}</span>
              </button>
            ))}
          </div>
        </div>
      ))}

      <!-- Result screen (hidden initially) -->
      <div class="pfw-result" id="pfw-result" aria-live="polite" style="display:none">
        <h3 class="pfw-result__title">Recommended For You</h3>
        <div class="pfw-result__list" id="pfw-result-list">
          <!-- Populated by JS -->
        </div>
        <div class="pfw-result__actions">
          <a href="/contact" class="btn btn-primary btn-pill">Get a Personalized Demo</a>
          <button type="button" class="pfw-restart" id="pfw-restart">Start Over</button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Card shell ── */
  .pfw-card {
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 24px;
    padding: 40px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.06);
  }

  /* ── Progress bar ── */
  .pfw-progress {
    height: 6px;
    background: #E2E8F0;
    border-radius: 999px;
    margin-bottom: 40px;
    overflow: hidden;
  }
  .pfw-progress__fill {
    height: 100%;
    width: 33.33%;
    background: var(--grad-brand);
    border-radius: 999px;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Step ── */
  .pfw-step {
    animation: pfwSlideIn 0.35s ease both;
  }
  .pfw-step__title {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--clr-light-text);
    margin-bottom: 28px;
    text-align: center;
  }

  /* ── Option grid ── */
  .pfw-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    max-width: 560px;
    margin-inline: auto;
  }
  .pfw-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 28px 16px;
    border: 2px solid #E2E8F0;
    border-radius: 16px;
    background: #F8FAFC;
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--clr-light-text);
  }
  .pfw-option:hover {
    border-color: var(--clr-primary);
    background: rgba(0, 200, 150, 0.06);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 200, 150, 0.12);
  }
  .pfw-option:focus-visible {
    outline: 2px solid var(--clr-primary);
    outline-offset: 2px;
  }
  .pfw-option__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--clr-primary);
  }
  .pfw-option__icon :global(svg) {
    width: 28px;
    height: 28px;
  }
  .pfw-option__label {
    font-size: 0.95rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
  }

  /* ── Slide-in animation ── */
  @keyframes pfwSlideIn {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  /* ── Result screen ── */
  .pfw-result {
    animation: pfwSlideIn 0.35s ease both;
  }
  .pfw-result__title {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--clr-light-text);
    margin-bottom: 28px;
    text-align: center;
  }
  .pfw-result__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 36px;
  }

  /* ── Result product card (JS-generated, needs :global) ── */
  .pfw-result__list :global(.pfw-result-card) {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 20px 24px;
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.03);
  }
  .pfw-result__list :global(.pfw-result-card:hover) {
    border-color: var(--clr-primary);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 200, 150, 0.12);
  }
  .pfw-result__list :global(.pfw-result-card__rank) {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--grad-brand);
    color: #fff;
    font-weight: 800;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .pfw-result__list :global(.pfw-result-card__info) {
    flex: 1;
    min-width: 0;
  }
  .pfw-result__list :global(.pfw-result-card__name) {
    font-size: 1.15rem;
    font-weight: 750;
    color: var(--clr-light-text);
    margin-bottom: 2px;
  }
  .pfw-result__list :global(.pfw-result-card__tagline) {
    font-size: 0.85rem;
    color: var(--clr-light-muted);
  }
  .pfw-result__list :global(.pfw-result-card__match) {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--clr-primary);
    white-space: nowrap;
    flex-shrink: 0;
    background: rgba(0, 200, 150, 0.08);
    padding: 4px 12px;
    border-radius: 999px;
  }
  .pfw-result__list :global(.pfw-result-card__arrow) {
    font-size: 1.3rem;
    color: var(--clr-primary);
    opacity: 0.3;
    transition: all 0.25s ease;
    flex-shrink: 0;
  }
  .pfw-result__list :global(.pfw-result-card:hover .pfw-result-card__arrow) {
    opacity: 1;
    transform: translateX(4px);
  }

  /* ── Result actions ── */
  .pfw-result__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .pfw-restart {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--clr-light-muted);
    cursor: pointer;
    padding: 8px 16px;
    border-radius: 999px;
    transition: all 0.2s ease;
    background: none;
    border: none;
  }
  .pfw-restart:hover {
    color: var(--clr-primary);
    background: rgba(0, 200, 150, 0.06);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .pfw-card {
      padding: 24px 20px;
    }
    .pfw-options {
      grid-template-columns: 1fr;
      max-width: 100%;
    }
    .pfw-option {
      flex-direction: row;
      padding: 18px 20px;
      gap: 14px;
    }
    .pfw-option__icon {
      width: 32px;
      height: 32px;
    }
    .pfw-option__icon :global(svg) {
      width: 24px;
      height: 24px;
    }
    .pfw-result__list :global(.pfw-result-card) {
      flex-wrap: wrap;
      gap: 12px;
      padding: 16px;
    }
    .pfw-result__actions {
      flex-direction: column;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .pfw-step,
    .pfw-result {
      animation: none;
    }
    .pfw-option,
    .pfw-result__list :global(.pfw-result-card),
    .pfw-progress__fill {
      transition: none;
    }
  }
</style>

<script define:vars={{ stepsJson, productsJson }}>
  (function () {
    var stepsData = JSON.parse(stepsJson);
    var productsData = JSON.parse(productsJson);

    var currentStep = 0;
    var answers = [];
    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    var progressFill = document.getElementById("pfw-progress-fill");
    var resultPanel = document.getElementById("pfw-result");
    var resultList = document.getElementById("pfw-result-list");
    var restartBtn = document.getElementById("pfw-restart");

    var stepEls = document.querySelectorAll(".pfw-step");

    // ── Show a specific step ──
    function showStep(index) {
      stepEls.forEach(function (el) {
        el.style.display = "none";
      });
      if (stepEls[index]) {
        stepEls[index].style.display = "";
        // Re-trigger slide animation (skip if user prefers reduced motion)
        if (!prefersReducedMotion) {
          stepEls[index].style.animation = "none";
          void stepEls[index].offsetHeight;
          stepEls[index].style.animation = "";
        }
        // Focus the first option button in this step
        var firstOption = stepEls[index].querySelector(".pfw-option");
        if (firstOption) {
          firstOption.focus();
        }
      }
      // Update progress
      var pct = ((index + 1) / stepsData.length) * 100;
      progressFill.style.width = pct + "%";
      progressFill.setAttribute("aria-valuenow", String(Math.round(pct)));
    }

    // ── Compute scores and render results ──
    function showResults() {
      // Hide all steps
      stepEls.forEach(function (el) {
        el.style.display = "none";
      });
      progressFill.style.width = "100%";
      progressFill.setAttribute("aria-valuenow", "100");

      // Score each product
      var scored = productsData.map(function (product) {
        var score = 0;
        answers.forEach(function (answer) {
          if (product.tags.indexOf(answer) !== -1) {
            score++;
          }
        });
        return { product: product, score: score };
      });

      // Sort descending
      scored.sort(function (a, b) {
        return b.score - a.score;
      });

      // Take top 3
      var top3 = scored.slice(0, 3);

      // Clear previous results safely
      while (resultList.firstChild) {
        resultList.removeChild(resultList.firstChild);
      }

      // Build result cards via DOM methods
      top3.forEach(function (item, idx) {
        var matchPct = Math.round((item.score / stepsData.length) * 100);

        var link = document.createElement("a");
        link.href = item.product.url;
        link.className = "pfw-result-card";

        var rankEl = document.createElement("div");
        rankEl.className = "pfw-result-card__rank";
        rankEl.textContent = String(idx + 1);

        var infoEl = document.createElement("div");
        infoEl.className = "pfw-result-card__info";

        var nameEl = document.createElement("div");
        nameEl.className = "pfw-result-card__name";
        nameEl.textContent = item.product.name;

        var taglineEl = document.createElement("div");
        taglineEl.className = "pfw-result-card__tagline";
        taglineEl.textContent = item.product.tagline;

        infoEl.appendChild(nameEl);
        infoEl.appendChild(taglineEl);

        var matchEl = document.createElement("div");
        matchEl.className = "pfw-result-card__match";
        matchEl.textContent = matchPct + "% match";

        var arrowEl = document.createElement("div");
        arrowEl.className = "pfw-result-card__arrow";
        arrowEl.textContent = "\u2192";

        link.appendChild(rankEl);
        link.appendChild(infoEl);
        link.appendChild(matchEl);
        link.appendChild(arrowEl);

        resultList.appendChild(link);
      });

      // Show result panel with animation
      resultPanel.style.display = "";
      if (!prefersReducedMotion) {
        resultPanel.style.animation = "none";
        void resultPanel.offsetHeight;
        resultPanel.style.animation = "";
      }

      // Focus the result title heading
      var resultTitle = resultPanel.querySelector(".pfw-result__title");
      if (resultTitle) {
        resultTitle.setAttribute("tabindex", "-1");
        resultTitle.focus();
      }
    }

    // ── Option click handler ──
    function handleOptionClick(e) {
      var btn = e.target.closest(".pfw-option");
      if (!btn) return;

      var value = btn.getAttribute("data-value");
      var stepIndex = parseInt(btn.getAttribute("data-step-index"), 10);

      // Update aria-checked for radio buttons in this step
      var stepEl = stepEls[stepIndex];
      if (stepEl) {
        var allOptions = stepEl.querySelectorAll(".pfw-option");
        allOptions.forEach(function (opt) {
          opt.setAttribute("aria-checked", "false");
        });
        btn.setAttribute("aria-checked", "true");
      }

      // Store answer
      answers[stepIndex] = value;
      currentStep = stepIndex + 1;

      if (currentStep < stepsData.length) {
        showStep(currentStep);
      } else {
        showResults();
      }
    }

    // ── Restart handler ──
    function handleRestart() {
      currentStep = 0;
      answers = [];
      resultPanel.style.display = "none";
      // Clear result list
      while (resultList.firstChild) {
        resultList.removeChild(resultList.firstChild);
      }
      // Reset all aria-checked states
      document.querySelectorAll(".pfw-option").forEach(function (opt) {
        opt.setAttribute("aria-checked", "false");
      });
      showStep(0);
    }

    // ── Bind events ──
    stepEls.forEach(function (stepEl) {
      stepEl.addEventListener("click", handleOptionClick);
    });

    if (restartBtn) {
      restartBtn.addEventListener("click", handleRestart);
    }

    // ── Initial state ──
    showStep(0);
  })();
