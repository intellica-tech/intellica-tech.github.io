---
// EasterEggTerminal.astro
// Hidden retro terminal overlay activated via Konami code or Ctrl+Shift+K
// Commands: help, about, ls products, cat <product>, ls team, ping ai, whoami, clear, exit
---

<div id="easter-terminal" class="terminal-overlay" aria-hidden="true">
  <div class="terminal-window">
    <div class="terminal-header">
      <div class="terminal-dots">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
      </div>
      <span class="terminal-title">intellica@terminal:~$</span>
      <button id="terminal-close-btn" class="terminal-close" aria-label="Close terminal">&times;</button>
    </div>
    <div class="terminal-body">
      <div class="scanline"></div>
      <div id="terminal-output" class="terminal-output"></div>
      <div class="terminal-input-line">
        <span class="terminal-prompt">visitor@intellica:~$&nbsp;</span>
        <input
          id="terminal-input"
          class="terminal-input"
          type="text"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          aria-label="Terminal command input"
        />
      </div>
    </div>
  </div>
</div>

<style>
  .terminal-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: none;
    align-items: flex-end;
    justify-content: center;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    padding: 0;
  }

  .terminal-overlay.open {
    display: flex;
  }

  .terminal-window {
    width: 100%;
    max-width: 800px;
    height: 420px;
    background: #0a0e14;
    border-top: 2px solid var(--clr-primary, #00C896);
    border-radius: 12px 12px 0 0;
    display: flex;
    flex-direction: column;
    box-shadow: 0 -8px 40px rgba(0, 200, 150, 0.15);
    animation: terminal-slide-up 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  @keyframes terminal-slide-up {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .terminal-header {
    display: flex;
    align-items: center;
    padding: 10px 16px;
    background: #0d1117;
    border-bottom: 1px solid rgba(0, 200, 150, 0.15);
    flex-shrink: 0;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
    margin-right: 12px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f56; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green { background: #27c93f; }

  .terminal-title {
    font-family: 'Courier New', Courier, monospace;
    font-size: 12px;
    color: var(--clr-primary, #00C896);
    opacity: 0.7;
    flex: 1;
  }

  .terminal-close {
    background: none;
    border: none;
    color: var(--clr-primary, #00C896);
    font-size: 22px;
    cursor: pointer;
    padding: 0 4px;
    line-height: 1;
    opacity: 0.6;
    transition: opacity 0.2s;
  }

  .terminal-close:hover {
    opacity: 1;
  }

  .terminal-body {
    flex: 1;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .scanline {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 200, 150, 0.03) 2px,
      rgba(0, 200, 150, 0.03) 4px
    );
  }

  .scanline::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(0, 200, 150, 0.015) 50%
    );
    background-size: 100% 4px;
    animation: scanline-move 8s linear infinite;
  }

  @keyframes scanline-move {
    from { transform: translateY(-100%); }
    to { transform: translateY(100%); }
  }

  .terminal-output {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 13px;
    line-height: 1.6;
    color: var(--clr-primary, #00C896);
    position: relative;
    z-index: 2;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 200, 150, 0.3) transparent;
  }

  .terminal-output::-webkit-scrollbar {
    width: 6px;
  }

  .terminal-output::-webkit-scrollbar-track {
    background: transparent;
  }

  .terminal-output::-webkit-scrollbar-thumb {
    background: rgba(0, 200, 150, 0.3);
    border-radius: 3px;
  }

  .terminal-input-line {
    display: flex;
    align-items: center;
    padding: 8px 16px 12px;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  .terminal-prompt {
    font-family: 'Courier New', Courier, monospace;
    font-size: 13px;
    color: var(--clr-primary, #00C896);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .terminal-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: 'Courier New', Courier, monospace;
    font-size: 13px;
    color: var(--clr-primary, #00C896);
    caret-color: var(--clr-primary, #00C896);
    padding: 0;
  }

  .terminal-input::placeholder {
    color: rgba(0, 200, 150, 0.3);
  }

  /* Output line styles */
  .terminal-output :global(.term-line) {
    display: block;
    min-height: 1.6em;
    word-break: break-word;
  }

  .terminal-output :global(.term-cmd) {
    color: var(--clr-muted, #8a99b3);
  }

  .terminal-output :global(.term-highlight) {
    color: #00E0A9;
  }

  .terminal-output :global(.term-dim) {
    color: var(--clr-light-muted, #5b6473);
  }

  .terminal-output :global(.term-accent) {
    color: var(--clr-secondary, #009FE3);
  }

  .terminal-output :global(.term-warn) {
    color: #ffbd2e;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .terminal-window {
      height: 320px;
      max-width: 100%;
      border-radius: 10px 10px 0 0;
    }

    .terminal-output {
      font-size: 11px;
      padding: 12px;
    }

    .terminal-prompt,
    .terminal-input {
      font-size: 11px;
    }

    .terminal-input-line {
      padding: 6px 12px 10px;
    }
  }
</style>

<script>
  (function () {
    // DOM references
    const overlay = document.getElementById('easter-terminal');
    const output = document.getElementById('terminal-output');
    const input = document.getElementById('terminal-input') as HTMLInputElement | null;
    const closeBtn = document.getElementById('terminal-close-btn');

    if (!overlay || !output || !input || !closeBtn) return;

    // State
    let isOpen = false;
    const commandHistory: string[] = [];
    let historyIndex = -1;
    let activeTypewriterId = 0;

    // Product data
    const products: Record<string, { name: string; desc: string; url: string }> = {
      'ifdm': { name: 'IFDM', desc: 'Finance Data Model - Enterprise financial data modeling solution', url: '/products/ifdm' },
      'itdm': { name: 'ITDM', desc: 'Telecom Data Model - Telecommunications data warehouse model', url: '/products/itdm' },
      'hrdm': { name: 'HRDM', desc: 'HR Data Model - Human resources analytics data model', url: '/products/hrdm' },
      'icc': { name: 'ICC', desc: 'Consistency Checker - Automated data consistency validation', url: '/products/icc' },
      'retouch': { name: 'ReTouch', desc: 'Data Entry Management - Streamlined data entry platform', url: '/products/retouch' },
      'retable': { name: 'Retable', desc: 'No-Code Platform - Build data apps without coding', url: '/products/retable' },
      'orqenta': { name: 'Orqenta', desc: 'Workflow Orchestration - Enterprise workflow automation', url: '/products/orqenta' },
      'talk-to': { name: 'Talk To', desc: 'NL-to-SQL AI - Ask questions in natural language, get SQL answers', url: '/products/talk-to-your-data' },
      'blue-octopus': { name: 'Blue Octopus', desc: 'Event Intelligence - Real-time event processing and analytics', url: '/products/blue-octopus' },
      'var': { name: 'VAR', desc: 'Voice AI Recognition - Voice-powered AI assistant', url: '/products/var' }
    };

    // --- Helpers ---

    function createLine(text: string, className?: string): HTMLElement {
      const span = document.createElement('span');
      span.className = 'term-line' + (className ? ' ' + className : '');
      span.textContent = text;
      return span;
    }

    function appendLine(text: string, className?: string) {
      output.appendChild(createLine(text, className));
      output.scrollTop = output.scrollHeight;
    }

    function appendEmptyLine() {
      output.appendChild(createLine(''));
    }

    function typewriterLines(lines: Array<{ text: string; className?: string }>, callback?: () => void) {
      const myId = ++activeTypewriterId;
      let lineIndex = 0;

      function typeLine() {
        if (activeTypewriterId !== myId) return;
        if (lineIndex >= lines.length) {
          if (callback) callback();
          return;
        }

        const { text, className } = lines[lineIndex];
        const lineEl = document.createElement('span');
        lineEl.className = 'term-line' + (className ? ' ' + className : '');
        output.appendChild(lineEl);

        let charIndex = 0;
        const speed = Math.max(5, 20 - Math.floor(text.length / 10));

        function typeChar() {
          if (activeTypewriterId !== myId) return;
          if (charIndex < text.length) {
            lineEl.textContent = text.substring(0, charIndex + 1);
            charIndex++;
            output.scrollTop = output.scrollHeight;
            setTimeout(typeChar, speed);
          } else {
            lineIndex++;
            setTimeout(typeLine, 30);
          }
        }

        typeChar();
      }

      typeLine();
    }

    // --- Commands ---

    function cmdHelp() {
      typewriterLines([
        { text: 'Available commands:', className: 'term-highlight' },
        { text: '' },
        { text: '  help              Show this help message' },
        { text: '  about             Learn about Intellica' },
        { text: '  ls products       List all products' },
        { text: '  cat <product>     Show product details (e.g. cat ifdm)' },
        { text: '  ls team           Team statistics' },
        { text: '  ping ai           Test AI connection' },
        { text: '  whoami            Who are you?' },
        { text: '  clear             Clear terminal' },
        { text: '  exit              Close terminal' },
        { text: '' },
        { text: 'Tip: Use arrow keys for command history', className: 'term-dim' }
      ]);
    }

    function cmdAbout() {
      typewriterLines([
        { text: '=== INTELLICA ===', className: 'term-highlight' },
        { text: '' },
        { text: 'Empowering enterprises to generate sustainable' },
        { text: 'value from data since 2006.' },
        { text: '' },
        { text: '  Founded:       2006' },
        { text: '  Headquarters:  Istanbul, Turkey' },
        { text: '  Team:          450+ professionals' },
        { text: '  Presence:      7 countries' },
        { text: '  Academy:       240+ graduates' },
        { text: '  Experience:    11+ years average' },
        { text: '' },
        { text: 'Core: Data Platforms | Analytics | AI Systems', className: 'term-accent' },
        { text: '' },
        { text: 'Visit: https://intellica.net', className: 'term-dim' }
      ]);
    }

    function cmdLsProducts() {
      const lines: Array<{ text: string; className?: string }> = [
        { text: 'drwxr-xr-x  10 intellica products  4096  Products/', className: 'term-highlight' },
        { text: '' }
      ];

      const keys = Object.keys(products);
      for (const key of keys) {
        const p = products[key];
        const paddedName = (p.name + '            ').substring(0, 16);
        lines.push({ text: '  -rw-r--r--  ' + paddedName + p.desc.split(' - ')[0] });
      }

      lines.push({ text: '' });
      lines.push({ text: keys.length + ' products listed. Use "cat <name>" for details.', className: 'term-dim' });

      typewriterLines(lines);
    }

    function cmdCatProduct(productKey: string) {
      const key = productKey.toLowerCase().trim();
      const product = products[key];

      if (!product) {
        typewriterLines([
          { text: 'cat: ' + productKey + ': No such product', className: 'term-warn' },
          { text: '' },
          { text: 'Available: ' + Object.keys(products).join(', '), className: 'term-dim' },
          { text: 'Usage: cat <product-key>', className: 'term-dim' }
        ]);
        return;
      }

      typewriterLines([
        { text: '=== ' + product.name + ' ===', className: 'term-highlight' },
        { text: '' },
        { text: product.desc },
        { text: '' },
        { text: 'URL: https://intellica.net' + product.url, className: 'term-accent' },
        { text: '' },
        { text: 'Navigate to product page? Visit the URL above.', className: 'term-dim' }
      ]);
    }

    function cmdLsTeam() {
      typewriterLines([
        { text: '=== TEAM STATS ===', className: 'term-highlight' },
        { text: '' },
        { text: '  Total team size:       450+' },
        { text: '  Countries:             7' },
        { text: '  Academy graduates:     240+' },
        { text: '  Avg experience:        11+ years' },
        { text: '' },
        { text: '  Regions:' },
        { text: '    Turkey (HQ)' },
        { text: '    UAE' },
        { text: '    Saudi Arabia' },
        { text: '    Pakistan' },
        { text: '    United Kingdom' },
        { text: '    United States' },
        { text: '    Albania' },
        { text: '' },
        { text: 'One team, seven countries, one mission.', className: 'term-accent' }
      ]);
    }

    function cmdPingAi() {
      const responses = [
        'PONG! AI systems operational. Response time: 0.042ms',
        'PONG! Neural networks online. Latency: 0.018ms',
        'PONG! Machine learning models loaded. Ping: 0.007ms',
        'PONG! Agentic AI ready. Processing time: 0.023ms',
        'PONG! Data intelligence active. Round-trip: 0.031ms'
      ];
      const response = responses[Math.floor(Math.random() * responses.length)];

      appendLine('Pinging AI systems at intellica.net...', 'term-dim');

      setTimeout(() => {
        typewriterLines([
          { text: '' },
          { text: response, className: 'term-highlight' },
          { text: '' },
          { text: 'All AI subsystems nominal.', className: 'term-accent' }
        ]);
      }, 800);
    }

    function cmdWhoami() {
      const messages = [
        'You are a curious explorer who found our hidden terminal.',
        'You are a data enthusiast with an eye for easter eggs.',
        'You are a visitor with excellent keyboard skills.',
        'You are someone who appreciates a good Konami code.',
        'You are a potential Intellica partner. Welcome aboard!'
      ];
      const msg = messages[Math.floor(Math.random() * messages.length)];

      typewriterLines([
        { text: 'user: visitor', className: 'term-highlight' },
        { text: 'role: explorer' },
        { text: 'access: read-only' },
        { text: 'status: authenticated via easter egg' },
        { text: '' },
        { text: msg, className: 'term-accent' }
      ]);
    }

    function cmdClear() {
      // Remove all child nodes safely
      while (output.firstChild) {
        output.removeChild(output.firstChild);
      }
    }

    function cmdNotFound(cmd: string) {
      typewriterLines([
        { text: 'command not found: ' + cmd, className: 'term-warn' },
        { text: 'Type "help" for available commands.', className: 'term-dim' }
      ]);
    }

    // --- Command router ---

    function processCommand(raw: string) {
      const trimmed = raw.trim();
      if (!trimmed) return;

      // Show the command in output
      appendLine('visitor@intellica:~$ ' + trimmed, 'term-cmd');
      appendEmptyLine();

      // Add to history
      commandHistory.unshift(trimmed);
      if (commandHistory.length > 50) commandHistory.pop();
      historyIndex = -1;

      // Parse
      const lower = trimmed.toLowerCase();
      const parts = lower.split(/\s+/);
      const cmd = parts[0];

      if (cmd === 'help') {
        cmdHelp();
      } else if (cmd === 'about') {
        cmdAbout();
      } else if (cmd === 'ls' && parts[1] === 'products') {
        cmdLsProducts();
      } else if (cmd === 'ls' && parts[1] === 'team') {
        cmdLsTeam();
      } else if (cmd === 'cat' && parts.length > 1) {
        cmdCatProduct(parts.slice(1).join('-'));
      } else if (cmd === 'ping' && parts[1] === 'ai') {
        cmdPingAi();
      } else if (cmd === 'whoami') {
        cmdWhoami();
      } else if (cmd === 'clear') {
        cmdClear();
      } else if (cmd === 'exit' || cmd === 'quit') {
        closeTerminal();
      } else {
        cmdNotFound(trimmed);
      }
    }

    // --- Open / Close ---

    function openTerminal() {
      if (isOpen) return;
      isOpen = true;
      overlay.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
      input.focus();

      // Show welcome message on first open
      if (!output.firstChild) {
        typewriterLines([
          { text: '  _____       _       _ _ _', className: 'term-highlight' },
          { text: ' |_   _|     | |     | | (_)', className: 'term-highlight' },
          { text: '   | |  _ __ | |_ ___| | |_  ___ __ _', className: 'term-highlight' },
          { text: '   | | | \'_ \\| __/ _ \\ | | |/ __/ _` |', className: 'term-highlight' },
          { text: '  _| |_| | | | ||  __/ | | | (_| (_| |', className: 'term-highlight' },
          { text: ' |_____|_| |_|\\__\\___|_|_|_|\\___\\__,_|', className: 'term-highlight' },
          { text: '' },
          { text: ' Welcome to the Intellica Secret Terminal v1.0', className: 'term-accent' },
          { text: ' Type "help" for available commands.', className: 'term-dim' },
          { text: '' }
        ]);
      }
    }

    function closeTerminal() {
      if (!isOpen) return;
      isOpen = false;
      activeTypewriterId++; // Cancel any running typewriter chains
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
    }

    // --- Event Listeners ---

    // Input handling
    input.addEventListener('keydown', function (e: KeyboardEvent) {
      if (e.key === 'Enter') {
        const val = input.value;
        input.value = '';
        processCommand(val);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (historyIndex < commandHistory.length - 1) {
          historyIndex++;
          input.value = commandHistory[historyIndex];
        }
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          input.value = commandHistory[historyIndex];
        } else {
          historyIndex = -1;
          input.value = '';
        }
      } else if (e.key === 'Escape') {
        closeTerminal();
      }
    });

    // Close button
    closeBtn.addEventListener('click', closeTerminal);

    // Click outside to close
    overlay.addEventListener('click', function (e: MouseEvent) {
      if (e.target === overlay) {
        closeTerminal();
      }
    });

    // Konami code detection: Up Up Down Down Left Right Left Right B A
    const konamiSequence = [
      'ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown',
      'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight',
      'KeyB', 'KeyA'
    ];
    let konamiIndex = 0;

    document.addEventListener('keydown', function (e: KeyboardEvent) {
      // Ctrl+Shift+K shortcut
      if (e.ctrlKey && e.shiftKey && e.code === 'KeyK') {
        e.preventDefault();
        if (isOpen) {
          closeTerminal();
        } else {
          openTerminal();
        }
        return;
      }

      // Skip Konami detection if terminal is open (input captures arrow keys)
      if (isOpen) return;

      // Konami code
      const expected = konamiSequence[konamiIndex];
      if (e.code === expected) {
        konamiIndex++;
        if (konamiIndex === konamiSequence.length) {
          konamiIndex = 0;
          openTerminal();
        }
      } else {
        konamiIndex = e.code === konamiSequence[0] ? 1 : 0;
      }
    });
  })();
</script>
