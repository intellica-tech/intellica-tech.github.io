---
/**
 * ProductConstellation.astro
 * Interactive space-themed visualization of Intellica's 10 products
 * as connected star nodes in 4 clusters.
 */

const products = [
  { id: 'ifdm', name: 'IFDM', tagline: 'Finance Data Model', description: 'International standard DWH model for banking', tags: ['Data Model', 'Banking'], href: '/products/ifdm', x: 15, y: 25, cluster: 'data-models' },
  { id: 'itdm', name: 'ITDM', tagline: 'Telecom Data Model', description: 'DWH model for telecom operators', tags: ['Data Model', 'Telecom'], href: '/products/itdm', x: 25, y: 40, cluster: 'data-models' },
  { id: 'hrdm', name: 'HRDM', tagline: 'HR Data Model', description: 'Optimized for HR analytics', tags: ['Data Model', 'HR'], href: '/products/hrdm', x: 10, y: 50, cluster: 'data-models' },
  { id: 'icc', name: 'ICC', tagline: 'Consistency Checker', description: 'Data reconciliation & quality control', tags: ['Data Quality', 'Reconciliation'], href: '/products/icc', x: 70, y: 20, cluster: 'governance' },
  { id: 'retouch', name: 'ReTouch', tagline: 'Data Entry Management', description: 'Validate & import external data', tags: ['Data Entry', 'Validation'], href: '/products/retouch', x: 80, y: 35, cluster: 'governance' },
  { id: 'retable', name: 'Retable', tagline: 'No-Code Platform', description: 'Build apps without code', tags: ['No-Code', 'Cloud'], href: '/products/retable', x: 20, y: 70, cluster: 'platform' },
  { id: 'orqenta', name: 'Orqenta', tagline: 'Workflow Orchestration', description: 'Job scheduling for regulated environments', tags: ['Orchestration', 'Enterprise'], href: '/products/orqenta', x: 35, y: 80, cluster: 'platform' },
  { id: 'talkto', name: 'Talk To', tagline: 'NL-to-SQL AI', description: 'Ask data questions in plain English', tags: ['GenAI', 'NL2SQL'], href: '/products/talk-to-your-data', x: 65, y: 65, cluster: 'ai' },
  { id: 'blueoctopus', name: 'Blue Octopus', tagline: 'Event Intelligence', description: 'Real-time critical event detection', tags: ['AI Analytics', 'Monitoring'], href: '/products/blue-octopus', x: 80, y: 70, cluster: 'ai' },
  { id: 'var', name: 'VAR', tagline: 'Voice AI Recognition', description: 'Voice signature & speaker matching', tags: ['Voice AI', 'Security'], href: '/products/var', x: 75, y: 85, cluster: 'ai' },
];

const connections = [
  ['ifdm', 'icc'],
  ['itdm', 'icc'],
  ['hrdm', 'icc'],
  ['icc', 'retouch'],
  ['retable', 'orqenta'],
  ['talkto', 'blueoctopus'],
  ['talkto', 'var'],
  ['blueoctopus', 'var'],
  ['retouch', 'retable'],
];
---

<section class="constellation-section" id="product-constellation" aria-label="Product Constellation Map">
  <div class="constellation__stars" aria-hidden="true"></div>
  <div class="container">
    <div class="constellation__header anim-fade-up">
      <div class="section-label">EXPLORE</div>
      <h2 class="section-title">Product <span class="grad-text">Constellation</span></h2>
      <p class="constellation__subtitle">Discover our solutions in a new way</p>
    </div>

    <!-- Desktop: Interactive constellation map -->
    <div class="constellation__canvas anim-fade-up" role="img" aria-label="Interactive map of Intellica products organized in four clusters: Data Models, Governance, Platform, and AI">
      <svg class="constellation__svg" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        {connections.map(([fromId, toId]) => {
          const from = products.find(p => p.id === fromId);
          const to = products.find(p => p.id === toId);
          return from && to ? (
            <line
              class="constellation__line"
              data-from={fromId}
              data-to={toId}
              x1={`${from.x}%`}
              y1={`${from.y}%`}
              x2={`${to.x}%`}
              y2={`${to.y}%`}
            />
          ) : null;
        })}
      </svg>

      {products.map((product) => (
        <button
          class="constellation__node"
          data-product-id={product.id}
          data-cluster={product.cluster}
          style={`left: ${product.x}%; top: ${product.y}%;`}
          aria-label={`${product.name} — ${product.tagline}. Click to learn more.`}
          aria-expanded="false"
          type="button"
        >
          <span class="constellation__dot" aria-hidden="true"></span>
          <span class="constellation__label">{product.name}</span>
        </button>
      ))}

      <!-- Expanded card (rendered once, populated via JS) -->
      <div class="constellation__card" role="dialog" aria-label="Product details" hidden>
        <div class="constellation__card-name"></div>
        <div class="constellation__card-tagline"></div>
        <div class="constellation__card-desc"></div>
        <div class="constellation__card-tags"></div>
        <a class="constellation__card-link" href="#">Learn More &rarr;</a>
      </div>
    </div>

    <!-- Mobile: Grid fallback -->
    <div class="constellation__mobile-grid anim-fade-up" aria-label="Product list">
      {products.map((product) => (
        <a class="constellation__mobile-card" href={product.href}>
          <div class="constellation__mobile-card-header">
            <span class="constellation__mobile-dot" aria-hidden="true"></span>
            <span class="constellation__mobile-name">{product.name}</span>
          </div>
          <p class="constellation__mobile-tagline">{product.tagline}</p>
          <p class="constellation__mobile-desc">{product.description}</p>
          <div class="constellation__mobile-tags">
            {product.tags.map((tag) => (
              <span class="constellation__mobile-tag">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section ──────────────────────────────────── */
  .constellation-section {
    position: relative;
    padding-block: clamp(64px, 8vw, 100px);
    background: radial-gradient(ellipse at 20% 30%, rgba(0, 200, 150, 0.06) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 70%, rgba(0, 159, 227, 0.06) 0%, transparent 50%),
                var(--clr-dark, #030B16);
    overflow: hidden;
  }

  /* ── Star background ──────────────────────────── */
  .constellation__stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    will-change: transform;
    transition: transform 0.15s ease-out;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.5) 50%, transparent 50%),
      radial-gradient(1px 1px at 25% 60%, rgba(255,255,255,0.4) 50%, transparent 50%),
      radial-gradient(1px 1px at 40% 30%, rgba(255,255,255,0.3) 50%, transparent 50%),
      radial-gradient(1px 1px at 55% 80%, rgba(255,255,255,0.45) 50%, transparent 50%),
      radial-gradient(1px 1px at 70% 10%, rgba(255,255,255,0.35) 50%, transparent 50%),
      radial-gradient(1px 1px at 85% 50%, rgba(255,255,255,0.5) 50%, transparent 50%),
      radial-gradient(1px 1px at 15% 85%, rgba(255,255,255,0.3) 50%, transparent 50%),
      radial-gradient(1px 1px at 50% 45%, rgba(255,255,255,0.4) 50%, transparent 50%),
      radial-gradient(1px 1px at 90% 90%, rgba(255,255,255,0.35) 50%, transparent 50%),
      radial-gradient(1.5px 1.5px at 5% 40%, rgba(255,255,255,0.6) 50%, transparent 50%),
      radial-gradient(1.5px 1.5px at 60% 20%, rgba(255,255,255,0.55) 50%, transparent 50%),
      radial-gradient(1px 1px at 33% 72%, rgba(255,255,255,0.3) 50%, transparent 50%),
      radial-gradient(1px 1px at 78% 38%, rgba(255,255,255,0.4) 50%, transparent 50%),
      radial-gradient(1px 1px at 45% 92%, rgba(255,255,255,0.35) 50%, transparent 50%),
      radial-gradient(1px 1px at 18% 5%, rgba(255,255,255,0.45) 50%, transparent 50%),
      radial-gradient(1.5px 1.5px at 92% 25%, rgba(255,255,255,0.5) 50%, transparent 50%),
      radial-gradient(1px 1px at 67% 55%, rgba(255,255,255,0.3) 50%, transparent 50%),
      radial-gradient(1px 1px at 3% 68%, rgba(255,255,255,0.4) 50%, transparent 50%);
  }

  /* ── Header ───────────────────────────────────── */
  .constellation__header {
    text-align: center;
    margin-bottom: 48px;
    position: relative;
    z-index: 1;
  }

  .constellation__subtitle {
    color: var(--clr-muted, #8A99B3);
    font-size: 1.1rem;
    margin-top: 8px;
  }

  /* ── Canvas (desktop) ─────────────────────────── */
  .constellation__canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    min-height: 400px;
    max-height: 600px;
    z-index: 1;
  }

  .constellation__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .constellation__line {
    stroke: rgba(255, 255, 255, 0.1);
    stroke-width: 1;
    transition: stroke 0.3s ease, stroke-opacity 0.3s ease;
  }

  .constellation__line.is-highlighted {
    stroke: var(--clr-primary, #00C896);
    stroke-opacity: 1;
    stroke-width: 1.5;
  }

  /* ── Node ──────────────────────────────────────── */
  .constellation__node {
    position: absolute;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 2;
    font-family: inherit;
    outline: none;
  }

  .constellation__node:focus-visible {
    outline: 2px solid var(--clr-primary, #00C896);
    outline-offset: 4px;
    border-radius: var(--radius-sm, 10px);
  }

  .constellation__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--clr-primary, #00C896);
    box-shadow: 0 0 8px rgba(0, 200, 150, 0.5), 0 0 20px rgba(0, 200, 150, 0.2);
    transition: width 0.25s ease, height 0.25s ease, box-shadow 0.25s ease;
    flex-shrink: 0;
  }

  .constellation__node:hover .constellation__dot,
  .constellation__node:focus-visible .constellation__dot,
  .constellation__node.is-active .constellation__dot {
    width: 20px;
    height: 20px;
    box-shadow: 0 0 16px rgba(0, 200, 150, 0.7), 0 0 40px rgba(0, 200, 150, 0.35);
  }

  .constellation__label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--clr-muted, #8A99B3);
    white-space: nowrap;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    transition: color 0.25s ease;
  }

  .constellation__node:hover .constellation__label,
  .constellation__node:focus-visible .constellation__label,
  .constellation__node.is-active .constellation__label {
    color: var(--clr-text, #F0F4FF);
  }

  /* ── Expanded card ────────────────────────────── */
  .constellation__card {
    position: absolute;
    z-index: 10;
    width: 280px;
    padding: 20px;
    background: rgba(5, 14, 26, 0.95);
    border: 1px solid var(--clr-border, rgba(255,255,255,0.08));
    border-radius: var(--radius-md, 16px);
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4), var(--shadow-glow, 0 0 60px rgba(0, 200, 150, 0.12));
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
  }

  .constellation__card.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .constellation__card-name {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--clr-text, #F0F4FF);
    margin-bottom: 2px;
  }

  .constellation__card-tagline {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--clr-primary, #00C896);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }

  .constellation__card-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--clr-muted, #8A99B3);
    margin-bottom: 12px;
  }

  .constellation__card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .constellation__card-link {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--clr-primary, #00C896);
    transition: color 0.2s ease;
  }

  .constellation__card-link:hover,
  .constellation__card-link:focus-visible {
    color: var(--clr-secondary, #009FE3);
  }

  /* ── Mobile grid (hidden on desktop) ──────────── */
  .constellation__mobile-grid {
    display: none;
  }

  /* ── Mobile fallback ──────────────────────────── */
  @media (max-width: 768px) {
    .constellation__canvas {
      display: none;
    }

    .constellation__mobile-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .constellation__mobile-card {
      display: block;
      padding: 16px 20px;
      background: var(--clr-card, rgba(255,255,255,0.04));
      border: 1px solid var(--clr-border, rgba(255,255,255,0.08));
      border-radius: var(--radius-md, 16px);
      transition: border-color 0.25s ease, transform 0.25s ease;
    }

    .constellation__mobile-card:hover,
    .constellation__mobile-card:focus-visible {
      border-color: var(--clr-primary, #00C896);
      transform: translateY(-2px);
    }

    .constellation__mobile-card-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 4px;
    }

    .constellation__mobile-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--clr-primary, #00C896);
      box-shadow: 0 0 6px rgba(0, 200, 150, 0.4);
      flex-shrink: 0;
    }

    .constellation__mobile-name {
      font-size: 1rem;
      font-weight: 700;
      color: var(--clr-text, #F0F4FF);
    }

    .constellation__mobile-tagline {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--clr-primary, #00C896);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 6px;
    }

    .constellation__mobile-desc {
      font-size: 0.85rem;
      line-height: 1.5;
      color: var(--clr-muted, #8A99B3);
      margin-bottom: 10px;
    }

    .constellation__mobile-tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .constellation__mobile-tag {
      font-size: 0.65rem;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 999px;
      background: rgba(0, 200, 150, 0.1);
      border: 1px solid rgba(0, 200, 150, 0.2);
      color: var(--clr-primary, #00C896);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
  }

  /* ── Reduced motion ───────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .constellation__stars {
      transition: none;
    }
    .constellation__dot {
      transition: none;
    }
    .constellation__line {
      transition: none;
    }
    .constellation__card {
      transition: none;
    }
    .constellation__node {
      transition: none;
    }
    .constellation__mobile-card {
      transition: none;
    }
    .constellation__label {
      transition: none;
    }
    .constellation__card-link {
      transition: none;
    }
  }
</style>

<script define:vars={{ products, connections }}>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('product-constellation');
    if (!section) return;

    const starsLayer = section.querySelector('.constellation__stars');
    const canvas = section.querySelector('.constellation__canvas');
    const svg = section.querySelector('.constellation__svg');
    const card = section.querySelector('.constellation__card');
    const nodes = section.querySelectorAll('.constellation__node');
    const lines = section.querySelectorAll('.constellation__line');

    if (!canvas || !svg || !card) return;

    // Check for reduced motion preference
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let activeNodeId = null;

    // ── Mouse parallax on star layer ──────────────
    if (starsLayer && !prefersReducedMotion) {
      section.addEventListener('mousemove', (e) => {
        const rect = section.getBoundingClientRect();
        const xRatio = (e.clientX - rect.left) / rect.width - 0.5;
        const yRatio = (e.clientY - rect.top) / rect.height - 0.5;
        const maxShift = 5;
        starsLayer.style.transform = `translate(${xRatio * maxShift}px, ${yRatio * maxShift}px)`;
      });

      section.addEventListener('mouseleave', () => {
        starsLayer.style.transform = 'translate(0, 0)';
      });
    }

    // ── Highlight connections on hover ────────────
    function highlightConnections(nodeId, active) {
      lines.forEach((line) => {
        const from = line.getAttribute('data-from');
        const to = line.getAttribute('data-to');
        if (from === nodeId || to === nodeId) {
          if (active) {
            line.classList.add('is-highlighted');
          } else {
            line.classList.remove('is-highlighted');
          }
        }
      });
    }

    // ── Position the card near a node ─────────────
    function positionCard(nodeEl) {
      const canvasRect = canvas.getBoundingClientRect();
      const nodeRect = nodeEl.getBoundingClientRect();
      const nodeX = nodeRect.left - canvasRect.left + nodeRect.width / 2;
      const nodeY = nodeRect.top - canvasRect.top + nodeRect.height;

      const cardWidth = 280;
      const cardHeight = 260;

      let left = nodeX - cardWidth / 2;
      let top = nodeY + 12;

      // Keep card within canvas bounds
      if (left < 8) left = 8;
      if (left + cardWidth > canvasRect.width - 8) left = canvasRect.width - cardWidth - 8;
      if (top + cardHeight > canvasRect.height - 8) {
        top = nodeRect.top - canvasRect.top - cardHeight - 12;
      }
      if (top < 8) top = 8;

      card.style.left = left + 'px';
      card.style.top = top + 'px';
    }

    // ── Populate the card with product data ───────
    function showCard(productId, nodeEl) {
      const product = products.find((p) => p.id === productId);
      if (!product) return;

      const nameEl = card.querySelector('.constellation__card-name');
      const taglineEl = card.querySelector('.constellation__card-tagline');
      const descEl = card.querySelector('.constellation__card-desc');
      const tagsEl = card.querySelector('.constellation__card-tags');
      const linkEl = card.querySelector('.constellation__card-link');

      nameEl.textContent = product.name;
      taglineEl.textContent = product.tagline;
      descEl.textContent = product.description;
      linkEl.setAttribute('href', product.href);

      // Clear and rebuild tags
      while (tagsEl.firstChild) {
        tagsEl.removeChild(tagsEl.firstChild);
      }
      product.tags.forEach((tag) => {
        const span = document.createElement('span');
        span.textContent = tag;
        span.style.cssText = 'font-size:0.65rem;font-weight:600;padding:3px 8px;border-radius:999px;background:rgba(0,200,150,0.1);border:1px solid rgba(0,200,150,0.2);color:var(--clr-primary,#00C896);text-transform:uppercase;letter-spacing:0.04em;';
        tagsEl.appendChild(span);
      });

      positionCard(nodeEl);
      card.removeAttribute('hidden');
      // Force reflow before adding visibility class
      void card.offsetHeight;
      card.classList.add('is-visible');
    }

    function hideCard() {
      card.classList.remove('is-visible');
      // Wait for transition before hiding
      setTimeout(() => {
        if (!card.classList.contains('is-visible')) {
          card.setAttribute('hidden', '');
        }
      }, 250);
    }

    // ── Node interactions ─────────────────────────
    nodes.forEach((node) => {
      const productId = node.getAttribute('data-product-id');

      // Hover: highlight connections
      node.addEventListener('mouseenter', () => {
        highlightConnections(productId, true);
      });
      node.addEventListener('mouseleave', () => {
        if (activeNodeId !== productId) {
          highlightConnections(productId, false);
        }
      });

      // Focus: highlight connections
      node.addEventListener('focus', () => {
        highlightConnections(productId, true);
      });
      node.addEventListener('blur', () => {
        if (activeNodeId !== productId) {
          highlightConnections(productId, false);
        }
      });

      // Click: expand card
      node.addEventListener('click', (e) => {
        e.stopPropagation();

        if (activeNodeId === productId) {
          // Close if clicking same node
          closeActiveNode();
          return;
        }

        // Close previous
        closeActiveNode();

        // Open new
        activeNodeId = productId;
        node.classList.add('is-active');
        node.setAttribute('aria-expanded', 'true');
        highlightConnections(productId, true);
        showCard(productId, node);
      });
    });

    function closeActiveNode() {
      if (activeNodeId) {
        const prevNode = section.querySelector(`.constellation__node[data-product-id="${activeNodeId}"]`);
        if (prevNode) {
          prevNode.classList.remove('is-active');
          prevNode.setAttribute('aria-expanded', 'false');
        }
        highlightConnections(activeNodeId, false);
        hideCard();
        activeNodeId = null;
      }
    }

    // Click outside to close card
    document.addEventListener('click', (e) => {
      if (activeNodeId && !card.contains(e.target)) {
        closeActiveNode();
      }
    });

    // Escape key to close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && activeNodeId) {
        const prevNode = section.querySelector(`.constellation__node[data-product-id="${activeNodeId}"]`);
        closeActiveNode();
        if (prevNode) prevNode.focus();
      }
    });

    // ── Resize: recalculate card position ─────────
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (activeNodeId) {
          const activeNode = section.querySelector(`.constellation__node[data-product-id="${activeNodeId}"]`);
          if (activeNode) {
            positionCard(activeNode);
          }
        }
      }, 100);
    });
  });
</script>
