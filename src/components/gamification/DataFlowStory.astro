---
/**
 * DataFlowStory.astro
 * Scroll-driven animated section showing data flowing through a 4-stage pipeline.
 * Each stage activates via IntersectionObserver as the user scrolls.
 */

const iconExtract = `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
  <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
  <circle cx="28" cy="12" r="5" stroke="currentColor" stroke-width="2"/>
  <circle cx="12" cy="28" r="5" stroke="currentColor" stroke-width="2"/>
  <circle cx="28" cy="28" r="5" stroke="currentColor" stroke-width="2"/>
</svg>`;

const iconTransform = `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M6 8 L34 8 L26 20 L34 20 L20 36 L22 24 L14 24 Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="none"/>
</svg>`;

const iconLoad = `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
  <ellipse cx="20" cy="10" rx="12" ry="4" stroke="currentColor" stroke-width="2"/>
  <path d="M8 10v20c0 2.2 5.4 4 12 4s12-1.8 12-4V10" stroke="currentColor" stroke-width="2"/>
  <ellipse cx="20" cy="20" rx="12" ry="4" stroke="currentColor" stroke-width="2" opacity="0.5"/>
</svg>`;

const iconAnalyze = `<svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
  <polyline points="6,32 14,20 22,26 30,10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  <circle cx="14" cy="20" r="2.5" fill="currentColor"/>
  <circle cx="22" cy="26" r="2.5" fill="currentColor"/>
  <circle cx="30" cy="10" r="2.5" fill="currentColor"/>
</svg>`;

const stages = [
  {
    label: 'EXTRACT',
    title: 'Collect from 50+ Sources',
    description: 'Databases, APIs, files, streaming — all unified.',
    icon: iconExtract,
  },
  {
    label: 'TRANSFORM',
    title: 'Apply Business Rules',
    description: 'Filter, join, aggregate, enrich — enterprise-grade processing.',
    icon: iconTransform,
  },
  {
    label: 'LOAD',
    title: 'Land in Your Data Warehouse',
    description: 'Structured, governed, and ready for consumption.',
    icon: iconLoad,
  },
  {
    label: 'ANALYZE',
    title: 'Generate Insights & AI',
    description: 'Dashboards, reports, ML models — value from data.',
    icon: iconAnalyze,
  },
];
---

<section class="dfs-section" id="data-flow-story">
  <div class="container">
    <!-- Header -->
    <div class="dfs-header anim-fade-up">
      <div class="section-label">HOW IT WORKS</div>
      <h2 class="section-title">Your <span class="grad-text">Data Journey</span></h2>
      <p class="section-sub">Scroll to follow the data through the pipeline</p>
    </div>

    <!-- Pipeline -->
    <div class="dfs-pipeline" aria-label="Data pipeline stages" role="list">
      <!-- Vertical connector -->
      <div class="dfs-connector" aria-hidden="true">
        <div class="dfs-connector__track"></div>
        <div class="dfs-connector__fill"></div>
      </div>

      <!-- Stages -->
      {stages.map((stage, index) => (
        <div class="dfs-stage" data-stage-index={index} role="listitem">
          <div class="dfs-stage__icon-wrap">
            <div class="dfs-stage__icon" set:html={stage.icon} />
            {/* Particles */}
            <span class="dfs-particle dfs-particle--1" aria-hidden="true" />
            <span class="dfs-particle dfs-particle--2" aria-hidden="true" />
            <span class="dfs-particle dfs-particle--3" aria-hidden="true" />
            <span class="dfs-particle dfs-particle--4" aria-hidden="true" />
            <span class="dfs-particle dfs-particle--5" aria-hidden="true" />
          </div>
          <div class="dfs-stage__content">
            <span class="dfs-stage__label">{stage.label}</span>
            <h3 class="dfs-stage__title">{stage.title}</h3>
            <p class="dfs-stage__desc">{stage.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="dfs-cta anim-fade-up">
      <a class="btn btn-primary btn-pill btn-lg" href="/contact">Build Your Pipeline With Us</a>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .dfs-section {
    background: radial-gradient(ellipse at 50% 0%, #0f1f3a 0%, #030B16 70%);
    padding: 80px 0;
    overflow: hidden;
  }

  /* ── Header ── */
  .dfs-header {
    text-align: center;
    margin-bottom: 64px;
  }

  /* ── Pipeline wrapper ── */
  .dfs-pipeline {
    position: relative;
    max-width: 640px;
    margin: 0 auto;
    padding-left: 40px;
  }

  /* ── Vertical connector ── */
  .dfs-connector {
    position: absolute;
    left: 28px;
    top: 30px;
    bottom: 30px;
    width: 3px;
  }

  .dfs-connector__track {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 2px;
  }

  .dfs-connector__fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: var(--grad-brand, linear-gradient(135deg, #00C896, #009FE3));
    border-radius: 2px;
    transition: height 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Stage ── */
  .dfs-stage {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding: 32px 0;
    opacity: 0.2;
    transform: translateX(-20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .dfs-stage.active {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Icon circle ── */
  .dfs-stage__icon-wrap {
    position: relative;
    flex-shrink: 0;
    width: 60px;
    height: 60px;
  }

  .dfs-stage__icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.04);
    color: var(--clr-muted, #8A99B3);
    transition: border-color 0.4s ease, box-shadow 0.4s ease, color 0.4s ease;
    padding: 12px;
  }

  .dfs-stage.active .dfs-stage__icon {
    border-color: var(--clr-primary, #00C896);
    box-shadow: 0 0 24px rgba(0, 200, 150, 0.3), 0 0 48px rgba(0, 200, 150, 0.1);
    color: var(--clr-primary, #00C896);
  }

  /* Target SVGs rendered via set:html */
  .dfs-stage__icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* ── Particles ── */
  .dfs-particle {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--clr-primary, #00C896);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .dfs-particle--1 { top: -4px; left: 50%; transform: translateX(-50%); }
  .dfs-particle--2 { top: 50%; right: -4px; transform: translateY(-50%); }
  .dfs-particle--3 { bottom: -4px; left: 50%; transform: translateX(-50%); }
  .dfs-particle--4 { top: 50%; left: -4px; transform: translateY(-50%); }
  .dfs-particle--5 { top: 8px; right: 2px; }

  .dfs-stage.active .dfs-particle {
    animation: dfs-pulse 2s ease-in-out infinite;
  }

  .dfs-stage.active .dfs-particle--1 { animation-delay: 0s; }
  .dfs-stage.active .dfs-particle--2 { animation-delay: 0.4s; }
  .dfs-stage.active .dfs-particle--3 { animation-delay: 0.8s; }
  .dfs-stage.active .dfs-particle--4 { animation-delay: 1.2s; }
  .dfs-stage.active .dfs-particle--5 { animation-delay: 1.6s; }

  @keyframes dfs-pulse {
    0%, 100% { opacity: 0; scale: 0.5; }
    50% { opacity: 0.8; scale: 1.2; }
  }

  /* ── Stage content ── */
  .dfs-stage__content {
    padding-top: 4px;
  }

  .dfs-stage__label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--clr-primary, #00C896);
    margin-bottom: 4px;
    text-transform: uppercase;
  }

  .dfs-stage__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--clr-text, #F0F4FF);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .dfs-stage__desc {
    font-size: 0.95rem;
    color: var(--clr-muted, #8A99B3);
    line-height: 1.5;
  }

  /* ── CTA ── */
  .dfs-cta {
    text-align: center;
    margin-top: 56px;
  }

  /* ── Mobile responsive ── */
  @media (max-width: 768px) {
    .dfs-section {
      padding: 48px 0;
    }

    .dfs-header {
      margin-bottom: 40px;
    }

    .dfs-pipeline {
      padding-left: 32px;
    }

    .dfs-connector {
      left: 20px;
    }

    .dfs-stage {
      gap: 16px;
      padding: 24px 0;
    }

    .dfs-stage__icon-wrap {
      width: 48px;
      height: 48px;
    }

    .dfs-stage__icon {
      width: 48px;
      height: 48px;
      padding: 10px;
    }

    .dfs-stage__title {
      font-size: 1.1rem;
    }

    .dfs-stage__desc {
      font-size: 0.875rem;
    }

    .dfs-cta {
      margin-top: 40px;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .dfs-stage {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .dfs-stage.active .dfs-particle {
      animation: none;
    }
    .dfs-connector__fill {
      transition: none;
    }
  }
</style>

<script>
  function initDataFlowStory() {
    const section = document.getElementById('data-flow-story');
    if (!section) return;

    const stages = section.querySelectorAll('.dfs-stage');
    const fill = section.querySelector('.dfs-connector__fill');
    if (!stages.length || !fill) return;

    const stageCount = stages.length;
    let activeCount = 0;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            observer.unobserve(entry.target);
          }
        });

        // Count active stages and update connector fill
        let count = 0;
        stages.forEach((stage) => {
          if (stage.classList.contains('active')) {
            count++;
          }
        });

        if (count !== activeCount) {
          activeCount = count;
          const percentage = activeCount > 0
            ? ((activeCount - 0.5) / (stageCount - 0.5)) * 100
            : 0;
          const clamped = Math.min(Math.max(percentage, 0), 100);
          (fill as HTMLElement).style.height = clamped + '%';
        }

        // Disconnect observer when all stages are active
        if (activeCount === stageCount) {
          observer.disconnect();
        }
      },
      {
        threshold: 0.4,
        rootMargin: '0px 0px -10% 0px',
      }
    );

    stages.forEach((stage) => {
      observer.observe(stage);
    });
  }

  // Run after DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDataFlowStory);
  } else {
    initDataFlowStory();
  }
</script>
