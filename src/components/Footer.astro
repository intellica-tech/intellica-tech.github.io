---
import { version } from '../../package.json';
import { defaultLang, type Lang } from '../i18n/config';
import { useTranslations, useTranslatedPath } from '../i18n/utils';

interface Props {
  hideCta?: boolean;
  lang?: Lang;
}
const { hideCta = false, lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);
---
<footer class="ix-footer-light" role="contentinfo">
  <!-- CTA BAND -->
  { !hideCta && (
  <section class="ix-footer__cta">
    <div class="ix-container ix-footer__ctaWrap">
      <div class="ix-footer__ctaText">
        <h3>{t('footer.cta.title')}</h3>
        <p>{t('footer.cta.desc')}</p>
      </div>
      <div class="ix-footer__ctaActions">
        <a class="btn btn-primary btn-pill btn-lg" href={tp('/contact')}>{t('footer.cta.getInTouch')}</a>
        <a class="btn btn-ghost-dark btn-pill btn-lg" href={tp('/clients')}>{t('footer.cta.viewClients')}</a>
      </div>
    </div>
  </section>
  )}

  <!-- MAIN -->
  <section class="ix-footer__main">
    <div class="ix-container ix-footer__grid">
      <!-- BRAND -->
      <div class="ix-footer__col ix-footer__brand">
        <div class="ix-footer__logoRow">
          <a href={tp('/')}>
            <img src="/assets/img/intellica-logo.png" alt="Intellica" height="34" />
          </a>
        </div>
        <p class="ix-footer__tagline" style="font-weight: 500; font-size: 0.9rem; line-height: 1.6; color: #64748B; margin-top: 16px; max-width: 320px;">
          {t('footer.tagline')}
        </p>
        <div class="ix-footer__contact-tiny" style="margin-top: 16px; display: flex; flex-direction: column; gap: 8px;">
          <a href="https://www.linkedin.com/company/intellica" target="_blank" rel="noopener" style="color: #64748B; font-size: 0.85rem; display: flex; align-items: center; gap: 10px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            <span>linkedin.com/company/intellica</span>
          </a>
          <a href="mailto:info@intellica.net" style="color: #64748B; font-size: 0.85rem; display: flex; align-items: center; gap: 10px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>info@intellica.net</span>
          </a>
          <a href="tel:+902166884546" style="color: #64748B; font-size: 0.85rem; display: flex; align-items: center; gap: 10px;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>+90 216 688 45 46</span>
          </a>
        </div>
      </div>

      <!-- PRODUCTS -->
      <div class="ix-footer__col">
        <h4>{t('footer.col.products')}</h4>
        <div class="ix-footer__link-flow">
          <a href={tp('/products#governance')}>{t('footer.link.coreProducts')}</a>
          <a href={tp('/products#ai-products')}>{t('footer.link.aiProducts')}</a>
          <a href={tp('/products#data-models')}>{t('footer.link.dataModels')}</a>
          <a href={tp('/products')}>{t('footer.link.allProducts')}</a>
        </div>
      </div>

      <!-- SOLUTIONS -->
      <div class="ix-footer__col">
        <h4>{t('footer.col.solutions')}</h4>
        <div class="ix-footer__link-flow">
          <a href={tp('/solutions')}>{t('footer.link.aiSolutions')}</a>
          <a href={tp('/data-platforms')}>{t('footer.link.dataPlatforms')}</a>
        </div>
      </div>

      <div class="ix-footer__col">
        <h4>{t('footer.col.company')}</h4>
        <div class="ix-footer__link-flow">
          <a href={tp('/about')}>{t('footer.link.about')}</a>
          <a href={tp('/careers')}>{t('footer.link.joinIntellica')}</a>
          <a href={tp('/academy')}>{t('footer.link.talentProgram')}</a>
          <a href={tp('/contact')}>{t('footer.link.contact')}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PIA GROUP BAND -->
  <section class="ix-footer__pia">
    <div class="ix-container ix-footer__piaWrap">
      <span class="ix-footer__pia-label">{t('footer.pia.prefix')}</span>
      <a href="https://www.pia-group.net/" target="_blank" rel="noopener noreferrer" class="ix-footer__pia-link" aria-label="PiA Group website">
        <img src="/assets/img/Pia.png" alt="PiA Group" class="ix-footer__pia-logo" />
      </a>
      <span class="ix-footer__pia-label">{t('footer.pia.suffix')}</span>
    </div>
  </section>

  <!-- BOTTOM BAR -->
  <section class="ix-footer__bottom">
    <div class="ix-container ix-footer__bottomWrap">
      <div class="ix-footer__trust">
        <span class="ix-dot"></span>
        <span>{t('footer.trust')}</span>
      </div>

      <div class="ix-footer__legal">
        <span>© {new Date().getFullYear()} Intellica. {t('footer.rights')} <span class="ix-footer__version">v{version}</span></span>
        <div class="ix-footer__legalLinks">
          <a href={tp('/privacy')}>{t('footer.legal.privacy')}</a>
          <a href={tp('/terms')}>{t('footer.legal.terms')}</a>
          <a href={tp('/cookies')}>{t('footer.legal.cookies')}</a>
        </div>
      </div>
    </div>
  </section>
</footer>

<style>
  .ix-container { max-width: 1240px; margin: 0 auto; padding: 0 24px; }

  .ix-footer-light {
    background: #FFFFFF;
    color: #0F172A;
    border-top: 1px solid #E2E8F0;
    position: relative;
    z-index: 10;
  }

  .ix-footer-light a { color: #64748B; text-decoration: none; transition: color 0.2s, transform 0.2s; font-size: 14px; font-weight: 500; }
  .ix-footer-light a:hover { color: var(--clr-primary); transform: translateX(2px); }

  /* CTA */
  .ix-footer__cta {
    padding: 32px 0;
    background: #F8FAFC;
    border-bottom: 1px solid #E2E8F0;
  }
  .ix-footer__ctaWrap {
    display: flex;
    gap: 32px;
    align-items: center;
    justify-content: space-between;
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 20px;
    padding: 24px 32px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }
  .ix-footer__ctaText h3 { margin: 0 0 4px; font-size: 22px; color: #0F172A; font-weight: 800; letter-spacing: -0.02em; }
  .ix-footer__ctaText p { margin: 0; color: #64748B; font-size: 15px; line-height: 1.5; }
  .ix-footer__ctaActions { display: flex; gap: 12px; }

  /* Standardized buttons already in global.css */
  @media (max-width: 768px) {
    .ix-footer__ctaActions { flex-direction: column; width: 100%; }
    .ix-footer__ctaActions .btn { width: 100%; }
  }

  /* MAIN GRID */
  .ix-footer__main { padding: 64px 0 48px; }
  .ix-footer__grid { display: grid; grid-template-columns: 2.2fr 1fr 1fr 1fr; gap: 48px; }

  .text-center { text-align: center; }
  .ix-footer__col h4 {
    margin: 0 0 20px;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--clr-primary);
    font-weight: 800;
  }

  /* Layout Flow */
  .ix-footer__link-flow { display: flex; flex-direction: column; }
  .ix-footer__divider { height: 1px; background: #E2E8F0; margin: 12px 0 16px; width: 40px; }

  /* Brand */
  .ix-footer__logoRow { margin-bottom: 24px; }
  .ix-footer__tagline { margin: 0 0 8px; color: #0F172A; font-size: 16px; font-weight: 700; }
  .ix-footer__meta { margin: 0 0 20px; color: #94A3B8; font-size: 13px; }
  .ix-footer__social { display: flex; gap: 12px; }
  .ix-footer__icon {
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    background: #F1F5F9;
    color: #64748B;
    border: 1px solid transparent;
  }
  .ix-footer__icon:hover { background: #FFFFFF; border-color: var(--clr-primary); color: var(--clr-primary); }

  /* Products subgrid */
  .ix-footer__subgrid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .ix-footer__vertical-list { display: flex; flex-direction: column; gap: 4px; }
  .ix-footer__vertical-list a { font-size: 14px; color: #64748B; font-weight: 500; }

  /* Remove old row styles */
  /* Remove old group h5 styles */

  /* PiA Group band */
  .ix-footer__pia {
    padding: 20px 0;
    border-top: 1px solid #E2E8F0;
    background: #FFFFFF;
  }
  .ix-footer__piaWrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .ix-footer__pia-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #94A3B8;
  }
  .ix-footer__pia-link {
    display: flex;
    align-items: center;
    opacity: 0.65;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .ix-footer__pia-link:hover {
    opacity: 1;
    transform: translateY(-1px) !important;
  }
  .ix-footer__pia-logo {
    height: 22px;
    width: auto;
    display: block;
  }

  /* Bottom */
  .ix-footer__bottom { padding: 24px 0; border-top: 1px solid #F1F5F9; background: #F8FAFC; }
  .ix-footer__bottomWrap { display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .ix-footer__trust { display: flex; gap: 12px; align-items: center; color: #64748B; font-size: 13px; font-weight: 500; }
  .ix-dot { width: 7px; height: 7px; border-radius: 999px; background: var(--clr-primary); box-shadow: 0 0 10px rgba(0, 200, 150, 0.3); }
  .ix-footer__legal { display: flex; gap: 32px; align-items: center; color: #94A3B8; font-size: 13px; }
  .ix-footer__legalLinks { display: flex; gap: 20px; }
  .ix-footer__legalLinks a { color: #94A3B8; font-size: 13px; }
  .ix-footer__legalLinks a:hover { color: #0F172A; }
  .ix-footer__version { color: #CBD5E1; font-size: 11px; font-weight: 500; margin-left: 6px; }

  /* Responsive */
  @media (max-width: 1100px) {
    .ix-footer__grid { grid-template-columns: 1fr 1fr; gap: 48px; }
    .ix-footer__brand { grid-column: 1 / -1; justify-content: center; text-align: center; }
    .ix-footer__logoRow { display: flex; justify-content: center; }
    .ix-footer__social { justify-content: center; }
  }
  @media (max-width: 768px) {
    .ix-footer__ctaWrap { flex-direction: column; text-align: center; padding: 32px 24px; }
    .ix-footer__subgrid { grid-template-columns: 1fr; }
    .ix-footer__bottomWrap { flex-direction: column; text-align: center; }
  }
  @media (max-width: 560px) {
    .ix-footer__grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
