---
interface Props {
  hideCta?: boolean;
}
const { hideCta = false } = Astro.props;
---
<footer class="ix-footer-light" role="contentinfo">
  <!-- CTA BAND -->
  { !hideCta && (
  <section class="ix-footer__cta">
    <div class="ix-container ix-footer__ctaWrap">
      <div class="ix-footer__ctaText">
        <h3>Ready to Transform Your Data?</h3>
        <p>From data platforms to AI products—let’s turn your infrastructure into a strategic asset.</p>
      </div>
      <div class="ix-footer__ctaActions">
        <a class="ix-btn ix-btn--primary" href="/contact">Talk to an Expert</a>
        <a class="ix-btn ix-btn--ghost" href="/clients">View Clients</a>
      </div>
    </div>
  </section>
  )}

  <!-- MAIN -->
  <section class="ix-footer__main">
    <div class="ix-container ix-footer__grid">
      <!-- BRAND -->
      <div class="ix-footer__col ix-footer__brand">
        <div class="ix-footer__logoRow">
          <a href="/">
            <img src="/assets/img/intellica-logo.png" alt="Intellica" height="34" />
          </a>
        </div>
        <p class="ix-footer__tagline">Unlock the infinite value of data.</p>
        <p class="ix-footer__meta">Data & AI • Since 2006</p>
        <div class="ix-footer__social">
          <a href="https://www.linkedin.com/company/intellica" target="_blank" rel="noopener" aria-label="LinkedIn" class="ix-footer__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
        </div>
      </div>

      <!-- PRODUCTS -->
      <div class="ix-footer__col ix-footer__products">
        <h4 class="text-center">Products</h4>
        <div class="ix-footer__subgrid">
          <div class="ix-footer__group">
            <h5>Data Models</h5>
            <a href="/products/ifdm">IFDM</a>
            <a href="/products/itdm">ITDM</a>
            <a href="/products/hrdm">HRDM</a>
          </div>
          <div class="ix-footer__group">
            <h5>Data Governance</h5>
            <a href="/products/icc">ICC</a>
            <a href="/products/retouch">ReTouch</a>
            <a href="/products/retable">Retable</a>
            <a href="/products/orqenta">Orqenta</a>
          </div>
          <div class="ix-footer__group">
            <h5>AI Products</h5>
            <a href="/products/talk-to-your-data">Talk To</a>
            <a href="/products/blue-octopus">Blue Octopus</a>
            <a href="/products/var">VAR</a>
          </div>
        </div>
      </div>

      <!-- SOLUTIONS -->
      <div class="ix-footer__col">
        <h4>Solutions</h4>
        <div class="ix-footer__link-flow">
          <a href="/solutions" class="parent-link">AI Solutions</a>
          <a href="/data-platforms" class="parent-link">Data Platforms</a>
        </div>
      </div>

      <!-- COMPANY -->
      <div class="ix-footer__col">
        <h4>Company</h4>
        <div class="ix-footer__link-flow">
          <a href="/about">About Us</a>
          <a href="/academy">Academy</a>
          <a href="/careers">Careers</a>
          <a href="/contact">Contact</a>
          <div class="ix-footer__divider"></div>
          <a href="/clients">Clients</a>
          <a href="/insights">Insights</a>
          <a href="/partners">Partners</a>
        </div>
      </div>
    </div>
  </section>

  <!-- BOTTOM BAR -->
  <section class="ix-footer__bottom">
    <div class="ix-container ix-footer__bottomWrap">
      <div class="ix-footer__trust">
        <span class="ix-dot"></span>
        <span>Leading enterprise partner in Finance, Telecom, Retail & Public Sector.</span>
      </div>

      <div class="ix-footer__legal">
        <span>© {new Date().getFullYear()} Intellica. All rights reserved.</span>
        <div class="ix-footer__legalLinks">
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/cookies">Cookies</a>
        </div>
      </div>
    </div>
  </section>
</footer>

<style>
  .ix-container { max-width: 1240px; margin: 0 auto; padding: 0 24px; }
  
  .ix-footer-light {
    background: #FFFFFF;
    color: #0F172A;
    border-top: 1px solid #E2E8F0;
    position: relative;
    z-index: 10;
  }
  
  .ix-footer-light a { color: #64748B; text-decoration: none; transition: color 0.2s, transform 0.2s; font-size: 14px; font-weight: 500; }
  .ix-footer-light a:hover { color: var(--clr-primary); transform: translateX(2px); }

  /* CTA */
  .ix-footer__cta {
    padding: 32px 0;
    background: #F8FAFC;
    border-bottom: 1px solid #E2E8F0;
  }
  .ix-footer__ctaWrap {
    display: flex;
    gap: 32px;
    align-items: center;
    justify-content: space-between;
    background: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 20px;
    padding: 24px 32px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }
  .ix-footer__ctaText h3 { margin: 0 0 4px; font-size: 22px; color: #0F172A; font-weight: 800; letter-spacing: -0.02em; }
  .ix-footer__ctaText p { margin: 0; color: #64748B; font-size: 15px; line-height: 1.5; }
  .ix-footer__ctaActions { display: flex; gap: 12px; }

  .ix-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 12px 20px;
    font-weight: 700;
    font-size: 14px;
    transition: 0.2s ease;
  }
  .ix-btn--primary{
    background: linear-gradient(135deg, #00C896, #009FE3);
    color: #fff !important;
    box-shadow: 0 8px 25px rgba(0, 200, 150, 0.4);
    border: none;
  }
  .ix-btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(0, 200, 150, 0.5);
    color: #fff !important;
  }

  .ix-btn--ghost {
    border: 1px solid #E2E8F0;
    background: #fff;
    color: #0F172A;
  }
  .ix-btn--ghost:hover { border-color: var(--clr-primary); background: #F8FAFC; }

  /* MAIN GRID */
  .ix-footer__main { padding: 64px 0 48px; }
  .ix-footer__grid { display: grid; grid-template-columns: 1.2fr 2fr 1fr 1fr; gap: 48px; }
  
  .text-center { text-align: center; }
  .ix-footer__col h4 {
    margin: 0 0 20px;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--clr-primary);
    font-weight: 800;
  }

  /* Layout Flow */
  .ix-footer__link-flow { display: flex; flex-direction: column; }
  .ix-footer__divider { height: 1px; background: #E2E8F0; margin: 12px 0 16px; width: 40px; }

  /* Brand */
  .ix-footer__logoRow { margin-bottom: 24px; }
  .ix-footer__tagline { margin: 0 0 8px; color: #0F172A; font-size: 16px; font-weight: 700; }
  .ix-footer__meta { margin: 0 0 20px; color: #94A3B8; font-size: 13px; }
  .ix-footer__social { display: flex; gap: 12px; }
  .ix-footer__icon {
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    background: #F1F5F9;
    color: #64748B;
    border: 1px solid transparent;
  }
  .ix-footer__icon:hover { background: #FFFFFF; border-color: var(--clr-primary); color: var(--clr-primary); }

  /* Products subgrid */
  .ix-footer__subgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px 32px; }
  .ix-footer__group h5 { margin: 0 0 12px; font-size: 12px; color: #0F172A; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; }

  /* Bottom */
  .ix-footer__bottom { padding: 24px 0; border-top: 1px solid #F1F5F9; background: #F8FAFC; }
  .ix-footer__bottomWrap { display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .ix-footer__trust { display: flex; gap: 12px; align-items: center; color: #64748B; font-size: 13px; font-weight: 500; }
  .ix-dot { width: 7px; height: 7px; border-radius: 999px; background: var(--clr-primary); box-shadow: 0 0 10px rgba(0, 200, 150, 0.3); }
  .ix-footer__legal { display: flex; gap: 32px; align-items: center; color: #94A3B8; font-size: 13px; }
  .ix-footer__legalLinks { display: flex; gap: 20px; }
  .ix-footer__legalLinks a { color: #94A3B8; font-size: 13px; }
  .ix-footer__legalLinks a:hover { color: #0F172A; }

  /* Responsive */
  @media (max-width: 1100px) {
    .ix-footer__grid { grid-template-columns: 1fr 1fr; gap: 48px; }
    .ix-footer__brand { grid-column: 1 / -1; justify-content: center; text-align: center; }
    .ix-footer__logoRow { display: flex; justify-content: center; }
    .ix-footer__social { justify-content: center; }
  }
  @media (max-width: 768px) {
    .ix-footer__ctaWrap { flex-direction: column; text-align: center; padding: 32px 24px; }
    .ix-footer__subgrid { grid-template-columns: 1fr; }
    .ix-footer__bottomWrap { flex-direction: column; text-align: center; }
  }
  @media (max-width: 560px) {
    .ix-footer__grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
