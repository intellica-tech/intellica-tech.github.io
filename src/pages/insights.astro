---
import Layout from '../layouts/Layout.astro';

const siteUrl = "https://intellica-tech.github.io";
const breadcrumbs = [{ name: "Insights", url: `${siteUrl}/insights` }];

const insights = [
  {
    title: "Why Trust Declines as the Number of Dashboards Increases",
    desc: "Why does dashboard inflation hurt trust? A practical framework through definition drift, loss of lineage, and maintenance obesity.",
    slug: "dashboard-guven",
    time: "6 min",
    date: "Feb 1, 2026",
    topics: ["Data Governance", "Dashboard Governance", "Data Lineage", "Semantic Layer"]
  },
  {
    title: "Why Manual Controls Are Still Alive",
    desc: "The real reason behind Excel silos: trust trauma and risk ownership. Trust must be built into the system to reduce manual reconciliation.",
    slug: "manuel-kontroller",
    time: "5 min",
    date: "Feb 1, 2026",
    topics: ["Data Quality", "Reconciliation", "Operational Risk", "Data Lineage"]
  },
  {
    title: "Data Autopsy or Data Pulse?",
    desc: "Reports are autopsies; early warning is a data-in-motion discipline. Dynamic thresholds + correlation + action timelines.",
    slug: "verinin-nabzi",
    time: "6 min",
    date: "Feb 1, 2026",
    topics: ["Early Warning", "Data Observability", "Anomaly Detection", "Event Correlation"]
  },
  {
    title: "Business Analysis: Where Everything Starts and Ends",
    desc: "Success starts before the code. A professional approach to clarifying scope and reducing regression risk with 5W1H + impact analysis.",
    slug: "is-analizi",
    time: "7 min",
    date: "Feb 1, 2026",
    topics: ["Business Analysis", "Scope Management", "Impact Analysis", "CR Process"]
  },
  {
    title: "When Does RAG (Retrieval) Work and When Does It Mislead?",
    desc: "The success of RAG depends more on the quality of information access than the model: chunking, metadata, relevance, freshness, and attribution.",
    slug: "rag-ne-zaman-ise-yarar",
    time: "8 min",
    date: "Feb 1, 2026",
    topics: ["RAG", "GenAI", "Information Retrieval", "Document AI"]
  },
  {
    title: "How to Establish a 'Trust Standard' in Enterprise GenAI?",
    desc: "Trust in GenAI is built through processes, measurement, and governance. Leveraging attribution, access, evaluation, and traceability.",
    slug: "genai-guven-standardi",
    time: "9 min",
    date: "Feb 1, 2026",
    topics: ["GenAI", "Governance", "Security", "LLM Evaluation"]
  }
];

const allTopics = Array.from(new Set(insights.flatMap(i => i.topics))).sort();
---

<Layout title="Insights | Intellica" description="Actionable insights, technical guides, and methodology notes for data & AI transformation." breadcrumbs={breadcrumbs} hideCta={true}>
  <!-- HERO -->
  <section class="hero noise" id="insights-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">Data & AI · Insights</div>
          <h1 class="hero__title">Intellica <span class="grad-text">Insights</span></h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">Actionable guides, technical deep-dives, and methodology notes from our data & AI engagements.</p>
        </div>
        
        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/insights_hero_v3.png" alt="Intellica Insights Visual" class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

<style>
#insights-hero { min-height: 750px !important; }
@media (max-width: 1100px) {
  #insights-hero { min-height: auto !important; }
}
</style>
<style>
/* HERO: STANDARDIZED */
.hero-disabled { 
  min-height: 750px; 
  display: flex; 
  align-items: center; 
  position: relative; 
  overflow: hidden;
  background: linear-gradient(135deg, #162a4d 0%, #020617 100%);
}
.hero-disabled__inner { 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  position: relative; 
  width: 100%; 
}
.hero-disabled__content-wrap { 
  display: grid; 
  grid-template-columns: 1.2fr 0.8fr; 
  align-items: center; 
  gap: 40px; 
  width: 100%; 
}
.hero-disabled__content { 
  display: flex; 
  flex-direction: column; 
  align-items: flex-start; 
  padding-block: 60px; 
}
.hero-disabled__title { 
  font-size: clamp(2.5rem, 5vw, 4.5rem); 
  font-weight: 900; 
  line-height: 1.1; 
  color: #fff; 
  margin-bottom: 24px; 
}
.hero-disabled__accent { 
  display: block; 
  width: 80px; 
  height: 4px; 
  border-radius: 4px; 
  background: var(--grad-brand); 
  margin-bottom: 32px; 
}
.hero-disabled__desc { 
  font-size: 1.25rem; 
  line-height: 1.6; 
  color: rgba(255, 255, 255, 0.85); 
  max-width: 600px; 
  margin-bottom: 48px; 
}
.hero-disabled__visual { 
  display: flex; 
  justify-content: center; 
  align-items: center; 
}
.hero-disabled__shape-new { 
  width: 100%; 
  max-width: 560px; 
  border-radius: 48px;
  overflow: hidden;
  animation: float 8s ease-in-out infinite; 
  filter: drop-shadow(0 20px 80px rgba(0, 200, 150, 0.3)); 
}

@keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-20px); } 100% { transform: translateY(0px); } }

@media (max-width: 1100px) {
  .hero-disabled { min-height: auto !important; padding-top: 5px !important; padding-bottom: 25px !important; height: auto; align-items: center; }
  .hero-disabled__inner { padding-top: 0; }
  .hero-disabled__content-wrap { grid-template-columns: 1fr; text-align: left; position: relative; display: flex; flex-direction: column; padding-top: 0px; }
  .hero-disabled__content { align-items: flex-start; padding-block: 0px; }
  .hero-disabled__visual { 
    position: absolute; top: -5px; right: 5px; width: 80px; height: 80px; 
    z-index: 10; display: flex; justify-content: flex-end; align-items: flex-start;
  }
  .hero-disabled__shape-new { width: 100%; height: auto; opacity: 1; border-radius: 16px; filter: drop-shadow(0 4px 12px rgba(0, 200, 150, 0.25)); }
  .hero-disabled__desc { font-size: 1.1rem; max-width: 100%; margin-bottom: 24px; line-height: 1.5; }
  .hero-disabled__title { font-size: 2.22rem; margin-bottom: 16px; padding-right: 80px; line-height: 1.15; }
  .hero-disabled__actions { margin-bottom: 24px; }
}
</style>

  <!-- FEATURED -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2 anim-fade-up" style="gap:48px; align-items: center;">
        <div>
          <div class="div-badge">Latest Featured</div>
          <h2 style="color:var(--clr-light-text); font-size: 2.5rem; line-height: 1.1; margin-bottom: 24px;">The Trust Standard in <span class="grad-text">Enterprise GenAI</span></h2>
          <p style="color:var(--clr-light-muted); font-size: 1.1rem; line-height: 1.6; margin-bottom: 32px;">
            How to build production-grade AI systems with verified grounding, source-aware answers, and governed access. Discover our methodology for moving from Proof of Concept to reliable production.
          </p>
          <a href="/insights/genai-guven-standardi" class="btn btn-primary btn-pill btn-lg">Read Article</a>
        </div>
        <div class="featured-visual">
          <img src="/assets/img/ai_knowledge_abstract_1772398712333.png" alt="Enterprise AI Trust" style="width:100%; border-radius: 32px; box-shadow: 0 40px 80px rgba(0,0,0,0.15);" />
        </div>
      </div>
    </div>
  </section>

  <!-- LIST -->
  <section class="section section--light" id="insights-list">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title" style="color:var(--clr-light-text);">Insight <span class="grad-text">Library</span></h2>
        <p class="section-sub">Search and filter through our collective knowledge.</p>
      </div>

      <div class="insights-toolbar anim-fade-up">
        <div class="search-box">
          <input id="insight-search" type="search" placeholder="Search by title or topic..." />
        </div>
        <div class="filter-box">
          <select id="topic-filter">
            <option value="">All Topics</option>
            {allTopics.map(t => <option value={t}>{t}</option>)}
          </select>
        </div>
      </div>

      <div class="grid-3 anim-fade-up" id="insights-grid">
        {insights.map(item => (
          <a href={`/insights/${item.slug}`} class="insight-card card-light" data-topics={item.topics.join(',')} data-title={item.title.toLowerCase()}>
            <div class="insight-meta">
              <span>{item.date}</span>
              <span class="dot"></span>
              <span>{item.time} read</span>
            </div>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
            <div class="insight-tags">
              {item.topics.slice(0, 3).map(t => <span class="topic-pill">{t}</span>)}
              {item.topics.length > 3 && <span class="topic-pill">+{item.topics.length - 3}</span>}
            </div>
          </a>
        ))}
      </div>


    </div>
  </section>

  <!-- ===== CTA STRIP ===== -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Have an insight to <span class="grad-text">share?</span></h2>
        <p>Let's collaborate on framing a problem and turning it into a practical guide for your organization.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Talk to an Expert</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.insights-toolbar {
  display: flex;
  gap: 20px;
  margin-bottom: 48px;
  margin-top: 32px;
}
.search-box { flex: 2; }
.filter-box { flex: 1; }
.insights-toolbar input, .insights-toolbar select {
  width: 100%;
  padding: 14px 20px;
  border-radius: 12px;
  border: 1px solid #e2e8f0;
  background: #fff;
  font-size: 0.95rem;
  color: #1e293b;
  outline: none;
  transition: border-color 0.2s ease;
}
.insights-toolbar input:focus, .insights-toolbar select:focus {
  border-color: var(--clr-primary);
}

.insight-card {
  display: flex;
  flex-direction: column;
  padding: 32px;
  text-decoration: none;
  transition: all 0.3s ease;
}
.insight-card:hover {
  transform: translateY(-8px);
  border-color: var(--clr-primary);
  box-shadow: 0 20px 40px rgba(0,200,150,0.08);
}
.insight-meta {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--clr-light-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 16px;
}
.insight-meta .dot {
  width: 4px; height: 4px; border-radius: 50%; background: #cbd5e1;
}
.insight-card h3 {
  font-size: 1.25rem;
  color: var(--clr-light-text);
  margin-bottom: 12px;
  line-height: 1.4;
}
.insight-card p {
  font-size: 0.95rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
  margin-bottom: 24px;
  flex-grow: 1;
}
.insight-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.topic-pill {
  font-size: 0.7rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 999px;
  background: #f1f5f9;
  color: #475569;
}

.cta-card {
  background: linear-gradient(135deg, rgba(16,185,129,0.05), rgba(59,130,246,0.05));
  border: 1px solid rgba(16,185,129,0.1);
  border-radius: 32px;
  padding: 60px;
  text-align: center;
}
.cta-card h3 {
  font-size: 1.8rem;
  color: var(--clr-light-text);
  margin-bottom: 16px;
}
.cta-card p {
  color: var(--clr-light-muted);
  margin-bottom: 32px;
  max-width: 600px;
  margin-inline: auto;
}

.div-badge {
  display: inline-block;
  padding: 6px 16px;
  background: rgba(16,185,129,0.1);
  color: var(--clr-primary);
  border-radius: 100px;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 24px;
}

@media (max-width: 768px) {
  .insights-toolbar { flex-direction: column; }
  .grid-2 { grid-template-columns: 1fr; }
  .cta-card { padding: 40px 24px; }
}
</style>

<script>
  const searchInput = document.getElementById('insight-search');
  const topicFilter = document.getElementById('topic-filter');
  const cards = document.querySelectorAll('.insight-card');

  function filterInsights() {
    const query = searchInput.value.toLowerCase();
    const topic = topicFilter.value;

    cards.forEach(card => {
      const title = card.getAttribute('data-title') || '';
      const topics = card.getAttribute('data-topics') || '';
      const matchesSearch = title.includes(query) || topics.toLowerCase().includes(query);
      const matchesTopic = !topic || topics.includes(topic);

      if (matchesSearch && matchesTopic) {
        card.style.display = 'flex';
      } else {
        card.style.display = 'none';
      }
    });
  }

  searchInput?.addEventListener('input', filterInsights);
  topicFilter?.addEventListener('change', filterInsights);
</script>
