---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'About', url: '/about' },
  { name: 'Partners', url: '/partners' }
];

const partners = [
  { name: 'Microsoft', src: 'https://logo.clearbit.com/microsoft.com' },
  { name: 'AWS', src: 'https://logo.clearbit.com/aws.amazon.com' },
  { name: 'Google Cloud', src: 'https://logo.clearbit.com/cloud.google.com' },
  { name: 'Oracle', src: 'https://logo.clearbit.com/oracle.com' },
  { name: 'Snowflake', src: 'https://logo.clearbit.com/snowflake.com' },
  { name: 'Databricks', src: 'https://logo.clearbit.com/databricks.com' },
  { name: 'Informatica', src: 'https://logo.clearbit.com/informatica.com' },
  { name: 'Tableau', src: 'https://logo.clearbit.com/tableau.com' },
  { name: 'PowerBI', src: 'https://logo.clearbit.com/powerbi.microsoft.com' },
  { name: 'Cloudera', src: 'https://logo.clearbit.com/cloudera.com' }
];
---

<Layout 
  title="Partners | Intellica" 
  description="We collaborate with the world's leading technology providers to deliver robust, scalable data and AI solutions." 
  breadcrumbs={breadcrumbs}
  hideCta={true}
>
  
  <!-- HERO -->
  <section class="hero noise" id="partners-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">PARTNERS</div>
          <h1 class="hero__title">Global Technology <br /><span class="grad-text">Ecosystem</span></h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">Intellica establishes strategic alliances with the world's most powerful technology companies. Together, we provide our clients with vendor-agnostic, best-in-class solutions that accelerate digital transformation across every industry.</p>
          <div class="hero__actions">
            <a href="/contact" class="btn btn-primary btn-pill btn-lg">Become a Partner</a>
          </div>
        </div>
        
        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/partners_hero.png" alt="Intellica Partnership Ecosystem" class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

  <!-- PARTNERS GRID -->
  <section class="section section--white">
    <div class="container text-center anim-fade-up">
      <div class="section-label" style="margin-inline:auto;">Ecosystem</div>
      <h2 class="section-title" style="color:var(--clr-light-text);">Our Strategic <span class="grad-text">Partners</span></h2>
      <p class="section-sub">We collaborate with global technology leaders to deliver world-class solutions.</p>
      
      <div class="logo-grid anim-fade-up" style="margin-top: 60px;">
        {partners.map(partner => (
          <div class="logo-tile">
            <span class="partner-name">{partner.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

<!-- ===== CTA STRIP ===== -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Talk to an Expert</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>


</Layout>

<style>
/* HERO: STANDARDIZED */
.hero { 
  min-height: 750px; display: flex; align-items: center; position: relative; overflow: hidden;
  background: linear-gradient(135deg, #162a4d 0%, #020617 100%);
}
.hero__inner { display: flex; align-items: center; justify-content: center; position: relative; width: 100%; height: 100%; }
.hero__content-wrap { display: grid; grid-template-columns: 1.1fr 0.9fr; align-items: center; gap: 40px; width: 100%; }
.hero__content { display: flex; flex-direction: column; align-items: flex-start; padding-block: 60px; }
.hero__title { font-size: clamp(2.5rem, 5.5vw, 4.8rem); font-weight: 950; line-height: 1.05; color: #fff; margin-bottom: 24px; letter-spacing: -0.05em; }
.hero__accent { display: block; width: 80px; height: 4px; border-radius: 4px; background: var(--grad-brand); margin-bottom: 32px; }
.hero__desc { font-size: 1.25rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85); max-width: 600px; margin-bottom: 48px; }
.hero__actions { display: flex; gap: 16px; flex-wrap: wrap; }
.hero__visual { display: flex; justify-content: center; align-items: center; }
.hero__shape-new { 
  width: 100%; max-width: 650px; 
  animation: float 8s ease-in-out infinite; 
  filter: drop-shadow(0 20px 80px rgba(59, 130, 246, 0.3)); 
  border-radius: 48px;
}

@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

/* LOGO GRID */
.logo-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24px;
}
.logo-tile {
  background: #FFF;
  border: 1px solid #E2E8F0;
  border-radius: 20px;
  padding: 16px; /* Reduced padding for larger logos */
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
.partner-name {
  font-size: 1.15rem;
  font-weight: 800;
  color: #1E293B;
  text-align: center;
  letter-spacing: -0.01em;
  transition: color 0.3s ease;
}
.logo-tile:hover {
  border-color: var(--clr-primary);
  transform: translateY(-8px);
  background: #F8FAFC;
  box-shadow: 0 20px 40px rgba(0,0,0,0.06);
}
.logo-tile:hover .partner-name {
  color: var(--clr-primary);
}

@media (max-width: 1100px) {
  .hero { min-height: auto !important; padding-top: 85px !important; padding-bottom: 50px !important; height: auto; align-items: center; }
  .hero__inner { padding-top: 0; }
  .hero__content-wrap { grid-template-columns: 1fr; text-align: left; position: relative; display: flex; flex-direction: column; padding-top: 0px; }
  .hero__content { align-items: flex-start; padding-block: 0px; }
  .hero__visual { 
    position: absolute; top: 5px; right: 5px; width: 80px; height: 80px; 
    z-index: 10; display: flex; justify-content: flex-end; align-items: flex-start;
  }
  .hero__shape-new { width: 100%; height: auto; opacity: 1; border-radius: 16px; filter: drop-shadow(0 4px 12px rgba(59, 130, 246, 0.25)); }
  .hero__desc { font-size: 1.1rem; max-width: 100%; margin-bottom: 24px; line-height: 1.5; }
  .hero__title { font-size: 2.22rem; margin-bottom: 16px; padding-right: 80px; line-height: 1.15; }
  .hero__actions { margin-bottom: 24px; }
  .logo-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 640px) {
  .logo-grid { grid-template-columns: repeat(2, 1fr); }
}

/* CTA Banner */
.cta-banner { background: #FFF; border: 1px solid #E2E8F0; border-radius: 24px; padding: 40px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 20px 50px rgba(0,0,0,0.03); }
.cta-banner-content h3 { font-size: 1.5rem; font-weight: 900; color: #1E293B; margin-bottom: 8px; }
.cta-banner-content p { color: #64748B; }
.cta-banner-actions { display: flex; gap: 16px; }

@media (max-width: 768px) {
  .cta-banner { flex-direction: column; text-align: center; gap: 32px; }
  .cta-banner-actions { width: 100%; flex-direction: column; }
}
</style>
