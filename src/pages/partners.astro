---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const breadcrumbs = [
  { name: 'About', url: '/about' },
  { name: 'Partners', url: '/partners' }
];

const partners = [
  { name: 'Microsoft', src: '/assets/images/logos/Microsoft_Logo.svg.png' },
  { name: 'AWS', src: '/assets/images/logos/Amazon_Web_Services_Logo.svg.png' },
  { name: 'Google Cloud', src: '/assets/images/logos/Google_Cloud_Logo.svg.png' },
  { name: 'Oracle', src: '/assets/images/logos/Oracle_logo.svg.png' },
  { name: 'Snowflake', src: '/assets/images/logos/Snowflake_Logo.svg.png' },
  { name: 'Databricks', src: '/assets/images/logos/Databricks_Logo.svg.png' },
  { name: 'Cloudera', src: '/assets/images/logos/cloudera-logo.png' },
  { name: 'Informatica', src: '/assets/images/logos/Informatica_logo.svg.png' },
  { name: 'Tableau', src: '/assets/images/logos/Tableau_Logo.png' },
  { name: 'PowerBI', src: '/assets/images/logos/Microsoft_Power_BI_Logo.svg.png' }
];
---

<Layout title="Partners | Intellica" description="We collaborate with the world's leading technology providers to deliver robust, scalable data and AI solutions." breadcrumbs={breadcrumbs}>
  
  <Header />

  <!-- HERO -->
  <section class="hero noise" id="partners-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">PARTNERS</div>
          <h1 class="hero__title">Global Technology <br /><span class="grad-text">Ecosystem</span></h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">Intellica establishes strategic alliances with the world's most powerful technology companies. Together, we provide our clients with vendor-agnostic, best-in-class solutions that accelerate digital transformation across every industry.</p>
          <div class="hero__actions">
            <a href="/contact" class="btn btn-primary btn-pill btn-lg">Become a Partner</a>
            <a href="/solutions" class="btn btn-ghost btn-pill btn-lg">View Solutions</a>
          </div>
        </div>
        
        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/partners_hero.png" alt="Intellica Partnership Ecosystem" class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

  <!-- PARTNERS GRID -->
  <section class="section section--white">
    <div class="container text-center anim-fade-up">
      <div class="section-label" style="margin-inline:auto;">Ecosystem</div>
      <h2 class="section-title" style="color:var(--clr-light-text);">Our Strategic <span class="grad-text">Partners</span></h2>
      <p class="section-sub">We collaborate with global technology leaders to deliver world-class solutions.</p>
      
      <div class="logo-grid anim-fade-up" style="margin-top: 60px;">
        {partners.map(partner => (
          <div class="logo-tile">
            <img alt={partner.name} src={partner.src} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--light">
    <div class="container">
      <div class="cta-banner anim-fade-up">
        <div class="cta-banner-content">
          <h3>Build the Future with Us</h3>
          <p>Interested in joining our global technology network or exploring how our partnerships can benefit your organization?</p>
        </div>
        <div class="cta-banner-actions">
          <a href="/contact" class="btn btn-primary btn-pill">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />

</Layout>

<style>
/* HERO: STANDARDIZED */
.hero { 
  min-height: 750px; display: flex; align-items: center; position: relative; overflow: hidden;
  background: linear-gradient(135deg, #162a4d 0%, #020617 100%);
}
.hero__inner { display: flex; align-items: center; justify-content: center; position: relative; width: 100%; height: 100%; }
.hero__content-wrap { display: grid; grid-template-columns: 1.1fr 0.9fr; align-items: center; gap: 40px; width: 100%; }
.hero__content { display: flex; flex-direction: column; align-items: flex-start; padding-block: 60px; }
.hero__title { font-size: clamp(2.5rem, 5.5vw, 4.8rem); font-weight: 950; line-height: 1.05; color: #fff; margin-bottom: 24px; letter-spacing: -0.05em; }
.hero__accent { display: block; width: 80px; height: 4px; border-radius: 4px; background: var(--grad-brand); margin-bottom: 32px; }
.hero__desc { font-size: 1.25rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85); max-width: 600px; margin-bottom: 48px; }
.hero__actions { display: flex; gap: 16px; flex-wrap: wrap; }
.hero__visual { display: flex; justify-content: center; align-items: center; }
.hero__shape-new { 
  width: 100%; max-width: 650px; 
  animation: float 8s ease-in-out infinite; 
  filter: drop-shadow(0 20px 80px rgba(59, 130, 246, 0.3)); 
  border-radius: 48px;
}

@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

/* LOGO GRID */
.logo-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24px;
}
.logo-tile {
  background: #FFF;
  border: 1px solid #E2E8F0;
  border-radius: 20px;
  padding: 32px;
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
.logo-tile img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  transition: transform 0.4s ease;
}
.logo-tile:hover {
  border-color: var(--clr-primary);
  transform: translateY(-8px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.06);
}
.logo-tile:hover img {
  transform: scale(1.1);
}

@media (max-width: 1100px) {
  .hero__content-wrap { grid-template-columns: 1fr; text-align: center; }
  .hero__content { align-items: center; }
  .hero__desc { margin-inline: auto; }
  .hero__actions { justify-content: center; }
  .hero__visual { display: none; }
  .logo-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 640px) {
  .logo-grid { grid-template-columns: repeat(2, 1fr); }
}

/* CTA Banner */
.cta-banner { background: #FFF; border: 1px solid #E2E8F0; border-radius: 24px; padding: 40px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 20px 50px rgba(0,0,0,0.03); }
.cta-banner-content h3 { font-size: 1.5rem; font-weight: 900; color: #1E293B; margin-bottom: 8px; }
.cta-banner-content p { color: #64748B; }
.cta-banner-actions { display: flex; gap: 16px; }

@media (max-width: 768px) {
  .cta-banner { flex-direction: column; text-align: center; gap: 32px; }
  .cta-banner-actions { width: 100%; flex-direction: column; }
}
</style>
