---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'About', url: '/about' },
  { name: 'Partners', url: '/partners' }
];

const partners = [
  { name: 'Microsoft', src: 'https://logo.clearbit.com/microsoft.com' },
  { name: 'AWS', src: 'https://logo.clearbit.com/aws.amazon.com' },
  { name: 'Google Cloud', src: 'https://logo.clearbit.com/cloud.google.com' },
  { name: 'Oracle', src: 'https://logo.clearbit.com/oracle.com' },
  { name: 'Snowflake', src: 'https://logo.clearbit.com/snowflake.com' },
  { name: 'Databricks', src: 'https://logo.clearbit.com/databricks.com' },
  { name: 'Informatica', src: 'https://logo.clearbit.com/informatica.com' },
  { name: 'Tableau', src: 'https://logo.clearbit.com/tableau.com' },
  { name: 'PowerBI', src: 'https://logo.clearbit.com/powerbi.microsoft.com' },
  { name: 'Cloudera', src: 'https://logo.clearbit.com/cloudera.com' }
];
---

<Layout 
  title="Partners | Intellica" 
  description="We collaborate with the world's leading technology providers to deliver robust, scalable data and AI solutions." 
  breadcrumbs={breadcrumbs}
  hideCta={true}
>
  
  <!-- HERO -->
  <section class="hero noise" id="partners-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">PARTNERS</div>
          <h1 class="hero__title">Global Technology <br /><span class="grad-text">Ecosystem</span></h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">Intellica establishes strategic alliances with the world's most powerful technology companies. Together, we provide our clients with vendor-agnostic, best-in-class solutions that accelerate digital transformation across every industry.</p>
          <div class="hero__actions">
            <a href="/contact" class="btn btn-primary btn-pill btn-lg">Become a Partner</a>
          </div>
        </div>
        
        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/partners_hero.png" alt="Intellica Partnership Ecosystem" class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

  <!-- PARTNERS GRID -->
  <section class="section section--white">
    <div class="container text-center anim-fade-up">
      <div class="section-label" style="margin-inline:auto;">Ecosystem</div>
      <h2 class="section-title" style="color:var(--clr-light-text);">Our Strategic <span class="grad-text">Partners</span></h2>
      <p class="section-sub">We collaborate with global technology leaders to deliver world-class solutions.</p>
      
      <div class="pcard-grid">
        {partners.map(partner => (
          <div class="pcard">
            <div class="pcard__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="24" height="24">
                <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
              </svg>
            </div>
            <span class="pcard__name">{partner.name}</span>
            <span class="pcard__tag">Technology Partner</span>
          </div>
        ))}
      </div>
    </div>
  </section>

<!-- ===== CTA STRIP ===== -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Talk to an Expert</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>


</Layout>

<style>
/* HERO: STANDARDIZED */
.hero-disabled { 
  min-height: 750px; display: flex; align-items: center; position: relative; overflow: hidden;
  background: linear-gradient(135deg, #162a4d 0%, #020617 100%);
}
.hero-disabled__inner { display: flex; align-items: center; justify-content: center; position: relative; width: 100%; height: 100%; }
.hero-disabled__content-wrap { display: grid; grid-template-columns: 1.1fr 0.9fr; align-items: center; gap: 40px; width: 100%; }
.hero-disabled__content { display: flex; flex-direction: column; align-items: flex-start; padding-block: 60px; }
.hero-disabled__title { font-size: clamp(2.5rem, 5.5vw, 4.8rem); font-weight: 950; line-height: 1.05; color: #fff; margin-bottom: 24px; letter-spacing: -0.05em; }
.hero-disabled__accent { display: block; width: 80px; height: 4px; border-radius: 4px; background: var(--grad-brand); margin-bottom: 32px; }
.hero-disabled__desc { font-size: 1.25rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85); max-width: 600px; margin-bottom: 48px; }
.hero-disabled__actions { display: flex; gap: 16px; flex-wrap: wrap; }
.hero-disabled__visual { display: flex; justify-content: center; align-items: center; }
.hero-disabled__shape-new { 
  width: 100%; max-width: 650px; 
  animation: float 8s ease-in-out infinite; 
  filter: drop-shadow(0 20px 80px rgba(59, 130, 246, 0.3)); 
  border-radius: 48px;
}

@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

/* PARTNER CARDS */
.pcard-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20px;
  margin-top: 60px;
}
.pcard {
  background: #FFFFFF;
  border: 1px solid #E2E8F0;
  border-radius: 24px;
  padding: 32px 20px 28px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10px;
  transition: all 0.3s ease;
  box-shadow: 0 4px 16px rgba(15,23,42,0.03);
}
.pcard:hover {
  transform: translateY(-6px);
  border-color: rgba(0,200,150,0.35);
  box-shadow: 0 20px 40px rgba(0,200,150,0.08);
}
.pcard__icon {
  width: 52px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(0,200,150,0.09), rgba(0,159,227,0.06));
  border: 1px solid rgba(0,200,150,0.2);
  border-radius: 14px;
  color: #00C896;
  margin-bottom: 6px;
  transition: all 0.3s ease;
}
.pcard:hover .pcard__icon {
  background: linear-gradient(135deg, rgba(0,200,150,0.16), rgba(0,159,227,0.1));
  border-color: rgba(0,200,150,0.4);
}
.pcard__name {
  font-size: 1rem;
  font-weight: 800;
  color: #0F172A;
  letter-spacing: -0.01em;
  line-height: 1.2;
}
.pcard__tag {
  font-size: 0.73rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: #94A3B8;
}
@media (max-width: 1100px) {
  .pcard-grid { grid-template-columns: repeat(3, 1fr) !important; }
}
@media (max-width: 640px) {
  .pcard-grid { grid-template-columns: repeat(2, 1fr) !important; }
}

@media (max-width: 1100px) {
  .hero-disabled { min-height: auto !important; padding-top: 5px !important; padding-bottom: 25px !important; height: auto; align-items: center; }
  .hero-disabled__inner { padding-top: 0; }
  .hero-disabled__content-wrap { grid-template-columns: 1fr; text-align: left; position: relative; display: flex; flex-direction: column; padding-top: 0px; }
  .hero-disabled__content { align-items: flex-start; padding-block: 0px; }
  .hero-disabled__visual { 
    position: absolute; top: 5px; right: 5px; width: 80px; height: 80px; 
    z-index: 10; display: flex; justify-content: flex-end; align-items: flex-start;
  }
  .hero-disabled__shape-new { width: 100%; height: auto; opacity: 1; border-radius: 16px; filter: drop-shadow(0 4px 12px rgba(59, 130, 246, 0.25)); }
  .hero-disabled__desc { font-size: 1.1rem; max-width: 100%; margin-bottom: 24px; line-height: 1.5; }
  .hero-disabled__title { font-size: 2.22rem; margin-bottom: 16px; padding-right: 80px; line-height: 1.15; }
  .hero-disabled__actions { margin-bottom: 24px; }
  .partner-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 640px) {
  .partner-grid { grid-template-columns: repeat(2, 1fr); }
}

/* CTA Banner */
.cta-banner { background: #FFF; border: 1px solid #E2E8F0; border-radius: 24px; padding: 40px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 20px 50px rgba(0,0,0,0.03); }
.cta-banner-content h3 { font-size: 1.5rem; font-weight: 900; color: #1E293B; margin-bottom: 8px; }
.cta-banner-content p { color: #64748B; }
.cta-banner-actions { display: flex; gap: 16px; }

@media (max-width: 768px) {
  .cta-banner { flex-direction: column; text-align: center; gap: 32px; }
  .cta-banner-actions { width: 100%; flex-direction: column; }
}
</style>
