---
import Layout from '../layouts/Layout.astro';

const siteUrl = "https://intellica-tech.github.io";
const breadcrumbs = [{ name: "About", url: `${siteUrl}/about` }];

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Intellica",
  "description": "Learn about Intellica — a Data & AI company founded in 2006, active in 20+ countries with 450+ Data & AI professionals.",
  "url": `${siteUrl}/about`,
  "mainEntity": { "@id": `${siteUrl}/#organization` }
};
---

<Layout title="About | Intellica" description="Learn about Intellica — a Data & AI company founded in 2006, active in 20+ countries with 450+ Data & AI professionals." breadcrumbs={breadcrumbs} hideCta={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />

  <!-- Page Hero -->
  <section class="hero noise" id="about-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">Data & AI · Trusted Since 2006</div>
          <h1 class="hero__title">About <span class="grad-text">Intellica</span></h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">A Data & AI company founded in 2006 — helping enterprises turn complex data into a strategic advantage, at scale.</p>
          <div class="hero__actions">
            <a href="/contact" class="btn btn-primary btn-pill btn-lg">Get in Touch</a>
          </div>
        </div>
        
        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica Logo" class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>


  <!-- Who We Are -->
  <section class="section section--white" id="team">
    <div class="container">
      <div class="about-intro anim-fade-up">
        <div class="about-intro__content">
          <div class="section-label">Global Presence</div>
          <h2 style="color:var(--clr-light-text);margin-bottom:24px;">Empowering Enterprises Through <span class="grad-text">Digital Intelligence</span></h2>
          <p style="color:var(--clr-light-muted);font-size:1.15rem;line-height:1.8;margin-bottom:24px;">
            Intellica is a global Data & AI company with nearly two decades of experience. Since 2006, we've helped enterprises transform raw data into a powerful strategic asset — and we've been at the forefront of how that work has evolved.
          </p>
          <p style="color:var(--clr-light-muted);font-size:1.05rem;line-height:1.8;margin-bottom:32px;">
            Our team of 100+ specialists — solution architects, data engineers, and AI practitioners — delivers end-to-end solutions across 20+ countries, from data platform engineering to production-grade agentic AI systems.
          </p>
          
            <div class="about-stats">
              <div class="about-stat">
                <span class="about-stat__number grad-text">20+</span>
                <span class="about-stat__label">Countries where Intellica has<br/> delivered Data & AI projects.</span>
              </div>
              <div class="about-stat">
                <span class="about-stat__number grad-text">80+</span>
                <span class="about-stat__label">Enterprise Data & AI projects delivered<br/> across industries worldwide.</span>
              </div>
              <div class="about-stat">
                <span class="about-stat__number grad-text">100+</span>
                <span class="about-stat__label">Data & AI professionals — architects,<br/> engineers, and AI specialists.</span>
              </div>
              <div class="about-stat">
                <span class="about-stat__number grad-text">30+</span>
                <span class="about-stat__label">Enterprise data platforms built — modern<br/> DWH, lakehouse, and cloud architectures.</span>
              </div>
            </div>
        </div>
        <div class="about-intro__visual anim-fade-up">
          <div class="img-frame">
            <img src="/assets/img/global_data_ai_abstract_presence.png" alt="Global Data Intelligence" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities & Expertise (The Refactored "Following HTML" pattern) -->
  <section class="section section--light" id="capabilities">
    <div class="container">
      <div class="grid-2 anim-fade-up" style="gap: 60px; align-items: center; margin-bottom: 80px;">
        <div>
          <div class="section-label">Expertise</div>
          <h2 style="color:var(--clr-light-text); margin-bottom: 24px;">Core <span class="grad-text">Capabilities</span></h2>
          <p style="color:var(--clr-light-muted); font-size: 1.1rem; line-height: 1.7;">
            We bridge the gap between complex data infrastructure and real business outcomes. Our work is results-driven: absolute data consistency, and AI that actually works in production.
          </p>
        </div>
        <div class="grid-2" style="gap: 20px;">
          <div class="cap-card-modern" style="background: #fff; padding: 24px;">
            <h4 style="margin-bottom: 12px; color: var(--clr-primary);">Data Platform</h4>
             <p style="font-size: 0.9rem; color: var(--clr-light-muted);">Lakehouse modernisation, DWH design, and high-performance data integration.</p>
          </div>
          <div class="cap-card-modern" style="background: #fff; padding: 24px;">
            <h4 style="margin-bottom: 12px; color: var(--clr-primary);">AI & agents</h4>
             <p style="font-size: 0.9rem; color: var(--clr-light-muted);">Production-grade LLMs, RAG applications, and multi-agent autonomous systems.</p>
          </div>
          <div class="cap-card-modern" style="background: #fff; padding: 24px;">
            <h4 style="margin-bottom: 12px; color: var(--clr-primary);">Governance</h4>
            <p style="font-size: 0.9rem; color: var(--clr-light-muted);">Data consistency monitoring, quality gates, and automated reconciliation.</p>
          </div>
          <div class="cap-card-modern" style="background: #fff; padding: 24px;">
            <h4 style="margin-bottom: 12px; color: var(--clr-primary);">Scale</h4>
            <p style="font-size: 0.9rem; color: var(--clr-light-muted);">Supporting massive telemetry and high-concurrency analytical workloads.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- How We Work -->
  <section class="section section--white">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <h2 style="color:var(--clr-light-text);">
          How We <span class="grad-text">Work</span>
        </h2>
      </div>

      <div class="grid-3 anim-fade-up" style="gap: 24px;">
        <div class="cap-card-modern" style="background: #f8fafc;">
          <h3>Understand</h3>
          <p>
            We start by understanding your business, data landscape, and key challenges.
          </p>
        </div>

        <div class="cap-card-modern" style="background: #f8fafc;">
          <h3>Design</h3>
          <p>
            We design scalable data architectures and AI solutions aligned with your goals.
          </p>
        </div>

        <div class="cap-card-modern" style="background: #f8fafc;">
          <h3>Deliver</h3>
          <p>
            We implement, optimize, and continuously improve solutions in production.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Our Values</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">What <span class="grad-text">Drives</span> Us</h2>
        <p class="section-sub">The principles that guide how we work — and shape who we are.</p>
      </div>
      <div class="grid-4 anim-fade-up">
        <div class="value-card card-light">
          <div class="value-card__icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 40px; height: auto; filter: drop-shadow(0 4px 10px rgba(0,196,204,0.3));" loading="lazy" />
          </div>
          <h3 style="color:var(--clr-light-text);font-size:1.1rem;margin-bottom:8px;">Measurable Impact</h3>
           <p style="color:var(--clr-light-muted);font-size:0.88rem;">We measure success by real business outcomes — not deliverables or effort.</p>
        </div>
        <div class="value-card card-light">
          <div class="value-card__icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 40px; height: auto; filter: drop-shadow(0 4px 10px rgba(0,196,204,0.3));" loading="lazy" />
          </div>
          <h3 style="color:var(--clr-light-text);font-size:1.1rem;margin-bottom:8px;">Technical Excellence</h3>
           <p style="color:var(--clr-light-muted);font-size:0.88rem;">Deep technical knowledge combined with industry experience — built to solve real problems in production.</p>
        </div>
        <div class="value-card card-light">
          <div class="value-card__icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 40px; height: auto; filter: drop-shadow(0 4px 10px rgba(0,196,204,0.3));" loading="lazy" />
          </div>
          <h3 style="color:var(--clr-light-text);font-size:1.1rem;margin-bottom:8px;">Long-term Partnership</h3>
           <p style="color:var(--clr-light-muted);font-size:0.88rem;">We build lasting relationships. Our commitment to clients extends well beyond go-live.</p>
        </div>
        <div class="value-card card-light">
          <div class="value-card__icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 40px; height: auto; filter: drop-shadow(0 4px 10px rgba(0,196,204,0.3));" loading="lazy" />
          </div>
          <h3 style="color:var(--clr-light-text);font-size:1.1rem;margin-bottom:8px;">Innovation Culture</h3>
           <p style="color:var(--clr-light-muted);font-size:0.88rem;">Continuous investment in R&D, proprietary products, and emerging technologies keeps us ahead of the curve.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Horizontal Grid (Strict 2 Rows) -->
  <section class="section section--dark history-section" id="tarihce">
    <div class="history-bg">
      <img src="/assets/img/history_background.png" alt="" aria-hidden="true" style="opacity: 0.2;" loading="lazy" />
    </div>
    <div class="container container--wide">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto; color: #00f0ff; border-color: rgba(0,240,255,0.3);">Our Journey</div>
        <h2 class="section-title">Company <span class="grad-text">History</span></h2>
        <p class="section-sub" style="color: rgba(255,255,255,0.6);">Nearly two decades of milestones — from a two-person founding to a global Data & AI firm.</p>
      </div>

      <div class="timeline-grid-v3 anim-fade-up">
        <!-- Row 1: 2006-2015 -->
        <div class="timeline-row">
          <div class="timeline-row-line"></div>
          <div class="timeline-row-items">
            <!-- 2006 -->
            <div class="timeline-node org">
              <div class="node-year">2006</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>Intellica Foundation</h3>
                <p>Dr. Kemal Unaltuna <br/> and Can Alhas</p>
              </div>
            </div>
            <!-- 2009 -->
            <div class="timeline-node prod">
              <div class="node-year">2009</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>EVAM</h3>
                <p>First Product <br/> Development</p>
              </div>
            </div>
            <!-- 2011 -->
            <div class="timeline-node intl">
              <div class="node-year">2011</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>Zagrebacka Bank</h3>
                <p>First major international project — Zagrebacka Bank, Croatia</p>
              </div>
            </div>
            <!-- 2012 -->
            <div class="timeline-node org">
              <div class="node-year">2012</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>Organizational</h3>
                <p>Major Re-structuring</p>
              </div>
            </div>
            <!-- 2014 -->
            <div class="timeline-node intl">
              <div class="node-year">2014</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>Zain Group</h3>
                <p>International expansion into telecoms — Zain Group projects</p>
              </div>
            </div>
            <!-- 2015-1 -->
            <div class="timeline-node org">
              <div class="node-year">2015</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>EVAM A.Ş.</h3>
                <p>Spin-off Company</p>
              </div>
            </div>
            <!-- 2015-2 -->
            <div class="timeline-node prod">
              <div class="node-year">2015</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>ITDM</h3>
                <p>Launch of Data Products</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Row 2: 2016-2025 -->
        <div class="timeline-row" style="margin-top: 80px;">
          <div class="timeline-row-line"></div>
          <div class="timeline-row-items">
            <!-- 2016 -->
            <div class="timeline-node org">
              <div class="node-year">2016</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>Merger with PiA</h3>
                <p>Merger with PiA, R&D centre established — 80 employees</p>
              </div>
            </div>
            <!-- 2019 -->
            <div class="timeline-node prod">
              <div class="node-year">2019</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>IFDM — ICC</h3>
                <p>Data products gaining market traction</p>
              </div>
            </div>
            <!-- 2020 -->
            <div class="timeline-node prod">
              <div class="node-year">2020</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>Retouch</h3>
                <p>Data management product launched</p>
              </div>
            </div>
            <!-- 2021 -->
            <div class="timeline-node intl">
              <div class="node-year">2021</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>UK Foundation</h3>
                <p>UK office established in Maidenhead</p>
              </div>
            </div>
            <!-- 2022 -->
            <div class="timeline-node prod">
              <div class="node-year">2022</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>Blue Octopus</h3>
                <p>Security data projects with Ministry of Interior</p>
              </div>
            </div>
            <!-- 2023 -->
            <div class="timeline-node org">
              <div class="node-year">2023</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>100+ Employee</h3>
                <p>Intellica reaches 100+ employees</p>
              </div>
            </div>
            <!-- 2025 -->
            <div class="timeline-node prod">
              <div class="node-year">2025</div>
              <div class="node-dot"></div>
              <div class="node-content">
                <h3>AI</h3>
                <p>AI team integrated into Intellica</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Legend (Dark Version) -->
      <div class="timeline-legend-v3 anim-fade-up">
        <div class="legend-item"><span class="dot org"></span> Organization</div>
        <div class="legend-item"><span class="dot intl"></span> International Expansions</div>
        <div class="legend-item"><span class="dot prod"></span> Products</div>
      </div>
    </div>
  </section>

  <!-- Clients Section -->
  <section class="section section--light" id="clients">
    <div class="container">
      <div class="grid-2 anim-fade-up" style="gap: 60px; align-items: center;">
        <div>
          <div class="section-label">Our Network</div>
          <h2 class="section-title" style="color:var(--clr-light-text);">Trusted by <span class="grad-text">Global Leaders</span></h2>
          <p class="section-sub" style="text-align: left; margin-inline: 0; max-width: 100%;">
            We work with 100+ enterprise organisations across banking, telecoms, and manufacturing — delivering measurable Data & AI outcomes.
          </p>
          <div style="margin-top: 32px;">
            <a href="/clients" class="btn btn-primary btn-pill">Explore Our Clients →</a>
          </div>
        </div>
        <div class="clients-preview-visual">
          <img src="/assets/img/global_network_premium.png" alt="Global Network" style="width: 100%; max-width: 520px; border-radius: 24px; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.15));" loading="lazy" />
        </div>
      </div>
    </div>
  </section>



<!-- ===== CTA STRIP ===== -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Get in Touch</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
/* HERO: STANDARDIZED (Shared with index/solutions) */
.hero-disabled { 
  min-height: 750px; 
  display: flex; 
  align-items: center; 
  position: relative; 
  overflow: hidden;
  background: linear-gradient(135deg, #162a4d 0%, #020617 100%);
}
.hero-disabled__inner { 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  position: relative; 
  width: 100%; 
}
.hero-disabled__content-wrap { 
  display: grid; 
  grid-template-columns: 1.2fr 0.8fr; 
  align-items: center; 
  gap: 40px; 
  width: 100%; 
}
.hero-disabled__content { 
  display: flex; 
  flex-direction: column; 
  align-items: flex-start; 
  padding-block: 60px; 
}
.hero-disabled__title { 
  font-size: clamp(2.5rem, 5vw, 4.5rem); 
  font-weight: 900; 
  line-height: 1.1; 
  color: #fff; 
  margin-bottom: 24px; 
}
.hero-disabled__accent { 
  display: block; 
  width: 80px; 
  height: 4px; 
  border-radius: 4px; 
  background: var(--grad-brand); 
  margin-bottom: 32px; 
}
.hero-disabled__desc { 
  font-size: 1.25rem; 
  line-height: 1.6; 
  color: rgba(255, 255, 255, 0.85); 
  max-width: 600px; 
  margin-bottom: 48px; 
}
.hero-disabled__actions { 
  display: flex; 
  gap: 16px; 
  flex-wrap: wrap; 
}
.hero-disabled__visual { 
  display: flex; 
  justify-content: center; 
  align-items: center; 
}
.hero-disabled__shape-new { 
  width: 100%; 
  max-width: 560px; 
  animation: float 8s ease-in-out infinite; 
  filter: drop-shadow(0 20px 80px rgba(0, 200, 150, 0.3)); 
}

@media (max-width: 1100px) {
  .hero-disabled { 
    min-height: auto !important; 
    padding-top: 5px !important;
    padding-bottom: 25px !important;
    height: auto;
  }
  .hero-disabled__content-wrap {
    grid-template-columns: 1fr;
    text-align: left;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .hero-disabled__content { align-items: flex-start; padding-block: 20px; }
  .hero-disabled__visual {
    position: absolute;
    top: 5px;
    right: 5px;
    width: 90px;
    height: 90px;
    justify-content: flex-end;
    align-items: flex-start;
    margin: 0;
    z-index: 10;
  }
  .hero-disabled__shape-new { 
    width: 100%; 
    height: auto;
    object-fit: contain;
    opacity: 1;
    filter: drop-shadow(0 4px 12px rgba(0, 200, 150, 0.25));
  }
  .hero-disabled__desc { font-size: 1.15rem; max-width: 100%; margin-bottom: 24px; height: auto; min-height: 0; }
  .hero-disabled__title { font-size: clamp(2.2rem, 8vw, 3.5rem); margin-bottom: 16px; }
}

@media (max-width: 768px) {
  .hero-disabled__actions { flex-direction: row; gap: 16px; flex-wrap: wrap; justify-content: flex-start; }
  .hero-disabled__actions .btn { width: auto; }
}

.about-intro {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 60px;
  align-items: center;
}
.about-intro__visual {
  display: flex;
  align-items: center;
  justify-content: center;
}
.about-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px 60px;
}
.about-stat {
  display: flex;
  flex-direction: column;
}
.about-stat__number {
  font-size: 2rem;
  font-weight: 900;
  line-height: 1;
}
.about-stat__label {
  font-size: 0.85rem;
  color: var(--clr-light-muted);
  font-weight: 600;
  margin-top: 10px;
  line-height: 1.4;
}
.img-frame {
  border-radius: 32px; 
  overflow: hidden; 
  box-shadow: 0 20px 60px rgba(0,0,0,0.1);
  width: 100%;
}
.img-frame img {
  width: 100%;
  height: auto;
  display: block;
}
.value-card {
  text-align: center;
  padding: 28px 24px;
}
.value-card__icon {
  font-size: 2rem;
  margin-bottom: 16px;
}
/* V3 Timeline Styles (Strict 2 Rows) */
.history-section {
  position: relative;
  overflow: hidden;
  background: #020810;
  padding: 100px 0;
}
.history-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  opacity: 0.25;
  pointer-events: none;
}
.history-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.timeline-grid-v3 {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 60px;
}

.timeline-row {
  position: relative;
  padding: 40px 0;
}

.timeline-row-line {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(0,240,255,0.4), var(--clr-primary), rgba(0,240,255,0.4), transparent);
  transform: translateY(-50%);
  z-index: 1;
}

.timeline-row-items {
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 2;
  padding: 0 40px;
}

.timeline-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140px;
  position: relative;
}

.node-year {
  font-size: 1.4rem;
  font-weight: 800;
  color: #00f0ff;
  margin-bottom: 20px;
  text-shadow: 0 0 10px rgba(0,240,255,0.3);
}

.node-dot {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #fff;
  border: 4px solid #fff;
  box-shadow: 0 0 15px rgba(255,255,255,0.6);
  z-index: 3;
}

.timeline-node.org .node-dot { background: #2563eb; border-color: #2563eb; box-shadow: 0 0 15px rgba(37,99,235,0.6); }
.timeline-node.intl .node-dot { background: #9333ea; border-color: #9333ea; box-shadow: 0 0 15px rgba(147,51,234,0.6); }
