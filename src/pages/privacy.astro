---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'Privacy Policy', url: '/privacy' }
];
---

<Layout
  title="Privacy Policy | Intellica"
  description="Learn how Intellica collects, uses, and protects personal data shared through this website."
  breadcrumbs={breadcrumbs}
  hideCta={true}
>
  <section class="section section--white">
    <div class="container--hero anim-fade-up legal-page">
      <div class="legal-header">
        <div class="section-label">PRIVACY</div>
        <h1 class="section-title" style="color:var(--clr-light-text);">Privacy <span class="grad-text">Policy</span></h1>
        <p class="section-sub">
          At Intellica, we respect your privacy and are committed to protecting the personal data you share with us through this website.
        </p>
      </div>

      <div class="legal-content">
        <div class="legal-block">
          <h2>Information We Collect</h2>
          <p>
            We may collect personal information such as your name, email address, company name, and any details you submit through our contact forms or other communication channels on this website.
          </p>
        </div>

        <div class="legal-block">
          <h2>How We Use Information</h2>
          <p>
            We use this information to respond to your inquiries, communicate with you, provide relevant information about our services, and improve our website and offerings.
          </p>
        </div>

        <div class="legal-block">
          <h2>Data Sharing</h2>
          <p>
            Intellica does not sell your personal data. We do not share your information with third parties except where necessary to operate our website, deliver services, or comply with legal obligations.
          </p>
        </div>

        <div class="legal-block">
          <h2>Data Protection</h2>
          <p>
            We take reasonable technical and organizational measures to protect personal data against unauthorized access, loss, misuse, or disclosure.
          </p>
        </div>

        <div class="legal-block">
          <h2>Your Rights</h2>
          <p>
            Depending on applicable laws, you may have the right to request access to, correction of, or deletion of your personal data. You may also contact us regarding any questions about how your information is handled.
          </p>
        </div>

        <div class="legal-block">
          <h2>Contact</h2>
          <p>
            If you have any questions about this Privacy Policy or your personal data, please contact Intellica through our contact page.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .legal-page {
    max-width: 900px;
    margin: 0 auto;
    padding-top: 80px;
    padding-bottom: 80px;
  }

  .legal-header {
    margin-bottom: 48px;
  }

  .legal-content {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .legal-block {
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
  }

  .legal-block h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--clr-light-text);
  }

  .legal-block p {
    color: var(--clr-light-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
  }
</style>
