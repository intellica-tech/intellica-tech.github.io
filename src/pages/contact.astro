---
import Layout from '../layouts/Layout.astro';

const siteUrl = "https://intellica-tech.github.io";
const breadcrumbs = [{ name: "Contact", url: `${siteUrl}/contact` }];

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Intellica",
  "description": "Get in touch with Intellica — schedule a demo, request a consultation, or reach our team.",
  "url": `${siteUrl}/contact`,
  "mainEntity": {
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`
  }
};
---

<Layout title="Contact | Intellica" description="Get in touch with Intellica — schedule a demo, request a consultation, or reach our team." breadcrumbs={breadcrumbs} hideCta={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <!-- Page Hero -->
  <section class="hero noise" id="contact-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">Contact Us</div>
          <h1 class="hero__title">Get in <span class="grad-text">Touch</span></h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">Schedule a demo, request a consultation, or simply reach out to our team.</p>
        </div>
        
        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/contact_hero_consultation.png" alt="Contact Intellica Visual" class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

<style>
#contact-hero { min-height: 650px !important; }
@media (max-width: 1100px) {
  #contact-hero { min-height: auto !important; padding-bottom: 60px; }
}
</style>

  <!-- Contact Section -->
  <section class="section section--white">
    <div class="container">
      <div class="contact-grid anim-fade-up">
        <!-- Form -->
        <div class="contact-form-wrap">
          <h2 style="color:var(--clr-light-text);font-size:1.8rem;margin-bottom:8px;">Send Us a Message</h2>
          <p style="color:var(--clr-light-muted);margin-bottom:36px;">Fill out the form and our team will get back to you</p>
          <form id="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="firstName">First Name</label>
                <input type="text" id="firstName" name="firstName" class="form-input" placeholder="John" required />
              </div>
              <div class="form-group">
                <label for="lastName">Last Name</label>
                <input type="text" id="lastName" name="lastName" class="form-input" placeholder="Doe" required />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="email">Business Email</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="john@company.com" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="tel" id="phone" name="phone" class="form-input" placeholder="+90 5xx xxx xxxx" />
              </div>
            </div>
            <div class="form-group">
              <label for="company">Company</label>
              <input type="text" id="company" name="company" class="form-input" placeholder="Company Name" />
            </div>
            <div class="form-group">
              <label for="interest">Area of Interest</label>
              <select id="interest" name="interest" class="form-input">
                <option value="">Select an option</option>
                <option value="data-platform">Modern Data Platforms</option>
                <option value="analytics">BI & Analytics</option>
                <option value="ai">AI & Machine Learning</option>
                <option value="governance">Data Governance</option>
                <option value="products">Product Demo</option>
                <option value="consulting">Consulting & Advisory</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" class="form-input" placeholder="Tell us about your project or requirements..." rows="5"></textarea>
            </div>
            <button type="submit" id="submit-btn" class="btn btn-primary btn-pill">
              Send Message →
            </button>
          </form>

          <div id="success-message" style="display: none; text-align: center; padding: 40px 20px; background: rgba(0, 200, 150, 0.05); border: 1px solid rgba(0, 200, 150, 0.2); border-radius: 24px; margin-top: 20px;">
            <div style="width: 64px; height: 64px; background: var(--grad-brand); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; color: #fff; font-size: 24px;">✓</div>
            <h3 style="color: var(--clr-light-text); font-size: 1.5rem; margin-bottom: 12px;">Message Sent Successfully!</h3>
            <p style="color: var(--clr-light-muted); line-height: 1.6;">Thank you for reaching out. Our team has received your message and will get back to you shortly.</p>
            <button onclick="window.location.reload()" class="btn btn-ghost btn-pill btn-sm" style="margin-top: 24px;">Send Another Message</button>
          </div>
        </div>

        <!-- Contact Info -->
        <div class="contact-info">
          <div class="contact-info-card card-light anim-fade-up">
            <div class="contact-info-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>

            <p style="color:var(--clr-light-muted);font-size:0.9rem;line-height:1.7;">
              <a href="https://www.google.com/maps/search/?api=1&query=Intellica+Atatürk+Mah.+Turgut+Özal+Blv.+Gardenya+1+Plaza+Ataşehir+İstanbul" target="_blank" rel="noopener" style="color:var(--clr-light-muted); transition: color 0.3s ease;" class="hover-primary">
                Atatürk Mah. Turgut Özal Blv.<br/>
                Gardenya 1 Plaza · Floor 1<br/>
                Ataşehir, Istanbul · Turkey
              </a>
            </p>
          </div>
          <div class="contact-info-card card-light anim-fade-up">
            <div class="contact-info-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>

            <p style="color:var(--clr-light-muted);font-size:0.9rem;">
              <a href="mailto:info@intellica.net" style="color:var(--clr-primary);">info@intellica.net</a>
            </p>
          </div>
          <div class="contact-info-card card-light anim-fade-up">
            <div class="contact-info-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>

            <p style="color:var(--clr-light-muted);font-size:0.9rem;">
              <a href="tel:+902166884546" style="color:var(--clr-primary);">+90 216 688 45 46</a>
            </p>
          </div>
          <div class="contact-info-card card-light anim-fade-up">
            <div class="contact-info-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </div>

            <p style="color:var(--clr-light-muted);font-size:0.9rem;">
              <a href="https://www.linkedin.com/company/intellica" target="_blank" rel="noopener" style="color:var(--clr-primary);">
                linkedin.com/company/intellica
              </a>
            </p>
          </div>

          <div class="contact-why anim-fade-up">
            <h3 style="color:var(--clr-light-text);font-size:1.1rem;margin-bottom:16px;">Why Join Intellica?</h3>
            <ul class="contact-why__list">
              <li>20+ Countries</li>
              <li>80+ Enterprise Data & AI Projects Delivered</li>
              <li>100+ Data & AI Professionals</li>
              <li>30+ Enterprise Data Platforms Implemented</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA STRIP ===== -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Get in Touch</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
.contact-grid {
  display: grid;
  grid-template-columns: 1.3fr 0.7fr;
  gap: 60px;
  align-items: start;
}
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.contact-info {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.contact-info-card {
  padding: 24px;
  display: flex;
  flex-direction: column;
}
.contact-info-card__icon {
  width: 52px;
  height: 52px;
  background: rgba(0, 200, 150, 0.08);
  border: 1px solid rgba(0, 200, 150, 0.2);
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  color: var(--clr-primary);
  transition: all 0.3s ease;
}
.contact-info-card:hover .contact-info-card__icon {
  background: var(--clr-primary);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 8px 16px rgba(0, 200, 150, 0.2);
}
.contact-info-card__icon svg {
  width: 24px;
  height: 24px;
}
.contact-why {
  padding: 28px;
  background: linear-gradient(135deg, rgba(0,200,150,0.06), rgba(0,159,227,0.04));
  border: 1px solid rgba(0,200,150,0.15);
  border-radius: var(--radius-md);
  margin-top: 8px;
}
.contact-why__list {
  list-style: none; padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: 10px;
}
.contact-why__list li {
  display: flex; align-items: center; gap: 10px;
  font-size: 0.88rem; color: var(--clr-light-muted);
}
.contact-why__list li::before {
  content: '✓';
  width: 20px; height: 20px;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.7rem;
  font-weight: 800;
  color: #fff;
  background: var(--grad-brand);
  border-radius: 50%;
  flex-shrink: 0;
}

.hover-primary:hover {
  color: var(--clr-primary) !important;
  text-decoration: underline;
}

select.form-input {
  appearance: none;
  background-image: url("data:image/svg+xml,%3Csvg width='12' height='12' viewBox='0 0 12 12' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M2 4l4 4 4-4' stroke='%236B7280' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 16px center;
  padding-right: 40px;
}
@media (max-width: 900px) {
  .contact-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .form-row { grid-template-columns: 1fr; }
}
</style>

<script is:inline>
  const contactForm = document.getElementById('contact-form');
  const successMessage = document.getElementById('success-message');
  const submitBtn = document.getElementById('submit-btn');

  if (contactForm) {
    contactForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Change button state
      const originalBtnText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner" style="display:inline-block; width:16px; height:16px; border:2px solid rgba(255,255,255,0.3); border-top-color:#fff; border-radius:50%; animation: spin 0.8s linear infinite; margin-right:8px;"></span>Sending...';

      // Simulate a small delay for better UX
      await new Promise(resolve => setTimeout(resolve, 1200));

      // In a real scenario, you would send data to your API here
      // const formData = new FormData(contactForm);
      // await fetch('/api/contact', { method: 'POST', body: formData });

      // Hide form and show success message
      contactForm.style.display = 'none';
      successMessage.style.display = 'block';
      
      // Scroll to success message
      successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>

<style is:inline>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
