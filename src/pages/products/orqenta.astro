---
import Layout from '../../layouts/Layout.astro';

const siteUrl = "https://intellica-tech.github.io";
const breadcrumbs = [
  { name: "Products", url: `${siteUrl}/products` },
  { name: "Orqenta", url: `${siteUrl}/products/orqenta` }
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Orqenta",
  "description": "Bank-grade workflow orchestration and automation engine for mission-critical enterprise processes.",
  "applicationCategory": "BusinessApplication, WorkflowEngine",
  "operatingSystem": "Platform independent",
  "author": { "@id": `${siteUrl}/#organization` },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD"
  }
};
---

<Layout title="Orqenta — Workflow Orchestration and Automation | Intellica" description="Orqenta: Bank-grade workflow orchestration and automation engine. Safe and auditable execution for mission-critical enterprise processes." breadcrumbs={breadcrumbs} hideCta={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label anim-fade-up">Data Platform & Governance</div>
      <h1 class="anim-fade-up">Orqenta — Bank-Grade <span class="grad-text">Orchestration</span></h1>
      <p class="anim-fade-up">Run critical workflows with absolute confidence. Orqenta is a next-generation orchestration engine that manages enterprise data and processes in a deterministic, auditable, and crash-safe manner.</p>
      <div class="hero-actions anim-fade-up" style="margin-top: 32px;">
        <a href="/contact" class="btn btn-primary btn-pill btn-lg">Talk to an Expert</a>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2" style="gap: 48px; align-items: start;">
        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px;">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">What does it <span class="grad-text">solve?</span></h2>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Problem</p>
            <p style="color: var(--clr-light-muted);">Critical workflows produce risks like dual-execution, missing steps, and data loss in distributed systems. In regulated sectors, these flaws lead to severe operational and audit risks.</p>
          </div>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Approach</p>
            <p style="color: var(--clr-light-muted);">Orqenta uses deterministic DAG logic and a central authority model. By persisting every state transition, it ensures predictable and safe execution across the enterprise.</p>
          </div>
          <div>
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Business Value</p>
            <p style="color: var(--clr-light-muted);">Zero-loss crash recovery, secure retry mechanisms, and a full audit trail. Maximum reliability and compliance for high-stakes mission-critical operations.</p>
          </div>
        </div>

        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px; background: #f8fafc;">
          <h3 style="color: var(--clr-light-text); margin-bottom: 24px;">When is it <span class="grad-text">preferred?</span></h3>
          <ul class="check-list">
            <li>When precision and "exactly-once" execution are non-negotiable</li>
            <li>In industries requiring strict audit trails (Telecom, Banking, Energy)</li>
            <li>To eliminate split-brain risks and duplicate execution in distributed systems</li>
            <li>When processes must recover instantly and correctly after a system crash</li>
            <li>For managing complex dependencies with professional operational control</li>
          </ul>
          <p style="font-size: 0.85rem; color: var(--clr-light-muted); margin-top: 24px; font-style: italic;">Note: Orqenta is designed specifically for regulated and high-compliance environments.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities Section -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Capabilities</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">Core <span class="grad-text">Capabilities</span></h2>
      </div>

      <div class="grid-3 anim-fade-up" style="gap: 24px;">
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Deterministic execution</h3>
          <p>Managed dependencies and synchronization points for predictable flow management across distributed nodes.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>3-Layer Idempotency</h3>
          <p>Prevention of duplicate effects using Event ID, Idempotency Key, and Execution ID for absolute correctness.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Crash-Safe Recovery</h3>
          <p>Database-driven state machine ensures full recovery without loss after any server or process interruption.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Operational Control</h3>
          <p>Professional management including pause, resume, cancel, node retry, and real-time agent rerouting.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Full Observability</h3>
          <p>Centralized logging, trace ID tracking, and dedicated execution incident management for rapid troubleshooting.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Bank-Grade Security</h3>
          <p>Built with RBAC, mTLS, HMAC authentication, SSRF protection, and automatic secret masking in logs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section (Reliability & Control) -->
  <section class="section section--dark noise">
    <div class="container">
      <div class="grid-2" style="gap: 60px; align-items: center;">
        <div class="anim-fade-up">
          <h2 style="color: #fff; margin-bottom: 24px;">Functional <span class="grad-text">Design</span> & Control</h2>
          <p style="color: rgba(255,255,255,0.7); margin-bottom: 32px; font-size: 1.1rem; line-height: 1.7;">
            High-level overview of Orqenta's reliability model and core execution capabilities, designed for long-running workloads in banking and telecom.
          </p>
          <div class="cap-card-modern" style="padding: 24px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
            <p style="font-weight: 700; color: #fff; margin-bottom: 8px;">Deterministic Workflow Design</p>
            <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem;">Visual DAG editor for complex cross-system synchronization and dependency management.</p>
          </div>
        </div>
        <div class="anim-fade-up">
          <div class="img-frame" style="background: rgba(255,255,255,0.03); padding: 12px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1);">
            <img src="/assets/images/Orqenta.png" alt="Orqenta Architecture & Reliability Model" style="width: 100%; border-radius: 12px;" />
            <p style="text-align: center; font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 12px; font-style: italic;">
              Orqenta Interface: Visualizing DAG workflow editing and operational oversight.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Strategic Use Cases (Updated for better alternating contrast) -->
  <section class="section section--light" id="use-cases">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Solutions</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">Strategic <span class="grad-text">Use Cases</span></h2>
        <p class="section-sub">Orqenta manages critical dependencies and SLA targets to ensure predictable operational outcomes.</p>
      </div>

      <div class="tabs-container anim-fade-up">
        <div class="tabs-nav">
          <button class="tab-btn active" data-tab="finance">Finance & Reporting</button>
          <button class="tab-btn" data-tab="telecom">Telecom & Energy</button>
          <button class="tab-btn" data-tab="operations">Operations Management</button>
        </div>

        <!-- Finance & Reporting Tab -->
        <div id="finance" class="tab-content active">
          <div class="grid-2" style="gap: 32px;">
            <div class="use-case-card-alt">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Finance</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">SLA & Batch</span>
              </div>
              <h4>SLA Management in End-of-Day Batch Flows</h4>
              <p class="scenario">When risk, accounting, or reporting steps in the end-of-day sequence delay, the entire chain is impacted, risking critical SLA breaches.</p>
              <div class="uc-section">
                <p class="uc-label">Orqenta Intervention</p>
                <ul class="uc-list">
                  <li>Unified model of complex cross-system dependencies.</li>
                  <li>Define clear cut-off times and specific SLA targets.</li>
                  <li>Real-time monitoring with automated escalations per delay.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Guaranteed SLA compliance for regulatory reporting.</li>
                  <li>Eliminated operational blind spots in batch cycles.</li>
                  <li>Faster response to execution incidents.</li>
                </ul>
              </div>
            </div>
            <div class="use-case-card-alt">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Enterprise</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">DWH & BI</span>
              </div>
              <h4>DWH-to-BI Synchronization Dependency</h4>
              <p class="scenario">Fragmented scheduling leads to BI refreshes triggering before DWH ETL processes are complete, resulting in dashboards displaying stale or incomplete data.</p>
              <div class="uc-section">
                <p class="uc-label">Orqenta Intervention</p>
                <ul class="uc-list">
                  <li>Orchestrate DWH load, transform, and publish steps as a single DAG.</li>
                  <li>Ensures BI refresh triggers only upon upstream ETL success.</li>
                  <li>Self-healing mechanisms for automated retry of failed steps.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>100% data reliability for executive dashboards.</li>
                  <li>Standardized, predictable publishing cycles.</li>
                  <li>Reduction in manual cross-team coordination effort.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Telecom & Energy Tab -->
        <div id="telecom" class="tab-content">
          <div class="grid-2" style="gap: 32px;">
            <div class="use-case-card-alt">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Telecom</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">Dependency</span>
              </div>
              <h4>Rating & Billing Chain Integrity</h4>
              <p class="scenario">Mediation, Rating, and Billing must trigger in perfect sequence. Premature downstream execution results in incorrect billing and revenue leakage.</p>
              <div class="uc-section">
                <p class="uc-label">Orqenta Intervention</p>
                <ul class="uc-list">
                  <li>Dynamic readiness checks for high-volume data files.</li>
                  <li>Early warning signals for upstream bottlenecks.</li>
                  <li>Automated eskalation to prevent billing cycle delays.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Minimized risk of revenue leakage and billing errors.</li>
                  <li>Enhanced process synchronization across distributed nodes.</li>
                  <li>Higher operational visibility for billing teams.</li>
                </ul>
              </div>
            </div>
            <div class="use-case-card-alt">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Energy</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">Cut-Off</span>
              </div>
              <h4>Critical Reporting Cut-Off Control</h4>
              <p class="scenario">Utility reports require strict time-window management. Missing a cut-off due to data arrival issues leads to regulatory non-compliance.</p>
              <div class="uc-section">
                <p class="uc-label">Orqenta Intervention</p>
                <ul class="uc-list">
                  <li>Strict enforcement of cut-off logic and time windows.</li>
                  <li>Conditional triggers: block downstream if upstream quality thresholds are not met.</li>
                  <li>Full audit trail for time-sensitive execution decisions.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>On-time regulatory reporting performance.</li>
                  <li>Lowered risks of operational fines and audit failures.</li>
                  <li>Robust, deterministic reporting governance.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Operations Tab -->
        <div id="operations" class="tab-content">
          <div style="display: flex; justify-content: center;">
            <div class="use-case-card-alt" style="max-width: 800px; width: 100%;">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Operations</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">Monitoring</span>
              </div>
              <h4>Proactive Monitoring & Incident Control</h4>
              <p class="scenario">Siloed process monitoring across tools increases issue detection time and extends Mean Time to Repair (MTTR).</p>
              <div class="uc-section">
                <p class="uc-label">Orqenta Intervention</p>
                <ul class="uc-list">
                  <li>Unified "single pane of glass" visibility for all enterprise flows.</li>
                  <li>Early error signal detection with proactive alerting.</li>
                  <li>Operational command: pause, resume, cancel, or reroute with full audibility.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Reduced MTTR and minimized production outages.</li>
                  <li>Significant gain in operational efficiency.</li>
                  <li>Audit-ready incident management history.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Execution & Security Model -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2" style="gap: 60px;">
        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 32px;">Central Authority <span class="grad-text">Model</span></h2>
          <p style="color: var(--clr-light-muted); margin-bottom: 24px;">Unlike traditional distributed schedulers, Orqenta centralizes decision logic to eliminate split-brain issues and out-of-sync states.</p>
          <div class="step-list">
            <div class="step-item">
              <span class="step-num">01</span>
              <div>
                <h6>Stateless Agents</h6>
                <p>Execution agents pull tasks via HTTP polling, meaning zero inbound ports and easy network scaling.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">02</span>
              <div>
                <h6>State Machine</h6>
                <p>The state is managed entirely by a central database, ensuring every transition is atomic and durable.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">03</span>
              <div>
                <h6>Tag-Based Routing</h6>
                <p>Intelligent job routing based on labels, capabilities, or geographical constraints of execution agents.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">Security & <span class="grad-text">Governance</span></h2>
          <p style="color: var(--clr-light-muted); margin-bottom: 24px;">Orqenta is built for mission-critical enterprise environments requiring high reliability:</p>
          <ul class="bullet-list">
            <li><strong>RBAC:</strong> Granular permissions for Admins, Developers, Operators, and Viewers.</li>
            <li><strong>Auth:</strong> mTLS or HMAC-SHA256 based agent authentication for secure communication.</li>
            <li><strong>Protection:</strong> Built-in SSRF protection to prevent metadata leakage in cloud environments.</li>
            <li><strong>Masking:</strong> Automatic redaction of secrets and credentials in logs and user interfaces.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Talk to an Expert</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.check-list, .bullet-list {
  list-style: none; padding: 0; margin: 0;
}
.check-list li, .bullet-list li {
  position: relative;
  padding-left: 28px;
  margin-bottom: 12px;
  color: var(--clr-light-muted);
  font-size: 0.95rem;
}
.check-list li::before {
  content: '✓';
  position: absolute; left: 0; top: 0;
  color: var(--clr-primary); font-weight: bold;
}
.bullet-list li::before {
  content: '';
  position: absolute; left: 0; top: 10px;
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--clr-primary);
}

.cap-card-modern {
  padding: 32px;
  background: #fff;
  border: 1px solid #e8eef5;
  border-radius: 20px;
  transition: all 0.3s ease;
}
.cap-card-modern:hover {
  transform: translateY(-5px);
  border-color: var(--clr-primary);
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.cap-icon-box {
  width: 80px;
  height: 80px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
  transition: all 0.3s ease;
}
.cap-icon-box img {
  width: 48px;
  height: 48px;
  object-fit: contain;
}
.cap-card-modern h3 {
  font-size: 1.1rem;
  color: var(--clr-light-text);
  margin-bottom: 12px;
}
.cap-card-modern p {
  font-size: 0.9rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
}

.step-list { display: flex; flex-direction: column; gap: 32px; }
.step-item { display: flex; gap: 24px; align-items: flex-start; }
.step-num {
  font-size: 2rem; font-weight: 800;
  color: rgba(0,200,150,0.15);
  line-height: 1;
}
.step-item h6 {
  font-size: 1.1rem; color: var(--clr-light-text);
  margin-bottom: 8px;
}
.step-item p { font-size: 0.95rem; color: var(--clr-light-muted); }

/* Use Case Tabs */
.tabs-nav {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}
@media (max-width: 768px) {
  .tabs-nav {
    flex-wrap: nowrap !important;
    justify-content: flex-start;
    overflow-x: auto;
    gap: 8px;
    padding: 4px 10px 12px;
    margin-bottom: 24px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .tabs-nav::-webkit-scrollbar { display: none; }
  .tab-btn {
    padding: 10px 18px;
    font-size: 0.85rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
}
.tab-btn {
  padding: 12px 24px;
  border-radius: 99px;
  border: 1px solid #E2E8F0;
  background: #fff;
  color: #64748B;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.3s ease;
}
.tab-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
  box-shadow: 0 4px 15px rgba(0, 200, 150, 0.25);
}
.tab-content {
  display: none;
  animation: fadeIn 0.5s ease;
}
.tab-content.active {
  display: block;
}

/* Use Case Cards Alt */
.use-case-card-alt {
  background: #fff;
  border: 1px solid #E8EEF5;
  border-radius: 24px;
  padding: 40px;
  transition: all 0.3s ease;
}
.use-case-card-alt:hover {
  border-color: var(--clr-primary);
  box-shadow: 0 10px 30px rgba(0,0,0,0.04);
}
.use-case-card-alt h4 {
  font-size: 1.25rem;
  color: var(--clr-light-text);
  margin-bottom: 20px;
}
.use-case-card-alt .scenario {
  font-size: 1rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid #F1F5F9;
}
.uc-section { margin-bottom: 24px; }
.uc-label {
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  color: var(--clr-primary);
  margin-bottom: 16px;
}
.uc-label--impact { color: #10B981; }
.uc-list { list-style: none; padding: 0; }
.uc-list li {
  position: relative;
  padding-left: 20px;
  margin-bottom: 10px;
  font-size: 0.95rem;
  color: var(--clr-light-muted);
}
.uc-list li::before {
  content: '•';
  position: absolute; left: 0; color: var(--clr-primary);
}

.img-card {
  background: #fff;
  padding: 24px;
  border-radius: 24px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.img-card img {
  width: 100%;
  max-width: 900px;
  border-radius: 12px;
  border: 1px solid #eee;
}
.img-caption {
  margin-top: 16px; font-size: 0.9rem;
  color: var(--clr-light-muted); font-style: italic;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 900px) {
  .grid-2 { grid-template-columns: 1fr; }
}
</style>

<script is:inline>
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const parent = btn.closest('.tabs-container');
      const target = btn.dataset.tab;
      
      parent.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      parent.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
      
      btn.classList.add('active');
      document.getElementById(target).classList.add('active');
    });
  });
</script>
