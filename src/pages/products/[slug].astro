---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const products = [
    { 
      slug: 'ifdm', 
      name: 'IFDM', 
      tagline: 'Intellica Finance Data Model',
      category: 'Data Models',
      desc: 'International standard data warehouse model for the finance industry. Pre-modeled with regulatory reporting, risk, CRM and more — ready to deploy.',
      features: ['Architecture assessment & target design', 'Phased migration plan', 'Security, performance, scalability'],
      icon: '📊'
    },
    { 
      slug: 'itdm', 
      name: 'ITDM', 
      tagline: 'Intellica Telecom Data Model',
      category: 'Data Models',
      desc: 'Industry-specific data warehouse model for telecom operators. Network, billing, CRM dimensioning — pre-built and tested globally.',
      features: ['Network & Billing dimensioning', 'CRM data integration', 'Global industry standards'],
      icon: '📱'
    },
    { 
      slug: 'hrdm', 
      name: 'HRDM', 
      tagline: 'Human Resources Data Model',
      category: 'Data Models',
      desc: 'Optimized data warehouse model for HR processes — workforce analytics, payroll, talent management ready from day one.',
      features: ['Workforce analytics', 'Payroll integration', 'Talent management insights'],
      icon: '👥'
    },
    { 
      slug: 'icc', 
      name: 'ICC', 
      tagline: 'Intellica Consistency Controller',
      category: 'Data Platform & Governance',
      desc: 'Central data consistency management platform. Define reconciliation rules, monitor quality gates, and get automated alerts on data drift.',
      features: ['Automated reconciliation', 'Quality gate monitoring', 'Drift alerts'],
      icon: '⚖️'
    },
    { 
      slug: 'retouch', 
      name: 'ReTouch', 
      tagline: 'Reference Data & Entry Management',
      category: 'Data Platform & Governance',
      desc: 'Validate, cleanse and import external data into your core systems with approval workflows, audit trails and version control.',
      features: ['Workflow approvals', 'Audit trails', 'Data validation'],
      icon: '✏️'
    },
    { 
      slug: 'retable', 
      name: 'Retable', 
      tagline: 'No-Code Data Application Platform',
      category: 'Data Platform & Governance',
      desc: 'Build flexible apps and data tables without code. Collaborative, cloud-based platform with automations, integrations and AI capabilities.',
      features: ['No-code builder', 'Real-time collaboration', 'AI integrations'],
      icon: '🏢'
    },
    { 
      slug: 'talkto', 
      name: 'Talk To', 
      tagline: 'Natural Language Data Interaction',
      category: 'AI Products',
      desc: 'Ask your enterprise data questions in natural language. Get instant SQL queries, visualizations and insights — completely governed and auditable.',
      features: ['NL2SQL technology', 'Self-service analytics', 'Full auditability'],
      icon: '💬'
    },
    { 
      slug: 'blueoctopus', 
      name: 'Blue Octopus', 
      tagline: 'AI Surveillance & Action Platform',
      category: 'AI Products',
      desc: 'Monitor critical data from a single center with AI-powered analytics. Event detection, alerting and action management across systems.',
      features: ['Centralized monitoring', 'Real-time alerting', 'Action management'],
      icon: '🐙'
    },
    { 
      slug: 'var', 
      name: 'VAR', 
      tagline: 'Voice AI Recognition',
      category: 'AI Products',
      desc: 'AI-powered voice signature creation, speaker matching and identity extraction. Built for security, call center and compliance use cases.',
      features: ['Voice biometrics', 'Speaker identification', 'Secure extraction'],
      icon: '🎙️'
    }
  ];

  return products.map(product => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const breadcrumbs = [
  { name: "Products", url: "/products" },
  { name: product.name, url: `/products/${product.slug}` }
];
---

<Layout title={`${product.name} | Intellica Product`} description={product.desc} breadcrumbs={breadcrumbs} hideCta={true}>
  <section class="page-hero">
    <div class="container">
      <div class="section-label anim-fade-up">{product.category}</div>
      <h1 class="anim-fade-up">{product.name}</h1>
      <p class="product-tagline anim-fade-up">{product.tagline}</p>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="product-detail-grid">
        <div class="product-info-panel anim-fade-up">
          <h2>Overview</h2>
          <p class="product-description">{product.desc}</p>
          
          <div class="feature-list-wrap">
            <h3>Key Features</h3>
            <ul class="feature-list">
              {product.features.map(feature => (
                <li>{feature}</li>
              ))}
            </ul>
          </div>
        </div>
        
        <div class="product-cta-panel anim-fade-up">
          <div class="product-icon-large">{product.icon}</div>
          <div class="cta-box">
            <h3>Ready to see {product.name} in action?</h3>
            <p>Schedule a personalized demo with our experts.</p>
            <a href="/contact" class="btn btn-primary btn-pill btn-lg">Get in Touch</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.product-tagline {
  font-size: 1.25rem;
  color: var(--grad-brand);
  font-weight: 600;
  margin-top: -12px;
}
.product-detail-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 64px;
}
.product-info-panel h2 {
  color: var(--clr-light-text);
  margin-bottom: 24px;
}
.product-description {
  font-size: 1.15rem;
  line-height: 1.7;
  color: var(--clr-light-muted);
  margin-bottom: 40px;
}
.feature-list-wrap h3 {
  color: var(--clr-light-text);
  margin-bottom: 20px;
  font-size: 1.2rem;
}
.feature-list {
  list-style: none; padding: 0; margin: 0;
  display: grid; gap: 16px;
}
.feature-list li {
  display: flex; align-items: center; gap: 12px;
  font-size: 1rem; color: var(--clr-light-text);
  padding: 12px 16px;
  background: #F8FAFC;
  border-radius: 12px;
  border: 1px solid #E8EEF5;
}
.feature-list li::before {
  content: '✓';
  color: var(--clr-primary);
  font-weight: bold;
}
.product-cta-panel {
  display: flex;
  flex-direction: column;
  gap: 32px;
}
.product-icon-large {
  font-size: 5rem;
  display: flex; align-items: center; justify-content: center;
  height: 200px;
  background: linear-gradient(145deg, #F0FDF9, #EFF6FF);
  border-radius: 24px;
  border: 1px solid rgba(0,200,150,0.1);
}
.cta-box {
  padding: 32px;
  background: #030B16;
  border-radius: 24px;
  color: #fff;
  text-align: center;
}
.cta-box h3 { margin-bottom: 12px; font-size: 1.4rem; }
.cta-box p { color: rgba(255,255,255,0.7); margin-bottom: 24px; font-size: 0.95rem; }

@media (max-width: 960px) {
  .product-detail-grid { grid-template-columns: 1fr; gap: 40px; }
  .product-cta-panel { order: -1; }
}
</style>
