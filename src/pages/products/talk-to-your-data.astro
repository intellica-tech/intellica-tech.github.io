---
import Layout from '../../layouts/Layout.astro';

const siteUrl = "https://intellica.net";
const breadcrumbs = [
  { name: "Products", url: `${siteUrl}/products` },
  { name: "Talk To", url: `${siteUrl}/products/talk-to-your-data` }
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Talk To",
  "description": "AI-powered data analyst that allows users to query enterprise data using natural language. Translates questions into SQL and provides instant insights.",
  "applicationCategory": "BusinessApplication, Analytics",
  "operatingSystem": "Web-based",
  "author": {
    "@id": `${siteUrl}/#organization`
  },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD"
  }
};
---

<Layout title="Talk To — AI Data Analytics | Intellica" description="Talk To: Query your enterprise data using natural language. AI-powered insights, visualization, and tool orchestration." breadcrumbs={breadcrumbs} hideCta={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label anim-fade-up">AI Products</div>
      <h1 class="anim-fade-up">Talk To — <span class="grad-text">Natural Query</span></h1>
      <p class="anim-fade-up">Interact with your enterprise data using natural language. Talk To acts as an AI data analyst, translating your questions into precise queries and delivering instant insights.</p>
      <div class="hero-actions anim-fade-up" style="margin-top: 32px;">
        <a href="/contact" class="btn btn-primary btn-pill btn-lg">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2" style="gap: 48px; align-items: start;">
        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px;">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">What does it <span class="grad-text">solve?</span></h2>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Problem</p>
            <p style="color: var(--clr-light-muted);">Data access typically remains the responsibility of expert teams (SQL/BI). Ad-hoc requests accumulate, waiting times lengthen, and the same questions are asked repeatedly.</p>
          </div>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Approach</p>
            <p style="color: var(--clr-light-muted);">Talk To matches natural language questions with schema/metadata; generates and executes the necessary query and presents the result as an understandable summary or visualization.</p>
          </div>
          <div>
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Business Value</p>
            <p style="color: var(--clr-light-muted);">Response in minutes, fewer errors, higher self-service adoption, and faster decision cycles.</p>
          </div>
        </div>

        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px; background: #f8fafc;">
          <h3 style="color: var(--clr-light-text); margin-bottom: 24px;">When is it <span class="grad-text">preferred?</span></h3>
          <ul class="check-list">
            <li>When ad-hoc analysis requests are piling up in SQL/BI teams</li>
            <li>To enable self-service insights for business units</li>
            <li>For more accurate query generation via schema/metadata awareness</li>
            <li>When building an assistant to take actions (MCP) with reporting tools</li>
            <li>To ensure security (RBAC, logging) in an enterprise AI framework</li>
          </ul>
          <p style="font-size: 0.85rem; color: var(--clr-light-muted); margin-top: 24px; font-style: italic;">Note: Scope and integration details are finalized during the discovery phase.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities Section -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Capabilities</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">Core <span class="grad-text">Capabilities</span></h2>
      </div>

      <div class="grid-3 anim-fade-up" style="gap: 24px;">
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Natural Language Querying</h3>
          <p>Get instant insights through a chat interface using simple question-and-answer interactions.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Schema Awareness</h3>
          <p>Understands data fields and relationships to produce highly accurate database queries.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Auto Visualization</h3>
          <p>Generates tables and core charts based on the context of your data request.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Tool Orchestration</h3>
          <p>Interacts with reporting tools and external applications via MCP for end-to-end action.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Error Reduction</h3>
          <p>Minimizes manual query errors and incorrect filtering through AI-driven validation.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Enterprise Governance</h3>
          <p>Role-based access (RBAC), auditing, and centralized logging for secure production use.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section (Interface Preview) -->
  <section class="section section--dark noise">
    <div class="container">
      <div class="product-grid anim-fade-up">
        <div class="anim-fade-up">
          <h2 style="color: #fff; margin-bottom: 24px;">Interact with Data. <span class="grad-text">Get Instant Insights.</span></h2>
          <p style="color: rgba(255,255,255,0.7); margin-bottom: 32px; font-size: 1.1rem; line-height: 1.7;">
            Talk To enables you to interact with your corporate data by converting natural language questions into database queries. Get insights through a single conversation interface without writing SQL or navigating complex BI tools.
          </p>
          <div class="cap-card-modern" style="padding: 24px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
            <p style="font-weight: 700; color: #fff; margin-bottom: 8px;">Intelligent Analyst Assistant</p>
            <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem;">Context-aware analysis using LLMs to provide follow-up answers and deep-dive discoveries.</p>
          </div>
        </div>
        <div class="anim-fade-up">
          <div class="img-frame">
            <img src="/assets/images/talktoekrangoruntusu.png" alt="Talk To Interface" class="product-screenshot" loading="lazy" />
          </div>
          <p style="text-align: center; font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 16px; font-style: italic;">
            Talk To: Natural language data analysis and intelligent insight platform.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Strategic Use Cases (Updated for consistency) -->
  <section class="section section--light" id="use-cases">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Solutions</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">Strategic <span class="grad-text">Use Cases</span></h2>
        <p class="section-sub">Discover the operational and strategic value created by Talk To across different departments.</p>
      </div>

      <div class="tabs-container anim-fade-up">
        <div class="tabs-nav">
          <button class="tab-btn active" data-tab="it-bi">IT & BI Workflow</button>
          <button class="tab-btn" data-tab="customer">Customer Support</button>
          <button class="tab-btn" data-tab="management">Executive Insights</button>
        </div>

        <!-- IT & BI Tab -->
        <div id="it-bi" class="tab-content active">
          <div class="grid-2" style="gap: 32px;">
            <div class="use-case-card-alt">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Efficiency</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">SQL & BI</span>
              </div>
              <h4>Reducing SQL and BI Complexity</h4>
              <p class="scenario">Business units being dependent on IT teams for data analysis or navigating complex BI tools can slow down decision-making.</p>
              <div class="uc-section">
                <p class="uc-label">Talk To Intervention</p>
                <ul class="uc-list">
                  <li>Automatically converts natural language questions into SQL queries.</li>
                  <li>Integrates seamlessly with databases and reporting tools.</li>
                  <li>Delivers responses as tables, charts, or summarized analysis.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Faster self-service analytics adoption.</li>
                  <li>Reduced ad-hoc workload on IT and BI teams.</li>
                  <li>Shorter data-to-decision cycles.</li>
                </ul>
              </div>
            </div>
            <div class="use-case-card-alt">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Self-Service</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">Reporting</span>
              </div>
              <h4>Ad-hoc Reporting Automation</h4>
              <p class="scenario">Teams spend excessive hours manually compiling reports for one-off vertical analysis requests.</p>
              <div class="uc-section">
                <p class="uc-label">Talk To Intervention</p>
                <ul class="uc-list">
                  <li>Standardize semantic layers for consistent field definitions.</li>
                  <li>Allow business users to generate on-the-fly reports via chat.</li>
                  <li>Export results instantly to common analysis formats.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Minimizes manual reporting errors.</li>
                  <li>Frees up expert resources for strategic projects.</li>
                  <li>Transparent and auditable query history.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Customer Support Tab -->
        <div id="customer" class="tab-content">
          <div style="display: flex; justify-content: center;">
            <div class="use-case-card-alt" style="max-width: 800px; width: 100%;">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Support</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">Customer 360</span>
              </div>
              <h4>360° Customer View & Rapid Support</h4>
              <p class="scenario">Support agents searching for data across CRM, billing, and interaction systems leads to time loss and incomplete context.</p>
              <div class="uc-section">
                <p class="uc-label">Talk To Intervention</p>
                <ul class="uc-list">
                  <li>Analyzes CRM and transaction history in an integrated way.</li>
                  <li>Provides contextual customer summaries to representatives.</li>
                  <li>Generates Next Best Action (NBA) suggestions based on data.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Higher First Contact Resolution (FCR) rates.</li>
                  <li>Shortened Average Handling Time (AHT) per case.</li>
                  <li>Increased customer satisfaction and cross-sell potential.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Management Tab -->
        <div id="management" class="tab-content">
          <div style="display: flex; justify-content: center;">
            <div class="use-case-card-alt" style="max-width: 800px; width: 100%;">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Executive</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">KPI Tracking</span>
              </div>
              <h4>Instant KPI Querying for Management</h4>
              <p class="scenario">Senior management often depends on dashboard updates or technical teams to access real-time KPI performance.</p>
              <div class="uc-section">
                <p class="uc-label">Talk To Intervention</p>
                <ul class="uc-list">
                  <li>Enables natural language querying of high-level KPIs.</li>
                  <li>Supports contextual filtering and seamless drill-down.</li>
                  <li>Produces instant charts and executive summary reports.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Immediate access to management reports.</li>
                  <li>Simplified KPI interpretation and trend analysis.</li>
                  <li>Strengthened strategic decision-making capabilities.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2" style="gap: 60px;">
        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 32px;">Intelligent <span class="grad-text">Workflow</span></h2>
          <p style="color: var(--clr-light-muted); margin-bottom: 24px;">Talk To orchestrates the entire intelligence cycle, from data connection to actionable visualization.</p>
          <div class="step-list">
            <div class="step-item">
              <span class="step-num">01</span>
              <div>
                <h6>Connect & Authorize</h6>
                <p>Define data sources, schema metadata, and role-based access controls.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">02</span>
              <div>
                <h6>Ask & Verify</h6>
                <p>Question submitted, query generated and validated before execution.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">03</span>
              <div>
                <h6>Insight & Action</h6>
                <p>Results delivered as summaries, charts, or triggered workflows (MCP).</p>
              </div>
            </div>
          </div>
        </div>

        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">Ecosystem <span class="grad-text">Integration</span></h2>
          <p style="color: var(--clr-light-muted); margin-bottom: 24px;">Built to integrate with existing enterprise architecture and governance standards:</p>
          <ul class="bullet-list">
            <li>Enterprise DB/DWH/Data Lake connectivity (SQL, NoSQL)</li>
            <li>Schema-aware mapping for accurate domain-specific querying</li>
            <li>MCP-compatible application orchestration (Reporting, CRM)</li>
            <li>Full SSO/LDAP integration and granular RBAC auditing</li>
            <li>Centralized logging for all AI-generated query operations</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Get in Touch</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.check-list, .bullet-list {
  list-style: none; padding: 0; margin: 0;
}
.check-list li, .bullet-list li {
  position: relative;
  padding-left: 28px;
  margin-bottom: 12px;
  color: var(--clr-light-muted);
  font-size: 0.95rem;
}
.check-list li::before {
  content: '✓';
  position: absolute; left: 0; top: 0;
  color: var(--clr-primary); font-weight: bold;
}
.bullet-list li::before {
  content: '';
  position: absolute; left: 0; top: 10px;
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--clr-primary);
}

/* Capabilities Modern */
.cap-card-modern {
  background: #fff;
  border: 1px solid #E2E8F0;
  border-radius: 20px;
  padding: 32px;
  transition: all 0.3s ease;
}
.cap-card-modern:hover {
  border-color: var(--clr-primary);
  transform: translateY(-4px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.cap-icon-box {
  width: 80px;
  height: 80px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
  transition: all 0.3s ease;
}
.cap-icon-box img {
  width: 48px;
  height: 48px;
  object-fit: contain;
}
.cap-card-modern h3 {
  font-size: 1.1rem;
  color: var(--clr-light-text);
  margin-bottom: 12px;
}
.cap-card-modern p {
  font-size: 0.9rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
}

/* Use Case Tabs */
.tabs-nav {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}
@media (max-width: 768px) {
  .tabs-nav {
    flex-wrap: nowrap !important;
    justify-content: flex-start;
    overflow-x: auto;
    gap: 8px;
    padding: 4px 10px 12px;
    margin-bottom: 24px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .tabs-nav::-webkit-scrollbar { display: none; }
  .tab-btn {
    padding: 10px 18px;
    font-size: 0.85rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
}
.tab-btn {
  padding: 12px 24px;
  border-radius: 99px;
  background: #fff;
  border: 1px solid #e2e8f0;
  color: #64748b;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.3s ease;
}
.tab-btn:hover {
  border-color: var(--clr-primary);
  color: var(--clr-primary);
}
.tab-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
  box-shadow: 0 4px 12px rgba(0, 200, 150, 0.2);
}
.tab-content {
  display: none;
  animation: fadeIn 0.5s ease;
}
.tab-content.active {
  display: block;
}

/* Use Case Cards Alt */
.use-case-card-alt {
  background: #fff;
  border: 1px solid #E8EEF5;
  border-radius: 24px;
  padding: 40px;
  transition: all 0.3s ease;
  height: 100%;
}
.use-case-card-alt:hover {
  border-color: var(--clr-primary);
  box-shadow: 0 10px 30px rgba(0,0,0,0.04);
}
.use-case-card-alt h4 {
  font-size: 1.25rem;
  color: var(--clr-light-text);
  margin-bottom: 20px;
}
.use-case-card-alt .scenario {
  font-size: 1rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid #F1F5F9;
}
.uc-section { margin-bottom: 24px; }
.uc-label {
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  color: var(--clr-primary);
  margin-bottom: 16px;
}
.uc-label--impact { color: #10B981; }
.uc-list { list-style: none; padding: 0; }
.uc-list li {
  position: relative;
  padding-left: 20px;
  margin-bottom: 10px;
  font-size: 0.95rem;
  color: var(--clr-light-muted);
}
.uc-list li::before {
  content: '•';
  position: absolute; left: 0; color: var(--clr-primary);
}

/* Step List */
.step-list { display: flex; flex-direction: column; gap: 32px; }
.step-item { display: flex; gap: 24px; align-items: flex-start; }
.step-num {
  font-size: 2rem; font-weight: 800;
  color: rgba(0,200,150,0.15);
  line-height: 1;
}
.step-item h6 {
  font-size: 1.1rem; color: var(--clr-light-text);
  margin-bottom: 8px;
}
.step-item p { font-size: 0.95rem; color: var(--clr-light-muted); }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 900px) {
  .grid-2 { grid-template-columns: 1fr; }
}
</style>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');

        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));

        tab.classList.add('active');
        const targetElement = document.getElementById(target as string);
        if (targetElement) {
          targetElement.classList.add('active');
        }
      });
    });
  }

  // Run on page load
  initTabs();

  // Run on view transition (for Astro)
  document.addEventListener('astro:page-load', initTabs);
</script>
