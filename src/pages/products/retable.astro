---
import Layout from '../../layouts/Layout.astro';

const siteUrl = "https://intellica.net";
const breadcrumbs = [
  { name: "Products", url: `${siteUrl}/products` },
  { name: "Retable", url: `${siteUrl}/products/retable` }
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Retable",
  "description": "Cloud-based, collaborative no-code data and application development platform for modern data teams.",
  "applicationCategory": "BusinessApplication, NoCode",
  "operatingSystem": "Web-based",
  "author": { "@id": `${siteUrl}/#organization` },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD"
  }
};
---

<Layout title="Retable — No-Code Data Application Platform | Intellica" description="Retable: Collaborative cloud-based no-code platform; transform spreadsheets into powerful databases with AI-driven automations and seamless integrations." breadcrumbs={breadcrumbs} hideCta={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label anim-fade-up">Data Platform & Governance</div>
      <h1 class="anim-fade-up">Retable — No-Code <span class="grad-text">Platform</span></h1>
      <p class="anim-fade-up">Build data-driven applications without writing code. Collaborative, cloud-based platform for modern teams. Transform your data into powerful internal tools with built-in AI.</p>
      <div class="hero-actions anim-fade-up" style="margin-top: 32px;">
        <a href="/contact" class="btn btn-primary btn-pill btn-lg">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2" style="gap: 48px; align-items: start;">
        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px;">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">What does it <span class="grad-text">solve?</span></h2>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Problem</p>
            <p style="color: var(--clr-light-muted);">Standard spreadsheets lack the structure and collaboration features needed for complex projects. Traditional app development for internal tools is slow and costly.</p>
          </div>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Approach</p>
            <p style="color: var(--clr-light-muted);">Intellica Retable provides a no-code platform to digitize manual data, integrates conformed dimensions, and enables business users to build collaborative data tables and micro-apps.</p>
          </div>
          <div>
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Business Value</p>
            <p style="color: var(--clr-light-muted);">Dramatically faster internal tool development, improved team collaboration, and seamless data workflow automation.</p>
          </div>
        </div>

        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px; background: #f8fafc;">
          <h3 style="color: var(--clr-light-text); margin-bottom: 24px;">When is it <span class="grad-text">preferred?</span></h3>
          <ul class="check-list">
            <li>When teams need a shared, structured space for complex project tracking</li>
            <li>To build custom internal tools (CRM, Inventory, HR) without coding</li>
            <li>When leveraging AI for data cleaning and generation within your tables</li>
            <li>To replace messy Excel files with professional, relational database views</li>
            <li>For rapid prototyping of data-intensive enterprise applications</li>
          </ul>
          <p style="font-size: 0.85rem; color: var(--clr-light-muted); margin-top: 24px; font-style: italic;">Note: Retable is a standalone cloud platform with enterprise-grade security.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities Section -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Capabilities</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">Core <span class="grad-text">Capabilities</span></h2>
      </div>

      <div class="grid-3 anim-fade-up" style="gap: 24px;">
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Flexible Views</h3>
          <p>Switch between Grid, Kanban, Calendar, and Form views for the same data set.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>AI Columns</h3>
          <p>Integrate GPT-powered columns for content generation and data enrichment.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>No-Code Automation</h3>
          <p>Trigger emails, Slack alerts, or webhooks based on data changes or time.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Extensive API</h3>
          <p>Full REST API to connect Retable with your existing enterprise tech stack.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Real-time Collab</h3>
          <p>Work together with your team in real-time with granular record-level permissions.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Reports & Charts</h3>
          <p>Generate visual insights directly from your data tables with custom dashboards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section (Visibility) -->
  <section class="section section--dark noise">
    <div class="container">
      <div class="product-grid anim-fade-up">
        <div class="anim-fade-up">
          <h2 style="color: #fff; margin-bottom: 24px;">Transform Spreadsheets into <span class="grad-text">Smart Apps</span></h2>
          <p style="color: rgba(255,255,255,0.7); margin-bottom: 32px; font-size: 1.1rem; line-height: 1.7;">
            Retable turns your tables into powerful applications with automation, AI, and API capabilities. Centralize your workflows and gain full operational visibility without writing a single line of code.
          </p>
          <div class="cap-card-modern" style="padding: 24px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
            <p style="font-weight: 700; color: #fff; margin-bottom: 8px;">Operational Flow</p>
            <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem;">Track requests, tasks, and approvals from a single, integrated command center.</p>
          </div>
        </div>
        <div class="anim-fade-up">
          <div class="img-frame">
            <img src="/assets/images/retableekrangörüntüsü.png" alt="Retable Operational Interface" class="product-screenshot" loading="lazy" />
          </div>
          <p style="text-align: center; font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 16px; font-style: italic;">
            Retable Interface: Integrated operational management and workflow tracking.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Strategic Use Cases -->
  <section class="section section--light" id="use-cases">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Solutions</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">Strategic <span class="grad-text">Use Cases</span></h2>
        <p class="section-sub">Explore how Retable resolves operational fragmentation and management challenges.</p>
      </div>

      <div class="grid-2 anim-fade-up" style="gap: 32px;">
        <div class="use-case-card-alt">
          <h4>Operational Defragmentation</h4>
          <p class="scenario">Using Excel, email, and scattered tools for tracking leads to lost tasks, delays, and zero process visibility.</p>
          <div class="uc-section">
            <p class="uc-label">RETABLE INTERVENTION</p>
            <ul class="uc-list">
              <li>Centralized table-based process orchestration.</li>
              <li>Integrated task assignment and status tracking.</li>
              <li>Standardized data entry via forms and grids.</li>
            </ul>
          </div>
          <div class="uc-section">
            <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
            <ul class="uc-list">
              <li>Improved visibility and team coordination.</li>
              <li>Reduced delays and faster delivery times.</li>
              <li>Single-source operational command center.</li>
            </ul>
          </div>
        </div>
        <div class="use-case-card-alt">
          <h4>Request & Approval Management</h4>
          <p class="scenario">Managing requests in Procurement, IT, or HR via email causes bottlenecks and loss of audit trails.</p>
          <div class="uc-section">
            <p class="uc-label">RETABLE INTERVENTION</p>
            <ul class="uc-list">
              <li>Requests captured via standard forms.</li>
              <li>Automated approval steps and role assignment.</li>
              <li>Status notifications for all stakeholders.</li>
            </ul>
          </div>
          <div class="uc-section">
            <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
            <ul class="uc-list">
              <li>Accelerated approval cycles.</li>
              <li>Increased transparency and control.</li>
              <li>Reduced operational overhead and errors.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Get in Touch</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.check-list, .bullet-list {
  list-style: none; padding: 0; margin: 0;
}
.check-list li, .bullet-list li {
  position: relative;
  padding-left: 28px;
  margin-bottom: 12px;
  color: var(--clr-light-muted);
  font-size: 0.95rem;
}
.check-list li::before {
  content: '✓';
  position: absolute; left: 0; top: 0;
  color: var(--clr-primary); font-weight: bold;
}
.bullet-list li::before {
  content: '';
  position: absolute; left: 0; top: 10px;
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--clr-primary);
}

.cap-card-modern {
  padding: 32px;
  background: #fff;
  border: 1px solid #e8eef5;
  border-radius: 20px;
  transition: all 0.3s ease;
}
.cap-card-modern:hover {
  transform: translateY(-5px);
  border-color: var(--clr-primary);
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.cap-icon-box {
  width: 80px;
  height: 80px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
  transition: all 0.3s ease;
}
.cap-icon-box img {
  width: 48px;
  height: 48px;
  object-fit: contain;
}
.cap-card-modern h3 {
  font-size: 1.1rem;
  color: var(--clr-light-text);
  margin-bottom: 12px;
}
.cap-card-modern p {
  font-size: 0.9rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
}

/* Use Case Cards Alt */
.use-case-card-alt {
  background: #fff;
  border: 1px solid #E8EEF5;
  border-radius: 24px;
  padding: 40px;
  transition: all 0.3s ease;
}
.use-case-card-alt:hover {
  border-color: var(--clr-primary);
  box-shadow: 0 10px 30px rgba(0,0,0,0.04);
}
.use-case-card-alt h4 {
  font-size: 1.25rem;
  color: var(--clr-light-text);
  margin-bottom: 20px;
}
.use-case-card-alt .scenario {
  font-size: 1rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid #F1F5F9;
}
.uc-section { margin-bottom: 24px; }
.uc-label {
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  color: var(--clr-primary);
  margin-bottom: 16px;
}
.uc-label--impact { color: #10B981; }
.uc-list { list-style: none; padding: 0; }
.uc-list li {
  position: relative;
  padding-left: 20px;
  margin-bottom: 10px;
  font-size: 0.95rem;
  color: var(--clr-light-muted);
}
.uc-list li::before {
  content: '•';
  position: absolute; left: 0; color: var(--clr-primary);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 900px) {
  .grid-2 { grid-template-columns: 1fr; }
}
</style>
