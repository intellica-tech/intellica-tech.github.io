---
import Layout from '../../layouts/Layout.astro';

const siteUrl = "https://intellica.net";
const breadcrumbs = [
  { name: "Products", url: `${siteUrl}/products` },
  { name: "Blue Octopus", url: `${siteUrl}/products/blue-octopus` }
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Blue Octopus",
  "description": "AI-powered centralized analytics and surveillance platform for critical data monitoring and action management.",
  "applicationCategory": "BusinessApplication, AISurveillance",
  "operatingSystem": "Web-based",
  "author": { "@id": `${siteUrl}/#organization` },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD"
  }
};
---

<Layout title="Blue Octopus — AI Surveillance & Action Platform | Intellica" description="Blue Octopus: AI-powered centralized analytics and surveillance platform for critical data monitoring, event detection, and action management." breadcrumbs={breadcrumbs} hideCta={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label anim-fade-up">AI Products</div>
      <h1 class="anim-fade-up">Blue Octopus — AI <span class="grad-text">Event Intelligence</span> Platform</h1>
      <p class="anim-fade-up">AI-powered event intelligence and orchestration for monitoring, detecting and managing critical business events across your organization.</p>
      <div class="hero-actions anim-fade-up" style="margin-top: 32px;">
        <a href="/contact" class="btn btn-primary btn-pill btn-lg">Get in Touch</a>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2" style="gap: 48px; align-items: start;">
        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px;">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">What does it <span class="grad-text">solve?</span></h2>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Problem</p>
            <p style="color: var(--clr-light-muted);">Monitoring massive data streams for critical events manually or with simple rules leads to missed incidents and high false-positive rates that desensitize operations teams.</p>
          </div>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Approach</p>
            <p style="color: var(--clr-light-muted);">Blue Octopus integrates event monitoring, analytics, and automated action management into a single platform for real-time operational excellence.</p>
          </div>
          <div>
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Business Value</p>
            <p style="color: var(--clr-light-muted);">Instant identification of critical business events, significantly reduced mean-time-to-resolution (MTTR), and automated compliance oversight.</p>
          </div>
        </div>

        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px; background: #f8fafc;">
          <h3 style="color: var(--clr-light-text); margin-bottom: 24px;">When is it <span class="grad-text">preferred?</span></h3>
          <ul class="check-list">
            <li>When you need a centralized command center for critical incidents and distributed field operations</li>
            <li>To monitor real-time events from multiple systems, sensors, logs and external sources on a single platform</li>
            <li>When rapid alerting, coordinated response and action management are required during security or operational events</li>
            <li>To correlate incident data, location intelligence and resource availability in map-based operational workflows</li>
            <li>When standard monitoring tools are not sufficient for multi-source event detection, AI-supported surveillance and tactical coordination</li>
          </ul>
          <p style="font-size: 0.85rem; color: var(--clr-light-muted); margin-top: 24px; font-style: italic;">Note: Blue Octopus supports both batch and real-time streaming data ingestion.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities Section -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Capabilities</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">Core <span class="grad-text">Capabilities</span></h2>
      </div>

      <div class="grid-3 anim-fade-up" style="gap: 24px;">
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Event Detection</h3>
          <p>AI-driven identification of anomalies, fraudulent activities, and complex data patterns.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Action Orchestration</h3>
          <p>Automated multi-system workflows triggered instantly by specific data events.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Integrated Console</h3>
          <p>Integrated "Single Pane of Glass" view of all monitored systems and active alerts.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Adaptive Alerting</h3>
          <p>Intelligent threshold management and AI-predicted alerting to reduce noise.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Event Correlation</h3>
          <p>Correlate multi-source events to detect hidden patterns and identify critical incidents in real time.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" loading="lazy" /></div>
          <h3>Integrated Ingestion</h3>
          <p>Connects directly with Kafka streams, Cloud events, and enterprise SQL/NoSQL sources.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section (Centralized Console) -->
  <section class="section section--dark noise">
    <div class="container">
      <div class="product-grid anim-fade-up">
        <div class="anim-fade-up">
          <h2 style="color: #fff; margin-bottom: 24px;">Centralized <span class="grad-text">Command Center</span></h2>
          <p style="color: rgba(255,255,255,0.7); margin-bottom: 32px; font-size: 1.1rem; line-height: 1.7;">
            Blue Octopus provides an integrated "Command & Control" layer to manage disparate security and operational events across your organization's entire data footprint.
          </p>
          <div class="cap-card-modern" style="padding: 24px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
            <p style="font-weight: 700; color: #fff; margin-bottom: 8px;">Action-Oriented Alerts</p>
            <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem;">Don't just watch the data; trigger immediate incident response workflows across the infrastructure.</p>
          </div>
        </div>
        <div class="anim-fade-up">
          <div class="img-frame">
            <img src="/assets/images/Blueoctopus_screen.png" alt="Blue Octopus Interface" class="product-screenshot" loading="lazy" />
          </div>
          <p style="text-align: center; font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 16px; font-style: italic;">
            Blue Octopus: Visualizing security analytics, event monitoring, and enterprise action management.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Strategic Use Cases -->
  <section class="section section--light" id="use-cases">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Solutions</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">Strategic <span class="grad-text">Use Cases</span></h2>
        <p class="section-sub">Discover how Blue Octopus provides intelligent surveillance and automated response for critical business events.</p>
      </div>

      <div class="tabs-container anim-fade-up">
        <div class="tabs-nav">
          <button class="tab-btn active" data-tab="logistics">Logistics & SLA</button>
          <button class="tab-btn" data-tab="banking">Banking & Security</button>
          <button class="tab-btn" data-tab="operations">Global Operations</button>
        </div>

        <!-- Logistics Tab -->
        <div id="logistics" class="tab-content active">
          <div style="display: flex; justify-content: center;">
            <div class="use-case-card-alt" style="max-width: 800px; width: 100%;">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Logistics</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">SLA Monitoring</span>
              </div>
              <h4>SLA Monitoring</h4>
              <p class="scenario">A logistics firm needs to monitor thousands of shipments. If a critical delay pattern is detected in a specific hub, the system must alert managers before the SLA breach occurs.</p>
              <div class="uc-section">
                <p class="uc-label">Blue Octopus Role</p>
                <ul class="uc-list">
                  <li>Real-time tracking of GPS and hub processing data streams.</li>
                  <li>AI-based delay prediction for ongoing shipments across all routes.</li>
                  <li>Automated escalation to regional hub managers via mobile alerts.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Reduced SLA penalties and customer refund costs.</li>
                  <li>Proactive management of logistics bottlenecks.</li>
                  <li>Standardized incident reporting across global hubs.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Banking Tab -->
        <div id="banking" class="tab-content">
          <div style="display: flex; justify-content: center;">
            <div class="use-case-card-alt" style="max-width: 800px; width: 100%;">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Banking</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">Systemic Failure</span>
              </div>
              <h4>Failure & Attack Detection</h4>
              <p class="scenario">A bank needs to detect if a specific ATM network or digital channel is experiencing a higher-than-average failure rate, indicating a potential cyber-attack or platform bug.</p>
              <div class="uc-section">
                <p class="uc-label">Blue Octopus Role</p>
                <ul class="uc-list">
                  <li>Detect success/fail ratios across thousands of transaction points.</li>
                  <li>Distinguish between maintenance patterns and anomalous failure spikes.</li>
                  <li>Orchestrate system-wide protective actions if thresholds are met.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Minimized financial exposure to digital channel downtime.</li>
                  <li>Faster Mean-Time-to-Repair (MTTR) for critical infra failures.</li>
                  <li>Robust protection against localized network attacks.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- Operations Tab -->
        <div id="operations" class="tab-content">
          <div style="display: flex; justify-content: center;">
            <div class="use-case-card-alt" style="max-width: 800px; width: 100%;">
              <div style="display: flex; gap: 8px; margin-bottom: 16px;">
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: rgba(0, 200, 150, 0.1); color: var(--clr-primary); text-transform: uppercase; letter-spacing: 0.05em;">Enterprise</span>
                <span style="font-size: 0.7rem; font-weight: 700; padding: 4px 12px; border-radius: 99px; background: #f1f5f9; color: #64748b; text-transform: uppercase;">Visibility</span>
              </div>
              <h4>Global Operations Visibility</h4>
              <p class="scenario">Regional operations teams using different monitoring tools leads to a fragmented view of enterprise health and delayed global responses.</p>
              <div class="uc-section">
                <p class="uc-label">Blue Octopus Role</p>
                <ul class="uc-list">
                  <li>Consolidate regional event streams into a single source of truth.</li>
                  <li>Apply global correlation rules to identify cross-regional trends.</li>
                  <li>Centralized situational awareness with role-based dashboarding.</li>
                </ul>
              </div>
              <div class="uc-section">
                <p class="uc-label uc-label--impact">BUSINESS IMPACT</p>
                <ul class="uc-list">
                  <li>Standardized operational response across the entire organization.</li>
                  <li>Improved executive oversight of global business processes.</li>
                  <li>Reduced noise by eliminating redundant regional alerts.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Deployment & How It Works -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2" style="gap: 60px;">
        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 32px;">Operational <span class="grad-text">Journey</span></h2>
          <p style="color: var(--clr-light-muted); margin-bottom: 24px;">Blue Octopus orchestrates the lifecycle of business event intelligence from ingestion to resolution.</p>
          <div class="step-list">
            <div class="step-item">
              <span class="step-num">01</span>
              <div>
                <h6>Ingest</h6>
                <p>Collect and integrate data from logs, systems, sensors and external sources into a centralized event stream.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">02</span>
              <div>
                <h6>Detect</h6>
                <p>Identify anomalies and critical patterns using AI-driven event intelligence and correlation across multiple data sources.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">03</span>
              <div>
                <h6>Act</h6>
                <p>Trigger automated workflows, alerts and coordinated responses to manage incidents in real time.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">Ecosystem <span class="grad-text">Integration</span></h2>
          <p style="color: var(--clr-light-muted); margin-bottom: 24px;">Built to integrate with existing enterprise IT and Security ecosystems seamlessly:</p>
          <ul class="bullet-list">
            <li>Native log ingestion (syslog, app logs, security appliances)</li>
            <li>Bidirectional SIEM/SOAR and ticketing system integration</li>
            <li>Granular SSO/LDAP based role-base access (RBAC)</li>
            <li>Direct connection to DWH and Data Lake layers</li>
            <li>Advanced UI for custom BI and dashboarding integration</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Get in Touch</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.check-list, .bullet-list {
  list-style: none; padding: 0; margin: 0;
}
.check-list li, .bullet-list li {
  position: relative;
  padding-left: 28px;
  margin-bottom: 12px;
  color: var(--clr-light-muted);
  font-size: 0.95rem;
}
.check-list li::before {
  content: '✓';
  position: absolute; left: 0; top: 0;
  color: var(--clr-primary); font-weight: bold;
}
.bullet-list li::before {
  content: '';
  position: absolute; left: 0; top: 10px;
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--clr-primary);
}

/* Capabilities Modern */
.cap-card-modern {
  background: #fff;
  border: 1px solid #E2E8F0;
  border-radius: 20px;
  padding: 32px;
  transition: all 0.3s ease;
}
.cap-card-modern:hover {
  border-color: var(--clr-primary);
  transform: translateY(-4px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.cap-icon-box {
  width: 80px;
  height: 80px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
  transition: all 0.3s ease;
}
.cap-icon-box img {
  width: 48px;
  height: 48px;
  object-fit: contain;
}
.cap-card-modern h3 {
  font-size: 1.1rem;
  color: var(--clr-light-text);
  margin-bottom: 12px;
}
.cap-card-modern p {
  font-size: 0.9rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
}

/* Use Case Tabs */
.tabs-nav {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}
@media (max-width: 768px) {
  .tabs-nav {
    flex-wrap: nowrap !important;
    justify-content: flex-start;
    overflow-x: auto;
    gap: 8px;
    padding: 4px 10px 12px;
    margin-bottom: 24px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .tabs-nav::-webkit-scrollbar { display: none; }
  .tab-btn {
    padding: 10px 18px;
    font-size: 0.85rem;
    white-space: nowrap;
    flex-shrink: 0;
  }
}
.tab-btn {
  padding: 12px 24px;
  border-radius: 99px;
  background: #fff;
  border: 1px solid #e2e8f0;
  color: #64748b;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.3s ease;
}
.tab-btn:hover {
  border-color: var(--clr-primary);
  color: var(--clr-primary);
}
.tab-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
  box-shadow: 0 4px 12px rgba(0, 200, 150, 0.2);
}
.tab-content {
  display: none;
  animation: fadeIn 0.5s ease;
}
.tab-content.active {
  display: block;
}

/* Use Case Cards Alt */
.use-case-card-alt {
  background: #fff;
  border: 1px solid #E8EEF5;
  border-radius: 24px;
  padding: 40px;
  transition: all 0.3s ease;
  height: 100%;
}
.use-case-card-alt:hover {
  border-color: var(--clr-primary);
  box-shadow: 0 10px 30px rgba(0,0,0,0.04);
}
.use-case-card-alt h4 {
  font-size: 1.25rem;
  color: var(--clr-light-text);
  margin-bottom: 20px;
}
.use-case-card-alt .scenario {
  font-size: 1rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
  margin-bottom: 32px;
  padding-bottom: 24px;
  border-bottom: 1px solid #F1F5F9;
}
.uc-section { margin-bottom: 24px; }
.uc-label {
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.05em;
  color: var(--clr-primary);
  margin-bottom: 16px;
}
.uc-label--impact { color: #10B981; }
.uc-list { list-style: none; padding: 0; }
.uc-list li {
  position: relative;
  padding-left: 20px;
  margin-bottom: 10px;
  font-size: 0.95rem;
  color: var(--clr-light-muted);
}
.uc-list li::before {
  content: '•';
  position: absolute; left: 0; color: var(--clr-primary);
}

/* Step List */
.step-list { display: flex; flex-direction: column; gap: 32px; }
.step-item { display: flex; gap: 24px; align-items: flex-start; }
.step-num {
  font-size: 2rem; font-weight: 800;
  color: rgba(0, 200, 150, 0.15);
  line-height: 1;
}
.step-item h6 {
  font-size: 1.1rem; color: var(--clr-light-text);
  margin-bottom: 8px;
}
.step-item p { font-size: 0.95rem; color: var(--clr-light-muted); }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@media (max-width: 900px) {
  .grid-2 { grid-template-columns: 1fr; }
}
</style>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');

        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.remove('active'));

        tab.classList.add('active');
        const targetElement = document.getElementById(target as string);
        if (targetElement) {
          targetElement.classList.add('active');
        }
      });
    });
  }

  // Run on page load
  initTabs();

  // Run on view transition (for Astro)
  document.addEventListener('astro:page-load', initTabs);
</script>
