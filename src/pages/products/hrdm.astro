---
import Layout from '../../layouts/Layout.astro';

const siteUrl = "https://intellica-tech.github.io";
const breadcrumbs = [
  { name: "Products", url: `${siteUrl}/products` },
  { name: "HRDM", url: `${siteUrl}/products/hrdm` }
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "HRDM — Human Resources Data Model",
  "description": "Data warehouse model optimized for HR processes, workforce analytics, payroll, and talent management.",
  "applicationCategory": "BusinessApplication, DataModel",
  "operatingSystem": "Platform independent",
  "author": { "@id": `${siteUrl}/#organization` },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD"
  }
};
---

<Layout title="HRDM — Human Resources Data Model | Intellica" description="HRDM: Comprehensive data warehouse model for HR analytics; covering talent management, employee lifecycle, and workforce optimization." breadcrumbs={breadcrumbs}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label anim-fade-up">Data Models</div>
      <h1 class="anim-fade-up">HRDM — Human Resources <span class="grad-text">Data Model</span></h1>
      <p class="anim-fade-up">Empower your workforce with data-driven HR insights. Transform payroll, talent management, and employee lifecycle data into actionable strategic insights with our pre-modeled architecture.</p>
      <div class="hero-actions anim-fade-up" style="margin-top: 32px;">
        <a href="/contact" class="btn btn-primary btn-pill btn-lg">CONTACT US</a>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2" style="gap: 48px; align-items: start;">
        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px;">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">What does it <span class="grad-text">solve?</span></h2>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Problem</p>
            <p style="color: var(--clr-light-muted);">HR data is often locked in disparate systems (Payroll, LMS, ATS). Creating a unified view of the employee lifecycle for strategic workforce planning is complex and time-consuming.</p>
          </div>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Approach</p>
            <p style="color: var(--clr-light-muted);">HRDM provides a holistic, subject-oriented data model specifically designed for HR processes, enabling fast integration and standardized reporting across all personnel domains.</p>
          </div>
          <div>
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Business Value</p>
            <p style="color: var(--clr-light-muted);">Dramatically reduced analysis effort for HR reporting and significantly improved accuracy in workforce cost and turnover tracking.</p>
          </div>
        </div>

        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px; background: #f8fafc;">
          <h3 style="color: var(--clr-light-text); margin-bottom: 24px;">When is it <span class="grad-text">preferred?</span></h3>
          <ul class="check-list">
            <li>During HR system migrations or digital HR transformations</li>
            <li>When building executive HR dashboards (Turnover, Cost analysis, etc.)</li>
            <li>To support strategic workforce planning and talent gap analysis</li>
            <li>When standardizing HR KPIs across a global or distributed organization</li>
            <li>To improve the quality and consistency of personnel-related data assets</li>
          </ul>
          <p style="font-size: 0.85rem; color: var(--clr-light-muted); margin-top: 24px; font-style: italic;">Note: Privacy and data residency requirements are central to our deployment model.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities Section -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Capabilities</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">HR-Specific <span class="grad-text">Capabilities</span></h2>
      </div>

      <div class="grid-3 anim-fade-up" style="gap: 24px;">
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Employee 360</h3>
          <p>Integrated view of staff data from initial recruitment to terminal exit/retirement.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Org Hierarchy</h3>
          <p>Robust management of complex, time-varying organizational structures and reporting lines.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Payroll & Benefits</h3>
          <p>Standardized models for salary buckets, bonuses, and distributed benefit schemes.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Talent & Learning</h3>
          <p>Tracks employee skills, mandatory certifications, and professional learning progress.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Workforce Analytics</h3>
          <p>Ready-to-use schemas for detailed attrition, turnover, and diversity analysis.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Strategic Library</h3>
          <p>Pre-defined metrics for labor cost, productivity ratios, and recruitment efficiency.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture Image Section -->
  <section class="section section--dark noise">
    <div class="container">
      <div class="product-grid anim-fade-up">
        <div class="anim-fade-up">
          <h2 style="color: #fff; margin-bottom: 24px;">Layered <span class="grad-text">Architecture</span> Approach</h2>
          <p style="color: rgba(255,255,255,0.7); margin-bottom: 32px; font-size: 1.1rem; line-height: 1.7;">
            HRDM provides process-oriented descriptions and key attributes for core HR domains. This structure ensures a unified data language for workforce analytics, recruitment tracking, and performance management.
          </p>
          <div class="cap-card-modern" style="padding: 24px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
            <p style="font-weight: 700; color: #fff; margin-bottom: 8px;">Subject-Oriented Design</p>
            <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem;">Extensible framework covering Employee journey, Payroll, and Organizational structures.</p>
          </div>
        </div>
        <div class="anim-fade-up">
          <div class="img-frame">
            <img src="/assets/images/hrdm-architecture.png" alt="HRDM Architecture Approach" class="product-screenshot" />
          </div>
          <p style="text-align: center; font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 16px; font-style: italic;">
            HRDM Architecture: Unified workforce visualization and performance tracking layers.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Implementation & Ecosystem -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <h2 class="section-title" style="color: var(--clr-light-text);">Deployment & <span class="grad-text">Ecosystem</span> Integration</h2>
        <p class="section-sub" style="margin-inline: auto;">A standardized approach to ensure rapid value realization and seamless organizational fit.</p>
      </div>
      <div class="grid-2" style="gap: 60px;">
        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 32px;">Implementation <span class="grad-text">Journey</span></h2>
          <div class="step-list">
            <div class="step-item">
              <span class="step-num">01</span>
              <div>
                <h6>Data Discovery</h6>
                <p>Auditing existing HR systems (Workday, SAP SuccessFactors, local payroll systems).</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">02</span>
              <div>
                <h6>KPI Standardization</h6>
                <p>Defining unified formulas for turnover, absenteeism, and cost-per-hire.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">03</span>
              <div>
                <h6>Dashboard Activation</h6>
                <p>Deploying strategic dashboards for HR leaders and department managers.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">Integration & <span class="grad-text">Synergy</span></h2>
          <p style="color: var(--clr-light-muted); margin-bottom: 24px;">HRDM is built with strict privacy and integration standards in mind, ensuring a secure organizational fit:</p>
          <ul class="bullet-list">
            <li>GDPR / KVKK compliant data handling patterns</li>
            <li>Granular role-based access control (RBAC)</li>
            <li>Data masking and anonymization techniques for analytics</li>
            <li>Audit trails for all personnel-related data access</li>
            <li>Secure integration with internal identity management</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Accelerate Your <span class="grad-text">Data Model</span> Journey</h2>
        <p>Talk to our experts to learn how our industry-standard models can reduce your modeling time by over 50%.</p>
        <a href="/contact" class="btn btn-primary btn-pill btn-lg" style="margin-top: 40px;">CONTACT US</a>
      </div>
    </div>
  </section>
</Layout>

<style>
.check-list, .bullet-list {
  list-style: none; padding: 0; margin: 0;
}
.check-list li, .bullet-list li {
  position: relative;
  padding-left: 28px;
  margin-bottom: 12px;
  color: var(--clr-light-muted);
  font-size: 0.95rem;
}
.check-list li::before {
  content: '✓';
  position: absolute; left: 0; top: 0;
  color: var(--clr-primary); font-weight: bold;
}
.bullet-list li::before {
  content: '';
  position: absolute; left: 0; top: 10px;
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--clr-primary);
}

.cap-card-modern {
  padding: 32px;
  background: #fff;
  border: 1px solid #e8eef5;
  border-radius: 20px;
  transition: all 0.3s ease;
}
.cap-card-modern:hover {
  transform: translateY(-5px);
  border-color: var(--clr-primary);
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.cap-icon-box {
  width: 80px;
  height: 80px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
  transition: all 0.3s ease;
}
.cap-icon-box img {
  width: 44px;
  height: 44px;
  object-fit: contain;
}
.cap-card-modern h3 {
  font-size: 1.1rem;
  color: var(--clr-light-text);
  margin-bottom: 12px;
}
.cap-card-modern p {
  font-size: 0.9rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
}

.img-card {
  background: #fff;
  padding: 24px;
  border-radius: 24px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.img-card img {
  width: 100%;
  max-width: 900px;
  border-radius: 12px;
  border: 1px solid #eee;
}
.img-caption {
  margin-top: 16px; font-size: 0.9rem;
  color: var(--clr-light-muted); font-style: italic;
}

.step-list { display: flex; flex-direction: column; gap: 32px; }
.step-item { display: flex; gap: 24px; align-items: flex-start; }
.step-num {
  font-size: 2rem; font-weight: 800;
  color: rgba(0,200,150,0.15);
  line-height: 1;
}
.step-item h6 {
  font-size: 1.1rem; color: var(--clr-light-text);
  margin-bottom: 8px;
}
.step-item p { font-size: 0.95rem; color: var(--clr-light-muted); }

@media (max-width: 900px) {
  .grid-2 { grid-template-columns: 1fr; }
}
</style>
