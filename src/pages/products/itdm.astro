---
import Layout from '../../layouts/Layout.astro';

const siteUrl = "https://intellica-tech.github.io";
const breadcrumbs = [
  { name: "Products", url: `${siteUrl}/products` },
  { name: "ITDM", url: `${siteUrl}/products/itdm` }
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "ITDM — Intellica Telecom Data Model",
  "description": "Industry-specific data model for telecom operators covering network, billing, and CRM dimensioning to accelerate business intelligence.",
  "applicationCategory": "BusinessApplication, DataModel",
  "operatingSystem": "Platform independent",
  "author": { "@id": `${siteUrl}/#organization` },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD"
  }
};
---

<Layout title="ITDM — Intellica Telecom Data Model | Intellica" description="ITDM: Industry-standard telecom data warehouse model; TM Forum SID aligned, covering network, billing and CRM for rapid analytics deployment." breadcrumbs={breadcrumbs} hideCta={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="section-label anim-fade-up">Data Models</div>
      <h1 class="anim-fade-up">ITDM — Telecom <span class="grad-text">Data Model</span></h1>
      <p class="anim-fade-up">Scale your telecom analytics infrastructure globally. Accelerate your digital transformation and network intelligence with a pre-modeled industry data warehouse.</p>
      <div class="hero-actions anim-fade-up" style="margin-top: 32px;">
        <a href="/contact" class="btn btn-primary btn-pill btn-lg">CONTACT US</a>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2" style="gap: 48px; align-items: start;">
        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px;">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">What does it <span class="grad-text">solve?</span></h2>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Problem</p>
            <p style="color: var(--clr-light-muted);">Telecom data (CDR, Billing, Network, CRM) is massive and highly complex. Designing a sustainable model from scratch is slow and prone to architectural debt.</p>
          </div>
          <div style="margin-bottom: 24px;">
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Approach</p>
            <p style="color: var(--clr-light-muted);">ITDM provides an industry-standard, subject-oriented telecom data model (aligned with TM Forum SID) with pre-defined mapping templates for rapid implementation.</p>
          </div>
          <div>
            <p style="font-weight: 700; color: var(--clr-light-text); margin-bottom: 8px;">Business Value</p>
            <p style="color: var(--clr-light-muted);">Significant reduction in modeling effort, faster time-to-market for network insights, and global industry standardization.</p>
          </div>
        </div>

        <div class="card-light anim-fade-up" style="padding: 40px; border-radius: 24px; background: #f8fafc;">
          <h3 style="color: var(--clr-light-text); margin-bottom: 24px;">When is it <span class="grad-text">preferred?</span></h3>
          <ul class="check-list">
            <li>During major DWH/Data Lake migrations or modernizations</li>
            <li>When standardizing KPIs across multiple regional operators</li>
            <li>To accelerate 5G and network performance analytics projects</li>
            <li>When aligning with industry standards like TM Forum SID</li>
            <li>To bridge the gap between complex network data and business-ready insights</li>
          </ul>
          <p style="font-size: 0.85rem; color: var(--clr-light-muted); margin-top: 24px; font-style: italic;">Note: Scalability and deployment patterns are discussed during technical workshops.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Capabilities Section -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <div class="section-label" style="margin-inline: auto;">Capabilities</div>
        <h2 class="section-title" style="color: var(--clr-light-text);">Telecom-Specific <span class="grad-text">Capabilities</span></h2>
      </div>

      <div class="grid-3 anim-fade-up" style="gap: 24px;">
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>SID Alignment</h3>
          <p>Strictly aligned with TM Forum Shared Information/Data model standards.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Domain Overlap</h3>
          <p>Complete coverage for Voice, Data, SMS, Billing, VAS, and CRM data points.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>High Performance</h3>
          <p>Tailored for processing and indexing massive telco-scale CDR volumes.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Universal Dimensions</h3>
          <p>Standardized geography, time, customer, and product dimensions.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Telco Metrics</h3>
          <p>Ready-to-use business formulas for churn, ARPU, and network QoS/QoE.</p>
        </div>
        <div class="cap-card-modern">
          <div class="cap-icon-box"><img src="/assets/img/intellica_camlogo_icibos.png" alt="" /></div>
          <h3>Future Ready</h3>
          <p>Supports emerging technologies like 5G, IoT, and edge-native data assets.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture Image Section -->
  <section class="section section--dark noise">
    <div class="container">
      <div class="product-grid anim-fade-up">
        <div class="anim-fade-up">
          <h2 style="color: #fff; margin-bottom: 24px;">Layered <span class="grad-text">Architecture</span> Approach</h2>
          <p style="color: rgba(255,255,255,0.7); margin-bottom: 32px; font-size: 1.1rem; line-height: 1.7;">
            ITDM structures raw telecom protocols into business-meaningful subject areas, enabling cross-domain analysis. Our approach ensures alignment between network engineering and commercial intelligence.
          </p>
          <div class="cap-card-modern" style="padding: 24px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
            <p style="font-weight: 700; color: #fff; margin-bottom: 8px;">TM Forum SID Aligned</p>
            <p style="color: rgba(255,255,255,0.6); font-size: 0.95rem;">Subject-oriented structures covering network, billing, and CRM ecosystems.</p>
          </div>
        </div>
        <div class="anim-fade-up">
          <div class="img-frame">
            <img src="/assets/images/itdm-architecture.png" alt="ITDM Architecture Approach" class="product-screenshot" />
          </div>
          <p style="text-align: center; font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 16px; font-style: italic;">
            ITDM Logical Model: Bridging the gap between network engineering and commercial intelligence.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Implementation & Ecosystem -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <h2 class="section-title" style="color: var(--clr-light-text);">Deployment & <span class="grad-text">Ecosystem</span> Integration</h2>
        <p class="section-sub" style="margin-inline: auto;">A standardized approach to ensure rapid value realization and seamless organizational fit.</p>
      </div>
      <div class="grid-2" style="gap: 60px;">
        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 32px;">Implementation <span class="grad-text">Journey</span></h2>
          <div class="step-list">
            <div class="step-item">
              <span class="step-num">01</span>
              <div>
                <h6>Discovery & Mapping</h6>
                <p>Aligning source system schemas with ITDM's subject-oriented structures.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">02</span>
              <div>
                <h6>ETL/ELT Integration</h6>
                <p>Deploying automated pipelines to populate the foundation and analytical layers.</p>
              </div>
            </div>
            <div class="step-item">
              <span class="step-num">03</span>
              <div>
                <h6>Insight Activation</h6>
                <p>Enabling self-service BI and standard regulatory/commercial reporting.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="anim-fade-up">
          <h2 style="color: var(--clr-light-text); margin-bottom: 24px;">Integration & <span class="grad-text">Synergy</span></h2>
          <p style="color: var(--clr-light-muted); margin-bottom: 24px;">ITDM is designed to be technology-neutral, supporting major modern data stacks:</p>
          <ul class="bullet-list">
            <li>Cloud Data Warehouses (Snowflake, BigQuery, Databricks)</li>
            <li>Hadoop/Spark-based Data Lakes</li>
            <li>Traditional SQL Engines (Oracle, SQL Server, Teradata)</li>
            <li>Modern BI Tools (Tableau, Power BI, Looker)</li>
            <li>Network Probe & Mediation Systems</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Talk to an Expert</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.check-list, .bullet-list {
  list-style: none; padding: 0; margin: 0;
}
.check-list li, .bullet-list li {
  position: relative;
  padding-left: 28px;
  margin-bottom: 12px;
  color: var(--clr-light-muted);
  font-size: 0.95rem;
}
.check-list li::before {
  content: '✓';
  position: absolute; left: 0; top: 0;
  color: var(--clr-primary); font-weight: bold;
}
.bullet-list li::before {
  content: '';
  position: absolute; left: 0; top: 10px;
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--clr-primary);
}

.cap-card-modern {
  padding: 32px;
  background: #fff;
  border: 1px solid #e8eef5;
  border-radius: 20px;
  transition: all 0.3s ease;
}
.cap-card-modern:hover {
  transform: translateY(-5px);
  border-color: var(--clr-primary);
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.cap-icon-box {
  width: 80px;
  height: 80px;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
  transition: all 0.3s ease;
}
.cap-icon-box img {
  width: 48px;
  height: 48px;
  object-fit: contain;
}
.cap-card-modern h3 {
  font-size: 1.1rem;
  color: var(--clr-light-text);
  margin-bottom: 12px;
}
.cap-card-modern p {
  font-size: 0.9rem;
  color: var(--clr-light-muted);
  line-height: 1.6;
}

.img-card {
  background: #fff;
  padding: 24px;
  border-radius: 24px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.img-card img {
  width: 100%;
  max-width: 900px;
  border-radius: 12px;
  border: 1px solid #eee;
}
.img-caption {
  margin-top: 16px; font-size: 0.9rem;
  color: var(--clr-light-muted); font-style: italic;
}

.step-list { display: flex; flex-direction: column; gap: 32px; }
.step-item { display: flex; gap: 24px; align-items: flex-start; }
.step-num {
  font-size: 2rem; font-weight: 800;
  color: rgba(0,200,150,0.15);
  line-height: 1;
}
.step-item h6 {
  font-size: 1.1rem; color: var(--clr-light-text);
  margin-bottom: 8px;
}
.step-item p { font-size: 0.95rem; color: var(--clr-light-muted); }

@media (max-width: 900px) {
  .grid-2 { grid-template-columns: 1fr; }
}
</style>
