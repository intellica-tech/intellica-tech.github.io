---

<Layout title="Clients | Intellica" description="Trusted by leading enterprises across banking, telecom, public sector, and manufacturing." breadcrumbs={breadcrumbs}>
  
  <!-- SECTION 1 — HERO -->
  <section class="hero noise" id="clients-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">OUR CLIENTS</div>
          <h1 class="hero__title">Trusted by Enterprises <br /><span class="grad-text">Across Industries</span></h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">Intellica supports leading organizations in building modern data platforms, delivering advanced analytics and deploying production-grade AI solutions across multiple industries and regions.</p>
          <div class="hero__actions">
            <a href="/contact" class="btn btn-primary btn-pill btn-lg">Contact Us</a>
          </div>
        </div>
        
        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica Brand" class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3 — INDUSTRY TABS -->
  <section class="section section--light" id="industry-experience">
    <div class="container">
      <div class="text-center anim-fade-up" style="margin-bottom: 48px;">
        <h2 class="section-title" style="color:var(--clr-light-text);">Industry <span class="grad-text">Experience</span></h2>
        <p class="section-sub">Explore a selection of client engagements by industry.</p>
      </div>

      <div class="tabs-container anim-fade-up">
        <div class="tabs-nav" role="tablist">
          <button class="tab-btn active" data-target="all" role="tab" aria-selected="true">All</button>
          {sectors.map(sector => (
            <button class="tab-btn" data-target={sector.id} role="tab" aria-selected="false">{sector.title}</button>
          ))}
        </div>

        <div class="tabs-content">
          {sectors.map(sector => (
            <div class="tab-pane active" id={sector.id} role="tabpanel">
              <div class="sector-header" data-sector-name={sector.title}>
                <div class="outcomes-grid">
                  {sector.outcomes.map(outcome => (
                    <div class="outcome-item">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="check-icon">
                        <polyline points="20 6 9 17 4 12"></polyline>
                      </svg>
                      <span>{outcome}</span>
                    </div>
                  ))}
                </div>
              </div>
              <div class="sector-logos">
                {sector.logos.map(logo => (
                  <div class="logo-tile">
                    <img src={logo.src} alt={logo.name} loading="lazy" />
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4 — GLOBAL DELIVERY -->
  <section class="section section--dark global-delivery">
    <div class="delivery-bg"></div>
    <div class="container">
      <div class="grid-2 anim-fade-up" style="gap: 60px; align-items: center;">
        <div>
          <h2 class="section-title">Global <span class="grad-text">Project Experience</span></h2>
          <p style="color: rgba(255,255,255,0.7); font-size: 1.15rem; line-height: 1.7; margin-bottom: 40px;">
            Intellica delivers projects across Europe, the Middle East and Asia—supporting distributed teams and enterprise-scale architectures.
          </p>
          <div class="stats-row">
            <div class="stat-card">
              <span class="stat-num grad-text">20+</span>
              <span class="stat-lab">Countries</span>
            </div>
            <div class="stat-card">
              <span class="stat-num grad-text">100+</span>
              <span class="stat-lab">Professionals</span>
            </div>
            <div class="stat-card">
              <span class="stat-num grad-text">30+</span>
              <span class="stat-lab">Platforms</span>
            </div>
          </div>
        </div>
        <div class="presence-visual">
           <img src="/assets/img/global_data_ai_abstract_presence.png" alt="Global Operations" style="width: 100%; opacity: 0.8; filter: drop-shadow(0 0 40px var(--clr-primary));" />
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5 — WHAT CLIENTS ACHIEVE -->
  <section class="section section--white">
    <div class="container">
      <div class="grid-2 anim-fade-up" style="gap: 80px; align-items: center;">
        <div class="impact-visual">
          <img src="/assets/img/measurable_impact_v2.png" alt="Measurable Impact" style="border-radius: 40px; box-shadow: 0 40px 80px rgba(0,0,0,0.1);" />
        </div>
        <div>
          <h2 class="section-title" style="color:var(--clr-light-text);">Delivering <span class="grad-text">Measurable Impact</span></h2>
          <div class="impact-list">
            <div class="impact-item">
              <div class="impact-icon">01</div>
              <div class="impact-content">
                <h3>Higher data reliability</h3>
                <p>Establishing robust governance frameworks that ensure truth at every level.</p>
              </div>
            </div>
            <div class="impact-item">
              <div class="impact-icon">02</div>
              <div class="impact-content">
                <h3>Faster, accurate reporting</h3>
                <p>Reducing manual overhead and latency in decision-making cycles.</p>
              </div>
            </div>
            <div class="impact-item">
              <div class="impact-icon">03</div>
              <div class="impact-content">
                <h3>AI-ready foundation</h3>
                <p>Scalable infrastructure ready for production-grade agentic AI systems.</p>
              </div>
            </div>
            <div class="impact-item">
              <div class="impact-icon">04</div>
              <div class="impact-content">
                <h3>Operational efficiency</h3>
                <p>Driving cost savings and throughput through intelligent automation.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 6 — CTA -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Work With <span class="grad-text">Intellica</span></h2>
        <p>Let's explore how Intellica can help your organization unlock the value of data and build scalable analytics and AI capabilities.</p>
        <div class="cta-actions" style="margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
/* HERO: STANDARDIZED */
.hero { 
  min-height: 700px; display: flex; align-items: center; position: relative; overflow: hidden;
  background: linear-gradient(135deg, #162a4d 0%, #020617 100%);
}
.hero__inner { display: flex; align-items: center; justify-content: center; position: relative; width: 100%; height: 100%; }
.hero__content-wrap { display: grid; grid-template-columns: 1.25fr 0.75fr; align-items: center; gap: 40px; width: 100%; }
.hero__content { display: flex; flex-direction: column; align-items: flex-start; padding-block: 60px; }
.hero__title { font-size: clamp(2.5rem, 5.5vw, 4.8rem); font-weight: 950; line-height: 1.05; color: #fff; margin-bottom: 24px; letter-spacing: -0.05em; }
.hero__accent { display: block; width: 80px; height: 4px; border-radius: 4px; background: var(--grad-brand); margin-bottom: 32px; }
.hero__desc { font-size: 1.25rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85); max-width: 600px; margin-bottom: 48px; }
.hero__actions { display: flex; gap: 16px; flex-wrap: wrap; }
.hero__visual { display: flex; justify-content: center; align-items: center; }
.hero__shape-new { 
  width: 100%; max-width: 600px; 
  animation: float 8s ease-in-out infinite; 
  filter: drop-shadow(0 20px 80px rgba(0, 200, 150, 0.3)); 
  border-radius: 40px;
}

@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

/* LOADS */
.logo-wall {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 20px;
}
.logo-item {
  height: 100px;
  background: #fff;
  border: 1px solid #f1f5f9;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
  transition: all 0.3s ease;
}
.logo-item:hover {
  transform: scale(1.05);
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.logo-img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  filter: grayscale(1) opacity(0.6);
  transition: filter 0.3s ease;
}
.logo-item:hover .logo-img {
  filter: grayscale(0) opacity(1);
}

/* TABS */
.tabs-nav {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-bottom: 40px;
  flex-wrap: wrap;
}
.tab-btn {
  padding: 12px 24px;
  border-radius: 99px;
  background: #fff;
  border: 1px solid #e2e8f0;
  color: #64748b;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}
.tab-btn.active {
  background: var(--clr-primary);
  border-color: var(--clr-primary);
  color: #fff;
  box-shadow: 0 10px 20px rgba(0, 200, 150, 0.2);
}

.tabs-content { position: relative; min-height: 400px; }
.tab-pane {
  display: none;
  animation: fadeIn 0.4s ease;
  margin-bottom: 80px; /* Separation for 'All' view */
}
.tab-pane.active { display: block; }

.sector-header {
  background: #fff;
  padding: 30px;
  border-radius: 24px;
  margin-bottom: 40px;
  border-left: 6px solid var(--clr-primary);
  box-shadow: 0 10px 30px rgba(0,0,0,0.03);
}
.outcomes-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}
.outcome-item {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 0.95rem;
  font-weight: 600;
  color: #1e293b;
}
.check-icon { color: var(--clr-primary); flex-shrink: 0; }

.sector-logos {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16px;
  margin-bottom: 40px;
}
.logo-tile {
  background: #fff;
  height: 120px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  border: 1px solid #f1f5f9;
}
.logo-tile img { 
  width: auto;
  height: auto;
  max-width: 94%; 
  max-height: 80%; 
  object-fit: contain; 
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
.logo-tile:hover {
  border-color: var(--clr-primary);
  transform: translateY(-4px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.05);
}
.logo-tile:hover img { 
  transform: scale(1.05);
}

.is-all-view .sector-header::before {
  content: "Sector: " attr(data-sector-name);
  display: block;
  font-size: 0.75rem;
  font-weight: 800;
  color: var(--clr-primary);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin-bottom: 12px;
  opacity: 0.8;
}

/* GLOBAL DELIVERY */
.global-delivery { position: relative; overflow: hidden; }
.delivery-bg {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: radial-gradient(circle at 70% 50%, rgba(0, 240, 255, 0.05), transparent 60%);
}
.stats-row { display: flex; gap: 32px; flex-wrap: wrap; margin-top: 40px; }
.stat-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  padding: 24px;
  border-radius: 16px;
  min-width: 160px;
  backdrop-filter: blur(10px);
}
.stat-num { font-size: 2.5rem; font-weight: 900; display: block; line-height: 1; margin-bottom: 8px; }
.stat-lab { font-size: 0.9rem; color: rgba(255,255,255,0.5); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }

/* IMPACT */
.impact-list { display: grid; gap: 32px; margin-top: 40px; }
.impact-item { display: flex; gap: 24px; }
.impact-icon {
  width: 48px; height: 48px; border-radius: 12px;
  background: rgba(0, 200, 150, 0.1);
  color: var(--clr-primary);
  display: flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: 1.1rem; flex-shrink: 0;
}
.impact-content h3 { font-size: 1.25rem; color: #1e293b; margin-bottom: 4px; }
.impact-content p { font-size: 0.95rem; color: #64748b; line-height: 1.5; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

@media (max-width: 1024px) {
  .hero { min-height: 650px !important; }
  .hero__content-wrap {
    grid-template-columns: 1fr;
    text-align: left;
    position: relative;
    padding-top: 20px;
  }
  .hero__content { align-items: flex-start; }
  .hero__visual {
    position: absolute;
    top: 10px; 
    right: 15px;
    width: 90px;
    justify-content: flex-end;
    margin: 0;
    z-index: 10;
  }
  .hero__shape-new { max-width: 100%; opacity: 0.9; }
  .hero__desc { font-size: 1.15rem; max-width: 100%; margin-bottom: 24px; }
  .hero__title { font-size: clamp(2.2rem, 8vw, 3.5rem); margin-bottom: 16px; }
  .logo-wall { grid-template-columns: repeat(4, 1fr); }
  .sector-logos { grid-template-columns: repeat(4, 1fr); }
  .outcomes-grid { grid-template-columns: 1fr; }
}
@media (max-width: 768px) {
  .logo-wall { grid-template-columns: repeat(2, 1fr); }
  .sector-logos { grid-template-columns: repeat(3, 1fr); }
  .grid-2 { grid-template-columns: 1fr !important; }
}

</style>

<script>
  // Tab Logic
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabPanes = document.querySelectorAll('.tab-pane');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.getAttribute('data-target');
      
      // Update nav
      tabBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');

      // Update content
      tabPanes.forEach(pane => {
        if (target === 'all') {
          pane.style.display = 'block';
          pane.classList.add('active');
          pane.classList.add('is-all-view');
        } else {
          pane.classList.remove('is-all-view');
          if (pane.id === target) {
            pane.style.display = 'block';
            pane.classList.add('active');
          } else {
            pane.style.display = 'none';
            pane.classList.remove('active');
          }
        }
      });
    });
  });

  // Initial state: show all
  document.querySelector('.tab-btn[data-target="all"]')?.click();
</script>
