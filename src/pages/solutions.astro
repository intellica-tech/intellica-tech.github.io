      useCases: ["Steel/Copper/Plastics price forecasting", "Packaging cost (oil/sugar) prediction", "Equipment cost tracking based on global indices"],
      metrics: ["↑ Prediction accuracy", "↓ Cost variance", "↑ Negotiation power", "↑ Budget reliability", "↑ Strategic planning efficiency"],
      complexity: "Medium. Non-linear relationships, multivariate time series, and lagged macro signals.",
      users: "Procurement Managers, Category Buyers, Finance Teams",
      tech: "Multivariate Time Series, ML Forecasting, Macro Signal Processing"
    },
    "likelihood-to-buy": {
      title: "Likelihood to Buy",
      description: "Scores purchase propensities from past behaviors of existing or potential customers to optimize sales focus.",
      useCases: ["Prioritizing high-potential leads", "Increasing campaign targeting accuracy", "Proactive action with churn risk prediction"],
      metrics: ["↑ Campaign conversion rate", "↓ Cost-per-acquisition (CPA)", "↑ Customer Lifetime Value (CLTV)"],
      complexity: "Medium. Feature engineering, classification models, and regular scoring pipelines.",
      users: "Marketing Teams, Sales Managers, Growth Teams, Analysts",
      tech: "ML Classification (XGBoost, LightGBM), Feature Engineering"
    },
    "document-answers": {
      title: "Document Answers",
      description: "Performs intelligent search and summarization from corporate document pools (RFP, contracts, instructions) to provide instant answers.",
      useCases: ["Internal policy/procedure queries", "Extracting info from technical documents", "Contract comparison and summarization"],
      metrics: ["↓ Time to reach information", "↑ Response accuracy", "↓ Error rate in operations", "↑ Employee productivity", "↑ Information consistency"],
      complexity: "Medium-High. RAG (Retrieval-Augmented Generation) architecture and Vector DB.",
      users: "Ops Support, Legal/Compliance, HR, Technical Support, All Employees",
      tech: "LLM (GPT/OpenSource), Vector DB (Pinecone/Chroma), LangChain"
    },
    "defect-solver": {
      title: "AI Defect Solver",
      description: "Predicts failures hours in advance by analyzing sensor data to reduce unplanned downtime and increase production efficiency.",
      useCases: ["Predicting downtime in high-speed lines", "Failure prediction in robotic assembly/paint lines", "Early warning in temperature-sensitive processes"],
      metrics: ["↑ Prediction accuracy", "↑ Warning lead time", "↓ Annual cost", "↓ Downtime", "↑ Maintenance efficiency"],
      complexity: "High. Sensor data cleaning, time series features, and real-time inference.",
      users: "Maintenance Managers, Production Planning, Factory Management",
      tech: "ML Classification, Time Series Features, DL (LSTM/CNN), Ensemble"
    },
    "rolling-force": {
      title: "Rolling Force Optimization",
      description: "Predicts optimal rolling force using chemical composition, temperature, and mechanical properties to reduce passes and energy.",
      useCases: ["Optimal force prediction for each pass", "Reaching target thickness with minimum passes", "Scheduling based on steel grades"],
      metrics: ["↓ Number of passes (e.g., 15% reduction)", "↑ Rolling efficiency", "↓ Energy consumption", "↑ Throughput", "↓ Scrap & rework"],
      complexity: "Medium-High. Non-linear process modeling and control system integration.",
      users: "Production Engineers, Rolling Operators, Process Ops, Managers",
      tech: "ML/DL Regression, Physics-Informed Features, Optimization"
    },
    "energy-optimization": {
      title: "Real-Time Energy Optimization",
      description: "Monitors energy consumption in production, detects anomalies in real-time, and reduces excess consumption with parameter adjustments.",
      useCases: ["Optimizing furnace/dryer settings", "Efficiency optimization in high-consumption machines", "Temperature-pressure optimization in painting/test rooms"],
      metrics: ["↓ Energy expense", "↓ CO2 emissions", "↓ Detection time", "↑ System efficiency", "↑ Scalability"],
      complexity: "Medium-High. Multivariate time series anomaly + optimization + dashboard integration.",
      users: "Factory Engineers, Energy Managers, Production Managers",
      tech: "Unsupervised Anomaly Detection, Time Series (Drift), Sensor Fusion"
    }
  };

  function initBlueprintBrowser() {
    const strips = document.querySelectorAll('.bp-strip');
    const detailWidget = document.getElementById('bp-detail-widget');
    const detailInner = document.getElementById('bp-detail-inner');
    const detailCol = document.querySelector('.bp-detail-col');
    const closeBtn = document.getElementById('bp-close-detail');
    const browserFrame = document.querySelector('.bp-browser-frame');

    if (!strips.length || !detailWidget || !detailInner || !detailCol) return;

    function updateDetail(id) {
      const data = blueprintData[id];
      if (!data) return;

      detailInner.innerHTML = `
        <span class="dt-label">Detailed Solution</span>
        <h3 class="dt-title">${data.title}</h3>
        <p class="dt-desc">${data.description}</p>
        
        <div class="dt-sec">
          <div class="dt-h">Core Use Cases</div>
          <ul class="dt-list">
            ${data.useCases.map(uc => `<li>${uc}</li>`).join('')}
          </ul>
        </div>

        <div class="dt-sec">
          <div class="dt-h">Success Metrics</div>
          <ul class="dt-list">
            ${data.metrics.map(m => `<li>${m}</li>`).join('')}
          </ul>
        </div>

        <div class="dt-meta">
          <div class="dt-meta-i"><b>Complexity:</b> <p>${data.complexity}</p></div>
          <div class="dt-meta-i"><b>Users:</b> <p>${data.users}</p></div>
          <div class="dt-meta-i"><b>Tech Stack:</b> <p>${data.tech}</p></div>
        </div>
      `;
    }

    function closeDetail() {
      strips.forEach(s => s.classList.remove('active'));
      detailCol.classList.remove('active');
      detailWidget.classList.remove('active');
      if (browserFrame) browserFrame.classList.remove('detail-active');
      document.body.style.overflow = '';
    }

    strips.forEach(strip => {
      strip.addEventListener('click', (e) => {
        const id = strip.getAttribute('data-id');
        const isActive = strip.classList.contains('active');
        
        if (isActive) {
          closeDetail();
        } else {
          strips.forEach(s => s.classList.remove('active'));
          strip.classList.add('active');
          updateDetail(id);
          
          detailCol.classList.add('active');
          detailWidget.classList.add('active');
          if (browserFrame) browserFrame.classList.add('detail-active');
          
          if (window.innerWidth <= 1200) {
            document.body.style.overflow = 'hidden'; 
          } else {
            const originalGrid = document.querySelector('.bp-browser-grid');
            if (originalGrid) {
               let targetTop = strip.offsetTop;
               const widgetHeight = detailWidget.offsetHeight;
               const gridHeight = originalGrid.offsetHeight;
               if (targetTop + widgetHeight > gridHeight) targetTop = gridHeight - widgetHeight;
               detailWidget.style.top = `${Math.max(0, targetTop)}px`;
            }
          }
        }
        e.stopPropagation();
      });
    });

    if (closeBtn) {
      closeBtn.onclick = (e) => {
        closeDetail();
        e.stopPropagation();
      };
    }

    detailCol.onclick = (e) => {
      if (e.target === detailCol) closeDetail();
    };

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDetail();
    });

    // Auto-open from URL parameter
    const urlParams = new URLSearchParams(window.location.search);
    const autoId = urlParams.get('id');
    if (autoId) {
      const targetStrip = document.querySelector(`.bp-strip[data-id="${autoId}"]`) as HTMLElement;
      if (targetStrip) {
        setTimeout(() => {
          targetStrip.click();
          targetStrip.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 300); // 300ms delay to ensure everything is rendered
      }
    }
  }

  initBlueprintBrowser();
  document.addEventListener('astro:swap', initBlueprintBrowser);
  document.addEventListener('astro:after-swap', initBlueprintBrowser);
</script>
