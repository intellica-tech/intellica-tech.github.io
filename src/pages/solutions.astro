}
</style>

<script>
  const blueprintData = {
    "customer-360": {
      title: "AI-Assisted Customer 360",
      description: "Combines CRM, complaint, and demographic data to offer intelligent assistant (copilot) support for call center and field teams.",
      useCases: ["Predicting call reason before the call", "Billing resolution with proactive plan offers", "Personalized card blockage support offers"],
      metrics: ["↑ Sales/conversion per call", "↓ Average Handle Time (AHT)", "↑ Customer satisfaction score (NPS/CSAT)"],
      complexity: "High. Real-time data synthesis (CRM, logs) and intelligent assistant integration.",
      users: "Service Reps, Campaign Managers, Ops Teams, Management",
