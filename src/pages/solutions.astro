.dt-title { font-size: 2.2rem; font-weight: 950; color: #111827; margin-bottom: 20px; letter-spacing: -0.05em; line-height: 1.1; }
.dt-desc { font-size: 1.05rem; color: #475569; line-height: 1.6; margin-bottom: 32px; }
.dt-sec { margin-bottom: 32px; }
.dt-h { font-size: 0.8rem; font-weight: 950; color: #111827; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 16px; padding-left: 12px; border-left: 3px solid #00C896; }
.dt-list { list-style: none; padding: 0; margin: 0; }
.dt-list li { font-size: 1.05rem; color: #1E293B; margin-bottom: 12px; display: flex !important; align-items: flex-start !important; gap: 12px !important; line-height: 1.5; }
.dt-list li::before { content: "✔" !important; color: #00C896 !important; font-weight: 950 !important; flex-shrink: 0; display: inline-block !important; }
.dt-meta { display: grid; gap: 20px; border-top: 2px solid #F1F5F9; padding-top: 24px; margin-top: 10px; }
.dt-meta-i b { display: block; font-size: 0.8rem; font-weight: 950; color: #111827; margin-bottom: 6px; text-transform: uppercase; }
.dt-meta-i p { font-size: 1rem; color: #64748B; margin: 0; line-height: 1.5; }

/* Mobile detail close button */
.bp-detail-close {
  position: absolute; top: 16px; right: 16px;
  width: 44px; height: 44px; border-radius: 50%;
  background: #F1F5F9; color: #1E293B;
  display: none; align-items: center; justify-content: center;
  transition: 0.3s; z-index: 100; border: 1px solid #E2E8F0;
  cursor: pointer;
}
.bp-detail-close svg { width: 22px; height: 22px; pointer-events: none; stroke-width: 3; }
.bp-detail-close:hover { background: #00C896; color: #FFF; border-color: #00C896; }

@media (max-width: 1400px) {
  .bp-browser-grid { grid-template-columns: 1fr; gap: 48px; }
  
  /* CRITICAL: Disable parent transforms when detail is active on tablets/mobile */
  .bp-browser-frame.detail-active { transform: none !important; animation: none !important; }

  .bp-detail-col { 
     position: fixed !important; top: 0 !important; left: 0 !important; width: 100vw !important; height: 100vh !important;
     z-index: 9999999 !important; background: rgba(15,23,42,0.92) !important; 
     backdrop-filter: blur(12px) !important; display: flex !important;
     align-items: center !important; justify-content: center !important; padding: 20px !important;
  }
  .bp-detail-col.active { opacity: 1 !important; pointer-events: auto !important; visibility: visible !important; }

  .bp-detail-widget { 
    position: relative !important; top: auto !important; left: auto !important; right: auto !important;
    width: 100% !important; max-width: 600px !important; height: auto !important; 
    max-height: 85vh !important; overflow: hidden !important; display: flex !important; flex-direction: column !important;
    border-radius: 32px !important; padding: 24px !important;
    transform: translateY(20px) !important;
    opacity: 1 !important; pointer-events: auto !important;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6) !important;
  }
  #bp-detail-inner { overflow-y: auto !important; flex-grow: 1; padding-top: 48px; padding-bottom: 8px; margin-top: -32px; }
  .bp-detail-col.active .bp-detail-widget { transform: translateY(0) !important; }
  .bp-detail-close { display: flex !important; }
  
  .dt-title { font-size: 1.7rem !important; line-height: 1.1 !important; }
  .dt-desc { font-size: 1rem !important; margin-bottom: 24px !important; }
  .dt-meta { grid-template-columns: 1fr !important; gap: 12px; }
}
</style>

<script>
  const blueprintData = {
    "customer-360": {
      title: "AI-Assisted Customer 360",
      description: "Combines customer data sources to support intelligent decision-making for call center and field teams.",
      useCases: ["Predicting customer intent before interaction", "Personalized service recommendations", "Proactive issue resolution"],
      metrics: ["↑ Conversion per interaction", "↓ Average handle time", "↑ Customer satisfaction"],
      users: "Call Center Teams, Campaign Managers, Field Operations"
    },
    "demand-prediction": {
      title: "Demand Prediction",
      description: "Predicts demand patterns using time series and machine learning to improve workforce planning and service levels.",
      useCases: ["Forecasting call volumes and peak periods", "Planning staffing for campaigns", "Detecting demand spikes"],
      metrics: ["↑ Staffing accuracy", "↓ Waiting times", "↓ Overtime costs"],
      users: "Operations Teams, Workforce Planners, Call Center Managers"
    },
    "procurement-analytics": {
      title: "Procurement Analytics",
      description: "Predicts material and commodity price movements to improve purchasing timing, cost control and budget planning.",
      useCases: ["Raw material price forecasting", "Market-based purchasing optimization", "Budget planning and cost tracking"],
      metrics: ["↑ Prediction accuracy", "↓ Cost variance", "↑ Budget reliability"],
      users: "Procurement Teams, Category Managers, Finance Teams"
    },
    "likelihood-to-buy": {
      title: "Likelihood to Buy",
      description: "Identifies high-potential customers to improve targeting, conversion and campaign performance.",
      useCases: ["Lead prioritization", "Campaign targeting optimization", "Churn and upsell prediction"],
      metrics: ["↑ Campaign conversion rate", "↓ Cost per acquisition", "↑ Customer lifetime value"],
      users: "Marketing Teams, Sales Teams, Growth Teams"
    },
    "document-answers": {
      title: "Document Answers",
      description: "Enables intelligent search and summarization across enterprise documents such as contracts, policies and reports.",
      useCases: ["Policy and procedure queries", "Contract analysis and summarization", "Technical document search"],
      metrics: ["↓ Time to access information", "↑ Response accuracy", "↑ Employee productivity"],
      users: "Operations, Legal, HR, Customer Support Teams"
    },
    "defect-solver": {
      title: "AI Defect Solver",
      description: "Predicts failures in advance by analyzing sensor data to reduce downtime and improve production efficiency.",
      useCases: ["Failure prediction in production lines", "Early warning for critical equipment", "Maintenance optimization"],
      metrics: ["↑ Prediction accuracy", "↓ Downtime", "↓ Maintenance cost"],
      users: "Maintenance Teams, Production Managers, Plant Operations"
    },
    "rolling-force": {
      title: "Rolling Force Optimization",
      description: "Optimizes production parameters to reduce passes, lower energy consumption and improve output quality.",
      useCases: ["Optimal force prediction per production step", "Production parameter tuning", "Efficiency optimization"],
      metrics: ["↓ Number of passes", "↑ Production efficiency", "↓ Energy consumption"],
      users: "Production Engineers, Process Teams, Operations Managers"
    },
    "energy-optimization": {
      title: "Real-Time Energy Optimization",
      description: "Monitors and optimizes energy usage in real time to reduce cost, emissions and operational inefficiencies.",
      useCases: ["Real-time consumption monitoring", "Anomaly detection in energy usage", "Optimization of production parameters"],
      metrics: ["↓ Energy costs", "↓ CO2 emissions", "↑ System efficiency"],
      users: "Energy Managers, Production Teams, Plant Operations"
    }
  };

  function initBlueprintBrowser() {
    const strips = document.querySelectorAll('.bp-strip');
    const detailWidget = document.getElementById('bp-detail-widget');
    const detailInner = document.getElementById('bp-detail-inner');
    const detailCol = document.querySelector('.bp-detail-col');
    const closeBtn = document.getElementById('bp-close-detail');
    const browserFrame = document.querySelector('.bp-browser-frame');

    if (!strips.length || !detailWidget || !detailInner || !detailCol) return;

    function updateDetail(id) {
      const data = blueprintData[id];
      if (!data) return;

      detailInner.innerHTML = `
        <span class="dt-label" style="font-size:12px; letter-spacing:1px; color:var(--accent); margin-bottom:10px; display:block;">DETAILED SOLUTION</span>
        <h3 class="dt-title">${data.title}</h3>
        <p class="dt-desc">${data.description}</p>
        
        <div class="dt-sec">
          <div class="dt-h" style="font-weight:750; color:var(--text); margin-bottom:12px;">Key Use Cases</div>
          <ul class="dt-list">
            ${data.useCases.map(uc => `<li>${uc}</li>`).join('')}
          </ul>
        </div>

        <div class="dt-sec">
          <div class="dt-h" style="font-weight:750; color:var(--text); margin-bottom:12px;">Business Impact</div>
          <ul class="dt-list">
            ${data.metrics.map(m => `<li>${m}</li>`).join('')}
          </ul>
        </div>

        <div class="dt-meta" style="margin-top:24px; padding-top:24px; border-top:1px solid #F1F5F9;">
          <div class="dt-meta-i">
            <div style="font-weight:750; color:var(--text); margin-bottom:8px;">Primary Users</div>
            <p>${data.users}</p>
          </div>
        </div>
      `;
    }

    function closeDetail() {
      strips.forEach(s => s.classList.remove('active'));
      detailCol.classList.remove('active');
      detailWidget.classList.remove('active');
      if (browserFrame) browserFrame.classList.remove('detail-active');
      document.body.style.overflow = '';
    }

    strips.forEach(strip => {
      strip.addEventListener('click', (e) => {
        const id = strip.getAttribute('data-id');
        const isActive = strip.classList.contains('active');
        
        if (isActive) {
          closeDetail();
        } else {
          strips.forEach(s => s.classList.remove('active'));
          strip.classList.add('active');
          updateDetail(id);
          
          detailCol.classList.add('active');
          detailWidget.classList.add('active');
          if (browserFrame) browserFrame.classList.add('detail-active');
          
          if (window.innerWidth <= 1400) {
            document.body.style.overflow = 'hidden'; 
          } else {
            const originalGrid = document.querySelector('.bp-browser-grid');
            if (originalGrid) {
               let targetTop = strip.offsetTop;
               const widgetHeight = detailWidget.offsetHeight;
               const gridHeight = originalGrid.offsetHeight;
               if (targetTop + widgetHeight > gridHeight) targetTop = gridHeight - widgetHeight;
               detailWidget.style.top = `${Math.max(0, targetTop)}px`;
            }
          }
        }
        e.stopPropagation();
      });
    });

    if (closeBtn) {
      closeBtn.onclick = (e) => {
        closeDetail();
        e.stopPropagation();
      };
    }

    detailCol.onclick = (e) => {
      if (e.target === detailCol) closeDetail();
    };

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDetail();
    });

    // Auto-open from URL parameter
    const urlParams = new URLSearchParams(window.location.search);
    const autoId = urlParams.get('id');
    if (autoId) {
      const targetStrip = document.querySelector(`.bp-strip[data-id="${autoId}"]`) as HTMLElement;
      if (targetStrip) {
        setTimeout(() => {
          targetStrip.click();
          targetStrip.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }, 300); // 300ms delay to ensure everything is rendered
      }
    }
  }

  initBlueprintBrowser();
  document.addEventListener('astro:swap', initBlueprintBrowser);
  document.addEventListener('astro:after-swap', initBlueprintBrowser);
</script>
