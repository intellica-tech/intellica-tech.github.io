---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'Solutions', url: '/solutions' },
  { name: 'Data Platforms', url: '/data-platforms' }
];
---

<Layout 
  title="Modern Data Platforms | Intellica" 
  description="Design and build scalable data platforms that collect, organize and govern enterprise data. A modern data foundation for analytics, reporting and AI."
  breadcrumbs={breadcrumbs}
  hideCta={true}
>
  <!-- ===== HERO ===== -->
  <section class="hero noise" id="data-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">DATA PLATFORM</div>
          <h1 class="hero__title">Enterprise Data Platforms <br /><span class="grad-text">Built for AI</span></h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">
            Scalable architectures that collect, integrate and govern enterprise data — enabling analytics and AI at scale.
          </p>

          <div class="hero__actions">
            <a class="btn btn-primary btn-pill btn-lg" href="/contact">Get in Touch</a>
          </div>


        </div>

        <div class="hero__visual anim-fade-up">
          <img 
            src="/assets/img/data_platforms_hero_v2.png" 
            alt="Enterprise Data Platform Architecture" 
            class="hero__shape-new" 
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STRATEGIC OVERVIEW ===== -->
  <section class="section section--light" style="padding-top: 60px; padding-bottom: 80px;">
    <div class="container">
      <div class="grid-4 metrics-grid anim-fade-up">
        
        <div class="metric-card">
          <div class="metric-header">
            <div class="metric-dot teal"></div>
            <span>Strategic Assessment</span>
          </div>
          <div class="metric-body">
            <h3>Discovery & Architecture Design</h3>
            <p>We assess your current data landscape and define a scalable architecture and transformation path as the foundation of your data platform.</p>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-header">
            <div class="metric-dot blue"></div>
            <span>Modernization</span>
          </div>
          <div class="metric-body">
            <h3>Implementation</h3>
            <p>Modern DWH/Lakehouse architecture, performance optimization, and cost-efficient cloud migration.</p>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-header">
            <div class="metric-dot purple"></div>
            <span>Data Operations</span>
          </div>
          <div class="metric-body">
            <h3>Integration</h3>
            <p>End-to-end data engineering, orchestration pipelines, and scalable KPI / semantic layer design.</p>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-header">
            <div class="metric-dot amber"></div>
            <span>Sustained Quality</span>
          </div>
          <div class="metric-body">
            <h3>Governance</h3>
            <p>Ensuring data quality, consistency, and security across the entire enterprise data platform.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== WHY ===== -->
  <section class="section section--white" id="why">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Strategic Value</div>
        <h2 class="section-title">Why Modern Data Platforms <span class="grad-text">Matter</span></h2>
        <p class="section-sub">
          Analytics and AI initiatives create sustainable value only when built on a reliable, scalable and operable data foundation.
        </p>
      </div>

      <div class="grid-3 cap-grid anim-fade-up">
        <div class="card-light">
          <div class="icon-box">
             <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 44px; height: auto; position: relative; z-index: 2;" />
          </div>
          <h3>Reliable Data</h3>
          <p>Single source of truth, data quality controls and end-to-end traceability for trusted decisions.</p>
        </div>
        <div class="card-light">
          <div class="icon-box" style="background:rgba(59,130,246,0.1);border-color:rgba(59,130,246,0.2);">
             <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 44px; height: auto; position: relative; z-index: 2;" />
          </div>
          <h3>Scalable Analytics</h3>
          <p>Architectures that grow with your data volumes and analytical workloads without performance loss.</p>
        </div>
        <div class="card-light">
          <div class="icon-box" style="background:rgba(139,92,246,0.1);border-color:rgba(139,92,246,0.2);">
             <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 44px; height: auto; position: relative; z-index: 2;" />
          </div>
          <h3>Operational Sustainability</h3>
          <p>Security, access governance and cost management for long-term stability and ROI.</p>
        </div>
      </div>

      <div class="kpi-banner anim-fade-up">
        <div class="kpi-item"><b>Standardization</b><span>Metric/KPI dictionary, data model and integration standards</span></div>
        <div class="kpi-item"><b>Traceability</b><span>Lineage, flow visibility and auditability</span></div>
        <div class="kpi-item"><b>AI Readiness</b><span>Trusted, scalable data layer for analytics & AI</span></div>
      </div>
    </div>
  </section>

  <!-- ===== ARCHITECTURE ===== -->
  <section class="section section--dark" id="architecture" style="background: radial-gradient(circle at 50% 50%, #1a365d 0%, #020617 100%);">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">Modern Data Platform <span class="grad-text">Architecture</span></h2>
        <p class="section-sub" style="color: rgba(255,255,255,0.7);">
          We design enterprise data platforms with a layered architecture—covering ingestion, integration, storage and consumption.
        </p>
      </div>

      <div class="architecture-main anim-fade-up">
        <div class="card-glass archi-card-modern">
          <div class="archi-layers-grid">
            <div class="archi-layer-col">
              <div class="layer-title">SOURCES</div>
              <div class="layer-chip">CRM / ERP</div>
              <div class="layer-chip">Logs / Files</div>
              <div class="layer-chip">Web / API</div>
            </div>
            <div class="archi-arrow">→</div>
            <div class="archi-layer-col main-layer">
              <div class="layer-title">DATA PLATFORM ENGINE</div>
              <div class="platform-box">
                <div class="platform-row">
                  <div class="platform-segment">INGESTION</div>
                  <div class="platform-segment">INTEGRATION</div>
                </div>
                <div class="platform-row">
                  <div class="platform-segment destaque">WAREHOUSE / LAKEHOUSE</div>
                </div>
                <div class="platform-row">
                  <div class="platform-segment">GOVERNANCE</div>
                  <div class="platform-segment">QUALITY</div>
                </div>
              </div>
            </div>
            <div class="archi-arrow">→</div>
            <div class="archi-layer-col">
              <div class="layer-title">VALUE</div>
              <div class="layer-chip highlight">BI / AI</div>
              <div class="layer-chip highlight">Analytics</div>
              <div class="layer-chip highlight">Insights</div>
            </div>
          </div>
          <div class="archi-note" style="background: rgba(255,255,255,0.03); border-top: 1px solid rgba(255,255,255,0.1);">
            <p style="color: rgba(255,255,255,0.8);">A reliable, scalable, and AI-ready data foundation tailored for enterprise scale.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITIES ===== -->
  <section class="section section--white" id="capabilities">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Capabilities</div>
        <h2 class="section-title">Platform <span class="grad-text">Capabilities</span></h2>
        <p class="section-sub">We approach the platform holistically across architecture, governance and operations.</p>
      </div>

      <div class="grid-3 cap-grid anim-fade-up">
        <div class="card-light" id="integration">
          <h3>Data Integration</h3>
          <p>Unify data from operational systems, apps and external sources with reliable pipelines.</p>
        </div>
        <div class="card-light" id="warehouse">
          <h3>Data Warehousing</h3>
          <p>High-performance analytical storage for reporting and advanced analytics.</p>
        </div>
        <div class="card-light" id="lakehouse">
          <h3>Lakehouse Architecture</h3>
          <p>Scale storage and processing for both structured and unstructured data.</p>
        </div>
        <div class="card-light" id="governance">
          <h3>Data Governance</h3>
          <p>Quality, lineage, access management and compliance—built into the platform.</p>
        </div>
        <div class="card-light" id="quality">
          <h3>Data Quality</h3>
          <p>Consistency monitoring, quality gates and automated reconciliation.</p>
        </div>
        <div class="card-light">
          <h3>Semantic Layer</h3>
          <p>Business-friendly models and KPIs that enable consistent self-service analytics.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VENDOR-AGNOSTIC ===== -->
  <section class="section section--dark" id="vendor-agnostic" style="border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
    <div class="container">
      <div class="vendor-box anim-fade-up">
        <div class="vendor-content">
          <h2 class="section-title" style="text-align: left; color: #fff;">Vendor-Agnostic by <span class="grad-text">Design</span></h2>
          <p class="section-sub" style="text-align: left; margin-inline: 0; margin-bottom: 24px; color: rgba(255,255,255,0.8);">
            We are not tied to a single technology vendor. We evaluate alternatives and design the best-fit architecture based on your specific needs.
          </p>
          <ul class="check-list">
            <li style="color: rgba(255,255,255,0.7);">Data volumes and performance requirements</li>
            <li style="color: rgba(255,255,255,0.7);">Your existing ecosystem and constraints</li>
            <li style="color: rgba(255,255,255,0.7);">Scalability and flexibility needs</li>
            <li style="color: rgba(255,255,255,0.7);">Cost efficiency and operational sustainability</li>
          </ul>
          <div class="vendor-badge" style="background: rgba(0,200,150,0.1); color: var(--clr-primary); border: 1px solid rgba(0,200,150,0.2);">
            Future-proof platforms without lock-in — optimized for your business goals.
          </div>
        </div>
        <div class="vendor-visual">
          <div class="tech-glow-box">
            <img src="/assets/img/vendor_agnostic_hub.png" alt="Vendor-Agnostic Design" class="vendor-img" style="filter: drop-shadow(0 0 30px rgba(0,200,150,0.3)); border-radius: 20px;" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TECHNOLOGY ECOSYSTEM ===== -->
  <section class="section section--white" id="technology">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">Technology <span class="grad-text">Ecosystem</span></h2>
        <p class="section-sub">
          Representative technologies we work with — final architecture is selected based on client needs.
        </p>
      </div>

      <div class="architecture-main anim-fade-up">
        <div class="card-light archi-card">
          <img
            src="/assets/images/technology.png"
            alt="Technology Ecosystem"
            class="archi-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== INTELLICA SOLUTIONS ON TOP ===== -->
  <section class="section section--light" id="solutions-on-top">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">Intellica Solutions <span class="grad-text">on Top</span></h2>
        <p class="section-sub">Our products and AI solutions deliver value on top of a strong data foundation.</p>
      </div>

      <div class="grid-4 anim-fade-up">
        <a href="/products/icc" class="card-link">
          <div class="card-light prod-card">
            <h4>ICC</h4>
            <p>Enterprise data consistency and reconciliation controls for high-stakes environments.</p>
          </div>
        </a>
        <a href="/products/retouch" class="card-link">
          <div class="card-light prod-card">
            <h4>Retouch</h4>
            <p>Controlled data entry and master data validation workflows for operational excellence.</p>
          </div>
        </a>
        <a href="/products/talk-to-your-data" class="card-link">
          <div class="card-light prod-card">
            <h4>Talk To</h4>
            <p>Conversational analytics powered by natural language interaction with your data.</p>
          </div>
        </a>
        <a href="/solutions?id=document-answers#portfolio" class="card-link">
          <div class="card-light prod-card">
            <h4>Document Answers</h4>
            <p>AI-powered knowledge assistant for enterprise documents and verified information.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="section section--white" id="services">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Services</div>
        <h2 class="section-title">Data Platform <span class="grad-text">Services</span></h2>
        <p class="section-sub">Structured services designed to deliver, modernize, and operate enterprise data platforms at scale.</p>
      </div>

      <div class="grid-2 services-grid anim-fade-up">
        <div class="card-light service-card accent-teal">
          <div class="service-h">
            <div class="serv-icon-wrapper">
              <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" class="serv-logo" />
            </div>
            <h3>Data Platform Assessment & Roadmap</h3>
          </div>
          <ul class="serv-list">
            <li>Assessment of your current data architecture and maturity</li>
            <li>Identification of gaps, risks and improvement areas</li>
            <li>Target architecture and technology recommendations</li>
            <li>Phased roadmap with priorities, quick wins and business impact</li>
          </ul>
        </div>

        <div class="card-light service-card accent-blue">
          <div class="service-h">
            <div class="serv-icon-wrapper">
              <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" class="serv-logo" />
            </div>
            <h3>Implementation / Modernization</h3>
          </div>
          <ul class="serv-list">
            <li>DWH/Lakehouse design and development</li>
            <li>Integration pipelines, orchestration and automation</li>
            <li>Modeling, semantic layer and KPI dictionary</li>
            <li>Governance framework and operating model</li>
          </ul>
        </div>

        <div class="card-light service-card">
          <div class="service-h">
            <div class="serv-icon-wrapper">
              <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" class="serv-logo" />
            </div>
            <h3>Migration</h3>
          </div>
          <ul class="serv-list">
            <li>Migration strategy (parallel run, cutover, rollback)</li>
            <li>Data validation and reconciliation</li>
            <li>Standardization of models and naming conventions</li>
            <li>BI/reporting dependency adaptation</li>
          </ul>
        </div>

        <div class="card-light service-card">
          <div class="service-h">
            <div class="serv-icon-wrapper">
              <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" class="serv-logo" />
            </div>
            <h3>Managed Services</h3>
          </div>
          <ul class="serv-list">
            <li>Flexible squads: architect, data engineer, analyst</li>
            <li>Monitoring, performance and reliability improvements</li>
            <li>SLA/SLO, incident and capacity management</li>
            <li>Cost optimization and continuous improvement</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== DELIVERY APPROACH ===== -->
  <section class="section section--light" id="delivery">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title"><span class="grad-text">Delivery</span> Approach</h2>
        <p class="section-sub">We deliver in phases with measurable outcomes and production-ready releases.</p>
      </div>

      <div class="grid-4 anim-fade-up delivery-steps">
        <div class="d-step">
          <div class="d-num">1</div>
          <div class="d-info">
            <h4>Discovery</h4>
            <p>Clarify data sources, requirements and constraints.</p>
          </div>
        </div>
        <div class="d-step">
          <div class="d-num">2</div>
          <div class="d-info">
            <h4>Design</h4>
            <p>Define target architecture, modeling and security approach.</p>
          </div>
        </div>
        <div class="d-step">
          <div class="d-num">3</div>
          <div class="d-info">
            <h4>Implement</h4>
            <p>Build the platform, pipelines and governance framework.</p>
          </div>
        </div>
        <div class="d-step">
          <div class="d-num">4</div>
          <div class="d-info">
            <h4>Operate</h4>
            <p>Monitor, optimize and sustain the platform via managed services.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip anim-fade-up">
        <h2>Ready to Transform Your <span class="grad-text">Data?</span></h2>
        <p>From data platforms to AI solutions, we help organizations turn data into measurable business value.</p>
        <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; margin-top: 32px;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Get in Touch</a>
          <a class="btn btn-ghost btn-pill btn-lg" href="/clients">View Clients</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Render Image */
  .hero-render {
    width: 100%;
    max-width: 600px;
    border-radius: 32px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6), 0 0 40px rgba(0,200,150,0.2);
    animation: float 8s ease-in-out infinite;
    display: block;
    margin: 0 auto;
  }

  /* Metric/Deliver Cards */
  .metrics-grid {
    gap: 16px;
  }
  .metric-card {
    background: #ffffff;
    border: 1px solid #E8EEF5;
    border-radius: 24px;
    padding: 24px;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }
  .metric-card:hover {
    background: #ffffff;
    border-color: rgba(0,200,150,0.3);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  }
  .metric-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .metric-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--clr-primary);
    box-shadow: 0 0 10px rgba(0, 200, 150, 0.4);
  }
  .metric-dot.blue { background: #3b82f6 !important; box-shadow: 0 0 10px rgba(59, 130, 246, 0.5) !important; }
  .metric-dot.purple { background: #8b5cf6 !important; box-shadow: 0 0 10px rgba(139, 92, 246, 0.5) !important; }
  .metric-dot.teal { background: #00c896 !important; box-shadow: 0 0 10px rgba(0, 200, 150, 0.5) !important; }
  .metric-dot.amber { background: #ff9800 !important; box-shadow: 0 0 10px rgba(255, 152, 0, 0.5) !important; }
  
  .metric-header span {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-light-muted);
  }
  .metric-body h3 {
    font-size: 1.1rem;
    color: var(--clr-light-text);
    margin-bottom: 8px;
    font-weight: 800;
  }
  .metric-body p {
    font-size: 0.9rem;
    color: var(--clr-light-muted);
    line-height: 1.5;
    margin: 0;
  }
  /* HERO: STANDARDIZED */
  .hero-disabled { 
    min-height: 800px; display: flex; align-items: center; position: relative; overflow: hidden;
    background: linear-gradient(135deg, #162a4d 0%, #020617 100%);
  }
  .hero-disabled__inner { 
    display: flex; align-items: center; justify-content: center; position: relative; width: 100%; 
  }
  .hero-disabled__content-wrap { 
    display: grid; grid-template-columns: 1.2fr 0.8fr; align-items: center; gap: 40px; width: 100%; 
  }
  .hero-disabled__content { 
    display: flex; flex-direction: column; align-items: flex-start; padding-block: 60px; 
  }
  .hero-disabled__title { 
    font-size: clamp(2.5rem, 5.5vw, 4.8rem); font-weight: 950; line-height: 1.05; color: #fff; margin-bottom: 24px; letter-spacing: -0.05em; 
  }
  .hero-disabled__accent { 
    display: block; width: 80px; height: 4px; border-radius: 4px; background: var(--grad-brand); margin-bottom: 32px; 
  }
  .hero-disabled__desc { 
    font-size: 1.25rem; line-height: 1.6; color: rgba(255, 255, 255, 0.85); max-width: 600px; margin-bottom: 48px; 
  }
  .hero-disabled__actions { 
    display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 48px;
  }
  .pills-row {
    display: flex; flex-wrap: wrap; gap: 12px;
  }
  .pill {
    padding: 8px 16px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 100px;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.7);
    font-weight: 500;
  }
  .hero-disabled__visual { 
    display: flex; justify-content: center; align-items: center; 
  }
  .hero-disabled__shape-new { 
    width: 100%; max-width: 600px; 
    filter: drop-shadow(0 20px 80px rgba(0, 200, 150, 0.2)); 
    animation: float 8s ease-in-out infinite;
    border-radius: 32px; /* Standardized large radius for desktop */
    overflow: hidden;
  }

  @keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-20px); } 100% { transform: translateY(0px); } }

  @media (max-width: 1100px) {
    .hero-disabled { min-height: auto !important; padding-top: 5px !important; padding-bottom: 25px !important; height: auto; }
    .hero-disabled__inner { padding-top: 0; }
    .hero-disabled__content-wrap {
      grid-template-columns: 1fr;
      text-align: left;
      position: relative;
      display: flex;
      flex-direction: column;
    }
    .hero-disabled__content { align-items: flex-start; padding-block: 10px; }
    .hero-disabled__visual {
      position: absolute;
      top: 5px; 
      right: 5px;
      width: 80px;
      height: 80px;
      margin: 0;
      z-index: 10;
      display: flex;
      justify-content: flex-end;
      align-items: flex-start;
    }
    .hero-disabled__shape-new { 
      width: 100%;
      height: auto;
      opacity: 1; 
      border-radius: 16px; 
      filter: drop-shadow(0 4px 12px rgba(0, 200, 150, 0.25));
    }
    .hero-disabled__desc { font-size: 1.1rem; max-width: 100%; margin-bottom: 24px; }
    .hero-disabled__title { font-size: 2.22rem; margin-bottom: 16px; padding-right: 80px; line-height: 1.15; }
    .hero-disabled__actions { margin-bottom: 24px; }
  }

  @media (max-width: 1100px) {
    .architecture-main { overflow-x: auto; -webkit-overflow-scrolling: touch; margin-inline: -10px; padding-inline: 10px; }
    .archi-card-modern { padding: 40px 24px; border-radius: 20px; width: max-content; min-width: 100%; }
    .archi-img { width: 100%; max-width: 100%; border-radius: 16px; }
    .kpi-banner { 
      grid-template-columns: 1fr; 
