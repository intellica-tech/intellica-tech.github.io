---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'Solutions', url: '/solutions' },
  { name: 'Data Platforms', url: '/data-platforms' }
];
---

<Layout 
  title="Modern Data Platforms | Intellica" 
  description="Design and build scalable data platforms that collect, organize and govern enterprise data. A modern data foundation for analytics, reporting and AI."
  breadcrumbs={breadcrumbs}
>
  <!-- ===== HERO ===== -->
  <section class="hero noise" id="data-hero">
    <div class="container hero-grid">
      <div class="hero-content anim-fade-up">
        <div class="section-label">DATA PLATFORM</div>
        <h1 class="hero-title">Enterprise Data Platforms <br /><span class="grad-text">Built for AI</span></h1>
        <p class="hero-desc">
          Scalable architectures that collect, integrate and govern enterprise data — enabling analytics and AI at scale.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Contact Us</a>
        </div>

        <div class="pills-row">
          <span class="pill">Assessment & Roadmap</span>
          <span class="pill">Migration & Modernization</span>
          <span class="pill">Lakehouse Architecture</span>
        </div>
      </div>

      <div class="hero-visual anim-fade-up">
        <img 
          src="/assets/img/data_platform_hero_architecture.png" 
          alt="Data Platform Architecture Flow" 
          class="hero-render" 
        />
      </div>
    </div>
  </section>

  <!-- ===== STRATEGIC OVERVIEW ===== -->
  <section class="section section--white" style="padding-top: 20px; padding-bottom: 80px;">
    <div class="container">
      <div class="grid-4 metrics-grid anim-fade-up">
        
        <div class="metric-card">
          <div class="metric-header">
            <div class="metric-dot"></div>
            <span>Strategic Assessment</span>
          </div>
          <div class="metric-body">
            <h3>Assessment & Roadmap</h3>
            <p>Current state analysis, target architecture design, and prioritized transformation planning.</p>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-header">
            <div class="metric-dot blue"></div>
            <span>Modernization</span>
          </div>
          <div class="metric-body">
            <h3>Implementation</h3>
            <p>Modern DWH/Lakehouse architecture, performance optimization, and cost-efficient cloud migration.</p>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-header">
            <div class="metric-dot purple"></div>
            <span>Data Operations</span>
          </div>
          <div class="metric-body">
            <h3>Integration</h3>
            <p>End-to-end data engineering, orchestration pipelines, and scalable KPI / semantic layer design.</p>
          </div>
        </div>

        <div class="metric-card">
          <div class="metric-header">
            <div class="metric-dot teal"></div>
            <span>Sustained Quality</span>
          </div>
          <div class="metric-body">
            <h3>Governance</h3>
            <p>Ensuring data quality, consistency, and security across the entire enterprise data platform.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== WHY ===== -->
  <section class="section section--white" id="why">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Strategic Value</div>
        <h2 class="section-title">Why Modern Data Platforms <span class="grad-text">Matter</span></h2>
        <p class="section-sub">
          Analytics and AI initiatives create sustainable value only when built on a reliable, scalable and operable data foundation.
        </p>
      </div>

      <div class="grid-3 cap-grid anim-fade-up">
        <div class="card-light">
          <div class="icon-box">
             <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 44px; height: auto; position: relative; z-index: 2;" />
          </div>
          <h3>Reliable Data</h3>
          <p>Single source of truth, data quality controls and end-to-end traceability for trusted decisions.</p>
        </div>
        <div class="card-light">
          <div class="icon-box" style="background:rgba(59,130,246,0.1);border-color:rgba(59,130,246,0.2);">
             <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 44px; height: auto; position: relative; z-index: 2;" />
          </div>
          <h3>Scalable Analytics</h3>
          <p>Architectures that grow with your data volumes and analytical workloads without performance loss.</p>
        </div>
        <div class="card-light">
          <div class="icon-box" style="background:rgba(139,92,246,0.1);border-color:rgba(139,92,246,0.2);">
             <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" style="width: 44px; height: auto; position: relative; z-index: 2;" />
          </div>
          <h3>Operational Sustainability</h3>
          <p>Security, access governance and cost management for long-term stability and ROI.</p>
        </div>
      </div>

      <div class="kpi-banner anim-fade-up">
        <div class="kpi-item"><b>Standardization</b><span>Metric/KPI dictionary, data model and integration standards</span></div>
        <div class="kpi-item"><b>Traceability</b><span>Lineage, flow visibility and auditability</span></div>
        <div class="kpi-item"><b>AI Readiness</b><span>Trusted, scalable data layer for analytics & AI</span></div>
      </div>
    </div>
  </section>

  <!-- ===== ARCHITECTURE ===== -->
  <section class="section section--light" id="architecture">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">Modern Data Platform <span class="grad-text">Architecture</span></h2>
        <p class="section-sub">
          We design enterprise data platforms with a layered architecture—covering ingestion, integration, storage and consumption.
        </p>
      </div>

      <div class="architecture-main anim-fade-up">
        <div class="card-light archi-card">
          <img
            src="/assets/img/modern_data_platform_architecture_blueprint.png"
            alt="Modern Data Platform Architecture"
            class="archi-img"
          />
          <div class="archi-note">
            <p>A modern data platform enables reliable analytics, scalable processing and AI-ready data foundations.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITIES ===== -->
  <section class="section section--white" id="capabilities">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Capabilities</div>
        <h2 class="section-title">Platform <span class="grad-text">Capabilities</span></h2>
        <p class="section-sub">We approach the platform holistically across architecture, governance and operations.</p>
      </div>

      <div class="grid-3 cap-grid anim-fade-up">
        <div class="card-light">
          <h3>Data Integration</h3>
          <p>Unify data from operational systems, apps and external sources with reliable pipelines.</p>
        </div>
        <div class="card-light">
          <h3>Data Warehousing</h3>
          <p>High-performance analytical storage for reporting and advanced analytics.</p>
        </div>
        <div class="card-light">
          <h3>Lakehouse Architecture</h3>
          <p>Scale storage and processing for both structured and unstructured data.</p>
        </div>
        <div class="card-light">
          <h3>Data Governance</h3>
          <p>Quality, lineage, access management and compliance—built into the platform.</p>
        </div>
        <div class="card-light">
          <h3>Real-Time Data</h3>
          <p>Streaming pipelines that enable real-time analytics and operational insights.</p>
        </div>
        <div class="card-light">
          <h3>Semantic Layer</h3>
          <p>Business-friendly models and KPIs that enable consistent self-service analytics.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VENDOR-AGNOSTIC ===== -->
  <section class="section section--dark" id="vendor-agnostic">
    <div class="container">
      <div class="vendor-box anim-fade-up">
        <div class="vendor-content">
          <h2 class="section-title" style="text-align: left; color: #fff;">Vendor-Agnostic by <span class="grad-text">Design</span></h2>
          <p class="section-sub" style="text-align: left; margin-inline: 0; margin-bottom: 24px;">
            We are not tied to a single technology vendor. We evaluate alternatives and design the best-fit architecture based on your specific needs.
          </p>
          <ul class="check-list">
            <li>Data volumes and performance requirements</li>
            <li>Your existing ecosystem and constraints</li>
            <li>Scalability and flexibility needs</li>
            <li>Cost efficiency and operational sustainability</li>
          </ul>
          <div class="vendor-badge">
            Future-proof platforms without lock-in — optimized for your business goals.
          </div>
        </div>
        <div class="vendor-visual">
          <img src="/assets/images/dataplatform.png" alt="Data Platform Vendor-Agnostic" class="vendor-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TECHNOLOGY ECOSYSTEM ===== -->
  <section class="section section--white" id="technology">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">Technology <span class="grad-text">Ecosystem</span></h2>
        <p class="section-sub">
          Representative technologies we work with — final architecture is selected based on client needs.
        </p>
      </div>

      <div class="architecture-main anim-fade-up">
        <div class="card-light archi-card">
          <img
            src="/assets/images/technology.png"
            alt="Technology Ecosystem"
            class="archi-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== INTELLICA SOLUTIONS ON TOP ===== -->
  <section class="section section--light" id="solutions-on-top">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">Intellica Solutions <span class="grad-text">on Top</span></h2>
        <p class="section-sub">Our products and AI solutions deliver value on top of a strong data foundation.</p>
      </div>

      <div class="grid-4 anim-fade-up">
        <a href="/products/icc" class="card-link">
          <div class="card-light prod-card">
            <h4>ICC</h4>
            <p>Enterprise data consistency and reconciliation controls for high-stakes environments.</p>
          </div>
        </a>
        <a href="/products/retouch" class="card-link">
          <div class="card-light prod-card">
            <h4>Retouch</h4>
            <p>Controlled data entry and master data validation workflows for operational excellence.</p>
          </div>
        </a>
        <a href="/products/talk-to-your-data" class="card-link">
          <div class="card-light prod-card">
            <h4>TalkTo</h4>
            <p>Conversational analytics powered by natural language interaction with your data.</p>
          </div>
        </a>
        <a href="/solutions?id=document-answers#portfolio" class="card-link">
          <div class="card-light prod-card">
            <h4>Document Answers</h4>
            <p>AI-powered knowledge assistant for enterprise documents and verified information.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="section section--white" id="services">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Services</div>
        <h2 class="section-title">Our <span class="grad-text">Services</span></h2>
        <p class="section-sub">From strategy to operations—end-to-end delivery for your data platform journey.</p>
      </div>

      <div class="grid-2 services-grid anim-fade-up">
        <div class="card-light service-card accent-teal">
          <div class="service-h">
            <div class="serv-icon-wrapper">
              <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" class="serv-logo" />
            </div>
            <h3>Assessment & Roadmap</h3>
          </div>
          <ul class="serv-list">
            <li>Current state & maturity assessment</li>
            <li>Target architecture and technology options</li>
            <li>Prioritized roadmap with phases and quick wins</li>
            <li>Risks, dependencies and delivery plan</li>
          </ul>
        </div>

        <div class="card-light service-card accent-blue">
          <div class="service-h">
            <div class="serv-icon-wrapper">
              <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" class="serv-logo" />
            </div>
            <h3>Implementation / Modernization</h3>
          </div>
          <ul class="serv-list">
            <li>DWH/Lakehouse design and development</li>
            <li>Integration pipelines, orchestration and automation</li>
            <li>Modeling, semantic layer and KPI dictionary</li>
            <li>Governance framework and operating model</li>
          </ul>
        </div>

        <div class="card-light service-card">
          <div class="service-h">
            <div class="serv-icon-wrapper">
              <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" class="serv-logo" />
            </div>
            <h3>Migration</h3>
          </div>
          <ul class="serv-list">
            <li>Migration strategy (parallel run, cutover, rollback)</li>
            <li>Data validation and reconciliation</li>
            <li>Standardization of models and naming conventions</li>
            <li>BI/reporting dependency adaptation</li>
          </ul>
        </div>

        <div class="card-light service-card">
          <div class="service-h">
            <div class="serv-icon-wrapper">
              <img src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica" class="serv-logo" />
            </div>
            <h3>Managed Services</h3>
          </div>
          <ul class="serv-list">
            <li>Flexible squads: architect, data engineer, analyst</li>
            <li>Monitoring, performance and reliability improvements</li>
            <li>SLA/SLO, incident and capacity management</li>
            <li>Cost optimization and continuous improvement</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== DELIVERY APPROACH ===== -->
  <section class="section section--light" id="delivery">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title"><span class="grad-text">Delivery</span> Approach</h2>
        <p class="section-sub">We deliver in phases with measurable outcomes and production-ready releases.</p>
      </div>

      <div class="grid-4 anim-fade-up delivery-steps">
        <div class="d-step">
          <div class="d-num">1</div>
          <div class="d-info">
            <h4>Discovery</h4>
            <p>Clarify data sources, requirements and constraints.</p>
          </div>
        </div>
        <div class="d-step">
          <div class="d-num">2</div>
          <div class="d-info">
            <h4>Design</h4>
            <p>Define target architecture, modeling and security approach.</p>
          </div>
        </div>
        <div class="d-step">
          <div class="d-num">3</div>
          <div class="d-info">
            <h4>Implement</h4>
            <p>Build the platform, pipelines and governance framework.</p>
          </div>
        </div>
        <div class="d-step">
          <div class="d-num">4</div>
          <div class="d-info">
            <h4>Operate</h4>
            <p>Monitor, optimize and sustain the platform via managed services.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section section--white">
    <div class="container">
      <div class="card-light cta-card text-center anim-fade-up">
        <h2 class="section-title" style="margin-bottom: 20px;">Build Your Data Platform <span class="grad-text">Strategy</span> with Intellica</h2>
        <p class="section-sub" style="margin-bottom: 32px;">
          Let's assess your current architecture, define the target platform and plan a roadmap that enables analytics and AI at scale.
        </p>
        <div class="hero-actions" style="justify-content: center;">
          <a class="btn btn-primary btn-pill btn-lg" href="/contact">Contact Us</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Render Image */
  .hero-render {
    width: 100%;
    max-width: 600px;
    border-radius: 32px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6), 0 0 40px rgba(0,200,150,0.2);
    animation: float 8s ease-in-out infinite;
    display: block;
    margin: 0 auto;
  }

  /* Metric/Deliver Cards */
  .metrics-grid {
    gap: 16px;
  }
  .metric-card {
    background: #ffffff;
    border: 1px solid #E8EEF5;
    border-radius: 24px;
    padding: 24px;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
  }
  .metric-card:hover {
    background: #ffffff;
    border-color: rgba(0,200,150,0.3);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
  }
  .metric-header {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .metric-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--clr-primary);
    box-shadow: 0 0 10px rgba(0, 200, 150, 0.4);
  }
  .metric-dot.blue { background: #3b82f6; box-shadow: 0 0 10px rgba(59, 130, 246, 0.4); }
  .metric-dot.purple { background: #8b5cf6; box-shadow: 0 0 10px rgba(139, 92, 246, 0.4); }
  .metric-dot.teal { background: #14b8a6; box-shadow: 0 0 10px rgba(20, 184, 166, 0.4); }
  
  .metric-header span {
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clr-light-muted);
  }
  .metric-body h3 {
    font-size: 1.1rem;
    color: var(--clr-light-text);
    margin-bottom: 8px;
    font-weight: 800;
  }
  .metric-body p {
    font-size: 0.9rem;
    color: var(--clr-light-muted);
    line-height: 1.5;
    margin: 0;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 60px;
    align-items: center;
    padding-top: 60px;
    padding-bottom: 80px;
  }
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .hero-title {
    margin-bottom: 24px;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: #fff;
    line-height: 1.1;
  }
  .hero-desc {
    font-size: 1.25rem;
    color: rgba(255,255,255,0.8);
    max-width: 600px;
    margin-bottom: 40px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    margin-bottom: 40px;
  }
  .pills-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }
  .hero-note {
    font-size: 0.85rem;
    color: var(--clr-muted);
    font-style: italic;
  }

  /* Hero Side Card */
  .hero-side-card {
    position: relative;
    z-index: 10;
  }
  .hero-side-card h3 {
    color: #fff;
    margin-bottom: 20px;
    font-size: 1.2rem;
  }
  .offer-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .offer-list li {
    display: flex;
    gap: 12px;
    font-size: 0.95rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.5;
  }
  .icon-dot {
    width: 6px;
    height: 6px;
    background: var(--clr-primary);
    border-radius: 50%;
    margin-top: 8px;
    flex-shrink: 0;
  }
  .offer-list b {
    color: #fff;
    display: block;
    margin-bottom: 2px;
  }
  .engagement-desc {
    font-size: 0.95rem;
    color: var(--clr-primary);
    font-weight: 500;
  }

  /* KPI Banner */
  .kpi-banner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 20px;
    padding: 32px;
    margin-top: 64px;
  }
  .kpi-item b {
    display: block;
    font-size: 1.1rem;
    color: var(--clr-light-text);
    margin-bottom: 8px;
    color: var(--clr-primary);
  }
  .kpi-item span {
    font-size: 0.95rem;
    color: var(--clr-light-muted);
  }

  /* Architecture Image */
  .archi-card {
    padding: 16px;
    border-radius: 32px;
    overflow: hidden;
  }
  .archi-img {
    width: 100%;
    max-width: 900px;
    height: auto;
    border-radius: 20px;
    display: block;
    margin: 0 auto;
  }
  .archi-note {
    padding: 16px 8px 8px;
    text-align: center;
    color: var(--clr-light-muted);
    font-weight: 500;
  }

  /* Vendor Box */
  .vendor-box {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    background: rgba(255,255,255,0.03);
    padding: 60px;
    border-radius: 40px;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .check-list {
    margin-bottom: 32px;
  }
  .check-list li {
    position: relative;
    padding-left: 28px;
    margin-bottom: 12px;
    color: rgba(255,255,255,0.8);
    font-weight: 500;
  }
  .check-list li::before {
    content: '✔';
    position: absolute;
    left: 0;
    color: var(--clr-primary);
    font-weight: 900;
  }
  .vendor-badge {
    padding: 16px 24px;
    background: rgba(0, 200, 150, 0.1);
    border: 1px solid rgba(0, 200, 150, 0.2);
    border-radius: 12px;
    color: var(--clr-primary);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .vendor-img {
    width: 110%;
    margin-left: -5%;
    border-radius: 24px;
    box-shadow: 0 40px 120px rgba(0,0,0,0.6);
    transition: var(--transition);
  }
  .vendor-img:hover {
    transform: scale(1.02);
  }

  /* Solutions cards */
  .card-link {
    text-decoration: none;
    display: block;
    transition: var(--transition);
  }
  .card-link:hover .prod-card {
    border-color: var(--clr-primary);
    transform: translateY(-4px);
    background: #fff;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  }
  .prod-card {
    height: 100%;
    transition: var(--transition);
  }
  .prod-card h4 {
    color: var(--clr-primary);
    margin-bottom: 12px;
    font-size: 1.2rem;
  }

  /* Services Grid */
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
    border-top: 4px solid #e2e8f0;
  }
  .service-card.accent-teal { border-top-color: var(--clr-primary); }
  .service-card.accent-blue { border-top-color: var(--clr-secondary); }
  .service-h {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .serv-icon-wrapper {
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid #E8EEF5;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .serv-logo {
    width: 28px;
    height: auto;
  }
  .serv-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
