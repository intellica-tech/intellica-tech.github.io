---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const siteUrl = "https://intellica-tech.github.io";

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Intellica",
  "url": siteUrl,
  "description": "Intellica empowers enterprises to generate sustainable value from data through modern data platforms, analytics solutions, and production-grade AI systems.",
  "publisher": { "@id": `${siteUrl}/#organization` }
};
---

<Layout title="Intellica | Unleashing Value From Data" description="Intellica empowers enterprises to generate sustainable value from data through modern data platforms, analytics solutions, and production-grade AI systems." hideCta={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- ===== HERO ===== -->
  <section class="hero noise" id="index-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content">
          <div class="section-label anim-fade-up">Data & AI · Trusted Since 2006</div>
          <h1 class="hero__title anim-fade-up" id="heroTitle">Unleashing<br /><span class="grad-text">Value From Data</span></h1>
          <span class="hero__accent anim-fade-up"></span>
          <p class="hero__desc anim-fade-up" id="heroDesc">We design and deliver enterprise data platforms that enable reliable analytics and production-ready AI.</p>
          <div class="hero__actions anim-fade-up">
            <a class="btn btn-primary btn-pill btn-lg uppercase-never" href="/contact">Get in Touch</a>
          </div>
          <div class="hero__subactions anim-fade-up">
            <a href="/solutions" class="hero-sublink">Explore AI Solutions</a>
            <a href="/products" class="hero-sublink">Explore Products</a>
          </div>
        </div>
        <div class="hero__visual anim-fade-up">
           <img class="hero__shape-new" src="/assets/img/intellica_camlogo_icibos.png" alt="Intellica Brand" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HERO PROOF ===== -->
  <section class="section section--white" style="padding-top: 36px; padding-bottom: 36px;">
    <div class="container">
      <div class="hero-proof anim-fade-up">
        <p class="hero-proof__text">
          We help organizations move from fragmented data to measurable business outcomes — enabling faster decisions, better operations and scalable AI.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CAPABILITIES ===== -->
  <section class="section section--light" id="capabilities">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Capabilities</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">
          Enterprise Data & <span class="grad-text">AI Capabilities</span>
        </h2>
        <p class="section-sub">
          From data platforms to enterprise AI applications — we design, build and operate scalable data ecosystems.
        </p>
      </div>
      <div class="grid-5 cap-grid">
        <a href="/data-platforms" class="cap-card anim-fade-up" style="--icon-grad:linear-gradient(135deg,#10B981,#3B82F6); text-decoration:none; color:inherit;">
          <div class="cap-card__icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="Modern Data Platforms Icon" />
          </div>
          <h3>Modern Data Platforms & DWH</h3>
          <p>We build scalable data platforms; managing architecture, cloud modernization and integration end-to-end across technologies.</p>
        </a>
        <a href="/solutions#framework" class="cap-card anim-fade-up" style="--icon-grad:linear-gradient(135deg,#3B82F6,#14B8A6); text-decoration:none; color:inherit;">
          <div class="cap-card__icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="BI & Analytics Icon" />
          </div>
          <h3>BI & Advanced Analytics</h3>
          <p>Transforming data into actionable insights with dashboards, decision support systems and self-service analytics for real-time decisions.</p>
        </a>
        <a href="/solutions#framework" class="cap-card anim-fade-up" style="--icon-grad:linear-gradient(135deg,#0EA5E9,#2563EB); text-decoration:none; color:inherit;">
          <div class="cap-card__icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="AI & ML Icon" />
          </div>
          <h3>AI & Machine Learning</h3>
          <p>Enhancing processes with GenAI/LLM and intelligent agents — demand forecasting, churn prediction and NLP analytics to boost efficiency.</p>
        </a>
        <a href="/products" class="cap-card anim-fade-up" style="--icon-grad:linear-gradient(135deg,#14B8A6,#0EA5E9); text-decoration:none; color:inherit;">
          <div class="cap-card__icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="Data Governance Icon" />
          </div>
          <h3>Data Governance & Products</h3>
          <p>Ensuring data quality and consistency with ICC, ReTouch and industry-specific data models for standardized, traceable data processes.</p>
        </a>
        <a href="/contact" class="cap-card anim-fade-up" style="--icon-grad:linear-gradient(135deg,#0D9488,#3B82F6); text-decoration:none; color:inherit;">
          <div class="cap-card__icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="Expert Support Icon" />
          </div>
          <h3>Consulting & Expert Support</h3>
          <p>Governance, GAP analysis and target architecture roadmaps to guide your journey — plus expert team deployment and managed services.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== GLOBAL IMPACT ===== -->
  <section class="section section--white" id="global-impact">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Global Presence</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">
          Global Impact in Data & <span class="grad-text">Artificial Intelligence</span>
        </h2>
        <p class="section-sub">
          Turkey-based data and AI company delivering enterprise-grade solutions across 20+ countries with successful projects in banking, telecom, public sector and manufacturing.
        </p>
      </div>
      <!-- MAP -->
      <div class="map-wrap anim-fade-up">
        <img alt="Global footprint" class="map-image" src="/assets/images/map/world-impact-map.png" />
        <svg aria-hidden="true" class="map-overlay" preserveAspectRatio="none" viewBox="0 0 1200 520">
          <path class="conn" d="M108,255 C300,180 400,140 500,137" /> <!-- Seattle to London -->
          <path class="conn" d="M500,137 C530,150 550,165 573,172" /> <!-- London to Tirana -->
          <path class="conn" d="M573,172 C600,185 620,195 645,208" /> <!-- Tirana to Turkey -->
          <path class="conn" d="M645,208 C670,250 690,285 708,305" /> <!-- Turkey to Riyadh -->
          <path class="conn" d="M645,208 C700,230 730,245 748,260" /> <!-- Turkey to Dubai -->
          <path class="conn" d="M645,208 C700,210 750,215 788,215" /> <!-- Turkey to Islamabad -->
          <g class="dot" style="--delay:0s"><circle cx="108" cy="255" r="5"/><circle class="ring" cx="108" cy="255" r="5"/></g> <!-- Seattle -->
          <g class="dot" style="--delay:0.2s"><circle cx="500" cy="137" r="5"/><circle class="ring" cx="500" cy="137" r="5"/></g> <!-- London -->
          <g class="dot" style="--delay:0.35s"><circle cx="573" cy="172" r="5"/><circle class="ring" cx="573" cy="172" r="5"/></g> <!-- Tirana -->
          <g class="dot" style="--delay:0.5s"><circle cx="645" cy="208" r="5"/><circle class="ring" cx="645" cy="208" r="5"/></g> <!-- Turkey -->
          <g class="dot" style="--delay:0.65s"><circle cx="708" cy="305" r="5"/><circle class="ring" cx="708" cy="305" r="5"/></g> <!-- Riyadh -->
          <g class="dot" style="--delay:0.8s"><circle cx="748" cy="260" r="5"/><circle class="ring" cx="748" cy="260" r="5"/></g> <!-- Dubai -->
          <g class="dot" style="--delay:0.95s"><circle cx="788" cy="215" r="5"/><circle class="ring" cx="788" cy="215" r="5"/></g> <!-- Islamabad -->
        </svg>
      </div>
      <!-- METRICS (Updated to match provided image) -->
      <div class="grid-4 metrics-grid anim-fade-up">
        <div class="metric-item">
          <span class="metric-label" style="font-weight: 800; color: #111; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 8px; display: block;">Countries</span>
          <span class="metric-number"><span class="counter" data-target="20">0</span>+ Countries</span>
          <p style="font-size: 0.9rem; color: #64748b; margin-top: 8px;">where Intellica has successfully delivered data and AI projects.</p>
        </div>
        <div class="metric-item">
          <span class="metric-label" style="font-weight: 800; color: #111; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 8px; display: block;">Projects</span>
          <span class="metric-number"><span class="counter" data-target="80">0</span>+ Data & AI Projects</span>
          <p style="font-size: 0.9rem; color: #64748b; margin-top: 8px;">delivered for global organizations across multiple industries.</p>
        </div>
        <div class="metric-item">
          <span class="metric-label" style="font-weight: 800; color: #111; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 8px; display: block;">Professionals</span>
          <span class="metric-number"><span class="counter" data-target="100">0</span>+ Data & AI Professionals</span>
          <p style="font-size: 0.9rem; color: #64748b; margin-top: 8px;">including solution architects, data engineers and AI specialists.</p>
        </div>
        <div class="metric-item">
          <span class="metric-label" style="font-weight: 800; color: #111; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 0.05em; margin-bottom: 8px; display: block;">Platforms</span>
          <span class="metric-number"><span class="counter" data-target="30">0</span>+ Enterprise Data Platforms Implemented</span>
          <p style="font-size: 0.9rem; color: #64748b; margin-top: 8px;">covering modern DWH, lakehouse and cloud architectures.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRUSTED CLIENTS ===== -->
  <section class="section section--light" id="trusted-clients">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Trusted By</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">
          Trusted by <span class="grad-text">Leading Enterprises</span>
        </h2>
        <p class="section-sub">
          From banking to telecoms, insurance to government — selected enterprises we run data and AI projects with.
        </p>
      </div>
      <div class="logo-grid anim-fade-up">
        <a class="logo-tile logo-tile--lg" aria-label="Ministry of Interior"><img alt="Ministry of Interior" src="/assets/images/logos/InteriorMinistryTR.png" /></a>
        <a class="logo-tile logo-tile--lg" aria-label="EGM"><img alt="EGM" src="/assets/images/logos/egm_logo2.png" /></a>
        <a class="logo-tile logo-tile--lg" aria-label="SGK"><img alt="SGK" src="/assets/images/logos/SGKLOGOTYPE-RENKLI.svg" /></a>
        <a class="logo-tile logo-tile--lg" aria-label="TCDD"><img alt="TCDD" src="/assets/images/logos/TCDD_Taşımacılık_Logo.png" /></a>
        <a class="logo-tile" aria-label="Akbank"><img alt="Akbank" src="/assets/images/logos/Akbank_logo.svg" /></a>
        <a class="logo-tile" aria-label="Fibabanka"><img alt="Fibabanka" src="/assets/images/logos/Fibabanka.png" /></a>
        <a class="logo-tile" aria-label="ING"><img alt="ING" src="/assets/images/logos/ING.png" /></a>
        <a class="logo-tile" aria-label="Odeabank"><img alt="Odeabank" src="/assets/images/logos/Odeabank_logo.png" /></a>
        <a class="logo-tile" aria-label="TEB"><img alt="TEB" src="/assets/images/logos/TEB_LOGO.png" /></a>
        <a class="logo-tile" aria-label="DenizBank"><img alt="DenizBank" src="/assets/images/logos/DenizBank_logo.svg (1).png" /></a>
        <a class="logo-tile" aria-label="TBI Bank"><img alt="TBI Bank" src="/assets/images/logos/tbi-bank.png" /></a>
        <a class="logo-tile" aria-label="Birbank"><img alt="Birbank" src="/assets/images/logos/birbank..svg" /></a>
        <a class="logo-tile" aria-label="Yapı Kredi"><img alt="Yapı Kredi" src="/assets/images/logos/Yapı_kredi_logo.png" /></a>
        <a class="logo-tile" aria-label="Vodafone"><img alt="Vodafone" src="/assets/images/logos/Vodafone_logo_2017.png" /></a>
        <a class="logo-tile" aria-label="Turkcell"><img alt="Turkcell" src="/assets/images/logos/Turkcell_logo.png" /></a>
        <a class="logo-tile" aria-label="Türk Telekom"><img alt="Türk Telekom" src="/assets/images/logos/TURKTELEKOM.png" /></a>
        <a class="logo-tile" aria-label="Zain"><img alt="Zain" src="/assets/images/logos/ZAINr.png" /></a>
        <a class="logo-tile" aria-label="T-Mobile"><img alt="T-Mobile" src="/assets/images/logos/TMOBILE.png" /></a>
        <a class="logo-tile" aria-label="Boyner"><img alt="Boyner" src="/assets/images/logos/Boyner_Logo.jpg" /></a>
        <a class="logo-tile" aria-label="LC Waikiki"><img alt="LC Waikiki" src="/assets/images/logos/lcw.png" /></a>
        <a class="logo-tile" aria-label="Allianz"><img alt="Allianz" src="/assets/images/logos/Allianz.svg.png" /></a>
        <a class="logo-tile" aria-label="Anadolu Sigorta"><img alt="Anadolu Sigorta" src="/assets/images/logos/Anadolu_Sigorta_logo.svg" /></a>
        <a class="logo-tile" aria-label="Hopi"><img alt="Hopi" src="/assets/images/logos/hopi.png" /></a>
        <a class="logo-tile" aria-label="Erciyes Anadolu Holding"><img alt="Erciyes Anadolu Holding" src="/assets/images/logos/Erciyes_Anadolu_Holding_logo.svg" /></a>
      </div>
      <div class="text-center anim-fade-up" style="margin-top: 48px;">
        <a href="/clients" class="btn btn-primary btn-pill btn-lg">View All Clients →</a>
      </div>
    </div>
  </section>

  <!-- ===== DWH / DATA PLATFORM TRANSFORMATION ===== -->
  <section class="section section--white" id="dwh-transformation" style="overflow:hidden;">
    <div class="deco-blob" aria-hidden="true" style="top:-80px;right:-80px;width:400px;height:400px;background:radial-gradient(circle,rgba(16,185,129,0.06) 0%,transparent 70%);"></div>
    <div class="deco-blob" aria-hidden="true" style="bottom:-80px;left:-80px;width:350px;height:350px;background:radial-gradient(circle,rgba(59,130,246,0.06) 0%,transparent 70%);"></div>
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Enterprise Data Platforms</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">
          Enterprise <span class="grad-text">Data Platforms</span> & DWH Transformation
        </h2>
        <p class="section-sub">
          Build modern data platforms that power analytics, AI and enterprise applications.
        </p>
      </div>
      <div class="grid-3 dwh-grid anim-fade-up">
        <div class="dwh-card" style="background:linear-gradient(145deg,#F0FDF9,#EFF6FF);border:1px solid rgba(16,185,129,0.15);">
          <div class="dwh-card__icon" style="border:1px solid rgba(16,185,129,0.25);">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="" />
          </div>
          <h3>DWH Modernization</h3>
          <p>Simplify your data warehouse, strengthen the layered architecture. Build scalable structures with cloud migration and cost/performance optimization.</p>
          <ul class="dwh-card__list">
            <li>Architecture assessment & target design</li>
            <li>Phased migration plan</li>
            <li>Security, performance, scalability</li>
          </ul>
        </div>
        <div class="dwh-card" style="background:linear-gradient(145deg,#EFF6FF,#F0FDF9);border:1px solid rgba(59,130,246,0.15);">
          <div class="dwh-card__icon" style="border:1px solid rgba(59,130,246,0.25);">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="" />
          </div>
          <h3>Data Integration & Operations</h3>
          <p>Build reliable data flows from source systems; ensure sustainable operations with data quality gates.</p>
          <ul class="dwh-card__list">
            <li>ETL/ELT and orchestration</li>
            <li>Data contracts & quality checks</li>
            <li>Observability (log/metric/alert)</li>
          </ul>
        </div>
        <div class="dwh-card" style="background:linear-gradient(145deg,#F5F3FF,#EFF6FF);border:1px solid rgba(99,102,241,0.15);">
          <div class="dwh-card__icon" style="border:1px solid rgba(99,102,241,0.25);">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="" />
          </div>
          <h3>Semantic Layer & BI Architecture</h3>
          <p>Standardize KPIs in a single truth layer, balance self-service with enterprise control.</p>
          <ul class="dwh-card__list">
            <li>Metric dictionary & KPI governance</li>
            <li>Semantic model design</li>
            <li>Reporting performance & standards</li>
          </ul>
        </div>
      </div>
      <div class="text-center anim-fade-up" style="margin-top:24px;">
        <a href="/data-platforms" class="btn btn-primary btn-pill btn-lg">Data Platforms Detail →</a>
      </div>
    </div>
  </section>

  <!-- ===== ENTERPRISE PRODUCT PORTFOLIO ===== -->
  <section class="section section--light" id="products-ecosystem">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">Enterprise Products</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">Enterprise <span class="grad-text">Product Portfolio</span></h2>
        <p class="section-sub">End-to-end product architecture — from industry data models to production-grade AI.</p>
      </div>

      <div class="premium-products anim-fade-up">
        <!-- Group 1: Data Models -->
        <div class="product-shelf">
          <div class="shelf-header">
            <h3 class="shelf-title">Data <span class="grad-text">Models</span></h3>
            <p class="shelf-desc">International industry standards for accelerated DWH transformation.</p>
          </div>
          <div class="shelf-grid">
            <a href="/products/ifdm" class="premium-card">
              <div class="card-p-logo"><img alt="IFDM" src="/assets/images/logos/IFDM_logo.png" /></div>
              <div class="card-p-content">
                <h4>IFDM</h4>
                <p>Standard data model for finance analytics.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
            <a href="/products/itdm" class="premium-card">
              <div class="card-p-logo"><img alt="ITDM" src="/assets/images/logos/ITDM_logo.png" /></div>
              <div class="card-p-content">
                <h4>ITDM</h4>
                <p>Global data model for telecom intelligence.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
            <a href="/products/hrdm" class="premium-card">
              <div class="card-p-logo"><img alt="HRDM" src="/assets/images/logos/hrdm.png" /></div>
              <div class="card-p-content">
                <h4>HRDM</h4>
                <p>Optimized model for HR & workforce analytics.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
          </div>
        </div>

        <!-- Group 2: Data Platform & Governance -->
        <div class="product-shelf">
          <div class="shelf-header">
            <h3 class="shelf-title">Platform & <span class="grad-text">Governance</span></h3>
            <p class="shelf-desc">Ensuring data quality, consistency and sustainable orchestration.</p>
          </div>
          <div class="shelf-grid">
            <a href="/products/icc" class="premium-card">
              <div class="card-p-logo"><img alt="ICC" src="/assets/images/logos/ıcc.png" /></div>
              <div class="card-p-content">
                <h4>ICC</h4>
                <p>Central data consistency & reconciliation.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
            <a href="/products/retouch" class="premium-card">
              <div class="card-p-logo"><img alt="ReTouch" src="/assets/images/logos/retouch.svg" /></div>
              <div class="card-p-content">
                <h4>ReTouch</h4>
                <p>Validated data entry & metadata management.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
            <a href="/products/retable" class="premium-card">
              <div class="card-p-logo"><img alt="Retable" src="/assets/images/logos/retable.png" /></div>
              <div class="card-p-content">
                <h4>Retable</h4>
                <p>Collaborative no-code application platform.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
            <a href="/products/orqenta" class="premium-card" target="_blank">
              <div class="card-p-logo"><img alt="Orqenta" src="/assets/images/logos/orqenta_logo.png" /></div>
              <div class="card-p-content">
                <h4>Orqenta</h4>
                <p>Workflow orchestration & distributed job scheduling platform.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
          </div>
        </div>

        <!-- Group 3: AI Products -->
        <div class="product-shelf">
          <div class="shelf-header">
            <h3 class="shelf-title">AI <span class="grad-text">Products</span></h3>
            <p class="shelf-desc">Enterprise AI applications for analytics, automation and decision intelligence.</p>
          </div>
          <div class="shelf-grid">
            <a href="/products/talk-to-your-data" class="premium-card">
              <div class="card-p-logo"><img alt="Talk To" src="/assets/images/logos/talkto.png" /></div>
              <div class="card-p-content">
                <h4>Talk To</h4>
                <p>Natural language data analyst agent.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
            <a href="/products/blue-octopus" class="premium-card">
              <div class="card-p-logo"><img alt="Blue Octopus" src="/assets/images/logos/BLUEOCT_logo.png" /></div>
              <div class="card-p-content">
                <h4>Blue Octopus</h4>
                <p>Event intelligence & automated response.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
            <a href="/products/var" class="premium-card">
              <div class="card-p-logo"><img alt="VAR" src="/assets/images/logos/VAR_logo.png" /></div>
              <div class="card-p-content">
                <h4>VAR</h4>
                <p>Voice analysis & recognition platform.</p>
              </div>
              <div class="card-p-arrow">→</div>
            </a>
          </div>
        </div>
        <div class="text-center anim-fade-up" style="margin-top: 48px;">
          <a href="/products" class="btn btn-primary btn-pill btn-lg">View All Products →</a>
        </div>
      </div>
    </div>
  </section>
  <!-- ===== AI SOLUTIONS ===== -->
  <section class="section section--white" id="ai-solutions">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">AI PORTFOLIO</div>
        <h2 class="section-title" style="color:var(--clr-light-text);">
          Enterprise AI Solutions
        </h2>
        <p class="section-sub">
          Production-grade AI solutions designed to improve decisions, automate operations and unlock business value.
        </p>
      </div>

      <div class="ai-summary-grid anim-fade-up">
        <div class="ai-summary-card">
          <div class="ais-card-icon">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="Conversational AI" />
          </div>
          <h3>Conversational & Copilot AI</h3>
          <p>Natural language access to enterprise data and intelligent assistants for business teams.</p>
