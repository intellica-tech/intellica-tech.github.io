<script>
  // Rotating hero text
  const rotatingTexts = [
    { title: "Unleashing<br />Value From Data", description: "Leading enterprises on their growth journey with data technologies and products — the \"game-changing\" partner of data." },
    { title: "Clarity and Speed in<br />Decision-Making", description: "Increase your organizational agility with modern data platforms." },
    { title: "A Strong Foundation<br />for AI", description: "Make your AI investments sustainable with reliable data architecture." },
    { title: "From Insight<br />to Action", description: "Transform data into value with our consulting, products and AI solutions." }
  ];
  let currentTextIndex = 0;
  function rotateText() {
    const titleEl = document.getElementById('heroTitle');
    const descEl = document.getElementById('heroDesc');
    if (!titleEl || !descEl) return;
    titleEl.style.opacity = '0';
    descEl.style.opacity = '0';
    setTimeout(() => {
      currentTextIndex = (currentTextIndex + 1) % rotatingTexts.length;
      const text = rotatingTexts[currentTextIndex];
      titleEl.innerHTML = text.title.replace(/(Value From Data|Decision-Making|Foundation for AI|Insight to Action)/, '<span class="grad-text">$1</span>');
      descEl.textContent = text.description;
      titleEl.style.opacity = '1';
      descEl.style.opacity = '1';
    }, 600);
  }
  setInterval(rotateText, 4500);
</script>
