---
import InsightDetailPage from '../../page-templates/InsightDetailPage.astro';

export function getStaticPaths() {
  const slugs = [
    "dashboard-guven",
    "manuel-kontroller",
    "verinin-nabzi",
    "is-analizi",
    "rag-ne-zaman-ise-yarar",
    "genai-guven-standardi"
  ];
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: string };
---
<InsightDetailPage lang="en" slug={slug} />
