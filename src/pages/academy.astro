---
import Layout from '../layouts/Layout.astro';

const breadcrumbs = [
  { name: 'About', url: '/about' },
  { name: 'Data & AI Talent Program', url: '/academy' }
];

const stats = [
  { value: '11+', label: 'Years of Experience' },
  { value: '240+', label: 'Graduates' },
  { value: '3', label: 'Week Camp Program' }
];

const modules = [
  {
    title: 'Module 1 — Foundations & Data Modeling',
    items: [
      'Understanding the fundamentals of the data ecosystem',
      'Learning core data modeling concepts and integration logic',
      'Building structured models inspired by real business scenarios'
    ]
  },
  {
    title: 'Module 2 — Data Processing & ETL',
    items: [
      'Understanding how data is extracted, transformed, and loaded',
      'Learning how data pipelines are designed with practical examples',
      'Developing hands-on skills through workshops and exercises'
    ],
    highlight: [
      'Build core and advanced data technology knowledge',
      'Gain practical skills that support career readiness',
      'Understand how real data teams solve business problems'
    ]
  },
  {
    title: 'Module 3 — Reporting & Data Visualization',
    items: [
      'Turning data into meaningful business insights',
      'Learning effective reporting and presentation techniques',
      'Understanding how analytics supports decision-making'
    ]
  }
];

const universities = [
  'Alaaddin University',
  'Istanbul Technical University',
  'Dokuz Eylul University',
  'Ege University',
  'Bahcesehir University',
  'Kocaeli University',
  'Istanbul University',
  'Marmara University',
  'Gebze University',
  'Yildiz Technical University'
];

const testimonials = [
  {
    quote:
      "I've been working at Intellica for eight years. Participating as an instructor in the camp program where I once joined as a student is very special to me. I believe Intellica Academy offers a perfect opportunity for those starting their careers.",
    author: 'Emre Usta',
    role: 'BI Team Leader'
  },
  {
    quote:
      'Our annual camp program for new graduates opens doors to the business world. Focused on data warehousing, business intelligence, and software development, we provide a wide range of knowledge from concepts to practical training.',
    author: 'Turgay Burgaz',
    role: 'BI Team Leader'
  },
  {
    quote:
      "The 2023 camp was a turning point for my experience. The sincere atmosphere and the instructors' helpfulness were most impressive. I believe the BI training I received formed a solid foundation for the first steps of my career.",
    author: 'Berkay Boz',
    role: 'BI Consultant'
  }
];

const faqs = [
  {
    q: 'Who is the program for?',
    a: "Senior undergraduate students, master's or doctoral students, and new graduates with up to 1 year of experience are prioritised."
  },
  {
    q: 'How long is the program?',
    a: 'The program lasts approximately 3 weeks, depending on the session.'
  },
  {
    q: 'Is there a fee?',
    a: 'The program is provided free of charge for new graduates.'
  },
  {
    q: 'What documents are required?',
    a: 'In addition to the application form, your CV and graduation certificate, if available, should be submitted.'
  },
  {
    q: 'Are there job opportunities after the program?',
    a: 'Successful participants may be considered for internship, part-time, or full-time opportunities, depending on business needs and evaluation results.'
  },
  {
    q: 'Where does it take place?',
    a: 'Training sessions are held at the Intellica Ataşehir office.'
  },
  {
    q: 'What does the content cover?',
    a: 'The program covers real business cases, practical applications, core data concepts, and industry-oriented problem solving.'
  },
  {
    q: 'Is everyone accepted?',
    a: 'We evaluate every application carefully, but because quotas are limited, not every applicant can be accepted.'
  },
  {
    q: 'Is a certificate provided?',
    a: 'Yes. Participants who successfully complete the program receive a certificate.'
  },
  {
    q: 'Is accommodation provided?',
    a: 'Participants are responsible for arranging their own accommodation during the program period.'
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a
    }
  }))
};
---

<Layout
  title="Data & AI Talent Program | Intellica"
  description="A hands-on program for senior students and new graduates who want to build real-world skills in data engineering, analytics, and AI."
  breadcrumbs={breadcrumbs}
  hideCta={true}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="hero noise" id="academy-hero">
    <div class="container hero__inner">
      <div class="hero__content-wrap">
        <div class="hero__content anim-fade-up">
          <div class="section-label">DATA & AI TALENT PROGRAM</div>
          <h1 class="hero__title">
            Start Your Career in <br /><span class="grad-text">Data & AI</span>
          </h1>
          <span class="hero__accent"></span>
          <p class="hero__desc">
            A hands-on program designed for senior students and new graduates who want to build
            real-world skills in data engineering, analytics, and AI. Learn from experienced
            professionals, work on practical use cases, and take your first step into the industry
            with confidence.
          </p>

          <div class="hero-stats">
            {stats.map(stat => (
              <div class="stat-item">
                <div class="stat-value">{stat.value}</div>
                <div class="stat-label">{stat.label}</div>
              </div>
            ))}
          </div>

          <div class="hero__actions">
            <a href="/contact" class="btn btn-primary btn-pill btn-lg">Apply Now</a>
          </div>
        </div>

        <div class="hero__visual anim-fade-up">
          <img src="/assets/img/academy_hero.png" alt="Intellica Talent Program" class="hero__shape-new" />
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section section--white">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">About the <span class="grad-text">Program</span></h2>
        <p class="section-sub">
          Intellica’s Data & AI Talent Program is designed to bridge the gap between academic
          learning and real business life. Through hands-on training, practical workshops, and
          real project examples, participants gain the technical and professional foundation needed
          to start a career in data and AI.
        </p>
      </div>

      <div class="grid-2 anim-fade-up" style="margin-top: 60px;">
        <div class="card-light luxury-card">
          <div class="icon-box">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="" style="width: 32px; height: 32px;" />
          </div>
          <h3>Learn from Real Experts</h3>
          <p>
            Participants work closely with experienced Intellica professionals and gain first-hand
            insight into how real data projects are designed, delivered, and improved in business
            environments.
          </p>
        </div>
        <div class="card-light luxury-card">
          <div class="icon-box">
            <img src="/assets/img/intellica_camlogo_icibos.png" alt="" style="width: 32px; height: 32px;" />
          </div>
          <h3>Hands-On Learning Experience</h3>
          <p>
            The program combines core concepts with practical workshops, helping participants turn
            theory into applicable skills in data modeling, ETL, reporting, and analytics.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- INVITATION -->
  <section class="section section--dark">
    <div class="container">
      <div class="card-glass text-center anim-fade-up invite-card">
        <h2 class="hero__title invite-heading">
          Join Our <span class="grad-text">3 Week Data & AI Program</span>
        </h2>
        <p class="hero__desc" style="margin-inline: auto; max-width: 800px;">
          If you want to build a strong foundation in data technologies and gain practical
          experience with real-world scenarios, this program is designed for you.
        </p>
        <div class="hero__actions" style="justify-content: center;">
          <a href="/contact" class="btn btn-primary btn-pill btn-lg">Reserve Your Spot</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CAMP CONTENT -->
  <section class="section section--white">
    <div class="container">
      <div class="text-center anim-fade-up">
        <div class="section-label" style="margin-inline:auto;">CURRICULUM</div>
        <h2 class="section-title">Program <span class="grad-text">Content</span></h2>
        <p class="section-sub">
          The program is structured in three modules, covering the fundamentals of modern data
          work from modeling to reporting.
        </p>
      </div>

      <div class="grid-3 anim-fade-up" style="margin-top: 60px;">
        {modules.map(mod => (
          <div class="card-light curriculum-card">
            <h3 style="color: var(--clr-primary); margin-bottom: 24px;">{mod.title}</h3>
            <ul class="curriculum-list">
              {mod.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
            {mod.highlight && (
              <div class="highlight-box">
                <div class="divider"></div>
                <ul>
                  {mod.highlight.map(h => <li>{h}</li>)}
                </ul>
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="grid-2 anim-fade-up" style="margin-top: 40px;">
        <div class="card-light promo-card">
          <h4>Who should apply?</h4>
          <p>
            Senior undergraduate students, master’s or doctoral students, and new graduates with
            up to one year of experience are prioritised.
          </p>
        </div>
        <div class="card-light promo-card">
          <h4>Why join the program?</h4>
          <p>
            Gain hands-on experience, learn from professionals, strengthen your technical
            foundation, and increase your opportunity to move into internship or full-time roles.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- UNIVERSITIES -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">University <span class="grad-text">Collaborations</span></h2>
        <p class="section-sub">
          For more than a decade, Intellica has collaborated with leading universities to help
          young talent transition from education into professional life through practical learning
          and industry exposure.
        </p>
      </div>

      <div class="uni-grid anim-fade-up">
        {universities.map(uni => (
          <div class="uni-tile">
            <b>{uni}</b>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section section--white">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">Participant <span class="grad-text">Insights</span></h2>
        <p class="section-sub">Experiences shared by our graduates and instructors.</p>
      </div>

      <div class="grid-3 anim-fade-up" style="margin-top: 60px;">
        {testimonials.map(t => (
          <div class="card-light testimonial-card">
            <div class="quote-icon">“</div>
            <p class="quote-text">{t.quote}</p>
            <div class="author-info">
              <div class="author-avatar">{t.author[0]}</div>
              <div class="author-meta">
                <div class="author-name">{t.author}</div>
                <div class="author-role">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--light">
    <div class="container">
      <div class="text-center anim-fade-up">
        <h2 class="section-title">Frequently Asked <span class="grad-text">Questions</span></h2>
        <p class="section-sub">Everything you may want to know about the program.</p>
      </div>

      <div class="grid-2 anim-fade-up" style="margin-top: 60px; gap: 24px;">
        {faqs.map(item => (
          <div class="card-light faq-item">
            <h4>{item.q}</h4>
            <p>{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-strip text-center anim-fade-up">
        <h3>Apply or Get Detailed Information</h3>
        <p>Contact us to learn more about the program, application process, and upcoming sessions.</p>
        <div class="hero__actions" style="justify-content: center; margin-top: 32px;">
          <a href="/contact" class="btn btn-primary btn-pill btn-lg">Get in Touch</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
/* HERO: STANDARDIZED */
.hero-disabled {
  min-height: 800px;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #162a4d 0%, #020617 100%);
}
.hero-disabled__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  width: 100%;
  height: 100%;
}
.hero-disabled__content-wrap {
  display: grid;
  grid-template-columns: 1.25fr 0.75fr;
  align-items: center;
  gap: 40px;
  width: 100%;
}
.hero-disabled__content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-block: 60px;
}
.hero-disabled__title {
  font-size: clamp(2.5rem, 5.5vw, 4.8rem);
  font-weight: 950;
  line-height: 1.05;
  color: #fff;
  margin-bottom: 24px;
  letter-spacing: -0.05em;
}
.hero-disabled__accent {
  display: block;
  width: 80px;
  height: 4px;
  border-radius: 4px;
  background: var(--grad-brand);
  margin-bottom: 32px;
}
.hero-disabled__desc {
  font-size: 1.25rem;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.85);
  max-width: 600px;
  margin-bottom: 48px;
}
.hero-disabled__actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.hero-disabled__visual {
  display: flex;
  justify-content: center;
  align-items: center;
}
.hero-disabled__shape-new {
  width: 100%;
  max-width: 600px;
  animation: float 8s ease-in-out infinite;
  filter: drop-shadow(0 20px 80px rgba(0, 200, 150, 0.3));
  border-radius: 40px;
}

.hero-stats {
  display: flex;
  gap: 40px;
  margin-bottom: 48px;
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 24px;
}
.stat-value {
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--clr-primary);
  line-height: 1;
}
.stat-label {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.6);
  margin-top: 4px;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20px); }
}

@media (max-width: 1100px) {
  .hero-disabled {
    min-height: auto !important;
    padding-top: 5px !important;
    padding-bottom: 25px !important;
    height: auto;
  }
  .hero-disabled__content-wrap {
    grid-template-columns: 1fr;
    text-align: left;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .hero-disabled__content {
    align-items: flex-start;
    padding-block: 10px;
  }
  .hero-disabled__desc {
    font-size: 1.1rem;
    max-width: 100%;
    margin-bottom: 24px;
  }
  .hero-disabled__title {
    font-size: 2.22rem;
    margin-bottom: 16px;
    padding-right: 80px;
    line-height: 1.15;
  }
  .hero-disabled__visual {
    position: absolute;
    top: 5px;
    right: 5px;
    width: 80px;
    height: 80px;
    z-index: 10;
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
  }
  .hero-disabled__shape-new {
    width: 100%;
    height: auto;
    opacity: 1;
    filter: drop-shadow(0 4px 12px rgba(0, 200, 150, 0.25));
  }
  .hero-disabled__actions {
    margin-bottom: 24px;
  }
  .hero-stats {
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 20px;
  }
}

/* Invite Card */
.invite-card {
  padding: 80px 40px;
  border-radius: 48px;
}
.invite-heading {
  font-size: clamp(1.5rem, 5vw, 2.5rem);
  margin-inline: auto;
  text-align: center;
  line-height: 1.2;
}
@media (max-width: 768px) {
  .invite-card {
    padding: 48px 24px;
    border-radius: 28px;
  }
  .invite-heading {
    font-size: 1.5rem;
  }
}

/* Luxury Cards */
.luxury-card { transition: all 0.4s; }
.luxury-card:hover { transform: translateY(-8px); border-color: var(--clr-primary); }

/* Curriculum */
.curriculum-card {
  display: flex;
  flex-direction: column;
  height: 100%;
}
.curriculum-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.curriculum-list li {
  position: relative;
  padding-left: 24px;
  margin-bottom: 12px;
  font-size: 0.95rem;
  color: #475569;
}
.curriculum-list li::before {
  content: "→";
  position: absolute;
  left: 0;
  color: var(--clr-primary);
  font-weight: 700;
}
.highlight-box {
  margin-top: auto;
  padding-top: 24px;
}
.divider {
  height: 1px;
  background: #E2E8F0;
  margin-bottom: 20px;
}
.highlight-box ul {
  list-style: none;
  padding: 0;
}
.highlight-box li {
  font-size: 0.85rem;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 8px;
}

/* Uni Grid */
.uni-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16px;
  margin-top: 48px;
}
.uni-tile {
  background: #FFF;
  border: 1px solid #E2E8F0;
  border-radius: 12px;
  padding: 24px;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80px;
}
.uni-tile b {
  font-size: 0.85rem;
  color: #1E293B;
}

@media (max-width: 1024px) {
  .uni-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 600px) {
  .uni-grid { grid-template-columns: repeat(2, 1fr); }
}

/* Testimonials */
.testimonial-card {
  display: flex;
  flex-direction: column;
  background: #FFF;
  border: 1px solid #E2E8F0;
}
.quote-icon {
  font-size: 4rem;
  color: var(--clr-primary);
  line-height: 1;
  height: 3rem;
  margin-top: -10px;
  opacity: 0.2;
}
.quote-text {
  font-size: 1rem;
  color: #475569;
  font-style: italic;
  line-height: 1.6;
  margin-bottom: 32px;
  flex: 1;
}
.author-info {
  display: flex;
  align-items: center;
  gap: 16px;
  border-top: 1px solid #F1F5F9;
  padding-top: 20px;
}
.author-avatar {
  width: 44px;
  height: 44px;
  background: var(--grad-brand);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFF;
  font-weight: 800;
}
.author-name {
  font-weight: 750;
  color: #1E293B;
  font-size: 0.95rem;
}
.author-role {
  font-size: 0.8rem;
  color: #64748B;
}

/* FAQ */
.faq-item h4 {
  font-size: 1.1rem;
  font-weight: 800;
  color: #1E293B;
  margin-bottom: 12px;
}
.faq-item p {
  font-size: 0.95rem;
  color: #64748B;
}

/* CTA Banner */
.cta-banner {
  background: #FFF;
  border: 1px solid #E2E8F0;
  border-radius: 24px;
  padding: 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 80px;
  box-shadow: 0 20px 50px rgba(0,0,0,0.03);
}
.cta-banner-content h3 {
  font-size: 1.5rem;
  font-weight: 900;
  color: #1E293B;
  margin-bottom: 8px;
}
.cta-banner-content p {
  color: #64748B;
}
.cta-banner-actions {
  display: flex;
  gap: 16px;
}

@media (max-width: 768px) {
  .cta-banner {
    flex-direction: column;
    text-align: center;
    gap: 32px;
  }
  .cta-banner-actions {
    width: 100%;
    flex-direction: column;
  }
}
</style>